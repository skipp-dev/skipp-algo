//@version=6
library("skipp_scoring", overlay = true)

import preuss_steffen/skipp_math/1 as m

// --------------------------------------------------
// Constants
// --------------------------------------------------

export SIDEWAYS_EMA_THRESH() => 0.005
export SIDEWAYS_ATR_THRESH() => 0.015

// --------------------------------------------------
// Trend / Regime
// --------------------------------------------------

// @function Continuous trend strength in [-1, 1]
export trend_strength(float emaF, float emaS) =>
    float emaDiff = (emaF - emaS) / math.max(nz(emaS, 1), m.PRICE_EPS())
    math.max(-1.0, math.min(1.0, emaDiff / math.max(SIDEWAYS_EMA_THRESH(), m.PRICE_EPS())))

// @function Discrete trend regime: +1 bull, -1 bear, 0 sideways
export trend_regime(float emaF, float emaS, float atrNorm) =>
    float emaDiff = (emaF - emaS) / math.max(nz(emaS, 1), m.PRICE_EPS())
    bool isSideways = math.abs(emaDiff) < SIDEWAYS_EMA_THRESH() and atrNorm < SIDEWAYS_ATR_THRESH()
    bool isBull = emaF > emaS and not isSideways
    bool isBear = emaF < emaS and not isSideways
    isBull ? 1.0 : isBear ? -1.0 : 0.0

// @function Composite state score in [-1, 1]
export state_score(float c, float emaF_tf, float emaS_tf, float r_tf, bool useSmoothTrend) =>
    float trend = useSmoothTrend ? trend_strength(emaF_tf, emaS_tf) : (emaF_tf > emaS_tf ? 1.0 : emaF_tf < emaS_tf ? -1.0 : 0.0)
    float mom   = r_tf > 55.0 ? 1.0 : r_tf < 45.0 ? -1.0 : 0.0
    float loc   = c > emaS_tf ? 0.5 : c < emaS_tf ? -0.5 : 0.0
    m.clamp01((trend + mom + loc + 2.0) / 4.0) * 2.0 - 1.0

// --------------------------------------------------
// Ensemble
// --------------------------------------------------

// @function Pullback quality score
export pullback_score(float c, float ef, float es, float bias) =>
    bias == 1.0 ? (c > ef ? 0.5 : c > es ? 1.0 : -1.0) :
     bias == -1.0 ? (c < ef ? 0.5 : c < es ? 1.0 : -1.0) : 0.0

// @function Weighted 4-factor ensemble in [-1, 1]
export ensemble4(float sA, float sB, float sC, float sD, float wA, float wB, float wC, float wD) =>
    float num = wA * sA + wB * sB + wC * sC + wD * sD
    float den = wA + wB + wC + wD
    float val = den == 0.0 ? 0.0 : num / den
    math.max(-1.0, math.min(1.0, val))

// @function Rate-of-change score in [-1, 1]
export roc_score(series float c, simple int rocL) =>
    float roc = ta.roc(c, rocL)
    float r   = na(roc) ? 0.0 : roc
    math.max(-1.0, math.min(1.0, r / 5.0))

// @function Volume relative to SMA, in [-1, 1]
export vol_score(series float vol, simple int volSmaLen) =>
    float sma = ta.sma(vol, volSmaLen)
    if na(vol) or vol == 0.0
        0.0
    else
        float ratio = na(sma) or sma == 0.0 ? 0.0 : (vol / sma - 1.0)
        math.max(-1.0, math.min(1.0, ratio))

// @function Bias from raw score
export bias_from_score(float score) =>
    score > 0.0 ? 1 : score < 0.0 ? -1 : 0

// @function Check if bull bias is consistent
export is_bull_bias(float score, float emaF_tf, float emaS_tf) =>
    score > 0.0 and emaF_tf > emaS_tf

// --------------------------------------------------
// Binning
// --------------------------------------------------

// @function Uniform bin index
export bin(float score, int bins) =>
    float u = (score + 1.0) * 0.5
    int b = int(math.floor(u * bins))
    b < 0 ? 0 : b > (bins - 1) ? (bins - 1) : b

// @function 2D bin index
export bin2D(float score, float trendScore, int binsA, int binsB, float[] cutsArr) =>
    int a = bin(score, binsA)
    int b = int(math.floor((trendScore + 1.0) * 0.5 * binsB))
    b := b < 0 ? 0 : b > (binsB - 1) ? (binsB - 1) : b
    a * binsB + b

// @function Fill quantile cuts from sorted array
export fill_cuts(float[] sorted, float[] cuts, int bins) =>
    int cutCount = bins - 1
    if cutCount > 0
        int n = array.size(sorted)
        for i = 0 to cutCount - 1
            float frac = (i + 1.0) / bins
            int idx = int(math.floor(frac * (n - 1)))
            array.set(cuts, i, array.get(sorted, idx))

// @function Bin using quantile cuts with uniform fallback
export bin_quantile(float score, float[] cuts, int bins) =>
    if array.size(cuts) == 0 or na(array.get(cuts, 0))
        bin(score, bins)
    else
        int b = 0
        for i = 0 to array.size(cuts) - 1
            if score <= array.get(cuts, i)
                b := i
                break
            else
                b := i + 1
        math.max(0, math.min(bins - 1, b))

// @function Regime bin: 0=bear, 1=neutral, 2=bull
export regime_bin(float trendScore) =>
    trendScore > 0.5 ? 2 : trendScore < -0.5 ? 0 : 1

// @function Bucket index for calibration
export bucket(float p, int B) =>
    int b = int(math.floor(p * B))
    b < 0 ? 0 : b > (B - 1) ? (B - 1) : b

// @function Edges from 3-way probabilities
export edges3(float pU, float pF, float pD) =>
    [pU - pD, math.max(pU, math.max(pF, pD)) - (1.0 / 3.0)]

// @function Decision quality metric
export decision_quality(float pU, float pF, float pD, int nBin, int total) =>
    if na(pU) or na(pF) or na(pD) or nBin < 5 or total <= 0
        float(na)
    else
        float edge = math.max(pU, math.max(pF, pD)) - (1.0 / 3.0)
        float sampleFrac = nBin / math.max(1.0, float(total))
        float q = edge * math.sqrt(sampleFrac)
        m.clamp01(q)
