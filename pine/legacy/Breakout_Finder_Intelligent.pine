//@version=6
indicator("Breakout Finder Intelligent", "BFI", overlay=true, max_bars_back=500, max_lines_count=400, max_labels_count=300)

// =====================
// Base Breakout Finder Inputs
// =====================
groupBase = "Breakout Finder"
prd = input.int(5, "Period", minval=2, group=groupBase)
boLen = input.int(200, "Max Breakout Length", minval=30, maxval=300, group=groupBase)
cwidthu = input.float(3.0, "Threshold Rate %", minval=1.0, maxval=10.0, group=groupBase) / 100.0
mintest = input.int(2, "Minimum Number of Tests", minval=1, group=groupBase)

bocolorup = input.color(color.blue, "Breakout Color", inline="bocol", group=groupBase)
bocolordown = input.color(color.red, "Breakdown Color", inline="bocol", group=groupBase)
lstyle = input.string("Solid", "Line Style", options=["Solid", "Dashed", "Dotted"], group=groupBase)

lineStyle = lstyle == "Dashed" ? line.style_dashed : lstyle == "Dotted" ? line.style_dotted : line.style_solid

// =====================
// Smart Flow Filters
// =====================
groupFlow = "Smart Flow Filters"
enableSmartFilters = input.bool(true, "Enable smart flow filters", group=groupFlow)
assetPreset = input.string("Custom", "Asset preset", options=["Custom", "US Stocks (balanced)", "US Stocks (aggressive)", "US Small Caps (aggressive)", "BTC/ETH Crypto (balanced)"], group=groupFlow)

lowerTf = input.timeframe("1", "Lower timeframe", group=groupFlow)
lookback = input.int(20, "Relative lookback", minval=2, group=groupFlow)

minRelVol = input.float(1.50, "Min relative volume", minval=0.1, step=0.05, group=groupFlow)
minRelAct = input.float(1.20, "Min relative activity", minval=0.1, step=0.05, group=groupFlow)
minRelSize = input.float(0.80, "Min relative avgSizeProxy", minval=0.1, step=0.05, group=groupFlow)
minDeltaAbsPct = input.float(0.05, "Min absolute delta % of bar volume", minval=0.0, maxval=1.0, step=0.01, group=groupFlow)

groupFp = "Footprint"
ticksPerRow = input.int(10, "Footprint ticks per row", minval=1, group=groupFp)
vaPercent = input.int(70, "Value area %", minval=1, maxval=100, group=groupFp)
imbalancePct = input.int(300, "Imbalance %", minval=1, group=groupFp)

// =====================
// Average Trade Size Proxy Monitor
// =====================
groupAts = "Average Trade Size Monitor"
smoothLen = input.int(5, "ATS smoothing length", minval=1, group=groupAts)
baselineLen = input.int(20, "ATS baseline length", minval=5, group=groupAts)
changePctThresh = input.float(5.0, "ATS change threshold %", minval=0.1, step=0.1, group=groupAts)
spikeZThresh = input.float(1.5, "ATS spike Z-score threshold", minval=0.1, step=0.1, group=groupAts)
colorBars = input.bool(true, "Color bars by confirmed setup", group=groupAts)
colorBackground = input.bool(true, "Color background on ATS spikes", group=groupAts)
requireAtsRisingLong = input.bool(true, "Require ATS rising for breakout", group=groupAts)
requireAtsFallingShort = input.bool(true, "Require ATS falling for breakdown", group=groupAts)
requireAtsSpikeLong = input.bool(false, "Require ATS spike up for breakout", group=groupAts)
requireAtsSpikeShort = input.bool(false, "Require ATS spike down for breakdown", group=groupAts)
atsSpikeSequenceBars = input.int(2, "Bullish ATS spike sequence bars", minval=2, maxval=10, group=groupAts)
requireBreakoutForSpikeSequence = input.bool(false, "Require breakout signal for ATS spike sequence alert", group=groupAts)
requireRelVolOrDeltaForSpikeSequence = input.bool(true, "Require relVol up or positive delta for ATS spike sequence alert", group=groupAts)

// =====================
// Width for breakout boxes
// =====================
lll = math.max(math.min(bar_index, 300), 1)
h_ = ta.highest(high, lll)
l_ = ta.lowest(low, lll)
chwidth = (h_ - l_) * cwidthu

// =====================
// Pivot points
// =====================
ph = ta.pivothigh(high, prd, prd)
pl = ta.pivotlow(low, prd, prd)

var phval = array.new_float(0)
var phloc = array.new_int(0)
var plval = array.new_float(0)
var plloc = array.new_int(0)

if not na(ph)
    array.unshift(phval, ph)
    array.unshift(phloc, bar_index - prd)
    if array.size(phval) > 1
        for x = array.size(phloc) - 1 to 1
            if bar_index - array.get(phloc, x) > boLen
                array.pop(phloc)
                array.pop(phval)

if not na(pl)
    array.unshift(plval, pl)
    array.unshift(plloc, bar_index - prd)
    if array.size(plval) > 1
        for x = array.size(plloc) - 1 to 1
            if bar_index - array.get(plloc, x) > boLen
                array.pop(plloc)
                array.pop(plval)

// =====================
// Flow metrics
// =====================
array<float> ltfVols = request.security_lower_tf(syminfo.tickerid, lowerTf, volume)
array<float> ltfOpens = request.security_lower_tf(syminfo.tickerid, lowerTf, open)
array<float> ltfCloses = request.security_lower_tf(syminfo.tickerid, lowerTf, close)

int activeBars = 0
float deltaProxy = 0.0

if array.size(ltfVols) > 0
    for i = 0 to array.size(ltfVols) - 1
        v = array.get(ltfVols, i)
        o = array.get(ltfOpens, i)
        c = array.get(ltfCloses, i)
        if v > 0
            activeBars += 1
        if c > o
            deltaProxy += v
        else if c < o
            deltaProxy -= v

activeBarsF = float(activeBars)
avgSizeProxyRaw = activeBars > 0 ? volume / activeBarsF : na

volAvg = ta.sma(volume, lookback)
actAvg = ta.sma(activeBarsF, lookback)
sizeAvg = ta.sma(avgSizeProxyRaw, lookback)

relVol = volAvg > 0 ? volume / volAvg : na
relAct = actAvg > 0 ? activeBarsF / actAvg : na
relSize = sizeAvg > 0 ? avgSizeProxyRaw / sizeAvg : na

fp = request.footprint(ticksPerRow, vaPercent, imbalancePct)
hasFootprint = not na(fp)
fpTotalVol = hasFootprint ? footprint.total_volume(fp) : na
fpDelta = hasFootprint ? footprint.delta(fp) : na

barDeltaRaw = hasFootprint ? fpDelta : deltaProxy
barDeltaDenom = hasFootprint ? fpTotalVol : volume
barDeltaPct = barDeltaDenom > 0 ? barDeltaRaw / barDeltaDenom : na

// ATS monitor metrics
avgSizeProxy = ta.ema(avgSizeProxyRaw, smoothLen)
baselineMean = ta.sma(avgSizeProxy, baselineLen)
baselineStd = ta.stdev(avgSizeProxy, baselineLen)
changePct = not na(avgSizeProxy[1]) and avgSizeProxy[1] > 0 ? ((avgSizeProxy / avgSizeProxy[1]) - 1.0) * 100.0 : na
zScore = baselineStd > 0 ? (avgSizeProxy - baselineMean) / baselineStd : na

minRelVolEff = minRelVol
changePctThreshEff = changePctThresh
spikeZThreshEff = spikeZThresh
if assetPreset == "US Stocks (balanced)"
    minRelVolEff := math.max(minRelVolEff, 1.40)
    changePctThreshEff := math.max(changePctThreshEff, 4.0)
    spikeZThreshEff := math.max(spikeZThreshEff, 1.3)
else if assetPreset == "US Stocks (aggressive)"
    minRelVolEff := math.max(minRelVolEff, 1.25)
    changePctThreshEff := math.max(changePctThreshEff, 3.5)
    spikeZThreshEff := math.max(spikeZThreshEff, 1.2)
else if assetPreset == "US Small Caps (aggressive)"
    minRelVolEff := math.max(minRelVolEff, 1.90)
    changePctThreshEff := math.max(changePctThreshEff, 8.0)
    spikeZThreshEff := math.max(spikeZThreshEff, 1.8)
else if assetPreset == "BTC/ETH Crypto (balanced)"
    minRelVolEff := math.max(minRelVolEff, 1.30)
    changePctThreshEff := math.max(changePctThreshEff, 6.0)
    spikeZThreshEff := math.max(spikeZThreshEff, 1.6)

rising = not na(changePct) and changePct >= changePctThreshEff
falling = not na(changePct) and changePct <= -changePctThreshEff
spikeUp = not na(zScore) and zScore >= spikeZThreshEff and rising
spikeDown = not na(zScore) and zScore <= -spikeZThreshEff and falling

bullishAtsSpikeBar = spikeUp and close > open

atsLineColor = spikeUp ? color.lime : spikeDown ? color.maroon : rising ? color.green : falling ? color.red : color.gray
atsLongOk = (not requireAtsRisingLong or rising) and (not requireAtsSpikeLong or spikeUp)
atsShortOk = (not requireAtsFallingShort or falling) and (not requireAtsSpikeShort or spikeDown)

flowLongOk = not enableSmartFilters or (
     not na(relVol) and relVol >= minRelVolEff and
     not na(relAct) and relAct >= minRelAct and
     not na(relSize) and relSize >= minRelSize and
     not na(barDeltaPct) and barDeltaPct >= minDeltaAbsPct and
     atsLongOk
)

flowShortOk = not enableSmartFilters or (
     not na(relVol) and relVol >= minRelVolEff and
     not na(relAct) and relAct >= minRelAct and
     not na(relSize) and relSize >= minRelSize and
     not na(barDeltaPct) and barDeltaPct <= -minDeltaAbsPct and
     atsShortOk
)

// =====================
// Bullish cup breakout
// =====================
float bomax = na
int bostart = bar_index
int num = 0
hgst = ta.highest(high, prd)[1]

if array.size(phval) >= mintest and close > open and close > hgst
    bomax := array.get(phval, 0)
    xx = 0
    for x = 0 to array.size(phval) - 1
        if array.get(phval, x) >= close
            break
        xx := x
        bomax := math.max(bomax, array.get(phval, x))
    if xx >= mintest and open <= bomax
        for x = 0 to xx
            if array.get(phval, x) <= bomax and array.get(phval, x) >= bomax - chwidth
                num += 1
                bostart := array.get(phloc, x)
        if num < mintest or hgst >= bomax
            bomax := na

bullRaw = not na(bomax) and num >= mintest
bullSignal = bullRaw and flowLongOk

var int bullishAtsSpikeStreak = 0
bullishAtsSpikeStreak := bullishAtsSpikeBar ? nz(bullishAtsSpikeStreak[1]) + 1 : 0
bullishAtsSpikeSequence = bullishAtsSpikeStreak >= atsSpikeSequenceBars
bullishAtsSpikeSequenceAlert = bullishAtsSpikeSequence and nz(bullishAtsSpikeStreak[1]) < atsSpikeSequenceBars and (not requireBreakoutForSpikeSequence or bullSignal)
bullishAtsSpikeSequenceArmed = bullishAtsSpikeSequence and (not requireBreakoutForSpikeSequence or bullSignal)
relVolUp = not na(relVol) and not na(relVol[1]) and relVol > relVol[1]
positiveDelta = not na(barDeltaPct) and barDeltaPct > 0
bullishAtsSpikeSequenceConfirmed = bullishAtsSpikeSequenceArmed and (not requireRelVolOrDeltaForSpikeSequence or relVolUp or positiveDelta)
bullishAtsSpikeSequenceConfirmedAlert = bullishAtsSpikeSequenceConfirmed and bullishAtsSpikeSequenceConfirmed[1] != true

if bullSignal
    line.new(x1=bar_index, y1=bomax, x2=bostart, y2=bomax, color=bocolorup, style=lineStyle)
    line.new(x1=bar_index, y1=bomax - chwidth, x2=bostart, y2=bomax - chwidth, color=bocolorup, style=lineStyle)
    line.new(x1=bostart, y1=bomax - chwidth, x2=bostart, y2=bomax, color=bocolorup, style=lineStyle)
    line.new(x1=bar_index, y1=bomax - chwidth, x2=bar_index, y2=bomax, color=bocolorup, style=lineStyle)

// =====================
// Bearish cup breakdown
// =====================
float bomin = na
bostart := bar_index
int num1 = 0
lwst = ta.lowest(low, prd)[1]

if array.size(plval) >= mintest and close < open and close < lwst
    bomin := array.get(plval, 0)
    xx1 = 0
    for x = 0 to array.size(plval) - 1
        if array.get(plval, x) <= close
            break
        xx1 := x
        bomin := math.min(bomin, array.get(plval, x))
    if xx1 >= mintest and open >= bomin
        for x = 0 to xx1
            if array.get(plval, x) >= bomin and array.get(plval, x) <= bomin + chwidth
                num1 += 1
                bostart := array.get(plloc, x)
        if num1 < mintest or lwst <= bomin
            bomin := na

bearRaw = not na(bomin) and num1 >= mintest
bearSignal = bearRaw and flowShortOk

setupBarColor = bullSignal and spikeUp ? color.lime : bearSignal and spikeDown ? color.maroon : bullSignal ? color.green : bearSignal ? color.red : na

if bearSignal
    line.new(x1=bar_index, y1=bomin, x2=bostart, y2=bomin, color=bocolordown, style=lineStyle)
    line.new(x1=bar_index, y1=bomin + chwidth, x2=bostart, y2=bomin + chwidth, color=bocolordown, style=lineStyle)
    line.new(x1=bostart, y1=bomin + chwidth, x2=bostart, y2=bomin, color=bocolordown, style=lineStyle)
    line.new(x1=bar_index, y1=bomin + chwidth, x2=bar_index, y2=bomin, color=bocolordown, style=lineStyle)

// =====================
// Visuals & alerts
// =====================
plotshape(bullSignal, location=location.belowbar, style=shape.triangleup, color=bocolorup, size=size.small, title="Breakout (smart)")
plotshape(bearSignal, location=location.abovebar, style=shape.triangledown, color=bocolordown, size=size.small, title="Breakdown (smart)")

plotshape(spikeUp, title="ATS Spike Up", style=shape.labelup, location=location.top, color=color.lime, text="ATS ↑")
plotshape(spikeDown, title="ATS Spike Down", style=shape.labeldown, location=location.bottom, color=color.maroon, text="ATS ↓")
plotshape(bullishAtsSpikeSequenceAlert, title="Bullish ATS Spike Sequence", style=shape.flag, location=location.abovebar, color=color.green, text="ATS xN")
plotshape(bullishAtsSpikeSequenceConfirmedAlert, title="Bullish ATS Spike Sequence Confirmed", style=shape.flag, location=location.abovebar, color=color.lime, text="ATS OK")

barcolor(colorBars ? setupBarColor : na)
bgcolor(colorBackground ? (spikeUp ? color.new(color.lime, 88) : spikeDown ? color.new(color.red, 88) : na) : na)

alertcondition(bullSignal, title="Breakout", message="Breakout (smart filters passed)")
alertcondition(bearSignal, title="Breakdown", message="Breakdown (smart filters passed)")
alertcondition(bullSignal or bearSignal, title="Breakout or Breakdown", message="Breakout or Breakdown (smart filters passed)")
alertcondition(bullishAtsSpikeSequenceAlert, title="Bullish ATS Spike Sequence", message="{{ticker}} — bullish ATS spike-up sequence threshold reached on {{interval}}")
alertcondition(bullishAtsSpikeSequenceConfirmedAlert, title="Bullish ATS Spike Sequence Confirmed", message="{{ticker}} — bullish ATS spike-up sequence confirmed by relVol or positive delta on {{interval}}")
alertcondition(rising, title="Avg Size Proxy Rising", message="Average size proxy is rising")
alertcondition(spikeUp, title="Avg Size Proxy Spike Up", message="Average size proxy spike up")
alertcondition(falling, title="Avg Size Proxy Falling", message="Average size proxy is falling")
alertcondition(spikeDown, title="Avg Size Proxy Spike Down", message="Average size proxy spike down")

// =====================
// Compact status table
// =====================
var table dash = table.new(position.top_right, 2, 16, border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "Metric", text_color=color.white, bgcolor=color.rgb(45,45,45))
    table.cell(dash, 1, 0, "Value", text_color=color.white, bgcolor=color.rgb(45,45,45))

    table.cell(dash, 0, 1, "Preset")
    table.cell(dash, 1, 1, assetPreset)

    table.cell(dash, 0, 2, "Rel Vol")
    table.cell(dash, 1, 2, str.tostring(relVol, "#.00"))

    table.cell(dash, 0, 3, "Rel Activity")
    table.cell(dash, 1, 3, str.tostring(relAct, "#.00"))

    table.cell(dash, 0, 4, "Rel AvgSize")
    table.cell(dash, 1, 4, str.tostring(relSize, "#.00"))

    table.cell(dash, 0, 5, "Delta %")
    table.cell(dash, 1, 5, str.tostring(barDeltaPct * 100.0, "#.0") + "%")

    table.cell(dash, 0, 6, "ATS")
    table.cell(dash, 1, 6, str.tostring(avgSizeProxy, "#.00"), text_color=atsLineColor)

    table.cell(dash, 0, 7, "ATS Change %")
    table.cell(dash, 1, 7, str.tostring(changePct, "#.0"))

    table.cell(dash, 0, 8, "ATS Z")
    table.cell(dash, 1, 8, str.tostring(zScore, "#.00"))

    table.cell(dash, 0, 9, "ATS State")
    table.cell(dash, 1, 9, spikeUp ? "SPIKE UP" : spikeDown ? "SPIKE DOWN" : rising ? "RISING" : falling ? "FALLING" : "NEUTRAL", text_color=atsLineColor)

    table.cell(dash, 0, 10, "ATS Thr %")
    table.cell(dash, 1, 10, str.tostring(changePctThreshEff, "#.0"))

    table.cell(dash, 0, 11, "ATS Z Thr")
    table.cell(dash, 1, 11, str.tostring(spikeZThreshEff, "#.00"))

    table.cell(dash, 0, 12, "Signal")
    table.cell(dash, 1, 12, bullSignal ? "BULL" : bearSignal ? "BEAR" : "NONE", text_color=bullSignal ? color.lime : bearSignal ? color.red : color.silver)

    table.cell(dash, 0, 13, "ATS Spike Streak")
    table.cell(dash, 1, 13, str.tostring(bullishAtsSpikeStreak), text_color=bullishAtsSpikeSequence ? color.lime : color.silver)

    table.cell(dash, 0, 14, "ATS Seq Alert")
    table.cell(dash, 1, 14, bullishAtsSpikeSequenceAlert ? "TRIGGERED" : bullishAtsSpikeSequence ? "ARMED" : "IDLE", text_color=bullishAtsSpikeSequenceAlert ? color.lime : bullishAtsSpikeSequence ? color.green : color.silver)

    table.cell(dash, 0, 15, "ATS Seq Confirm")
    table.cell(dash, 1, 15, bullishAtsSpikeSequenceConfirmed ? "CONFIRMED" : bullishAtsSpikeSequenceArmed and requireRelVolOrDeltaForSpikeSequence ? "WAIT" : "OFF", text_color=bullishAtsSpikeSequenceConfirmed ? color.lime : color.silver)