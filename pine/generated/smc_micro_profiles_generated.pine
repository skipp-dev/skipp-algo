//@version=6
library("smc_micro_profiles_generated")

// ── Usage ──────────────────────────────────────────────────────
// import preuss_steffen/smc_micro_profiles_generated/1 as mp
//
// Fields are grouped into seven sections (v5, 51 fields total):
//   Core/Meta       — ASOF_DATE, ASOF_TIME, UNIVERSE_ID, LOOKBACK_DAYS, UNIVERSE_SIZE, REFRESH_COUNT
//   Microstructure  — *_TICKERS lists (clean_reclaim, stop_hunt_prone, …)
//   Regime          — MARKET_REGIME, VIX_LEVEL, MACRO_BIAS, SECTOR_BREADTH
//   News            — NEWS_*_TICKERS, NEWS_HEAT_GLOBAL, TICKER_HEAT_MAP
//   Calendar        — EARNINGS_*_TICKERS, HIGH_IMPACT_MACRO_TODAY, MACRO_EVENT_*
//   Layering        — GLOBAL_HEAT, GLOBAL_STRENGTH, TONE, TRADE_STATE
//   Providers       — PROVIDER_COUNT, STALE_PROVIDERS
//   Volume          — VOLUME_LOW_TICKERS, HOLIDAY_SUSPECT_TICKERS
//   Event Risk (v5) — EVENT_WINDOW_STATE … EVENT_PROVIDER_STATUS (14 fields)
//
// All fields are export const — safe to read as mp.FIELD_NAME.
// ───────────────────────────────────────────────────────────────

export const string ASOF_DATE = "2026-03-23"
export const string ASOF_TIME = ""
export const string UNIVERSE_ID = "us_equities_v1"
export const int LOOKBACK_DAYS = 20
export const int UNIVERSE_SIZE = 3
export const int REFRESH_COUNT = 0

export const string CLEAN_RECLAIM_TICKERS = "AAA"

export const string STOP_HUNT_PRONE_TICKERS = "BBB"

export const string MIDDAY_DEAD_TICKERS = "CCC"

export const string RTH_ONLY_TICKERS = "CCC"

export const string WEAK_PREMARKET_TICKERS = "CCC"

export const string WEAK_AFTERHOURS_TICKERS = "CCC"

export const string FAST_DECAY_TICKERS = "BBB"

// ── Market Regime ──
export const string MARKET_REGIME = "NEUTRAL"
export const float VIX_LEVEL = 0.0
export const float MACRO_BIAS = 0.0
export const float SECTOR_BREADTH = 0.0

// ── News Sentiment ──
export const string NEWS_BULLISH_TICKERS = ""
export const string NEWS_BEARISH_TICKERS = ""
export const string NEWS_NEUTRAL_TICKERS = ""
export const float NEWS_HEAT_GLOBAL = 0.0
export const string TICKER_HEAT_MAP = ""

// ── Earnings & Macro Calendar ──
export const string EARNINGS_TODAY_TICKERS = ""
export const string EARNINGS_TOMORROW_TICKERS = ""
export const string EARNINGS_BMO_TICKERS = ""
export const string EARNINGS_AMC_TICKERS = ""
export const bool HIGH_IMPACT_MACRO_TODAY = false
export const string MACRO_EVENT_NAME = ""
export const string MACRO_EVENT_TIME = ""

// ── Layering / Global Tone ──
export const float GLOBAL_HEAT = 0.0
export const float GLOBAL_STRENGTH = 0.0
export const string TONE = "NEUTRAL"
export const string TRADE_STATE = "ALLOWED"

// ── Provider Status ──
export const int PROVIDER_COUNT = 0
export const string STALE_PROVIDERS = ""

// ── Volume Regime ──
export const string VOLUME_LOW_TICKERS = ""
export const string HOLIDAY_SUSPECT_TICKERS = ""

// ── Event Risk ──
export const string EVENT_WINDOW_STATE = "CLEAR"
export const string EVENT_RISK_LEVEL = "NONE"
export const string NEXT_EVENT_CLASS = ""
export const string NEXT_EVENT_NAME = ""
export const string NEXT_EVENT_TIME = ""
export const string NEXT_EVENT_IMPACT = "NONE"
export const int EVENT_RESTRICT_BEFORE_MIN = 0
export const int EVENT_RESTRICT_AFTER_MIN = 0
export const bool EVENT_COOLDOWN_ACTIVE = false
export const bool MARKET_EVENT_BLOCKED = false
export const bool SYMBOL_EVENT_BLOCKED = false
export const string EARNINGS_SOON_TICKERS = ""
export const string HIGH_RISK_EVENT_TICKERS = ""
export const string EVENT_PROVIDER_STATUS = "ok"
