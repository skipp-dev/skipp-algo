// ────────────────────────────────────────────────────────────────
//  CHOCH + BOS  ·  Market Structure Strategy
//  Extracted from QuickALGO v6.3.5  ·  Pine Script v6
//  Entries on ChoCH / BOS with Volume filter.
//  Exits via opposite ChoCH, EMA cross, or ATR stop/TP/trail.
// ────────────────────────────────────────────────────────────────
//@version=6
strategy("CHOCH + BOS Strategy", overlay=true, max_labels_count=500,
     initial_capital=10000, default_qty_type=strategy.fixed,
     default_qty_value=1, pyramiding=0, commission_type=strategy.commission.percent,
     commission_value=0.01, slippage=1, process_orders_on_close=false)

// ─── Constants ───────────────────────────────────────────────
string GRP_STRUCT = "Market Structure"
string GRP_VOL    = "Volume Filter"
string GRP_EMA    = "EMA / ATR"
string GRP_RISK   = "Risk Model"
string GRP_EXIT   = "Exit Extensions"
string GRP_TRADE  = "Trade Settings"
string GRP_VIS    = "Visibility"

// ─── Inputs: Market Structure ────────────────────────────────
swingL          = input.int(5,         "Swing Left (L)",           minval=1, maxval=20, group=GRP_STRUCT)
swingR          = input.int(3,         "Swing Right (R)",          minval=1, maxval=20, group=GRP_STRUCT, tooltip="Lower R values detect new levels faster.")
swingMaxAgeBars = input.int(0,         "Swing Max Age (bars)",     minval=0, maxval=2000, group=GRP_STRUCT, tooltip="0 = no expiry.")
breakoutSource  = input.string("Close","Breakout Source",          options=["Close", "Wick"], group=GRP_STRUCT, tooltip="Close: candle must close beyond level. Wick: high/low cross is enough.")
structureLogic  = input.string("Standard", "Structure Logic",      options=["Standard", "SMC+Sweep"], group=GRP_STRUCT, tooltip="Standard: reversal via trend break. SMC+Sweep: adds failed-breakout reclaims (Turtle Soup).")

// ─── Inputs: Volume Filter ──────────────────────────────────
useVolFilter    = input.bool(true,     "Volume Filter",            group=GRP_VOL)
volSmaLen       = input.int(20,        "Volume SMA Length",        minval=2, group=GRP_VOL)
volMult         = input.float(1.20,    "Volume Multiplier",        minval=0.1, step=0.05, group=GRP_VOL, tooltip="Signal requires volume > SMA × this multiplier.")
chochReqVol     = input.bool(true,     "ChoCH Requires Volume",   group=GRP_VOL, tooltip="When ON, ChoCH signals without volume are suppressed.")

// ─── Inputs: EMA / ATR ──────────────────────────────────────
emaFastLen      = input.int(21,        "EMA Fast",                 minval=1, group=GRP_EMA)
emaSlowLen      = input.int(55,        "EMA Slow",                 minval=1, group=GRP_EMA)
atrLen          = input.int(14,        "ATR Length",               minval=1, group=GRP_EMA)

// ─── Inputs: Risk Model ─────────────────────────────────────
useAtrRisk      = input.bool(true,     "ATR Risk Model",          group=GRP_RISK)
stopATR         = input.float(2.00,    "Stop Loss (ATR)",          minval=0.1, step=0.1, group=GRP_RISK)
tpATR           = input.float(5.00,    "Take Profit (ATR)",        minval=0.1, step=0.1, group=GRP_RISK)
trailATR        = input.float(2.50,    "Trail ATR",                minval=0.1, step=0.1, group=GRP_RISK)
trailAfterR     = input.float(1.50,    "Trail after R multiple",   minval=0.0, step=0.1, group=GRP_RISK)

// ─── Inputs: Exit Extensions ────────────────────────────────
useEmaCrossExit = input.bool(true,     "Exit on EMA cross flip",  group=GRP_EXIT, tooltip="Close when EMA Fast crosses below/above Slow against the trade.")
useOppositeExit = input.bool(true,     "Exit on opposite ChoCH",  group=GRP_EXIT, tooltip="Close long on Bear ChoCH, close short on Bull ChoCH.")
cooldownBars    = input.int(2,         "Cooldown bars",            minval=0, group=GRP_EXIT)

// ─── Inputs: Trade Settings ─────────────────────────────────
enableLongs     = input.bool(true,     "Enable Longs",            group=GRP_TRADE)
enableShorts    = input.bool(false,    "Enable Shorts",           group=GRP_TRADE)
entryOn         = input.string("ChoCH Only", "Entry Signal",      options=["ChoCH Only", "ChoCH + BOS", "BOS Only"], group=GRP_TRADE, tooltip="Which structure events trigger entries.")

// ─── Inputs: Visibility ─────────────────────────────────────
showLabels      = input.bool(true,     "Structure labels",        group=GRP_VIS)
showSwingLines  = input.bool(true,     "Swing High/Low lines",    group=GRP_VIS)
showEma         = input.bool(true,     "EMA lines",               group=GRP_VIS)
showBgState     = input.bool(true,     "Background structure tint",group=GRP_VIS)

// ─── Helpers ─────────────────────────────────────────────────
f_fmtVol(v) =>
    na(v) ? "—" : v >= 1e9 ? (str.tostring(v / 1e9, "#.###") + "B") : v >= 1e6 ? (str.tostring(v / 1e6, "#.###") + "M") : v >= 1e3 ? (str.tostring(v / 1e3, "#.###") + "K") : str.tostring(v, "#")

// ─── Core: EMA / ATR ────────────────────────────────────────
emaF = ta.ema(close, emaFastLen)
emaS = ta.ema(close, emaSlowLen)
atr  = ta.atr(atrLen)

// ─── Core: Volume ────────────────────────────────────────────
volSma     = ta.sma(volume, volSmaLen)
volOk      = (not useVolFilter) or (not na(volume) and volume > volSma * volMult)
volRatio   = (not na(volume) and not na(volSma) and volSma > 0) ? volume / volSma : 0.0

// ─── Core: Swing Detection ──────────────────────────────────
var float lastSwingHigh    = na
var float lastSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

ph = ta.pivothigh(high, swingL, swingR)
pl = ta.pivotlow(low,  swingL, swingR)

if not na(ph)
    lastSwingHigh    := ph
    lastSwingHighBar := bar_index
if not na(pl)
    lastSwingLow     := pl
    lastSwingLowBar  := bar_index

if swingMaxAgeBars > 0
    if not na(lastSwingHighBar) and (bar_index - lastSwingHighBar > swingMaxAgeBars)
        lastSwingHigh    := na
        lastSwingHighBar := na
    if not na(lastSwingLowBar) and (bar_index - lastSwingLowBar > swingMaxAgeBars)
        lastSwingLow     := na
        lastSwingLowBar  := na

// ─── Core: Breakout Detection ────────────────────────────────
bool breakHigh = false
bool breakLow  = false

bool _xoWick = ta.crossover(high,  lastSwingHigh)
bool _xuWick = ta.crossunder(low,  lastSwingLow)

if breakoutSource == "Close"
    breakHigh := close > lastSwingHigh and close[1] <= lastSwingHigh
    breakLow  := close < lastSwingLow  and close[1] >= lastSwingLow
else
    if not na(lastSwingHigh)
        breakHigh := _xoWick
    if not na(lastSwingLow)
        breakLow  := _xuWick

breakoutLong  = not na(lastSwingHigh) and breakHigh
breakoutShort = not na(lastSwingLow)  and breakLow

// ─── Core: SMC+Sweep (Turtle Soup) ──────────────────────────
bool sweepHigh  = false
bool reclaimLow = false

bool cx_sweepHigh  = ta.crossunder(low,  lastSwingHigh)
bool cx_reclaimLow = ta.crossover(high,  lastSwingLow)

if structureLogic == "SMC+Sweep" and not na(lastSwingHigh) and not na(lastSwingLow)
    if breakoutSource == "Close"
        sweepHigh  := close < lastSwingHigh and high > lastSwingHigh and close[1] > lastSwingHigh
        reclaimLow := close > lastSwingLow  and low  < lastSwingLow  and close[1] < lastSwingLow
    else
        sweepHigh  := cx_sweepHigh
        reclaimLow := cx_reclaimLow

// ─── Core: Structure State Machine ──────────────────────────
var int structState = 0
bool isChoCH_Long  = false
bool isBOS_Long    = false
bool isChoCH_Short = false
bool isBOS_Short   = false

if structureLogic == "Standard"
    if breakoutLong
        if structState == -1
            isChoCH_Long := true
        else
            isBOS_Long   := true
        structState := 1
    if breakoutShort
        if structState == 1
            isChoCH_Short := true
        else
            isBOS_Short   := true
        structState := -1
else
    if breakoutLong
        if structState == -1
            isChoCH_Long := true
        else
            isBOS_Long   := true
        structState := 1
    if breakoutShort
        if structState == 1
            isChoCH_Short := true
        else
            isBOS_Short   := true
        structState := -1
    if reclaimLow
        isChoCH_Long  := true
    if sweepHigh
        isChoCH_Short := true

// ─── Signal Gating ───────────────────────────────────────────
bool confirmed  = barstate.isconfirmed
bool chochVolOk = (not chochReqVol) or volOk

bool sigChoCH_L = isChoCH_Long  and confirmed and chochVolOk
bool sigChoCH_S = isChoCH_Short and confirmed and chochVolOk
bool sigBOS_L   = isBOS_Long    and confirmed
bool sigBOS_S   = isBOS_Short   and confirmed

// ─── Entry Logic ─────────────────────────────────────────────
bool entryChochL = (entryOn == "ChoCH Only" or entryOn == "ChoCH + BOS") and sigChoCH_L
bool entryBosL   = (entryOn == "BOS Only"   or entryOn == "ChoCH + BOS") and sigBOS_L
bool entryChochS = (entryOn == "ChoCH Only" or entryOn == "ChoCH + BOS") and sigChoCH_S
bool entryBosS   = (entryOn == "BOS Only"   or entryOn == "ChoCH + BOS") and sigBOS_S

bool goLong  = enableLongs  and (entryChochL or entryBosL)
bool goShort = enableShorts and (entryChochS or entryBosS)

// Cooldown
var int lastEntryBar = 0
bool cooldownOk      = bar_index - lastEntryBar > cooldownBars

// ─── Risk Levels ─────────────────────────────────────────────
var float stopPx  = na
var float tpPx    = na
var float trailPx = na
var float entryPx = na
var int   tradeDir = 0   // 1=Long  -1=Short

bool isFlat = strategy.position_size == 0

// ─── Execute Entries ─────────────────────────────────────────
if goLong and cooldownOk and isFlat
    strategy.entry("Long", strategy.long)
    entryPx     := close
    tradeDir    := 1
    lastEntryBar := bar_index
    if useAtrRisk and not na(atr)
        stopPx  := close - atr * stopATR
        tpPx    := close + atr * tpATR
        trailPx := na
    else
        stopPx  := na
        tpPx    := na
        trailPx := na

if goShort and cooldownOk and isFlat
    strategy.entry("Short", strategy.short)
    entryPx     := close
    tradeDir    := -1
    lastEntryBar := bar_index
    if useAtrRisk and not na(atr)
        stopPx  := close + atr * stopATR
        tpPx    := close - atr * tpATR
        trailPx := na
    else
        stopPx  := na
        tpPx    := na
        trailPx := na

// ─── ATR Trailing Stop ──────────────────────────────────────
if not isFlat and useAtrRisk and not na(atr) and not na(entryPx)
    float riskDist = math.abs(entryPx - nz(stopPx, entryPx))
    float curPnl   = tradeDir == 1 ? (close - entryPx) : (entryPx - close)
    bool  trailArm = riskDist > 0 ? (curPnl / riskDist >= trailAfterR) : (curPnl > 0)

    if trailArm
        if tradeDir == 1
            float newTrail = close - atr * trailATR
            trailPx := na(trailPx) ? newTrail : math.max(trailPx, newTrail)
        else
            float newTrail = close + atr * trailATR
            trailPx := na(trailPx) ? newTrail : math.min(trailPx, newTrail)

// ─── Exit Logic ──────────────────────────────────────────────
bool exitLong  = false
bool exitShort = false

// 1. ATR hard stop / take profit
if not isFlat and useAtrRisk
    if tradeDir == 1
        if (not na(stopPx)  and low  <= stopPx)  or (not na(tpPx) and high >= tpPx)
            exitLong := true
        if not na(trailPx) and low <= trailPx
            exitLong := true
    if tradeDir == -1
        if (not na(stopPx)  and high >= stopPx)  or (not na(tpPx) and low  <= tpPx)
            exitShort := true
        if not na(trailPx) and high >= trailPx
            exitShort := true

// 2. EMA cross flip exit
if useEmaCrossExit and not isFlat
    if tradeDir == 1 and ta.crossunder(emaF, emaS)
        exitLong := true
    if tradeDir == -1 and ta.crossover(emaF, emaS)
        exitShort := true

// 3. Opposite ChoCH exit
if useOppositeExit and not isFlat
    if tradeDir == 1 and sigChoCH_S
        exitLong := true
    if tradeDir == -1 and sigChoCH_L
        exitShort := true

// Execute Exits
if exitLong and tradeDir == 1
    strategy.close("Long", comment="Exit")
    tradeDir := 0
    stopPx   := na
    tpPx     := na
    trailPx  := na
    entryPx  := na

if exitShort and tradeDir == -1
    strategy.close("Short", comment="Exit")
    tradeDir := 0
    stopPx   := na
    tpPx     := na
    trailPx  := na
    entryPx  := na

// Reset on flat (safety)
if isFlat and tradeDir != 0
    tradeDir := 0
    stopPx   := na
    tpPx     := na
    trailPx  := na
    entryPx  := na

// ─── Plot: Labels ────────────────────────────────────────────
plotshape(showLabels and sigBOS_L,   title="BOS  ▲",  style=shape.labelup,   location=location.belowbar, size=size.small, text="BOS",   textcolor=color.white, color=color.new(color.green, 50))
plotshape(showLabels and sigChoCH_L, title="ChoCH ▲", style=shape.labelup,   location=location.belowbar, size=size.small, text="ChoCH", textcolor=color.white, color=color.new(color.purple, 0))
plotshape(showLabels and sigBOS_S,   title="BOS  ▼",  style=shape.labeldown, location=location.abovebar, size=size.small, text="BOS",   textcolor=color.white, color=color.new(color.red, 50))
plotshape(showLabels and sigChoCH_S, title="ChoCH ▼", style=shape.labeldown, location=location.abovebar, size=size.small, text="ChoCH", textcolor=color.white, color=color.new(color.maroon, 0))

// ─── Plot: Swing Lines ───────────────────────────────────────
plot(showSwingLines ? lastSwingHigh : na, title="Swing High", color=color.new(color.red,   60), style=plot.style_stepline_diamond, linewidth=1)
plot(showSwingLines ? lastSwingLow  : na, title="Swing Low",  color=color.new(color.green, 60), style=plot.style_stepline_diamond, linewidth=1)

// ─── Plot: EMA Lines ─────────────────────────────────────────
plot(showEma ? emaF : na, title="EMA Fast", color=color.new(color.blue,   30), linewidth=1)
plot(showEma ? emaS : na, title="EMA Slow", color=color.new(color.orange, 30), linewidth=1)

// ─── Plot: Risk Levels ───────────────────────────────────────
plot(not isFlat and useAtrRisk ? stopPx  : na, title="Stop",  color=color.red,    style=plot.style_linebr, linewidth=1)
plot(not isFlat and useAtrRisk ? tpPx    : na, title="TP",    color=color.green,  style=plot.style_linebr, linewidth=1)
plot(not isFlat and useAtrRisk ? trailPx : na, title="Trail", color=color.orange, style=plot.style_linebr, linewidth=1)

// ─── Plot: Background Tint ──────────────────────────────────
bgCol = structState == 1 ? color.new(color.green, 92) : structState == -1 ? color.new(color.red, 92) : na
bgcolor(showBgState ? bgCol : na, title="Structure Bias")
