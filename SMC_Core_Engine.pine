//@version=6

indicator("SMC Core Engine", "SMC Core", overlay = true, max_bars_back = 500, max_lines_count = 300, max_boxes_count = 300, max_labels_count = 300)
 
import preuss_steffen/smc_core_types/1 as ct
import preuss_steffen/smc_utils/1 as u
import preuss_steffen/smc_draw/1 as d
import preuss_steffen/smc_micro_profiles_generated/1 as mp

// High-level architecture:
// - Market structure, OB/FVG engines, dashboards, alerts, and the long-dip lifecycle are coordinated locally.
// - Shared enums and core types live in ct, generic formatting/range helpers live in u, and draw wrappers live in d.
// - The long lifecycle flows as: zone detection -> reclaim/arm -> confirm -> ready/entry -> invalidated/reset.
// - Active zones stay ranking/UI concepts, while armed/confirmed validation reads from locked source state.
// - Profile alignment is optional and should fail closed on malformed thresholds or empty source arrays.

// Safe refactor notes:
// - Core BOS/CHoCH, Order Block and FVG logic is intentionally unchanged.
// - Improvements are limited to readability, defensive guards around draw/delete paths,
//   clearer configuration naming and more descriptive alerts.
// - The Order Block lifecycle remains: tracking -> extension -> awaiting confirmation -> confirmed/broken.
// - Shared enums (ct.SmcLibMovingAverage, ct.LevelBreakMode, ct.SignalMode) live in smc_core_types (ct).
// - Generic helpers (in_range, format_level, edge, ...) live in smc_utils (u).
// - Draw wrappers (SmcLabel, SmcLine, SmcBox, factories, methods) live in smc_draw (d).

// --------------------------------------------------
// Embedded Library Subset (remaining local helpers)
// --------------------------------------------------

// ATR helper
smc_lib_atr(simple int length) =>
    float atr_value = ta.atr(length)
    float tr_cum = ta.cum(ta.tr(true))
    if bar_index < length
        atr_value := tr_cum / (bar_index + 1)
    atr_value

// Moving-average selector helpers used by DDVI

smc_lib_ehma(float source, simple int length) =>
    int half_length = math.max(1, int(math.round(length / 2.0)))
    int sqrt_length = math.max(1, int(math.round(math.sqrt(length))))
    ta.ema(2 * ta.ema(source, half_length) - ta.ema(source, length), sqrt_length)

smc_lib_thma(float source, simple int length) =>
    int len_sixth = math.max(1, int(math.round(length / 6.0)))
    int len_quarter = math.max(1, int(math.round(length / 4.0)))
    int len_half = math.max(1, int(math.round(length / 2.0)))
    ta.wma(ta.wma(source, len_sixth) * 3 - ta.wma(source, len_quarter) - ta.wma(source, len_half), len_half)

smc_lib_get_ma(simple ct.SmcLibMovingAverage select_ma = ct.SmcLibMovingAverage.SMA, float source, simple int length) =>
    switch select_ma
        ct.SmcLibMovingAverage.EMA => ta.ema(source, length)
        ct.SmcLibMovingAverage.RMA => ta.rma(source, length)
        ct.SmcLibMovingAverage.WMA => ta.wma(source, length)
        ct.SmcLibMovingAverage.VWMA => ta.vwma(source, length)
        ct.SmcLibMovingAverage.HMA => ta.hma(source, length)
        ct.SmcLibMovingAverage.EHMA => smc_lib_ehma(source, length)
        ct.SmcLibMovingAverage.THMA => smc_lib_thma(source, length)
        => ta.sma(source, length)

smc_lib_bb(float source, simple int length, float mult, simple ct.SmcLibMovingAverage select_ma) =>
    float base = smc_lib_get_ma(select_ma, source, length)
    float dev = mult * ta.stdev(source, length)
    [base, base + dev, base - dev]

// DMI helper used by DDVI
smc_lib_dmi(simple int di_length = 17, simple int adx_smoothing = 14) =>
    ta.dmi(di_length, adx_smoothing)

// Divergence helper used by DDVI
smc_lib_detect_divergence(float osc, simple int pivot_confirmation_bars_left = 5, simple int pivot_confirmation_bars_right = 3, simple int pivot_min_x_distance = 5, simple int pivot_max_x_distance = 50, series float ref_low = low, series float ref_high = high, simple int pivot_min_y_distance_len = 14, simple float pivot_min_y_distance_dev_mult = 0.1, simple float pivot_min_y_distance_atr_mult = 0.1) =>
    bool osc_pivot_l = not na(ta.pivotlow(osc, pivot_confirmation_bars_left, pivot_confirmation_bars_right))
    bool osc_pivot_h = not na(ta.pivothigh(osc, pivot_confirmation_bars_left, pivot_confirmation_bars_right))
    float pivot_osc_value = osc[pivot_confirmation_bars_right]
    float osc_dev_value = nz(ta.dev(pivot_osc_value, pivot_min_y_distance_len), 0.0) * pivot_min_y_distance_dev_mult
    float price_atr_value = smc_lib_atr(pivot_min_y_distance_len) * pivot_min_y_distance_atr_mult
    var int osc_prev_l_idx = na
    var float osc_prev_l_value = na
    var float price_prev_l = na
    var int osc_prev_h_idx = na
    var float osc_prev_h_value = na
    var float price_prev_h = na

    if barstate.isconfirmed and (osc_pivot_h or osc_pivot_l)
        float prev_pivot_value = osc_pivot_h ? osc_prev_h_value : osc_prev_l_value
        float prev_pivot_price = osc_pivot_h ? price_prev_h : price_prev_l
        float new_pivot_value = osc[pivot_confirmation_bars_right]
        float new_pivot_price = osc_pivot_h ? ref_high[pivot_confirmation_bars_right] : ref_low[pivot_confirmation_bars_right]
        int new_pivot_distance = osc_pivot_h ? bar_index - osc_prev_h_idx : bar_index - osc_prev_l_idx
        bool has_prev_pivot = osc_pivot_h ? not na(osc_prev_h_idx) and not na(prev_pivot_value) and not na(prev_pivot_price) : not na(osc_prev_l_idx) and not na(prev_pivot_value) and not na(prev_pivot_price)

        if osc_pivot_h
            osc_prev_h_idx := bar_index
            osc_prev_h_value := new_pivot_value
            price_prev_h := new_pivot_price
        if osc_pivot_l
            osc_prev_l_idx := bar_index
            osc_prev_l_value := new_pivot_value
            price_prev_l := new_pivot_price

        int mode = has_prev_pivot ? new_pivot_value < prev_pivot_value - osc_dev_value ? -1 : new_pivot_value > prev_pivot_value + osc_dev_value ? 1 : 0 : 0
        int mode_p = has_prev_pivot ? new_pivot_price < prev_pivot_price - price_atr_value ? -1 : new_pivot_price > prev_pivot_price + price_atr_value ? 1 : 0 : 0
        bool x_distance_in_range = has_prev_pivot and new_pivot_distance >= pivot_min_x_distance and new_pivot_distance <= pivot_max_x_distance

        bool strong_bull = osc_pivot_l and x_distance_in_range and mode == 1 and mode_p == -1
        bool medium_bull = osc_pivot_l and x_distance_in_range and mode == 1 and mode_p == 0
        bool weak_bull = osc_pivot_l and x_distance_in_range and mode == 0 and mode_p == -1
        bool hidden_bull = osc_pivot_l and x_distance_in_range and mode == -1 and mode_p == 1
        bool strong_bear = osc_pivot_h and x_distance_in_range and mode == -1 and mode_p == 1
        bool medium_bear = osc_pivot_h and x_distance_in_range and mode == -1 and mode_p == 0
        bool weak_bear = osc_pivot_h and x_distance_in_range and mode == 0 and mode_p == 1
        bool hidden_bear = osc_pivot_h and x_distance_in_range and mode == 1 and mode_p == -1
        [strong_bull, strong_bear, medium_bull, medium_bear, weak_bull, weak_bear, hidden_bull, hidden_bear, osc_pivot_h, osc_pivot_l]
    else
        [false, false, false, false, false, false, false, false, osc_pivot_h, osc_pivot_l]

// Embedded profile engine subset replacing the former lib_profile dependency.
type Bucket
    varip int idx
    varip float value
    varip float top
    varip float btm
    varip float center
    varip float fraction
    d.SmcLine plot_bucket_line = na

method update(Bucket this, float top, float bottom, float value, float fraction) =>
    rounded_top = math.round_to_mintick(top)
    rounded_bottom = math.round_to_mintick(bottom)
    rounded_fraction = math.round(fraction, 2)
    this.top := rounded_top
    this.btm := rounded_bottom
    this.center := math.avg(rounded_top, rounded_bottom)
    this.value := value
    this.fraction := rounded_fraction
    this

normalize_profile_resolution(int resolution) =>
    math.max(1, resolution)

normalize_profile_vah_pc(float vah_pc, float val_pc) =>
    math.max(0.0, math.min(100.0, math.max(vah_pc, val_pc)))

normalize_profile_val_pc(float vah_pc, float val_pc) =>
    math.max(0.0, math.min(100.0, math.min(vah_pc, val_pc)))

profile_data_ready(float[] highs, float[] lows, float[] values) =>
    not na(highs) and not na(lows) and not na(values) and array.size(highs) > 0 and array.size(lows) > 0 and array.size(values) > 0

is_impulse_candle_now(float candle_body, float impulse_candle_size) =>
    candle_body >= impulse_candle_size

is_indecision_candle_now(float high_now, float low_now, float prior_high, float prior_low, float candle_top_now, float candle_btm_now, float prior_candle_top, float prior_candle_btm, float prior_candle_body, float candle_body, float candle_open, float candle_close) =>
    u.in_range(high_now, low_now, prior_high, prior_low) and prior_candle_body > candle_body or u.in_range(candle_top_now, candle_btm_now, prior_candle_top, prior_candle_btm) or candle_open == candle_close

profile_features_enabled(bool capture_profile_now, bool align_edge_to_value_area_now, bool align_break_price_to_poc_now) =>
    capture_profile_now or align_edge_to_value_area_now or align_break_price_to_poc_now

method update(Bucket this, float value, float fraction) =>
    this.value := value
    this.fraction := math.round(fraction, 2)
    this

type ProfileConfig
    bool show_poc = true
    bool show_profile = false
    bool show_va = false
    bool show_background = false
    bool show_labels = false
    bool show_price_levels = false
    bool extend = false

    string poc_label_text = 'POC'
    d.LineArgs args_poc_line = na
    d.LineArgs args_vah_line = na
    d.LineArgs args_val_line = na
    d.LabelArgs args_poc_label = na
    d.LineArgs args_profile_line = na
    d.BoxArgs args_profile_bg = na
    bool initialized = false

method init(ProfileConfig this) =>
    if na(this) ? false : not this.initialized
        if na(this.args_poc_line)
            this.args_poc_line := d.LineArgs.new(color.orange, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_vah_line)
            this.args_vah_line := d.LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_val_line)
            this.args_val_line := d.LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_poc_label)
            this.args_poc_label := d.LabelArgs.new(color.orange, #00000000, xloc = xloc.bar_index, style = label.style_label_left)
        if na(this.args_profile_line)
            this.args_profile_line := d.LineArgs.new(color.rgb(120, 123, 134, 40), line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_profile_bg)
            this.args_profile_bg := d.BoxArgs.new(#00000000, bg_color = color.rgb(120, 123, 134, 92), xloc = xloc.bar_index)
        this.initialized := true
    this

type Profile
    int id
    int resolution
    float vah_threshold_pc
    float val_threshold_pc
    varip float[] data_opens
    varip float[] data_highs
    varip float[] data_lows
    varip float[] data_closes
    varip float[] data_values
    varip float h = na
    varip float l = na
    varip float total = 0
    varip float total_up = 0
    varip float total_down = 0
    Bucket[] buckets
    varip int poc_bucket_index = na
    varip int vah_bucket_index = na
    varip int val_bucket_index = na
    varip float poc = na
    varip float vah = na
    varip float val = na
    d.SmcLine plot_poc = na
    d.SmcLine plot_vah = na
    d.SmcLine plot_val = na
    d.SmcLabel plot_poc_label = na
    d.SmcBox plot_profile_bg = na
    bool hidden = false

method apply_style(Profile this, ProfileConfig args) =>
    if not na(this) and not na(args)
        if not na(this.plot_poc)
            this.plot_poc.apply_style(args.args_poc_line)
        if not na(this.plot_vah)
            this.plot_vah.apply_style(args.args_vah_line)
        if not na(this.plot_val)
            this.plot_val.apply_style(args.args_val_line)
        if not na(this.plot_poc_label)
            this.plot_poc_label.apply_style(args.args_poc_label)
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.apply_style(args.args_profile_bg, d.BoxTextArgs.new())
    this

method delete(Profile this) =>
    if not na(this)
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.delete()
                    bucket.plot_bucket_line := na
            array.clear(this.buckets)
            this.buckets := na
        if not na(this.plot_poc)
            this.plot_poc.delete()
            this.plot_poc := na
        if not na(this.plot_vah)
            this.plot_vah.delete()
            this.plot_vah := na
        if not na(this.plot_val)
            this.plot_val.delete()
            this.plot_val := na
        if not na(this.plot_poc_label)
            this.plot_poc_label.delete()
            this.plot_poc_label := na
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.delete()
            this.plot_profile_bg := na
        if not na(this.data_opens)
            array.clear(this.data_opens)
        if not na(this.data_highs)
            array.clear(this.data_highs)
        if not na(this.data_lows)
            array.clear(this.data_lows)
        if not na(this.data_closes)
            array.clear(this.data_closes)
        if not na(this.data_values)
            array.clear(this.data_values)
        this.hidden := false
    this

method hide(Profile this) =>
    if na(this) ? false : not this.hidden
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.hide()
        if not na(this.plot_poc)
            this.plot_poc.hide()
        if not na(this.plot_vah)
            this.plot_vah.hide()
        if not na(this.plot_val)
            this.plot_val.hide()
        if not na(this.plot_poc_label)
            this.plot_poc_label.hide()
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.hide()
        this.hidden := true
    this

method init(Profile this, bool update_buckets = false) =>
    if not na(this)
        create_buckets = na(this.buckets)
        if create_buckets or update_buckets
            float bucket_size = this.resolution > 0 ? (this.h - this.l) / this.resolution : 0
            if create_buckets
                this.buckets := array.new<Bucket>(this.resolution)
            for i = 0 to this.resolution - 1
                float bucket_bottom = this.l + i * bucket_size
                float bucket_top = bucket_bottom + bucket_size
                if create_buckets
                    this.buckets.set(i, Bucket.new(i, 0, bucket_top, bucket_bottom, math.avg(bucket_top, bucket_bottom), 0))
                else
                    this.buckets.get(i).update(bucket_top, bucket_bottom, 0, 0)
    this

method calculate(Profile this, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    int range_count = array.size(this.data_values)
    if not na(this.buckets)
        this.poc_bucket_index := na
        this.val_bucket_index := na
        this.vah_bucket_index := na
        this.poc := na
        this.val := na
        this.vah := na
        this.total_up := 0
        this.total_down := 0
        float poc_volume = 0
        float sum_volume_up = 0
        float sum_volume_down = 0
        int range_count_opens = na(this.data_opens) ? 0 : array.size(this.data_opens)
        int range_count_closes = na(this.data_closes) ? 0 : array.size(this.data_closes)

        if range_count <= 0 or this.total <= 0
            for i = 0 to this.resolution - 1
                this.buckets.get(i).update(0, 0)
        else
            for i = 0 to this.resolution - 1
                Bucket bucket = this.buckets.get(i)
                float bucket_value = 0
                for j = 0 to range_count - 1
                    float range_value = array.get(this.data_values, j)
                    float range_high = array.get(this.data_highs, j)
                    float range_low = array.get(this.data_lows, j)
                    float range_size = range_high - range_low
                    float overlap = math.max(0, math.min(range_high, bucket.top) - math.max(range_low, bucket.btm))
                    if (i == 0 or 0 < use_open_close_data_for_ranges_shorter_than_bars) and j < range_count_opens and j < range_count_closes
                        float range_open = array.get(this.data_opens, j)
                        float range_close = array.get(this.data_closes, j)
                        if i == 0
                            if range_open < range_close
                                sum_volume_up += range_value
                            else
                                sum_volume_down += range_value
                        if j < use_open_close_data_for_ranges_shorter_than_bars
                            overlap += math.max(0, math.min(math.max(range_open, range_close), bucket.top) - math.max(math.min(range_open, range_close), bucket.btm)) / 2
                            range_size += math.abs(range_open - range_close) / 2
                    float range_value_fraction = range_size > 0 ? overlap / range_size : (overlap > 0 ? 1 : 0)
                    bucket_value += range_value_fraction * range_value
                bucket.update(bucket_value, bucket_value / this.total)
                if bucket_value > 0 and (na(this.poc_bucket_index) or bucket_value >= poc_volume)
                    poc_volume := bucket_value
                    this.poc_bucket_index := i
                    this.poc := bucket.center
            if not na(this.poc_bucket_index)
                int left_va = this.poc_bucket_index
                int right_va = this.poc_bucket_index
                float va_sum = this.buckets.get(this.poc_bucket_index).value
                float va_target = this.total * math.max(this.vah_threshold_pc - this.val_threshold_pc, 0) / 100.0

                while va_sum < va_target and (left_va > 0 or right_va < this.resolution - 1)
                    float next_left = left_va > 0 ? this.buckets.get(left_va - 1).value : -1
                    float next_right = right_va < this.resolution - 1 ? this.buckets.get(right_va + 1).value : -1

                    if next_left > next_right
                        left_va -= 1
                        va_sum += next_left
                    else
                        right_va += 1
                        va_sum += next_right

                this.val_bucket_index := left_va
                this.vah_bucket_index := right_va
                this.val := this.buckets.get(left_va).center
                this.vah := this.buckets.get(right_va).center
            this.total_up := sum_volume_up
            this.total_down := sum_volume_down
    this

create_profile(float[] opens, float[] highs, float[] lows, float[] closes, float[] values, int resolution = 25, float vah_pc = 80, float val_pc = 20, int idx = bar_index, bool init_calculated = true, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    int profile_resolution = normalize_profile_resolution(resolution)
    float profile_vah_pc = normalize_profile_vah_pc(vah_pc, val_pc)
    float profile_val_pc = normalize_profile_val_pc(vah_pc, val_pc)
    bool profile_has_range_data = profile_data_ready(highs, lows, values)
    float profile_high = profile_has_range_data ? highs.max() : na
    float profile_low = profile_has_range_data ? lows.min() : na
    float profile_total = profile_has_range_data ? values.sum() : 0
    profile = Profile.new(idx, profile_resolution, profile_vah_pc, profile_val_pc, opens, highs, lows, closes, values, h = profile_high, l = profile_low, total = profile_total)
    profile.init(update_buckets = true)
    if init_calculated
        profile.calculate(use_open_close_data_for_ranges_shorter_than_bars)
    profile

method update(Profile this, float[] opens = na, float[] highs = na, float[] lows = na, float[] closes = na, float[] values = na) =>
    if not na(this)
        recalculation_required = false
        layout_required = false
        if not na(opens)
            this.data_opens := opens
            recalculation_required := true
        if not na(highs)
            this.data_highs := highs
            high_max = highs.max()
            layout_required := this.h != high_max
            this.h := high_max
            recalculation_required := true
        if not na(lows)
            this.data_lows := lows
            low_min = lows.min()
            layout_required := layout_required or this.l != low_min
            this.l := low_min
            recalculation_required := true
        if not na(closes)
            this.data_closes := closes
            recalculation_required := true
        if not na(values)
            this.data_values := values
            this.total := values.sum()
            recalculation_required := true
        if layout_required
            this.init(update_buckets = true)
        if recalculation_required or na(this.poc)
            this.calculate()
    this

method draw(Profile this, ProfileConfig config, int left = na, int right = na, bool extend_only = true, simple bool force_overlay = false, string poc_text_override = na) =>
    if na(this) ? false : na(this.buckets) ? false : this.buckets.size() > 0
        config.init()
        this.init()
        if config.show_background
            if na(this.plot_profile_bg)
                this.plot_profile_bg := d.create_box(left, this.h, right, this.l, config.args_profile_bg.xloc)
            else
                this.plot_profile_bg.left_top.update(left, this.h, config.args_profile_bg.xloc)
                this.plot_profile_bg.right_bottom.update(right, this.l, config.args_profile_bg.xloc)
            this.plot_profile_bg.draw(config.args_profile_bg, na, extend_only, force_overlay)
        if config.show_poc and not na(this.poc)
            if na(this.plot_poc)
                this.plot_poc := d.create_line(left, this.poc, right, this.poc, config.args_poc_line.xloc)
            else
                this.plot_poc.start.update(left, this.poc, config.args_poc_line.xloc)
                this.plot_poc.end.update(right, this.poc, config.args_poc_line.xloc)
            this.plot_poc.draw(config.args_poc_line, extend_only, force_overlay)
            if config.show_labels
                tooltip = str.format('{0} ({1})', na(poc_text_override) ? config.poc_label_text : poc_text_override, this.poc)
                txt = config.show_price_levels ? tooltip : na(poc_text_override) ? config.poc_label_text : poc_text_override
                if na(this.plot_poc_label)
                    this.plot_poc_label := d.create_label(d.create_point(right, this.poc, config.args_poc_label.xloc), txt, tooltip)
                else
                    this.plot_poc_label.point.update(right, this.poc, config.args_poc_label.xloc)
                    this.plot_poc_label.txt := txt
                    this.plot_poc_label.tooltip := tooltip
                this.plot_poc_label.draw(config.args_poc_label, force_overlay)
        if config.show_va and not na(this.vah) and not na(this.val)
            if na(this.plot_vah)
                this.plot_vah := d.create_line(left, this.vah, right, this.vah, config.args_vah_line.xloc)
            else
                this.plot_vah.start.update(left, this.vah, config.args_vah_line.xloc)
                this.plot_vah.end.update(right, this.vah, config.args_vah_line.xloc)
            this.plot_vah.draw(config.args_vah_line, extend_only, force_overlay)
            if na(this.plot_val)
                this.plot_val := d.create_line(left, this.val, right, this.val, config.args_val_line.xloc)
            else
                this.plot_val.start.update(left, this.val, config.args_val_line.xloc)
                this.plot_val.end.update(right, this.val, config.args_val_line.xloc)
            this.plot_val.draw(config.args_val_line, extend_only, force_overlay)
        this.hidden := false
    this

/////////////////////////////////////////////////////////////////////////////////
//#region    EMBEDDED SMC SUBSET
/////////////////////////////////////////////////////////////////////////////////

//-----------------------------------------------------------------------------
//Core structures and helpers
//-----------------------------------------------------------------------------

type OrderBlock
    int id
    int dir
    chart.point left_top
    chart.point right_bottom
    float break_price
    ct.LevelBreakMode break_mode = ct.LevelBreakMode.CLOSE
    
    float[] ltf_open
    float[] ltf_high
    float[] ltf_low
    float[] ltf_close
    float[] ltf_volume

    d.SmcBox plot
    Profile profile

    float quality_score                          = 0
    bool trailing                                = false
    bool extending                               = false
    bool awaiting_confirmation                   = false
    bool touched_break_price_before_confirmation = false
    bool soft_confirmed                          = false
    bool has_fvg_out                             = false
    bool has_big_candle                          = false
    bool hidden                                  = false
    bool broken                                  = false
    int  broken_time                             = na
    int  broken_index                            = na

type OrderBlockConfig
    bool show = true
    int show_last = 5
    bool show_id = false
    bool show_profile = true
    bool show_text = true
    bool show_fvg_out = true
    bool show_quality_score = false
    bool extend_until_broken = true

    d.BoxArgs args
    string txt = 'OB'
    d.BoxTextArgs txt_args
    bool use_profile = false
    ProfileConfig profile_config = na

method delete(OrderBlock this) =>
    if not na(this)
        if not na(this.plot)
            this.plot.delete()
            this.plot := na
        if not na(this.profile)
            this.profile.delete()
            this.profile := na
        this.hidden := false
    this

method delete(OrderBlock[] blocks) =>
    if not na(blocks)
        for block in blocks
            block.delete()
    blocks

create_ob(int id, int mode, int start_t, int start_i, float top, int end_t, int end_i, float bottom, float break_price = na, simple ct.LevelBreakMode break_mode = ct.LevelBreakMode.CLOSE) =>
    OrderBlock block = OrderBlock.new(id, mode,
     chart.point.new(start_t, start_i, top),
     chart.point.new(end_t, end_i, bottom),
     not na(break_price) ? break_price : mode == 1 ? top : bottom,
     break_mode,
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0)
     )

    float block_height = math.max(top - bottom, syminfo.mintick)
    float normalized_height = math.min(block_height / math.max(syminfo.mintick * 20, syminfo.mintick), 1.0)
    block.quality_score := math.max(0.0, math.min(1.0, 0.20 + normalized_height * 0.20))

    block

ob_quality_score(OrderBlock block) =>
    if na(block)
        0.0
    else
        float block_height = math.max(block.left_top.price - block.right_bottom.price, syminfo.mintick)
        float size_component = math.min(block_height / math.max(syminfo.mintick * 20, syminfo.mintick), 1.0)
        float score = 0.15
        score += size_component * 0.20
        score += block.has_fvg_out ? 0.20 : 0.0
        score += block.has_big_candle ? 0.15 : 0.0
        score += block.soft_confirmed ? 0.15 : 0.0
        score += not block.broken ? 0.10 : 0.0
        score += not na(block.profile) and block.profile.total > 0 ? 0.05 : 0.0
        math.max(0.0, math.min(1.0, score))

method align_to_profile(OrderBlock block, bool align_edge = false, bool align_break_price = false) =>
    if not na(block.profile) and block.profile.total > 0
        if align_edge and not na(block.profile.vah)
            block.left_top.price     := block.profile.vah
            block.right_bottom.price := block.profile.val
        if align_break_price and not na(block.profile.poc)
            block.break_price        := block.profile.poc
    block

method _create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if na(block.profile)
        block.profile := create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, block.left_top.index, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    else
        block.profile.update(opens, tops, bottoms, closes, values)
    block

method create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if barstate.isconfirmed and not na(block)
        block._create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    block

method create_profile(OrderBlock block, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    block.create_profile(block.ltf_open, block.ltf_high, block.ltf_low, block.ltf_close, block.ltf_volume, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)

resolve_confirmed_ob_break_price(bool align_edge_to_value_area, bool align_break_price_to_poc, float original_top, float original_bottom, float confirmed_top, float confirmed_bottom, float current_break_price) =>
    float resolved_break_price = current_break_price
    if not align_break_price_to_poc
        resolved_break_price := align_edge_to_value_area ? math.avg(confirmed_top, confirmed_bottom) : math.avg(original_top, original_bottom)
    resolved_break_price

method overlaps_range(OrderBlock this, float range_top = 0, float range_btm = 0) =>
    na(this) ? false : u.range_overlap(this.left_top.price, this.right_bottom.price, range_top, range_btm)

method any_overlaps(OrderBlock[] this, float range_top, float range_btm) =>
    found = false
    if not na(this) and this.size() > 0
        for i = this.size() - 1 to 0
            if this.get(i).overlaps_range(range_top, range_btm)
                found := true
                break
    found

method contains_id(OrderBlock[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for block in this
            if block.id == id
                found := true
                break
    found

method get_by_id(OrderBlock[] this, int id) =>
    OrderBlock found = na
    if not na(this) and not na(id)
        for block in this
            if block.id == id
                found := block
                break
    found

current_bar_right_time() =>
    barstate.isrealtime ? math.min(time_close, timenow) : time_close

effective_live_event_time(int event_time, int fallback_time) =>
    base_time = nz(event_time, fallback_time)
    barstate.isrealtime ? math.min(base_time, current_bar_right_time()) : base_time

method rendered_right_time(OrderBlock this, bool extend_until_broken = true) =>
    if na(this)
        na
    else
        int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
        extend_until_broken ? (this.broken ? effective_live_event_time(this.broken_time, base_right_time) : current_bar_right_time()) : base_right_time

method overlaps_window(OrderBlock this, int left_time, int right_time, bool extend_until_broken = true) =>
    if na(this)
        false
    else
        effective_right_time = this.rendered_right_time(extend_until_broken)
        effective_right_time >= left_time and this.left_top.time <= right_time

update_broken(int mode, OrderBlock[] tracking_blocks, OrderBlock[] broken_blocks, OrderBlock[] broken_blocks_new, simple ct.LevelBreakMode broken_by = ct.LevelBreakMode.HIGHLOW, int keep_broken_max = 5, OrderBlock[] discarded_buffer = na) =>
    bool broken_by_close = broken_by == ct.LevelBreakMode.CLOSE
    OrderBlock[] moved_blocks = array.new<OrderBlock>(0)
    
    broken_blocks_new.clear()
    
    tracking_size = tracking_blocks.size()
    if tracking_size > 0
        break_src = broken_by_close ? close : mode == 1 ? low : high
        
        for i = tracking_size - 1 to 0
            block = tracking_blocks.get(i)

            if broken_by != ct.LevelBreakMode.CLOSE or barstate.isconfirmed
                if mode == 1 ? block.break_price > break_src : block.break_price < break_src
                    block.broken       := true                    
                    block.broken_time  := time_close
                    block.broken_index := bar_index + 1
                    moved_blocks.unshift(block)
                    tracking_blocks.remove(i)

        for block in moved_blocks
            broken_blocks.push(block)
            broken_blocks_new.push(block)

        if keep_broken_max >= 0
            while broken_blocks.size() > keep_broken_max
                if not na(discarded_buffer)
                    discarded_buffer.push(broken_blocks.shift())
                else
                    broken_blocks.shift()

    true

method reset_tracking(OrderBlock this) =>
    this.ltf_high.clear()
    this.ltf_low.clear()
    this.ltf_open.clear()
    this.ltf_close.clear()
    this.ltf_volume.clear()

    this.trailing := true
    this.extending := false
    this.awaiting_confirmation := false
    this.touched_break_price_before_confirmation := false
    this.soft_confirmed := false
    this.has_fvg_out := false
    this.broken := false
    this.broken_time := na
    this.broken_index := na

    this.left_top := chart.point.now(high)
    this.right_bottom := chart.point.now(low)
    this.break_price := hl2

method capture_profile_bar(OrderBlock this, bool enabled) =>
    if enabled
        this.ltf_open.push(open)
        this.ltf_high.push(high)
        this.ltf_low.push(low)
        this.ltf_close.push(close)
        this.ltf_volume.push(volume)
    this

handle_pending_tracking_reset(OrderBlock block, bool reset_next_bar) =>
    if reset_next_bar
        block.reset_tracking()
        false
    else
        reset_next_bar

prepare_order_block_confirmation(OrderBlock block, float min_block_size, float max_block_size, bool round_size_bounds, bool update_profile_current_bar, bool align_edge_to_value_area, bool align_break_price_to_poc, bool should_prepare) =>
    if should_prepare
        block.left_top.price := math.max(open, block.left_top.price)
        block.right_bottom := chart.point.new(time_close[1], bar_index[1], block.right_bottom.price)
        block.extending := false
        block.awaiting_confirmation := true
    int ob_length = math.max(block.right_bottom.index - block.left_top.index + 1, 1)
    float ob_size_min = round_size_bounds ? math.round_to_mintick(min_block_size) : min_block_size
    float ob_size_max = round_size_bounds ? math.round_to_mintick(max_block_size * ob_length) : max_block_size * ob_length
    if should_prepare and update_profile_current_bar and (align_edge_to_value_area or align_break_price_to_poc)
        block.create_profile()
        block.align_to_profile(align_break_price = true)
    [ob_size_min, ob_size_max]

update_soft_confirmation(OrderBlock block, bool bullish_side, bool use_soft_confirm_big_candle, bool is_impulse_candle, bool is_trend_candle, float soft_confirm_offset, float impulse_candle_size) =>
    if barstate.isconfirmed and not block.soft_confirmed
        if not block.touched_break_price_before_confirmation
            bool touched_break = bullish_side ? block.break_price > low and block.right_bottom.index < bar_index : block.break_price < high and block.right_bottom.index < bar_index
            if touched_break
                block.touched_break_price_before_confirmation := true
        bool soft_offset_reached = bullish_side ? block.touched_break_price_before_confirmation and block.left_top.price + soft_confirm_offset < close : block.touched_break_price_before_confirmation and block.right_bottom.price - soft_confirm_offset > close
        bool big_candle_override = use_soft_confirm_big_candle and is_impulse_candle and is_trend_candle and (bullish_side ? close - block.left_top.price >= impulse_candle_size / 2 : block.right_bottom.price - close >= impulse_candle_size / 2)
        if soft_offset_reached or big_candle_override
            block.soft_confirmed := true
    block.soft_confirmed

confirmation_price_exited(OrderBlock block, bool bullish_side, float soft_confirm_offset) =>
    bullish_side ? block.left_top.price + soft_confirm_offset < close : block.right_bottom.price - soft_confirm_offset > close

confirmation_trigger_active(OrderBlock block, bool use_soft_confirm, float swing_confirmed, bool bos_alert, bool choch_alert, int swing_len) =>
    (block.soft_confirmed and use_soft_confirm) or not na(swing_confirmed) or bos_alert or choch_alert or bar_index - block.right_bottom.index >= swing_len

ob_size_within_bounds(OrderBlock block, bool align_edge_to_value_area, float ob_size_max, float ob_size_min) =>
    align_edge_to_value_area and not na(block.profile) ? u.in_range(math.round_to_mintick(block.profile.vah - block.profile.val), ob_size_max, ob_size_min) : u.in_range(math.round_to_mintick(block.left_top.price - block.right_bottom.price), ob_size_max, ob_size_min)
  
method remove_insignificant(OrderBlock[] blocks, float min_size, float max_size, OrderBlock[] removed_buffer = na, int protected_id = na) =>
    if blocks.size() > 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            size = block.left_top.price - block.right_bottom.price
            bool is_protected = not na(protected_id) and block.id == protected_id
            if not is_protected and (size < min_size or max_size < size)
                log.info("clearing out old OB to free memory (top: {0} | bottom: {1}) with size ({2}) outside range (min: {3} | max: {4})", block.left_top.price, block.right_bottom.price, size, min_size, max_size)

                if not na(removed_buffer)
                    removed_buffer.push(block)

                block.delete()
                blocks.remove(i)
                
    blocks

track_obs(
 int swing_len,
 float swing_high_confirmed,
 float swing_low_confirmed,
 bool bull_bos_alert,
 bool bull_choch_alert,
 bool bear_bos_alert,
 bool bear_choch_alert,
 float min_block_size,
 float max_block_size,
 bool enabled = true,
 simple bool include_consecutive_bars = true,
 bool capture_profile = false,
 bool update_profile_current_bar = true,
 bool align_edge_to_value_area = false,
 bool align_break_price_to_poc = false,
 simple bool use_soft_confirm = true,
 float soft_confirm_offset = 0,
 simple bool use_soft_confirm_big_candle = true,
 simple bool use_retracements_with_FVG_out = true,
 simple ct.LevelBreakMode broken_by = ct.LevelBreakMode.HIGHLOW,
 simple int keep_broken_max = 5,
 simple int gc_cycle = na,
 int protected_bull_id = na,
 int protected_bear_id = na
 ) =>
    // Order block lifecycle:
    // 1. trailing: candidate block is tracked while price builds it
    // 2. extending: block grows as same-direction candles continue
    // 3. awaiting_confirmation: extension stopped, block waits for confirmation
    // 4. confirmed: block is copied into the tracked blocks buffer
    // 5. broken: later mitigation/break moves it into the broken history buffer

    var OrderBlock[] tracking_blocks_bull   = array.new<OrderBlock>(0)
    var OrderBlock[] tracking_blocks_bear   = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bull     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bear     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bull = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bear = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bull  = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bear  = array.new<OrderBlock>(0)

    float atr = smc_lib_atr(200)
    float fvg_min_size = atr * 0.2
    float impulse_candle_size = atr * 3
        
    var int next_id = 0
    var OrderBlock bull_ob = create_ob(0,  1, time, bar_index, high, time, bar_index, low, hl2, broken_by)
    var OrderBlock bear_ob = create_ob(0, -1, time, bar_index, high, time, bar_index, low, hl2, broken_by)

    if barstate.isfirst
        bull_ob.reset_tracking()
        bear_ob.reset_tracking()

    var float ob_size_min_bull = min_block_size
    var float ob_size_min_bear = min_block_size
    var float ob_size_max_bull = max_block_size
    var float ob_size_max_bear = max_block_size

    bool is_green = open < close
    bool is_red = close < open
    bool is_fvg_up = low - high[2] > fvg_min_size
    bool is_fvg_down = low[2] - high > fvg_min_size
    float candle_top = math.max(open, close)
    float candle_btm = math.min(open, close)
    float candle_body = math.abs(open - close)
    bool is_impulse_candle = is_impulse_candle_now(candle_body, impulse_candle_size)
    bool is_indecision = is_indecision_candle_now(high, low, high[1], low[1], candle_top, candle_btm, candle_top[1], candle_btm[1], candle_body[1], candle_body, open, close)
    OrderBlock bull_ob_confirmed = na
    OrderBlock bear_ob_confirmed = na
    var bool reset_bull_next_bar = false
    var bool reset_bear_next_bar = false

    bool profile_features_active = profile_features_enabled(capture_profile, align_edge_to_value_area, align_break_price_to_poc)
    bool bull_prepare_confirmation = enabled and barstate.isconfirmed and bull_ob.trailing and bull_ob.extending and bull_ob.left_top.index < bar_index and is_red and not is_indecision and u.in_range(close, bull_ob.left_top.price, bull_ob.right_bottom.price)
    bool bear_prepare_confirmation = enabled and barstate.isconfirmed and bear_ob.trailing and bear_ob.extending and bear_ob.left_top.index < bar_index and is_green and not is_indecision and u.in_range(close, bear_ob.left_top.price, bear_ob.right_bottom.price)
    [prepared_ob_size_min_bull, prepared_ob_size_max_bull] = prepare_order_block_confirmation(bull_ob, min_block_size, max_block_size, true, update_profile_current_bar, align_edge_to_value_area, align_break_price_to_poc, bull_prepare_confirmation)
    [prepared_ob_size_min_bear, prepared_ob_size_max_bear] = prepare_order_block_confirmation(bear_ob, min_block_size, max_block_size, true, update_profile_current_bar, align_edge_to_value_area, align_break_price_to_poc, bear_prepare_confirmation)

    if enabled
        update_broken( 1, tracking_blocks_bull, broken_blocks_bull, broken_blocks_new_bull, broken_by, keep_broken_max, discarded_blocks_bull)
        update_broken(-1, tracking_blocks_bear, broken_blocks_bear, broken_blocks_new_bear, broken_by, keep_broken_max, discarded_blocks_bear)

        if gc_cycle > 0 and bar_index % gc_cycle == 0
            tracking_blocks_bull.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bull, protected_bull_id)
            tracking_blocks_bear.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bear, protected_bear_id)

        reset_bull_next_bar := handle_pending_tracking_reset(bull_ob, reset_bull_next_bar)
        reset_bear_next_bar := handle_pending_tracking_reset(bear_ob, reset_bear_next_bar)

        if bull_ob.trailing 
            bull_ob.capture_profile_bar(profile_features_active and update_profile_current_bar)

            _check_start_t = bull_ob.left_top.time
            _check_start_i = bull_ob.left_top.index
            _check_end_t = bull_ob.right_bottom.time
            _check_end_i = bull_ob.right_bottom.index
            _check_top = bull_ob.left_top.price
            _check_btm = bull_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bull_ob.extending

            if bull_ob.right_bottom.price > low
                if barstate.isconfirmed and _check_start_i < bar_index - 1 and use_retracements_with_FVG_out and is_fvg_down
                    if not _check_ext[2] and not tracking_blocks_bear.any_overlaps(_check_top[2], _check_btm[2]) and not bear_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bear_ob_confirmed := create_ob(next_id, -1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bear_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bear_ob_confirmed.ltf_open := bull_ob.ltf_open.copy()
                            bear_ob_confirmed.ltf_high := bull_ob.ltf_high.copy()
                            bear_ob_confirmed.ltf_low := bull_ob.ltf_low.copy()
                            bear_ob_confirmed.ltf_close := bull_ob.ltf_close.copy()
                            bear_ob_confirmed.ltf_volume := bull_ob.ltf_volume.copy()

                            if align_edge_to_value_area or align_break_price_to_poc
                                bear_ob_confirmed.create_profile()
                                bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                            bear_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, _check_top[2], _check_btm[2], bear_ob_confirmed.left_top.price, bear_ob_confirmed.right_bottom.price, bear_ob_confirmed.break_price)

                        bear_ob_confirmed.right_bottom.index := bar_index
                        bear_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bear.push(bear_ob_confirmed)

                if is_green
                    bull_ob.reset_tracking()
                else 
                    reset_bull_next_bar := true

                if barstate.isconfirmed
                    bull_ob.profile := na

            else if bull_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bull_ob.extending := true

            if bull_ob.extending and is_green and bull_ob.left_top.price < high
                bull_ob.left_top.price := high
                bull_ob.right_bottom := chart.point.now(bull_ob.right_bottom.price)
                bull_ob.touched_break_price_before_confirmation := false
                bull_ob.soft_confirmed := false

                if is_impulse_candle
                    bull_ob.has_big_candle := true

        if bear_ob.trailing
            bear_ob.capture_profile_bar(profile_features_active and update_profile_current_bar)

            _check_start_t = bear_ob.left_top.time
            _check_start_i = bear_ob.left_top.index
            _check_end_t = bear_ob.right_bottom.time
            _check_end_i = bear_ob.right_bottom.index
            _check_top = bear_ob.left_top.price
            _check_btm = bear_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bear_ob.extending

            if bear_ob.left_top.price < high
                if barstate.isconfirmed and use_retracements_with_FVG_out and is_fvg_up
                    if not _check_ext[2] and not tracking_blocks_bull.any_overlaps(_check_top[2], _check_btm[2]) and not bull_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bull_ob_confirmed := create_ob(next_id, 1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bull_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bull_ob_confirmed.ltf_open := bear_ob.ltf_open.copy()
                            bull_ob_confirmed.ltf_high := bear_ob.ltf_high.copy()
                            bull_ob_confirmed.ltf_low := bear_ob.ltf_low.copy()
                            bull_ob_confirmed.ltf_close := bear_ob.ltf_close.copy()
                            bull_ob_confirmed.ltf_volume := bear_ob.ltf_volume.copy()

                            if align_edge_to_value_area or align_break_price_to_poc
                                bull_ob_confirmed.create_profile()
                                bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                            bull_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, _check_top[2], _check_btm[2], bull_ob_confirmed.left_top.price, bull_ob_confirmed.right_bottom.price, bull_ob_confirmed.break_price)

                        bull_ob_confirmed.right_bottom.index := bar_index
                        bull_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bull.push(bull_ob_confirmed)

                if is_red
                    bear_ob.reset_tracking()
                else 
                    reset_bear_next_bar := true

                if barstate.isconfirmed
                    bear_ob.profile := na

            else if bear_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bear_ob.extending := true

            if bear_ob.extending and is_red
                bear_ob.right_bottom := chart.point.now(math.min(bear_ob.right_bottom.price, low))
                bear_ob.touched_break_price_before_confirmation := false
                bear_ob.soft_confirmed := false

                if is_impulse_candle
                    bear_ob.has_big_candle := true

        if barstate.isconfirmed
            if bull_prepare_confirmation
                ob_size_min_bull := prepared_ob_size_min_bull
                ob_size_max_bull := prepared_ob_size_max_bull

                if not bear_ob.awaiting_confirmation and not bear_ob.extending
                    bear_ob.reset_tracking()

            if bear_prepare_confirmation
                ob_size_min_bear := prepared_ob_size_min_bear
                ob_size_max_bear := prepared_ob_size_max_bear

                if not bull_ob.awaiting_confirmation and not bull_ob.extending
                    bull_ob.reset_tracking()

        if bull_ob.trailing and bull_ob.awaiting_confirmation
            update_soft_confirmation(bull_ob, true, use_soft_confirm_big_candle, is_impulse_candle, is_green, soft_confirm_offset, impulse_candle_size)

            bull_price_exited = confirmation_price_exited(bull_ob, true, soft_confirm_offset)
            bull_confirm_trigger = confirmation_trigger_active(bull_ob, use_soft_confirm, swing_low_confirmed, bull_bos_alert, bull_choch_alert, swing_len)
            bull_should_confirm = bull_price_exited and barstate.isconfirmed and bull_confirm_trigger

            if bull_should_confirm
                if ob_size_within_bounds(bull_ob, align_edge_to_value_area, ob_size_max_bull, ob_size_min_bull)
                    bull_ob.trailing := false
                    next_id += 1
                    bull_ob.id := next_id
                    bull_ob_confirmed := bull_ob.copy()
                    bull_ob_confirmed.id := bull_ob.id
                    bull_ob_confirmed.left_top := bull_ob.left_top.copy()
                    bull_ob_confirmed.right_bottom := bull_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        bull_ob_confirmed.create_profile()
                        bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    bull_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, bull_ob.left_top.price, bull_ob.right_bottom.price, bull_ob_confirmed.left_top.price, bull_ob_confirmed.right_bottom.price, bull_ob_confirmed.break_price)
                    bull_ob.profile := na

                    if is_fvg_up and high[2] < bull_ob_confirmed.left_top.price and bull_ob_confirmed.left_top.price < low
                        bull_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bull.push(bull_ob_confirmed)

                    if barstate.isconfirmed
                        bull_ob.reset_tracking()
                else
                    bull_ob.reset_tracking()

        if bear_ob.trailing and bear_ob.awaiting_confirmation
            update_soft_confirmation(bear_ob, false, use_soft_confirm_big_candle, is_impulse_candle, is_red, soft_confirm_offset, impulse_candle_size)

            bear_price_exited = confirmation_price_exited(bear_ob, false, soft_confirm_offset)
            bear_confirm_trigger = confirmation_trigger_active(bear_ob, use_soft_confirm, swing_high_confirmed, bear_bos_alert, bear_choch_alert, swing_len)
            bear_should_confirm = bear_price_exited and barstate.isconfirmed and bear_confirm_trigger

            if bear_should_confirm
                if ob_size_within_bounds(bear_ob, align_edge_to_value_area, ob_size_max_bear, ob_size_min_bear)
                    bear_ob.trailing := false
                    next_id += 1
                    bear_ob.id := next_id
                    bear_ob_confirmed := bear_ob.copy()
                    bear_ob_confirmed.id := bear_ob.id
                    bear_ob_confirmed.left_top := bear_ob.left_top.copy()
                    bear_ob_confirmed.right_bottom := bear_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        bear_ob_confirmed.create_profile()
                        bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    bear_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, bear_ob.left_top.price, bear_ob.right_bottom.price, bear_ob_confirmed.left_top.price, bear_ob_confirmed.right_bottom.price, bear_ob_confirmed.break_price)
                    bear_ob.profile := na

                    if is_fvg_down and low[2] < bear_ob_confirmed.right_bottom.price and bear_ob_confirmed.right_bottom.price < high
                        bear_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bear.push(bear_ob_confirmed)

                    if barstate.isconfirmed
                        bear_ob.reset_tracking()
                else
                    bear_ob.reset_tracking()

    if discarded_blocks_bull.size() > 0
        delete(discarded_blocks_bull)
        array.clear(discarded_blocks_bull)
    if discarded_blocks_bear.size() > 0
        delete(discarded_blocks_bear)
        array.clear(discarded_blocks_bear)

    [tracking_blocks_bull, tracking_blocks_bear, bull_ob_confirmed, bear_ob_confirmed, broken_blocks_bull, broken_blocks_bear, broken_blocks_new_bull, broken_blocks_new_bear, discarded_blocks_bull, discarded_blocks_bear]

method draw(OrderBlock this, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    visible_match = na(visible_left) or na(visible_right) or this.overlaps_window(visible_left, visible_right, config.extend_until_broken)

    if not visible_match
        if not na(this.plot) and not this.hidden
            this.plot.hide()
            if not na(this.profile)
                this.profile.hide()
            this.hidden := true
        this
    else

        if barstate.islast and not na(this) and config.show
            txt_fvg = config.show_fvg_out and this.has_fvg_out ? '+FVG' : ''
            float ob_quality = config.show_quality_score ? ob_quality_score(this) : 0.0
            txt_quality = config.show_quality_score and ob_quality > 0 ? str.format(' (Q {0,number,percent})', ob_quality) : ''
            txt_id = config.show_id ? ' #' + str.tostring(this.id) : ''
            txt = config.show_text ? config.show_profile and config.profile_config.show_poc and config.profile_config.show_labels ? str.format('{0}{1}{2}', config.txt, txt_fvg, txt_id) : str.format('{0}{1}{2}{3}', config.txt, txt_fvg, txt_quality, txt_id) : ''

            xloc_bartime = config.args.xloc == xloc.bar_time
            int broken_right_time = effective_live_event_time(this.broken_time, math.max(this.left_top.time, this.right_bottom.time))

            int left = not na(left_override) ? left_override : xloc_bartime ? this.left_top.time : this.left_top.index
            int right = not na(right_override) ? right_override : config.extend_until_broken ? this.broken ? xloc_bartime ? broken_right_time : this.broken_index - 1 : xloc_bartime ? current_bar_right_time() : bar_index : xloc_bartime ? this.right_bottom.time : this.right_bottom.index

            chart.point plot_left_top = d.create_point(left, this.left_top.price, config.args.xloc)
            chart.point plot_right_bottom = d.create_point(right, this.right_bottom.price, config.args.xloc)

            if config.show
                if na(this.plot)
                    this.plot := d.SmcBox.new(plot_left_top, plot_right_bottom, txt)
                else
                    this.plot.left_top := plot_left_top
                    this.plot.right_bottom := plot_right_bottom

                this.plot.draw(config.args, config.txt_args, extend_only, force_overlay)
                if this.broken or this.has_fvg_out
                    this.plot.plot.set_text(txt)

                if config.show_profile and not na(this.profile)
                    poc_txt = config.show_quality_score and config.profile_config.show_poc and config.profile_config.show_labels ? config.profile_config.poc_label_text + txt_fvg + txt_quality : na
                    this.profile.draw(config.profile_config, left, right, extend_only, force_overlay, poc_txt)
                else if not na(this.profile)
                    this.profile.hide()

                if this.broken and broken_right_time <= current_bar_right_time()
                    this.plot.apply_style(config.args, config.txt_args)
                    if not na(this.profile) and config.show_profile
                        this.profile.apply_style(config.profile_config)

            this.hidden := false

    this

method hide(OrderBlock this) =>
    if not na(this) and not this.hidden
        if not na(this.plot)
            this.plot.hide()
        if not na(this.profile)
            this.profile.hide()
        this.hidden := true
    this

method draw(OrderBlock[] blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    if na(blocks) ? false : config.show and blocks.size() > 0
        count = 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            visible_match = na(visible_left) or na(visible_right) or block.overlaps_window(visible_left, visible_right, config.extend_until_broken)
            if visible_match and count < config.show_last
                block.draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
                count += 1
            else
                if not na(block.plot) and not block.hidden
                    block.hide()
    blocks

method draw(map<int, OrderBlock> blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    blocks.values().draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
    blocks

// Market structure helpers

detect_swings(simple int length = 10) =>
    var os = 0
    float hh = na
    float ll = na
    int idx = na

    h_swing = high[length]
    l_swing = low[length]
    upper = ta.highest(high, length)
    lower = ta.lowest(low, length)

    os := h_swing > upper ? 0 : l_swing < lower ? 1 : os[1]
    hh := os == 0 and os[1] != 0 ? h_swing : na
    ll := os == 1 and os[1] != 1 ? l_swing : na
    idx := not na(hh) or not na(ll) ? bar_index - length : na

    [idx, hh, ll]

detect_pivot(simple int mode, int trend, int hhll_x, float hhll, float super_hhll = na, bool filter_insignificant_internal_breaks = false) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var sy = 0.
    var x = 0, var y = 0.
    var trail_x = 0, var trail_y = mode_high ? high : mode_low ? low : na
    var lvl_cross = true
    bool choch_alert = false
    bool bos_alert = false

    if not na(super_hhll)
        sy := super_hhll

    if not na(hhll)
        lvl_cross := true
        y := hhll
        x := hhll_x
        trail_y := hhll
        trail_x := hhll_x

    trail_y := mode_high ? math.max(high, trail_y) : math.min(low, trail_y)
    trail_x := (mode_high and trail_y == high) or (mode_low and trail_y == low) ? bar_index : trail_x

    var trend_concordant = true
    atr = ta.atr(3)

    structure_detected = switch mode
        1 => ta.crossover(close, y)
        -1 => ta.crossunder(close, y)
        => false

    if structure_detected and lvl_cross and y != sy
        lvl_cross := false
        trend_concordant := true

        if filter_insignificant_internal_breaks
            body = math.abs(open - close)
            distance_to_level = math.abs(open - y)
            big_candle = body > 2 * distance_to_level or body > atr

            top_wick = high - math.max(close, open)
            btm_wick = math.min(close, open) - low
            impulse_wick = switch mode
                1 => top_wick > btm_wick
                -1 => top_wick < btm_wick
                => false

            trend_concordant := big_candle or impulse_wick

        if trend_concordant
            _trend = (trend != 1 and trend != -1 ? 1 : trend)
            choch_alert := mode == _trend * -1
            bos_alert := mode == _trend

    [x, y, trail_x, trail_y, bos_alert, choch_alert]

detect_structure(simple int swing_len = 50, float super_hh = na, float super_ll = na, bool filter_insignificant_internal_breaks = true) =>
    var trend = 1

    [hhll_x, hh, ll] = detect_swings(swing_len)
    [top_x, top_y, trail_up_x, trail_up, bull_bos_alert, bull_choch_alert] = detect_pivot(1, trend, hhll_x, hh, super_hh, filter_insignificant_internal_breaks)
    [btm_x, btm_y, trail_dn_x, trail_dn, bear_bos_alert, bear_choch_alert] = detect_pivot(-1, trend, hhll_x, ll, super_ll, filter_insignificant_internal_breaks)

    trend := bull_choch_alert ? 1 : bear_choch_alert ? -1 : trend

    [trend, bull_bos_alert, bull_choch_alert, top_x, top_y, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm_y, trail_dn_x, trail_dn, ll, hhll_x]

plot_pivot_points(int mode, int x, float y, bool enabled, d.LabelArgs args, bool keep_history) =>
    var float prev_high_pivot = na
    var float prev_low_pivot = na
    if enabled and not na(x)
        txt_swing_point = mode == 1 ? (na(prev_high_pivot) or y > prev_high_pivot ? 'HH' : 'LH') : mode == -1 ? (na(prev_low_pivot) or y < prev_low_pivot ? 'LL' : 'HL') : na
        label_swing_point = label.new(x, y, txt_swing_point, color = args.bg_color, textcolor = args.text_color, style = args.style, size = args.size)
        if mode == 1
            prev_high_pivot := y
        else if mode == -1
            prev_low_pivot := y
        if not keep_history
            label.delete(label_swing_point[1])

plot_swing_levels(int mode, int trail_x, float trail_y, int trend, bool enabled, d.LabelArgs label_args, d.LineArgs line_args, int override_right_index = na, string text_prefix = '') =>
    var label label_latest_swing = label.new(na, na, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)
    var line line_latest_swing = line.new(na, na, na, na, color = line_args.line_color, style = line_args.style)

    if enabled
        if trail_x != line_latest_swing.get_x1() or na(line_latest_swing.get_x1())
            line_latest_swing.set_xy1(trail_x, trail_y)
        else
            line_latest_swing.set_y1(trail_y)

        if barstate.islast
            hl_swing_txt = mode == 1 ? (trend < 0 ? 'Strong High' : 'Weak High') : mode == -1 ? (trend > 0 ? 'Strong Low' : 'Weak Low') : na
            right = not na(override_right_index) ? override_right_index : bar_index + 20
            line_latest_swing.set_xy2(right, trail_y)
            label_latest_swing.set_xy(right, trail_y)

plot_structure(int x, float y, bool is_bos = false, bool is_choch = false, d.LabelArgs label_args, d.LineArgs line_args, bool keep_history, string text_prefix = '', string bos_text = 'BOS', string choch_text = 'CHoCH') =>
    if is_bos or is_choch
        txt = text_prefix + (is_choch ? choch_text : bos_text)
        structure_line = line.new(x, y, bar_index, y, color = line_args.line_color, style = line_args.style)
        structure_lbl = label.new(int(math.avg(x, bar_index)), y, txt, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)

        if not keep_history
            line.delete(structure_line[1])
            label.delete(structure_lbl[1])

detect_equal_level(int mode, int len, float eq_threshold, bool enabled = true) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var int x1 = 0, var float y1 = 0.
    var int x2 = 0, var float y2 = 0.

    eq_alert = false
    ph = ta.pivothigh(len, len)
    pl = ta.pivotlow(len, len)

    if enabled
        eq_lvl = mode_high ? ph : pl
        if not na(eq_lvl)
            x1 := x2, y1 := y2
            x2 := bar_index - len, y2 := eq_lvl

            max = math.max(eq_lvl, y1)
            min = math.min(eq_lvl, y1)

            if mode_high and (max < min + eq_threshold) or mode_low and (min > max - eq_threshold)
                eq_alert := true

    [eq_alert, eq_alert ? x1 : na, eq_alert ? y1 : na, eq_alert ? x2 : na, eq_alert ? y2 : na]

detect_equal_levels(int len, float threshold, bool enabled = true) =>
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2] = detect_equal_level(1, len, threshold, enabled)
    [eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_level(-1, len, threshold, enabled)
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2]

plot_equal_level(bool show_eq, int x1, float y1, int x2, float y2, string label_txt, d.LabelArgs label_args, d.LineArgs line_args, bool keep_history = true, bool force_overlay = false) =>
    if show_eq and not na(x1) and not na(x2) and not na(y1) and not na(y2)
        line eq_line = na
        label eq_lbl = na

        if force_overlay
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width, force_overlay = true)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, xloc = label_args.xloc, yloc = label_args.yloc, color = label_args.bg_color, style = label_args.style, textcolor = label_args.text_color, size = label_args.size, textalign = label_args.text_align, text_font_family = label_args.text_font_family, force_overlay = true)
        else
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, xloc = label_args.xloc, yloc = label_args.yloc, color = label_args.bg_color, style = label_args.style, textcolor = label_args.text_color, size = label_args.size, textalign = label_args.text_align, text_font_family = label_args.text_font_family)

        if not keep_history
            line.delete(eq_line[1])
            label.delete(eq_lbl[1])

type FVGConfig
    bool show_box = true
    bool show_target = true
    bool show_target_label = true
    int show_last = 5
    bool show_text = true
    bool show_quality_score = false
    bool show_profile = false
    d.BoxArgs box_args = na
    d.BoxTextArgs box_text_args = na
    d.LineArgs line_args = na
    d.LabelArgs label_args = na
    string txt = na
    int extend_bars = 1
    bool extend_until_filled = false

type FVG
    int id
    int dir
    ct.LevelBreakMode fill_mode
    chart.point left_top
    chart.point right_bottom
    float fvg_fill_target_ratio
    float fill_target_level
    float fill_current_ratio
    float fill_current_level
    float total_volume
    float quality_score = na
    bool filled = false
    int fill_time = na
    int fill_index = na
    d.SmcBox plot_box = na
    d.SmcLine plot_fill_target_level = na
    d.SmcLabel plot_fill_target_label = na
    bool hidden = false

method rendered_right_time(FVG this, bool extend_until_filled = true) =>
    int rendered_right_time_value = na
    if not na(this)
        int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
        int effective_fill_time = effective_live_event_time(this.fill_time, base_right_time)
        rendered_right_time_value := extend_until_filled ? (this.filled ? effective_fill_time : current_bar_right_time()) : (this.filled ? math.min(effective_fill_time, base_right_time) : base_right_time)
    rendered_right_time_value

method overlaps_window(FVG this, int left_time, int right_time, bool extend_until_filled = true) =>
    if na(this)
        false
    else
        effective_right_time = this.rendered_right_time(extend_until_filled)
        effective_right_time >= left_time and this.left_top.time <= right_time

method contains_id(FVG[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for fvg in this
            if fvg.id == id
                found := true
                break
    found

method get_by_id(FVG[] this, int id) =>
    FVG found = na
    if not na(this) and not na(id)
        for fvg in this
            if fvg.id == id
                found := fvg
                break
    found

zone_candidate_preferred(bool candidate_touch_anchor, int candidate_recency, float candidate_quality, float candidate_overlap, int candidate_id, bool best_touch_anchor, int best_recency, float best_quality, float best_overlap, int best_id) =>
    bool prefer_candidate = candidate_touch_anchor and not best_touch_anchor
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor
        prefer_candidate := na(best_recency) or candidate_recency > best_recency
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency
        prefer_candidate := na(best_quality) or candidate_quality > best_quality
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency and candidate_quality == best_quality
        prefer_candidate := na(best_overlap) or candidate_overlap > best_overlap
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency and candidate_quality == best_quality and candidate_overlap == best_overlap
        prefer_candidate := na(best_id) or candidate_id > best_id
    prefer_candidate

prefer_primary_zone(bool primary_touch_anchor, int primary_recency, float primary_quality, float primary_overlap, int primary_id, bool secondary_touch_anchor, int secondary_recency, float secondary_quality, float secondary_overlap, int secondary_id) =>
    zone_candidate_preferred(primary_touch_anchor, primary_recency, primary_quality, primary_overlap, primary_id, secondary_touch_anchor, secondary_recency, secondary_quality, secondary_overlap, secondary_id)

int LONG_SOURCE_NONE = 0
int LONG_SOURCE_OB = 1
int LONG_SOURCE_FVG = 2
int LONG_SOURCE_SWING_LOW = 3
int LONG_SOURCE_INTERNAL_LOW = 4

resolve_long_source_text(int long_source_kind) =>
    string source_text = 'None'
    if long_source_kind == LONG_SOURCE_OB
        source_text := 'OB'
    else if long_source_kind == LONG_SOURCE_FVG
        source_text := 'FVG'
    else if long_source_kind == LONG_SOURCE_SWING_LOW
        source_text := 'Swing Low'
    else if long_source_kind == LONG_SOURCE_INTERNAL_LOW
        source_text := 'Internal Low'
    source_text

long_source_is_zone_kind(int long_source_kind) =>
    long_source_kind == LONG_SOURCE_OB or long_source_kind == LONG_SOURCE_FVG

select_locked_source_touch_count(bool source_upgrade_now, bool prefer_ob_upgrade_now, int ob_candidate_id, int active_ob_touch_id, int active_ob_touch_count, int touched_ob_touch_count, int fvg_candidate_id, int active_fvg_touch_id, int active_fvg_touch_count, int touched_fvg_touch_count, int locked_source_touch_count) =>
    int touch_count = locked_source_touch_count
    if source_upgrade_now
        if prefer_ob_upgrade_now
            if ob_candidate_id == active_ob_touch_id
                touch_count := active_ob_touch_count
            else
                touch_count := math.max(touched_ob_touch_count, 1)
        else
            if fvg_candidate_id == active_fvg_touch_id
                touch_count := active_fvg_touch_count
            else
                touch_count := math.max(touched_fvg_touch_count, 1)
    touch_count

stage_locked_source_transition(bool source_upgrade_now, bool prefer_ob_upgrade_now, int prev_locked_source_kind, int prev_locked_source_id, int current_backing_zone_kind, int current_backing_zone_id, int ob_candidate_id, int fvg_candidate_id) =>
    int next_locked_source_kind = prev_locked_source_kind
    int next_locked_source_id = prev_locked_source_id
    int next_backing_zone_kind = current_backing_zone_kind
    int next_backing_zone_id = current_backing_zone_id
    if source_upgrade_now
        if prefer_ob_upgrade_now
            next_locked_source_kind := LONG_SOURCE_OB
            next_locked_source_id := ob_candidate_id
            next_backing_zone_kind := LONG_SOURCE_OB
            next_backing_zone_id := ob_candidate_id
        else
            next_locked_source_kind := LONG_SOURCE_FVG
            next_locked_source_id := fvg_candidate_id
            next_backing_zone_kind := LONG_SOURCE_FVG
            next_backing_zone_id := fvg_candidate_id
    [next_locked_source_kind, next_locked_source_id, next_backing_zone_kind, next_backing_zone_id]

select_long_arm_backing_zone_touch_count(int arm_backing_zone_kind, int arm_backing_zone_id, int active_ob_touch_id, int active_ob_touch_count, int touched_bull_ob_id, int touched_bull_ob_touch_count, int active_fvg_touch_id, int active_fvg_touch_count, int touched_bull_fvg_id, int touched_bull_fvg_touch_count) =>
    int touch_count = 0
    if arm_backing_zone_kind == LONG_SOURCE_OB and arm_backing_zone_id == active_ob_touch_id
        touch_count := active_ob_touch_count
    else if arm_backing_zone_kind == LONG_SOURCE_OB and arm_backing_zone_id == touched_bull_ob_id
        touch_count := touched_bull_ob_touch_count
    else if arm_backing_zone_kind == LONG_SOURCE_FVG and arm_backing_zone_id == active_fvg_touch_id
        touch_count := active_fvg_touch_count
    else if arm_backing_zone_kind == LONG_SOURCE_FVG and arm_backing_zone_id == touched_bull_fvg_id
        touch_count := touched_bull_fvg_touch_count
    touch_count

resolve_long_zone_id(int long_zone_kind, int long_zone_id) =>
    long_source_is_zone_kind(long_zone_kind) ? long_zone_id : na

resolve_long_zone_top(int long_zone_kind, int long_zone_id, int active_bull_ob_id, float active_bull_ob_top, int touched_bull_ob_id, float touched_bull_ob_top, int active_bull_fvg_id, float active_bull_fvg_top, int touched_bull_fvg_id, float touched_bull_fvg_top, bool preserve_prior_bounds = false, int prior_long_zone_kind = 0, int prior_long_zone_id = na, float prior_long_zone_top = na) =>
    float zone_top = na
    if long_zone_kind == LONG_SOURCE_OB and long_zone_id == active_bull_ob_id
        zone_top := active_bull_ob_top
    else if long_zone_kind == LONG_SOURCE_OB and long_zone_id == touched_bull_ob_id
        zone_top := touched_bull_ob_top
    else if long_zone_kind == LONG_SOURCE_FVG and long_zone_id == active_bull_fvg_id
        zone_top := active_bull_fvg_top
    else if long_zone_kind == LONG_SOURCE_FVG and long_zone_id == touched_bull_fvg_id
        zone_top := touched_bull_fvg_top
    else if preserve_prior_bounds and long_zone_kind == prior_long_zone_kind and long_zone_id == prior_long_zone_id
        zone_top := prior_long_zone_top
    zone_top

resolve_long_zone_bottom(int long_zone_kind, int long_zone_id, int active_bull_ob_id, float active_bull_ob_bottom, int touched_bull_ob_id, float touched_bull_ob_bottom, int active_bull_fvg_id, float active_bull_fvg_bottom, int touched_bull_fvg_id, float touched_bull_fvg_bottom, bool preserve_prior_bounds = false, int prior_long_zone_kind = 0, int prior_long_zone_id = na, float prior_long_zone_bottom = na) =>
    float zone_bottom = na
    if long_zone_kind == LONG_SOURCE_OB and long_zone_id == active_bull_ob_id
        zone_bottom := active_bull_ob_bottom
    else if long_zone_kind == LONG_SOURCE_OB and long_zone_id == touched_bull_ob_id
        zone_bottom := touched_bull_ob_bottom
    else if long_zone_kind == LONG_SOURCE_FVG and long_zone_id == active_bull_fvg_id
        zone_bottom := active_bull_fvg_bottom
    else if long_zone_kind == LONG_SOURCE_FVG and long_zone_id == touched_bull_fvg_id
        zone_bottom := touched_bull_fvg_bottom
    else if preserve_prior_bounds and long_zone_kind == prior_long_zone_kind and long_zone_id == prior_long_zone_id
        zone_bottom := prior_long_zone_bottom
    zone_bottom

resolve_long_validation_source(int long_locked_source_kind) =>
    int validation_source = LONG_SOURCE_NONE
    if long_locked_source_kind == LONG_SOURCE_OB
        validation_source := LONG_SOURCE_OB
    else if long_locked_source_kind == LONG_SOURCE_FVG
        validation_source := LONG_SOURCE_FVG
    validation_source

resolve_long_invalidation_reason(bool long_source_broken, bool long_source_lost, bool long_setup_expired, bool long_confirm_expired, int long_validation_source, int long_entry_origin_source, string long_setup_source_display) =>
    string long_validation_source_text = resolve_long_source_text(long_validation_source)
    string long_entry_origin_source_text = resolve_long_source_text(long_entry_origin_source)
    string invalidation_reason = long_setup_source_display
    if long_source_broken
        invalidation_reason := long_validation_source_text + ' source invalidated'
    else if long_source_lost
        invalidation_reason := long_validation_source_text + ' backing zone lost'
    else if long_setup_expired
        invalidation_reason := long_entry_origin_source_text + ' setup expired'
    else if long_confirm_expired
        invalidation_reason := long_entry_origin_source_text + ' confirm expired'
    invalidation_reason

compose_long_setup_source_display(int long_entry_origin_source, int long_validation_source) =>
    string long_entry_origin_source_text = resolve_long_source_text(long_entry_origin_source)
    string long_validation_source_text = resolve_long_source_text(long_validation_source)
    string source_display = long_validation_source_text
    if long_entry_origin_source == LONG_SOURCE_NONE
        source_display := long_validation_source_text
    else if long_validation_source == LONG_SOURCE_NONE or long_entry_origin_source == long_validation_source
        source_display := long_entry_origin_source_text
    else
        source_display := long_entry_origin_source_text + ' -> ' + long_validation_source_text
    source_display

compose_zone_summary_text(bool show_ob_zone, float ob_top, float ob_bottom, bool show_fvg_zone, float fvg_top, float fvg_bottom, string empty_text) =>
    string zone_text = empty_text
    if show_ob_zone
        zone_text := 'OB ' + u.format_level(ob_top) + ' / ' + u.format_level(ob_bottom)
    if show_fvg_zone
        zone_text := 'FVG ' + u.format_level(fvg_top) + ' / ' + u.format_level(fvg_bottom)
    if show_ob_zone and show_fvg_zone
        zone_text := 'OB ' + u.format_level(ob_top) + ' / ' + u.format_level(ob_bottom) + ' | FVG ' + u.format_level(fvg_top) + ' / ' + u.format_level(fvg_bottom)
    zone_text

compose_enabled_debug_modules_text(bool show_ob_debug, bool show_fvg_debug, bool show_long_engine_debug, string long_engine_debug_mode) =>
    string debug_text = 'off'
    string long_debug_mode_suffix = ' Compact'
    if long_engine_debug_mode == 'Full'
        long_debug_mode_suffix := ' Full'
    if show_ob_debug
        debug_text := 'OB'
    if show_fvg_debug
        if debug_text == 'off'
            debug_text := 'FVG'
        else
            debug_text := debug_text + ' | FVG'
    if show_long_engine_debug
        if debug_text == 'off'
            debug_text := 'Long' + long_debug_mode_suffix
        else
            debug_text := debug_text + ' | Long' + long_debug_mode_suffix
    debug_text

debug_mode_is_full(string long_engine_debug_mode) =>
    long_engine_debug_mode == 'Full'

resolve_trade_gate_reason(bool session_structure_gate_ok, bool micro_session_gate_ok, bool micro_freshness_gate_ok, bool overhead_zone_ok) =>
    string trade_gate_reason = 'Trade OK'
    if not session_structure_gate_ok
        trade_gate_reason := 'Blocked: Session Gate'
    else if not micro_session_gate_ok
        trade_gate_reason := 'Blocked: Micro Session'
    else if not micro_freshness_gate_ok
        trade_gate_reason := 'Blocked: Micro Freshness'
    else if not overhead_zone_ok
        trade_gate_reason := 'Blocked: Overhead'
    trade_gate_reason

resolve_environment_gate_reason(bool market_regime_gate_ok, bool vola_regime_gate_safe, bool event_risk_gate_ok_param) =>
    string environment_gate_reason = 'Env OK'
    if not market_regime_gate_ok
        environment_gate_reason := 'Blocked: Market Gate'
    else if not vola_regime_gate_safe
        environment_gate_reason := 'Blocked: Vola Gate'
    else if not event_risk_gate_ok_param
        environment_gate_reason := 'Blocked: Event Risk'
    environment_gate_reason

// Long engine architecture
// 1. Source tracking identifies the active OB/FVG candidate and locks the current setup anchor.
// 2. Confirmed state validates reclaim structure on close-safe data.
// 3. Ready inherits the confirmed lifecycle and adds touch hygiene, trade release, environment, and context gates.
// 4. Best and Strict are execution tiers layered on top of Ready rather than separate lifecycle stages.
// 5. Debug labels, alerts, and dashboard rows read the same Ready/Strict outputs to keep user messaging consistent.
// Core user-facing controls:
// - Signal mode controls realtime vs close-safe alert behavior.
// - Strict sequence/sweep/confirm toggles decide how demanding the higher execution tiers are.
// - Context quality, overhead, and microstructure switches decide how much market filtering is required before entry.
//
// Gate Classification (v5.5b):
//   HARD (always required, safety):  lifecycle, environment (event_risk, market_regime, vola_regime)
//   OPERATIONAL (toggle-gated):      session_structure, micro_session, micro_freshness, overhead, setup (touch count)
//   SCORING (toggle-gated, opt-in):  quality, accel, sd, vol, stretch, ddvi, lean_signal_quality
//     → with use_scoring_over_blocking: SCORING gates bypass Ready, count as penalty; still block Best/Strict
//   INFO ONLY (not in pipeline):     v5.1-v5.3 context gates (session_context_ok, struct_state_ok, etc.) — BUS compat only
compute_long_environment_context(bool market_regime_gate_ok, bool vola_regime_gate_safe, bool primary_quality_gate_ok, bool session_structure_gate_ok, bool micro_session_gate_ok, bool micro_freshness_gate_ok, bool overhead_zone_ok, bool event_risk_gate_ok_param) =>
    bool helper_environment_hard_gate_ok = market_regime_gate_ok and vola_regime_gate_safe and event_risk_gate_ok_param
    bool helper_quality_gate_ok = primary_quality_gate_ok
    bool helper_microstructure_entry_gate_ok = micro_session_gate_ok and micro_freshness_gate_ok
    bool helper_trade_hard_gate_ok = session_structure_gate_ok and micro_session_gate_ok and micro_freshness_gate_ok and overhead_zone_ok
    string helper_long_environment_focus_display = 'Env OK'
    if not market_regime_gate_ok
        helper_long_environment_focus_display := 'Market Block'
    else if not vola_regime_gate_safe
        helper_long_environment_focus_display := 'Vola Block'
    else if not event_risk_gate_ok_param
        helper_long_environment_focus_display := 'Event Block'
    [helper_environment_hard_gate_ok, helper_quality_gate_ok, helper_microstructure_entry_gate_ok, helper_trade_hard_gate_ok, helper_long_environment_focus_display]

resolve_long_ready_lifecycle_reason(bool long_ready_state, bool long_setup_confirmed, bool close_safe_mode, bool ready_bar_gap_ok, bool long_confirm_expired, bool ready_is_fresh, bool long_confirm_bearish_guard_ok, bool require_main_break_for_ready, bool bull_bos_sig, bool main_bos_recent) =>
    string lifecycle_reason = ''
    if long_ready_state
        lifecycle_reason := 'Passed'
    else if not long_setup_confirmed
        lifecycle_reason := 'Awaiting Confirm'
    else if not close_safe_mode
        lifecycle_reason := 'Awaiting Close'
    else if not ready_bar_gap_ok
        lifecycle_reason := 'Awaiting Next Bar'
    else if long_confirm_expired
        lifecycle_reason := 'Blocked: Confirm Expired'
    else if not ready_is_fresh
        lifecycle_reason := 'Blocked: Confirm Stale'
    else if not long_confirm_bearish_guard_ok
        lifecycle_reason := 'Blocked: Bearish Guard'
    else if require_main_break_for_ready and not (bull_bos_sig or main_bos_recent)
        lifecycle_reason := 'Awaiting Main Break'
    lifecycle_reason

resolve_long_ready_gate_reason(bool setup_hard_gate_ok, bool session_structure_gate_ok, bool micro_session_gate_ok, bool micro_freshness_gate_ok, bool overhead_zone_ok, bool market_regime_gate_ok, bool vola_regime_gate_safe, bool quality_gate_ok, bool accel_ready_gate_ok, bool sd_ready_gate_ok, bool vol_ready_context_ok, bool stretch_ready_context_ok, bool ddvi_ready_ok_safe) =>
    string ready_gate_reason = 'Eligible'
    if not setup_hard_gate_ok
        ready_gate_reason := 'Blocked: Touch Count'
    else if not session_structure_gate_ok or not micro_session_gate_ok or not micro_freshness_gate_ok or not overhead_zone_ok
        ready_gate_reason := resolve_trade_gate_reason(session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok)
    else if not market_regime_gate_ok or not vola_regime_gate_safe
        ready_gate_reason := resolve_environment_gate_reason(market_regime_gate_ok, vola_regime_gate_safe, true)
    else if not quality_gate_ok
        ready_gate_reason := 'Blocked: Quality'
    else if not accel_ready_gate_ok
        ready_gate_reason := 'Blocked: Acceleration'
    else if not sd_ready_gate_ok
        ready_gate_reason := 'Blocked: SD Confluence'
    else if not vol_ready_context_ok
        ready_gate_reason := 'Blocked: Volatility Context'
    else if not stretch_ready_context_ok
        ready_gate_reason := 'Blocked: Stretch Context'
    else if not ddvi_ready_ok_safe
        ready_gate_reason := 'Blocked: DDVI Context'
    ready_gate_reason

resolve_long_strict_gate_reason(bool strict_signal_quality_gate_ok, bool strict_entry_ltf_ok, bool htf_alignment_ok, bool accel_strict_entry_gate_ok, bool sd_entry_strict_gate_ok, bool vol_entry_strict_context_ok_safe, bool stretch_entry_strict_context_ok, bool ddvi_entry_strict_ok_safe) =>
    string strict_gate_reason = 'Eligible'
    if not strict_signal_quality_gate_ok
        strict_gate_reason := 'Blocked: Signal Quality'
    else if not strict_entry_ltf_ok
        strict_gate_reason := 'Blocked: LTF Confirmation'
    else if not htf_alignment_ok
        strict_gate_reason := 'Blocked: HTF Alignment'
    else if not accel_strict_entry_gate_ok
        strict_gate_reason := 'Blocked: Acceleration'
    else if not sd_entry_strict_gate_ok
        strict_gate_reason := 'Blocked: SD Confluence'
    else if not vol_entry_strict_context_ok_safe
        strict_gate_reason := 'Blocked: Volatility Context'
    else if not stretch_entry_strict_context_ok
        strict_gate_reason := 'Blocked: Stretch Context'
    else if not ddvi_entry_strict_ok_safe
        strict_gate_reason := 'Blocked: DDVI Context'
    strict_gate_reason

compute_long_ready_state(bool close_safe_mode, bool long_setup_confirmed, bool ready_bar_gap_ok, bool long_confirm_expired, bool ready_is_fresh, bool long_confirm_bearish_guard_ok, bool require_main_break_for_ready, bool bull_bos_sig, bool main_bos_recent, bool setup_hard_gate_ok, bool trade_hard_gate_ok, bool environment_hard_gate_ok, bool quality_gate_ok, bool accel_ready_gate_ok, bool sd_ready_gate_ok, bool vol_ready_context_ok, bool stretch_ready_context_ok, bool ddvi_ready_ok_safe) =>
    bool helper_lifecycle_ready_ok = close_safe_mode and long_setup_confirmed and ready_bar_gap_ok and not long_confirm_expired and ready_is_fresh and long_confirm_bearish_guard_ok and (not require_main_break_for_ready or bull_bos_sig or main_bos_recent)
    bool helper_long_ready_state = helper_lifecycle_ready_ok and setup_hard_gate_ok and trade_hard_gate_ok and environment_hard_gate_ok and quality_gate_ok and accel_ready_gate_ok and sd_ready_gate_ok and vol_ready_context_ok and stretch_ready_context_ok and ddvi_ready_ok_safe
    [helper_lifecycle_ready_ok, helper_long_ready_state]

compute_long_entry_best_state(bool long_ready_state, bool best_signal_quality_gate_ok, bool accel_entry_best_gate_ok, bool sd_entry_best_gate_ok, bool vol_entry_best_context_ok_safe, bool stretch_entry_best_context_ok, bool ddvi_entry_best_ok_safe) =>
    long_ready_state and best_signal_quality_gate_ok and accel_entry_best_gate_ok and sd_entry_best_gate_ok and vol_entry_best_context_ok_safe and stretch_entry_best_context_ok and ddvi_entry_best_ok_safe

compute_long_entry_strict_state(bool long_ready_state, bool strict_signal_quality_gate_ok, bool strict_entry_ltf_ok, bool htf_alignment_ok, bool accel_strict_entry_gate_ok, bool sd_entry_strict_gate_ok, bool vol_entry_strict_context_ok_safe, bool stretch_entry_strict_context_ok, bool ddvi_entry_strict_ok_safe) =>
    long_ready_state and strict_signal_quality_gate_ok and strict_entry_ltf_ok and htf_alignment_ok and accel_strict_entry_gate_ok and sd_entry_strict_gate_ok and vol_entry_strict_context_ok_safe and stretch_entry_strict_context_ok and ddvi_entry_strict_ok_safe

resolve_long_ready_blocker_text(bool long_ready_state, bool long_setup_confirmed, bool close_safe_mode, bool ready_bar_gap_ok, bool long_confirm_expired, bool ready_is_fresh, bool long_confirm_bearish_guard_ok, bool require_main_break_for_ready, bool bull_bos_sig, bool main_bos_recent, bool setup_hard_gate_ok, bool session_structure_gate_ok, bool micro_session_gate_ok, bool micro_freshness_gate_ok, bool overhead_zone_ok, bool market_regime_gate_ok, bool vola_regime_gate_safe, bool quality_gate_ok, bool accel_ready_gate_ok, bool sd_ready_gate_ok, bool vol_ready_context_ok, bool stretch_ready_context_ok, bool ddvi_ready_ok_safe) =>
    string lifecycle_reason = resolve_long_ready_lifecycle_reason(long_ready_state, long_setup_confirmed, close_safe_mode, ready_bar_gap_ok, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready, bull_bos_sig, main_bos_recent)
    string ready_blocker_text = lifecycle_reason
    if str.length(lifecycle_reason) == 0
        ready_blocker_text := resolve_long_ready_gate_reason(setup_hard_gate_ok, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, market_regime_gate_ok, vola_regime_gate_safe, quality_gate_ok, accel_ready_gate_ok, sd_ready_gate_ok, vol_ready_context_ok, stretch_ready_context_ok, ddvi_ready_ok_safe)
    ready_blocker_text

resolve_long_strict_blocker_text(bool long_entry_strict_state, bool long_ready_state, string long_ready_blocker_text, bool strict_signal_quality_gate_ok, bool strict_entry_ltf_ok, bool htf_alignment_ok, bool accel_strict_entry_gate_ok, bool sd_entry_strict_gate_ok, bool vol_entry_strict_context_ok_safe, bool stretch_entry_strict_context_ok, bool ddvi_entry_strict_ok_safe) =>
    string strict_blocker_text = 'Passed'
    if long_entry_strict_state
        strict_blocker_text := 'Passed'
    else if not long_ready_state
        strict_blocker_text := 'Need Ready: ' + long_ready_blocker_text
    else
        strict_blocker_text := resolve_long_strict_gate_reason(strict_signal_quality_gate_ok, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)
    strict_blocker_text

compose_long_debug_compact_text(string long_setup_source_display, string long_ready_blocker_text, string long_strict_blocker_text) =>
    'src=' + long_setup_source_display + ' | rdy=' + long_ready_blocker_text + ' | st=' + long_strict_blocker_text

compose_long_debug_source_touch_text(string long_setup_source_display, int long_setup_backing_zone_touch_count) =>
    'src=' + long_setup_source_display + ' | touch=' + str.tostring(long_setup_backing_zone_touch_count)

compose_long_debug_ready_strict_text(string long_ready_blocker_text, string long_strict_blocker_text) =>
    'ready=' + long_ready_blocker_text + ' | strict=' + long_strict_blocker_text

compose_long_debug_fresh_source_text(string freshness_text, string source_state_text) =>
    'fresh=' + freshness_text + ' | ' + source_state_text

compose_long_debug_zone_env_text(string zone_quality_text, string long_environment_focus_display) =>
    'zone=' + zone_quality_text + ' | env=' + long_environment_focus_display

compose_long_debug_upgrade_text(string long_source_upgrade_reason) =>
    'upgrade=' + long_source_upgrade_reason

compose_long_debug_event_context_text(int long_setup_backing_zone_touch_count, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display) =>
    'touch=' + str.tostring(long_setup_backing_zone_touch_count) + ' | ' + compose_long_debug_fresh_source_text(freshness_text, source_state_text) + ' | ' + compose_long_debug_zone_env_text(zone_quality_text, long_environment_focus_display)

compose_long_debug_levels_text(float long_setup_trigger, float long_invalidation_level, string overhead_text) =>
    'trig=' + u.format_level(long_setup_trigger) + ' | inv=' + u.format_level(long_invalidation_level) + ' | overhead=' + overhead_text

compose_long_debug_summary_text(string long_engine_debug_mode, bool long_setup_armed, bool long_setup_confirmed, bool long_ready_state, string long_setup_source_display, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, int long_setup_backing_zone_touch_count, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    string debug_text = 'idle'
    bool debug_mode_full = debug_mode_is_full(long_engine_debug_mode)
    if long_setup_armed or long_setup_confirmed or long_ready_state
        if debug_mode_full
            debug_text := compose_long_debug_source_touch_text(long_setup_source_display, long_setup_backing_zone_touch_count) + ' | ' + compose_long_debug_fresh_source_text(freshness_text, source_state_text) + ' | ' + compose_long_debug_zone_env_text(zone_quality_text, long_environment_focus_display) + ' | ' + compose_long_debug_ready_strict_text(long_ready_blocker_text, long_strict_blocker_text)
        else
            debug_text := compose_long_debug_compact_text(long_setup_source_display, long_ready_blocker_text, long_strict_blocker_text)
    else if long_last_invalid_source != 'None'
        debug_text := 'last=' + long_last_invalid_source
    if long_source_upgrade_now
        debug_text += ' | ' + compose_long_debug_upgrade_text(long_source_upgrade_reason)
    debug_text

compose_long_engine_debug_label_text(string long_engine_debug_mode, string long_setup_text, string long_visual_text, string long_setup_source_display, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, string overhead_text, float long_setup_trigger, float long_invalidation_level, int long_setup_backing_zone_touch_count, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    bool debug_mode_full = debug_mode_is_full(long_engine_debug_mode)
    string debug_text = 'Long Engine (' + long_engine_debug_mode + ')'
    debug_text += '\nsetup=' + long_setup_text + ' | visual=' + long_visual_text
    if debug_mode_full
        debug_text += '\n' + compose_long_debug_source_touch_text(long_setup_source_display, long_setup_backing_zone_touch_count)
    else
        debug_text += '\n' + compose_long_debug_compact_text(long_setup_source_display, long_ready_blocker_text, long_strict_blocker_text)
    if debug_mode_full
        debug_text += '\n' + compose_long_debug_fresh_source_text(freshness_text, source_state_text)
        debug_text += '\n' + compose_long_debug_zone_env_text(zone_quality_text, long_environment_focus_display)
        debug_text += '\n' + compose_long_debug_ready_strict_text(long_ready_blocker_text, long_strict_blocker_text)
        debug_text += '\n' + compose_long_debug_levels_text(long_setup_trigger, long_invalidation_level, overhead_text)
    if long_source_upgrade_now
        debug_text += '\n' + compose_long_debug_upgrade_text(long_source_upgrade_reason)
    if long_last_invalid_source != 'None'
        debug_text += '\nlast=' + long_last_invalid_source
    debug_text

compose_long_engine_event_log(string long_engine_debug_mode, string event_name, string long_setup_source_display, float long_setup_trigger, float long_invalidation_level, int long_setup_backing_zone_touch_count, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    bool debug_mode_full = debug_mode_is_full(long_engine_debug_mode)
    string event_text = event_name + ' | src=' + long_setup_source_display + ' | trig=' + u.format_level(long_setup_trigger) + ' | inv=' + u.format_level(long_invalidation_level)
    if debug_mode_full
        event_text += ' | ' + compose_long_debug_event_context_text(long_setup_backing_zone_touch_count, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display)
    event_text += ' | ' + compose_long_debug_ready_strict_text(long_ready_blocker_text, long_strict_blocker_text)
    if long_source_upgrade_now
        event_text += ' | ' + compose_long_debug_upgrade_text(long_source_upgrade_reason)
    if long_last_invalid_source != 'None'
        event_text += ' | reason=' + long_last_invalid_source
    event_text

resolve_long_upgrade_reason(bool long_source_upgrade_now, bool prefer_ob_upgrade, bool ob_source_upgrade_ok, bool fvg_source_upgrade_ok, float touched_bull_ob_quality, float touched_bull_fvg_quality, float long_locked_source_quality) =>
    string upgrade_reason = 'none'
    if long_source_upgrade_now
        int target_source_kind = LONG_SOURCE_FVG
        if prefer_ob_upgrade
            target_source_kind := LONG_SOURCE_OB
        string target_source_text = resolve_long_source_text(target_source_kind)
        float target_quality = touched_bull_fvg_quality
        if prefer_ob_upgrade
            target_quality := touched_bull_ob_quality
        float quality_gain = math.max(target_quality - long_locked_source_quality, 0.0)
        string edge_text = 'beat locked source confluence'
        if ob_source_upgrade_ok and fvg_source_upgrade_ok
            edge_text := 'won tie on stronger confluence'
        upgrade_reason := target_source_text + ' ' + edge_text + ' +' + str.tostring(quality_gain, '#.##') + 'Q'
    upgrade_reason

describe_long_freshness(bool long_setup_armed, bool long_setup_confirmed, bool ready_is_fresh, bool confirm_is_fresh) =>
    string freshness_text = 'n/a'
    if long_setup_confirmed
        if ready_is_fresh
            freshness_text := 'confirm fresh'
        else
            freshness_text := 'confirm stale'
    else if long_setup_armed
        if confirm_is_fresh
            freshness_text := 'armed fresh'
        else
            freshness_text := 'armed stale'
    freshness_text

describe_long_source_state(bool long_source_tracked, bool long_source_alive, bool long_source_broken) =>
    string source_state_text = 'n/a'
    if long_source_tracked
        if long_source_alive
            source_state_text := 'source alive'
        else if long_source_broken
            source_state_text := 'source invalid'
        else
            source_state_text := 'source lost'
    source_state_text

select_effective_long_touch_count(bool long_setup_armed, bool long_setup_confirmed, int long_setup_backing_zone_touch_count, bool bull_reclaim_ob_strict, bool in_bull_ob_zone, bool in_bull_fvg_zone, int active_ob_touch_count, bool bull_reclaim_fvg_strict, int active_fvg_touch_count, int active_zone_touch_count) =>
    int effective_touch_count = active_zone_touch_count
    if long_setup_armed or long_setup_confirmed
        effective_touch_count := long_setup_backing_zone_touch_count
    else if bull_reclaim_ob_strict or (in_bull_ob_zone and not in_bull_fvg_zone)
        effective_touch_count := active_ob_touch_count
    else if bull_reclaim_fvg_strict or (in_bull_fvg_zone and not in_bull_ob_zone)
        effective_touch_count := active_fvg_touch_count
    effective_touch_count

describe_long_zone_quality(bool long_zone_active, bool long_setup_armed, bool long_setup_confirmed, int effective_long_active_touch_count) =>
    string zone_quality_text = 'n/a'
    if long_zone_active or long_setup_armed or long_setup_confirmed
        if effective_long_active_touch_count <= 1
            zone_quality_text := 'fresh touch'
        else if effective_long_active_touch_count == 2
            zone_quality_text := '2nd touch'
        else
            zone_quality_text := 'crowded'
    zone_quality_text

// Long state codes:
// -1 invalidated, 0 no setup, 1 in zone, 2 armed, 3 building, 4 confirmed, 5 ready, 6 entry best, 7 entry strict.
// Source-state semantics: tracked = locked source id exists, alive = source still resolves, broken = explicit mitigation/fill break, lost = tracked but no longer resolvable and not broken.
resolve_long_state_code(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar, bool long_invalidate_signal = false) =>
    bool invalid_state = (long_setup_armed or long_setup_confirmed or long_invalidate_signal or invalidated_prior_setup or long_invalidated_now or long_invalidated_this_bar) and (long_invalidated_now or long_invalidated_this_bar)
    if invalid_state
        -1
    else if long_entry_strict_state
        7
    else if long_entry_best_state
        6
    else if long_ready_state
        5
    else if long_setup_confirmed
        4
    else if long_building_state
        3
    else if long_setup_armed
        2
    else if long_zone_active
        1
    else
        0

compose_long_setup_text(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidated_now, bool invalidated_prior_setup, bool long_invalidated_this_bar, string long_setup_source_display) =>
    int state_code = resolve_long_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)
    string setup_text = 'No Setup'
    if state_code == -1
        setup_text := 'Invalidated'
    else if state_code == 1
        setup_text := 'In Zone'
    else if state_code == 2
        setup_text := 'Armed | ' + long_setup_source_display
    else if state_code == 3
        setup_text := 'Building | ' + long_setup_source_display
    else if state_code == 4
        setup_text := 'Confirmed | ' + long_setup_source_display
    else if state_code == 5
        setup_text := 'Ready | ' + long_setup_source_display
    else if state_code == 6
        setup_text := 'Entry Best | ' + long_setup_source_display
    else if state_code == 7
        setup_text := 'Entry Strict | ' + long_setup_source_display
    setup_text

resolve_long_visual_state(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidate_signal, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar) =>
    resolve_long_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar, long_invalidate_signal)


resolve_long_visual_text(int long_visual_state) =>
    string visual_text = 'Ready'
    if long_visual_state == -1
        visual_text := 'Fail'
    else if long_visual_state == 0
        visual_text := 'Neutral'
    else if long_visual_state == 1
        visual_text := 'In Zone'
    else if long_visual_state == 2
        visual_text := 'Armed'
    else if long_visual_state == 3
        visual_text := 'Building'
    else if long_visual_state == 4
        visual_text := 'Confirmed'
    visual_text

resolve_long_bg_color(int long_visual_state, color long_color_building) =>
    color bg_color = na
    if long_visual_state == -1
        bg_color := color.new(color.red, 90)
    else if long_visual_state == 1
        bg_color := color.new(color.aqua, 92)
    else if long_visual_state == 2
        bg_color := color.new(color.orange, 88)
    else if long_visual_state == 3
        bg_color := color.new(long_color_building, 84)
    else if long_visual_state == 4
        bg_color := color.new(color.lime, 88)
    else if long_visual_state == 5
        bg_color := color.new(color.green, 82)
    else if long_visual_state == 6
        bg_color := color.new(color.green, 74)
    else if long_visual_state >= 7
        bg_color := color.new(color.green, 66)
    bg_color

resolve_long_bar_color(int long_visual_state, color long_color_building) =>
    color bar_color = na
    if long_visual_state == -1
        bar_color := color.new(color.red, 0)
    else if long_visual_state == 1
        bar_color := color.new(color.aqua, 45)
    else if long_visual_state == 2
        bar_color := color.new(color.orange, 25)
    else if long_visual_state == 3
        bar_color := color.new(long_color_building, 5)
    else if long_visual_state == 4
        bar_color := color.new(color.lime, 0)
    else if long_visual_state == 5
        bar_color := color.new(color.green, 0)
    else if long_visual_state == 6
        bar_color := color.new(color.green, 0)
    else if long_visual_state >= 7
        bar_color := color.new(color.teal, 0)
    bar_color

pack_bus_row(int row_state, int reason_code) =>
    float((row_state + 1) * 100 + reason_code)

pack_bus_four(float value1, float value2, float value3, float value4) =>
    value1 * 1000000000.0 + value2 * 1000000.0 + value3 * 1000.0 + value4

normalize_bus_trend(int dir) =>
    dir > 0 ? 2 : dir < 0 ? 0 : 1

pack_bus_trend_set(int trend_now, int trend_htf_1, int trend_htf_2, int trend_htf_3) =>
    float(normalize_bus_trend(trend_now) * 1000 + normalize_bus_trend(trend_htf_1) * 100 + normalize_bus_trend(trend_htf_2) * 10 + normalize_bus_trend(trend_htf_3))

pack_bus_meta(int freshness_code, int source_state_code, int reclaim_code, int zone_code) =>
    float(freshness_code * 1000 + source_state_code * 100 + reclaim_code * 10 + zone_code)

resolve_bus_freshness_code(bool long_setup_armed, bool long_setup_confirmed, bool ready_is_fresh, bool confirm_is_fresh) =>
    int freshness_code = 0
    if long_setup_confirmed
        freshness_code := ready_is_fresh ? 1 : 2
    else if long_setup_armed
        freshness_code := confirm_is_fresh ? 3 : 4
    freshness_code

resolve_bus_source_state_code(bool long_source_tracked, bool long_source_alive, bool long_source_broken) =>
    int source_state_code = 0
    if long_source_tracked
        if long_source_alive
            source_state_code := 1
        else if long_source_broken
            source_state_code := 2
        else
            source_state_code := 3
    source_state_code

resolve_bus_zone_code(bool long_zone_active, bool in_bull_ob_zone, bool in_bull_fvg_zone) =>
    int zone_code = 0
    if long_zone_active
        zone_code := 1
    if in_bull_fvg_zone
        zone_code := 2
    if in_bull_ob_zone
        zone_code := 3
    if in_bull_ob_zone and in_bull_fvg_zone
        zone_code := 4
    zone_code

resolve_bus_zone_row(bool long_zone_active, bool in_bull_ob_zone, bool in_bull_fvg_zone) =>
    int zone_code = resolve_bus_zone_code(long_zone_active, in_bull_ob_zone, in_bull_fvg_zone)
    int zone_state = 0
    if zone_code == 2 or zone_code == 3
        zone_state := 4
    else if zone_code == 4
        zone_state := 5
    pack_bus_row(zone_state, zone_code)

resolve_bus_reclaim_code(bool reclaim_recent, bool bull_reclaim_internal_low_strict, bool bull_reclaim_swing_low_strict, bool bull_reclaim_fvg_strict, bool bull_reclaim_ob_strict) =>
    int reclaim_code = 0
    if reclaim_recent
        reclaim_code := 1
    if bull_reclaim_internal_low_strict
        reclaim_code := 2
    if bull_reclaim_swing_low_strict
        reclaim_code := 3
    if bull_reclaim_fvg_strict
        reclaim_code := 4
    if bull_reclaim_ob_strict
        reclaim_code := 5
    reclaim_code

resolve_bus_reclaim_row(bool reclaim_recent, bool bull_reclaim_internal_low_strict, bool bull_reclaim_swing_low_strict, bool bull_reclaim_fvg_strict, bool bull_reclaim_ob_strict) =>
    int reclaim_code = resolve_bus_reclaim_code(reclaim_recent, bull_reclaim_internal_low_strict, bull_reclaim_swing_low_strict, bull_reclaim_fvg_strict, bull_reclaim_ob_strict)
    int reclaim_state = 0
    if reclaim_code == 1
        reclaim_state := 2
    else if reclaim_code == 2 or reclaim_code == 3
        reclaim_state := 4
    else if reclaim_code == 4 or reclaim_code == 5
        reclaim_state := 5
    pack_bus_row(reclaim_state, reclaim_code)

resolve_bus_session_row(bool intraday_time_chart, bool use_trade_session_gate, bool use_opening_range_gate, bool session_structure_gate_ok, bool session_gate_ok) =>
    if not intraday_time_chart
        pack_bus_row(0, 1)
    else if not use_trade_session_gate and not use_opening_range_gate
        pack_bus_row(0, 2)
    else if session_structure_gate_ok
        pack_bus_row(5, 1)
    else if not session_gate_ok
        pack_bus_row(-1, 3)
    else
        pack_bus_row(-1, 4)

resolve_bus_market_row(bool use_index_gate, bool use_sector_gate, bool use_breadth_symbol_gate, bool market_symbols_missing, bool block_on_missing_market_symbol, bool market_regime_gate_ok, bool index_gate_effective_ok, bool sector_gate_effective_ok) =>
    if not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate
        pack_bus_row(0, 1)
    else if market_symbols_missing and block_on_missing_market_symbol
        pack_bus_row(-1, 2)
    else if market_symbols_missing
        pack_bus_row(2, 2)
    else if market_regime_gate_ok
        pack_bus_row(5, 1)
    else if not index_gate_effective_ok
        pack_bus_row(-1, 3)
    else if not sector_gate_effective_ok
        pack_bus_row(-1, 4)
    else
        pack_bus_row(-1, 5)

resolve_bus_vola_row(bool use_vola_compression_gate, bool vola_regime_gate_safe, bool vola_expansion_now, bool vola_compression_recent) =>
    if not use_vola_compression_gate
        pack_bus_row(0, 1)
    else if vola_regime_gate_safe and vola_expansion_now
        pack_bus_row(5, 2)
    else if vola_regime_gate_safe and vola_compression_recent
        pack_bus_row(3, 3)
    else if vola_regime_gate_safe
        pack_bus_row(3, 1)
    else
        pack_bus_row(-1, 4)

resolve_bus_micro_session_row(bool use_microstructure_profiles, bool intraday_time_chart, bool micro_session_gate_ok, bool micro_rth_gate_ok, bool micro_midday_gate_ok, bool micro_premarket_gate_ok) =>
    if not use_microstructure_profiles or not intraday_time_chart
        pack_bus_row(0, 1)
    else if micro_session_gate_ok
        pack_bus_row(5, 1)
    else if not micro_rth_gate_ok
        pack_bus_row(-1, 2)
    else if not micro_midday_gate_ok
        pack_bus_row(-1, 3)
    else if not micro_premarket_gate_ok
        pack_bus_row(-1, 4)
    else
        pack_bus_row(-1, 5)

resolve_bus_micro_fresh_row(bool use_microstructure_profiles, bool micro_freshness_gate_ok) =>
    if not use_microstructure_profiles
        pack_bus_row(0, 1)
    else if micro_freshness_gate_ok
        pack_bus_row(5, 1)
    else
        pack_bus_row(-1, 2)

resolve_bus_volume_data_row(bool volume_current_bar_ok, bool volume_feed_quality_ok, bool ltf_sampling_active, bool ltf_price_ok, bool ltf_volume_ok, bool ltf_price_only) =>
    if not volume_current_bar_ok
        pack_bus_row(-1, 1)
    else if not volume_feed_quality_ok
        pack_bus_row(2, 2)
    else if ltf_sampling_active and ltf_price_ok and not ltf_volume_ok
        pack_bus_row(2, 3)
    else if ltf_price_only
        pack_bus_row(2, 4)
    else
        pack_bus_row(5, 1)

resolve_bus_quality_env_row(bool environment_hard_gate_ok, bool market_regime_gate_ok, bool vola_regime_gate_safe) =>
    if environment_hard_gate_ok
        pack_bus_row(5, 1)
    else if not market_regime_gate_ok
        pack_bus_row(-1, 2)
    else if not vola_regime_gate_safe
        pack_bus_row(-1, 3)
    else
        pack_bus_row(2, 4)

resolve_bus_quality_strict_row(bool long_entry_strict_state, bool strict_entry_ltf_ok, bool htf_alignment_ok, bool accel_strict_entry_gate_ok, bool sd_entry_strict_gate_ok, bool vol_entry_strict_context_ok_safe, bool stretch_entry_strict_context_ok, bool ddvi_entry_strict_ok_safe) =>
    bool strict_quality_ok = strict_entry_ltf_ok and htf_alignment_ok and accel_strict_entry_gate_ok and sd_entry_strict_gate_ok and vol_entry_strict_context_ok_safe and stretch_entry_strict_context_ok and ddvi_entry_strict_ok_safe
    if long_entry_strict_state
        pack_bus_row(5, 1)
    else if strict_quality_ok
        pack_bus_row(4, 2)
    else if not strict_entry_ltf_ok
        pack_bus_row(-1, 3)
    else if not htf_alignment_ok
        pack_bus_row(-1, 4)
    else if not accel_strict_entry_gate_ok
        pack_bus_row(-1, 5)
    else if not sd_entry_strict_gate_ok
        pack_bus_row(-1, 6)
    else if not vol_entry_strict_context_ok_safe
        pack_bus_row(-1, 7)
    else if not stretch_entry_strict_context_ok
        pack_bus_row(-1, 8)
    else
        pack_bus_row(-1, 9)

// ── Event Risk BUS Row ──
// Reason codes: 1=CLEAR, 2=PRE_EVENT(soft), 3=COOLDOWN(soft), 4=BLOCKED_MARKET(hard),
//               5=BLOCKED_SYMBOL(hard), 6=MACRO_HIGH, 7=EARNINGS
resolve_bus_event_risk_row(bool event_risk_gate_ok_param, bool hard_block, bool soft_block, bool market_blocked, bool symbol_blocked, string window_state, string risk_level) =>
    if not event_risk_gate_ok_param and market_blocked
        pack_bus_row(-1, 4)
    else if not event_risk_gate_ok_param and symbol_blocked
        pack_bus_row(-1, 5)
    else if not event_risk_gate_ok_param
        pack_bus_row(-1, 6)
    else if soft_block and window_state == "COOLDOWN"
        pack_bus_row(2, 3)
    else if soft_block and window_state == "PRE_EVENT"
        pack_bus_row(2, 2)
    else if risk_level == "LOW"
        pack_bus_row(4, 1)
    else
        pack_bus_row(5, 1)

resolve_bus_close_strength_row(bool use_strong_close_filter, bool bull_close_strong) =>
    if not use_strong_close_filter
        pack_bus_row(0, 1)
    else if bull_close_strong
        pack_bus_row(5, 1)
    else
        pack_bus_row(-1, 2)

resolve_bus_ema_support_row(bool show_ema_support, bool ema_support_ok) =>
    if not show_ema_support
        pack_bus_row(0, 1)
    else if ema_support_ok
        pack_bus_row(5, 1)
    else
        pack_bus_row(-1, 2)

resolve_bus_adx_row(bool use_adx, bool adx_data_ok, float plus_di, float minus_di, bool adx_strong, float adx_value, float adx_trend_min) =>
    if not use_adx
        pack_bus_row(0, 1)
    else if not adx_data_ok
        pack_bus_row(0, 2)
    else if plus_di < minus_di
        pack_bus_row(-1, 3)
    else if adx_strong
        pack_bus_row(5, 4)
    else if adx_value >= adx_trend_min
        pack_bus_row(3, 5)
    else
        pack_bus_row(2, 6)

resolve_bus_relvol_row(bool use_rel_volume, bool relvol_data_ok, bool allow_relvol_without_volume_data, bool relvol_ok) =>
    if not use_rel_volume
        pack_bus_row(0, 1)
    else if not relvol_data_ok and allow_relvol_without_volume_data
        pack_bus_row(2, 2)
    else if not relvol_data_ok
        pack_bus_row(-1, 3)
    else if relvol_ok
        pack_bus_row(5, 4)
    else
        pack_bus_row(-1, 5)

resolve_bus_vwap_row(bool use_vwap_filter, bool intraday_time_chart, bool vwap_session_active, bool vwap_filter_ok) =>
    if not use_vwap_filter
        pack_bus_row(0, 1)
    else if not intraday_time_chart
        pack_bus_row(0, 2)
    else if not vwap_session_active
        pack_bus_row(0, 3)
    else if vwap_filter_ok
        pack_bus_row(5, 4)
    else
        pack_bus_row(-1, 5)

resolve_bus_context_quality_row(bool use_context_quality_score_eff, bool context_quality_gate_ok) =>
    if not use_context_quality_score_eff
        pack_bus_row(0, 1)
    else if context_quality_gate_ok
        pack_bus_row(5, 2)
    else
        pack_bus_row(2, 3)

resolve_bus_quality_score_row(int signal_quality_score) =>
    if signal_quality_score >= 75
        pack_bus_row(5, 4)
    else if signal_quality_score >= 50
        pack_bus_row(5, 3)
    else if signal_quality_score >= 25
        pack_bus_row(4, 2)
    else
        pack_bus_row(2, 1)

resolve_bus_quality_clean_row(bool long_quality_clean_tier) =>
    long_quality_clean_tier ? pack_bus_row(5, 1) : pack_bus_row(0, 2)

resolve_bus_sd_confluence_row(bool use_sd_confluence, bool sd_support_both_recent, bool sd_bullish_divergence_recent, bool sd_higher_lows_recent, bool sd_support_any_recent) =>
    if not use_sd_confluence
        pack_bus_row(0, 1)
    else if sd_support_both_recent
        pack_bus_row(5, 2)
    else if sd_bullish_divergence_recent
        pack_bus_row(4, 3)
    else if sd_higher_lows_recent
        pack_bus_row(4, 4)
    else if sd_support_any_recent
        pack_bus_row(4, 5)
    else
        pack_bus_row(0, 6)

resolve_bus_sd_osc_row(bool use_sd_confluence, float sd_value, bool sd_above_zero, bool sd_rising, bool sd_below_zero, bool sd_falling) =>
    if not use_sd_confluence
        pack_bus_row(0, 1)
    else if na(sd_value)
        pack_bus_row(0, 2)
    else if sd_above_zero and sd_rising
        pack_bus_row(5, 3)
    else if sd_rising
        pack_bus_row(3, 4)
    else if sd_below_zero and sd_falling
        pack_bus_row(-1, 5)
    else
        pack_bus_row(2, 6)

resolve_bus_vol_regime_row(bool use_volatility_regime, bool vol_regime_trend_ok) =>
    if not use_volatility_regime
        pack_bus_row(0, 1)
    else if vol_regime_trend_ok
        pack_bus_row(5, 2)
    else
        pack_bus_row(-1, 3)

resolve_bus_vol_squeeze_row(bool use_volatility_regime, bool vol_squeeze_on, bool vol_squeeze_release_recent, bool vol_squeeze_recent) =>
    if not use_volatility_regime
        pack_bus_row(0, 1)
    else if vol_squeeze_on
        pack_bus_row(5, 2)
    else if vol_squeeze_release_recent
        pack_bus_row(4, 3)
    else if vol_squeeze_recent
        pack_bus_row(3, 4)
    else
        pack_bus_row(0, 5)

resolve_bus_vol_expand_row(bool use_volatility_regime, bool vol_momentum_expanding_long, bool vol_stack_spread_rising) =>
    if not use_volatility_regime
        pack_bus_row(0, 1)
    else if vol_momentum_expanding_long and vol_stack_spread_rising
        pack_bus_row(5, 2)
    else if vol_momentum_expanding_long or vol_stack_spread_rising
        pack_bus_row(3, 3)
    else
        pack_bus_row(0, 4)

resolve_bus_stretch_row(bool use_stretch_context, float distance_to_mean_z, bool in_lower_extreme, bool lower_extreme_recent, bool anti_chase_ok_entry_best, bool anti_chase_ok_ready) =>
    if not use_stretch_context
        pack_bus_row(0, 1)
    else if na(distance_to_mean_z)
        pack_bus_row(0, 2)
    else if (in_lower_extreme or lower_extreme_recent) and anti_chase_ok_entry_best
        pack_bus_row(5, in_lower_extreme ? 3 : 4)
    else if anti_chase_ok_ready
        pack_bus_row(3, 5)
    else
        pack_bus_row(-1, 6)

resolve_bus_ddvi_row(bool use_ddvi_context, bool ddvi_bias_ok, bool ddvi_bull_divergence_any, bool ddvi_lower_extreme_context) =>
    if not use_ddvi_context
        pack_bus_row(0, 1)
    else if ddvi_bias_ok and ddvi_bull_divergence_any
        pack_bus_row(5, 2)
    else if ddvi_bias_ok
        pack_bus_row(4, 3)
    else if ddvi_bull_divergence_any
        pack_bus_row(4, 4)
    else if ddvi_lower_extreme_context
        pack_bus_row(3, 5)
    else
        pack_bus_row(0, 6)

resolve_bus_ltf_bias_row(bool show_dashboard_ltf_eff, bool ltf_sampling_active, bool ltf_price_ok, bool ltf_price_only, float ltf_bull_share, float ltf_bias_hint) =>
    if not show_dashboard_ltf_eff
        pack_bus_row(0, 1)
    else if not ltf_sampling_active or not ltf_price_ok
        pack_bus_row(0, 2)
    else if ltf_bull_share >= ltf_bias_hint and ltf_price_only
        pack_bus_row(5, 3)
    else if ltf_bull_share >= ltf_bias_hint
        pack_bus_row(5, 4)
    else if ltf_bull_share >= 0.50
        pack_bus_row(3, 5)
    else
        pack_bus_row(-1, 6)

resolve_bus_ltf_delta_row(bool show_dashboard_ltf_eff, bool ltf_sampling_active, bool ltf_price_only, float ltf_volume_delta) =>
    if not show_dashboard_ltf_eff
        pack_bus_row(0, 1)
    else if not ltf_sampling_active
        pack_bus_row(0, 2)
    else if ltf_price_only
        pack_bus_row(2, 3)
    else if na(ltf_volume_delta)
        pack_bus_row(0, 4)
    else if ltf_volume_delta >= 0
        pack_bus_row(5, 5)
    else
        pack_bus_row(-1, 6)

resolve_bus_objects_row(int ob_count, int fvg_count) =>
    if ob_count > 0 and fvg_count > 0
        pack_bus_row(5, 3)
    else if ob_count > 0
        pack_bus_row(3, 1)
    else if fvg_count > 0
        pack_bus_row(3, 2)
    else
        pack_bus_row(0, 4)

resolve_bus_swing_row(bool bullish_trend_safe, bool bearish_trend_safe) =>
    if bullish_trend_safe
        pack_bus_row(5, 1)
    else if bearish_trend_safe
        pack_bus_row(-1, 2)
    else
        pack_bus_row(0, 3)

resolve_bus_micro_profile_row(bool use_microstructure_profiles, string micro_profile_text, string micro_modifier_text) =>
    int reason_code = 1
    if micro_profile_text == 'Stop-Hunt Sensitive'
        reason_code := 2
    else if micro_profile_text == 'Clean Reclaim'
        reason_code := 3
    else if micro_profile_text == 'RTH Only'
        reason_code := 4
    else if micro_profile_text == 'Midday Dead'
        reason_code := 5
    else if micro_profile_text == 'Fast Decay'
        reason_code := 6
    int profile_state = 0
    if use_microstructure_profiles
        profile_state := str.length(micro_modifier_text) > 0 or micro_profile_text != 'Default' ? 5 : 3
    pack_bus_row(use_microstructure_profiles ? profile_state : 0, use_microstructure_profiles ? reason_code : 0)

resolve_bus_micro_modifier_mask(string micro_modifier_text) =>
    int modifier_mask = 0
    if str.contains(micro_modifier_text, 'Stop-Hunt')
        modifier_mask += 1
    if str.contains(micro_modifier_text, 'Clean Reclaim')
        modifier_mask += 2
    if str.contains(micro_modifier_text, 'Fast Decay')
        modifier_mask += 4
    if str.contains(micro_modifier_text, 'RTH Only')
        modifier_mask += 8
    if str.contains(micro_modifier_text, 'Midday Dead')
        modifier_mask += 16
    if str.contains(micro_modifier_text, 'Weak Premarket')
        modifier_mask += 32
    if str.contains(micro_modifier_text, 'Weak Afterhours')
        modifier_mask += 64
    float(modifier_mask)

resolve_bus_long_triggers_row(bool long_plan_active) =>
    long_plan_active ? pack_bus_row(5, 1) : pack_bus_row(0, 2)

resolve_bus_risk_plan_row(bool long_plan_active) =>
    long_plan_active ? pack_bus_row(5, 1) : pack_bus_row(0, 2)

resolve_bus_ready_gate_row(bool long_ready_state, bool long_setup_confirmed, bool lifecycle_ready_ok, bool setup_hard_gate_ok, bool trade_hard_gate_ok, bool environment_hard_gate_ok, bool close_safe_mode, bool ready_bar_gap_ok, bool long_confirm_expired, bool ready_is_fresh, bool long_confirm_bearish_guard_ok, bool require_main_break_for_ready, bool bull_bos_sig, bool main_bos_recent, bool session_structure_gate_ok, bool micro_session_gate_ok, bool micro_freshness_gate_ok, bool overhead_zone_ok, bool market_regime_gate_ok, bool vola_regime_gate_safe, bool quality_gate_ok, bool accel_ready_gate_ok, bool sd_ready_gate_ok, bool vol_ready_context_ok, bool stretch_ready_context_ok, bool ddvi_ready_ok_safe) =>
    int row_state = 2
    int reason_code = 1
    if long_ready_state
        row_state := 5
    else if not long_setup_confirmed
        row_state := 2
        reason_code := 2
    else if not close_safe_mode
        row_state := 2
        reason_code := 3
    else if not ready_bar_gap_ok
        row_state := 2
        reason_code := 4
    else if long_confirm_expired or not ready_is_fresh
        row_state := 2
        reason_code := long_confirm_expired ? 5 : 6
    else if not long_confirm_bearish_guard_ok
        row_state := 2
        reason_code := 7
    else if require_main_break_for_ready and (not bull_bos_sig or not main_bos_recent)
        row_state := 2
        reason_code := 8
    else if not lifecycle_ready_ok
        row_state := 2
        reason_code := 9
    else if not setup_hard_gate_ok
        row_state := -1
        reason_code := 10
    else if not session_structure_gate_ok
        row_state := -1
        reason_code := 11
    else if not micro_session_gate_ok
        row_state := -1
        reason_code := 12
    else if not micro_freshness_gate_ok
        row_state := -1
        reason_code := 13
    else if not overhead_zone_ok
        row_state := -1
        reason_code := 14
    else if not trade_hard_gate_ok
        row_state := -1
        reason_code := 15
    else if not market_regime_gate_ok
        row_state := -1
        reason_code := 16
    else if not vola_regime_gate_safe
        row_state := -1
        reason_code := 17
    else if not environment_hard_gate_ok
        row_state := -1
        reason_code := 18
    else if not quality_gate_ok
        row_state := -1
        reason_code := 19
    else if not accel_ready_gate_ok
        row_state := -1
        reason_code := 20
    else if not sd_ready_gate_ok
        row_state := -1
        reason_code := 21
    else if not vol_ready_context_ok
        row_state := -1
        reason_code := 22
    else if not stretch_ready_context_ok
        row_state := -1
        reason_code := 23
    else if not ddvi_ready_ok_safe
        row_state := -1
        reason_code := 24
    pack_bus_row(row_state, reason_code)

resolve_bus_strict_gate_row(bool long_entry_strict_state, bool long_ready_state, bool strict_entry_ltf_ok, bool htf_alignment_ok, bool accel_strict_entry_gate_ok, bool sd_entry_strict_gate_ok, bool vol_entry_strict_context_ok_safe, bool stretch_entry_strict_context_ok, bool ddvi_entry_strict_ok_safe) =>
    int row_state = 2
    int reason_code = 1
    if long_entry_strict_state
        row_state := 5
    else if not long_ready_state
        row_state := 2
        reason_code := 2
    else if not strict_entry_ltf_ok
        row_state := -1
        reason_code := 3
    else if not htf_alignment_ok
        row_state := -1
        reason_code := 4
    else if not accel_strict_entry_gate_ok
        row_state := -1
        reason_code := 5
    else if not sd_entry_strict_gate_ok
        row_state := -1
        reason_code := 6
    else if not vol_entry_strict_context_ok_safe
        row_state := -1
        reason_code := 7
    else if not stretch_entry_strict_context_ok
        row_state := -1
        reason_code := 8
    else if not ddvi_entry_strict_ok_safe
        row_state := -1
        reason_code := 9
    pack_bus_row(row_state, reason_code)

resolve_bus_debug_state_row(bool show_long_engine_debug, int long_visual_state, bool long_setup_armed, bool long_setup_confirmed, bool long_ready_state) =>
    int debug_state = 0
    int reason_code = 1
    if not show_long_engine_debug
        debug_state := 0
        reason_code := 0
    else if long_visual_state == -1
        debug_state := -1
        reason_code := 2
    else if long_setup_armed or long_setup_confirmed or long_ready_state
        debug_state := 5
        reason_code := 3
    else
        debug_state := 2
        reason_code := 4
    pack_bus_row(debug_state, reason_code)

resolve_bus_debug_flags_row(bool show_ob_debug, bool show_fvg_debug, bool show_long_engine_debug) =>
    int reason_code = (show_ob_debug ? 1 : 0) + (show_fvg_debug ? 2 : 0) + (show_long_engine_debug ? 4 : 0)
    pack_bus_row(reason_code > 0 ? 5 : 0, reason_code)

