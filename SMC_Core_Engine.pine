bool   signal_quality_high       = lib_sq_score >= 75
bool   signal_freshness_ok       = lib_sq_freshness != "stale"
// Structure Light: trend strength from generator
bool   struct_light_trending     = lib_strl_trend_strength >= 30
// OB Context Light: primary OB is bullish + fresh
bool   ob_light_bull_ok          = lib_obl_side == "BULL" and lib_obl_fresh
// FVG Lifecycle Light: primary FVG alive + not invalidated
bool   fvg_light_active_ok       = lib_fvgl_side != "NONE" and not lib_fvgl_invalidated
// Session Context Light: lean session quality
bool   session_light_ok          = lib_scl_context_score >= 2

// ── Legacy context gates REMOVED in v5.5 ──
// 17 gates (flow_quality_ok, compression_entry_ok, atr_regime_ok,
//   zone_context_long_ok, reversal_context_boost, session_context_ok,
//   sweep_context_long_ok, pool_magnet_long_ok, ob_context_long_ok,
//   zone_proj_ok, profile_quality_ok, struct_state_ok, imbalance_ok,
//   session_struct_ok, range_regime_ok, range_profile_ok,
//   session_struct_state_ok) were declared but never consumed.
// They derived from deprecated v5.1-v5.3 fields; pipeline uses
// v5.5 lean context gates above exclusively. Removed to reduce noise.

var string micro_midday_block_session = input.session('1130-1330', 'Midday block', group = g_micro, display = display.none)
var string micro_premarket_session = input.session('0400-0929', 'Premarket', group = g_micro, display = display.none)
var string micro_afterhours_session = input.session('1601-2000', 'After-hours', group = g_micro, display = display.none)
var float micro_stop_hunt_ob_sweep_depth = input.float(0.65, 'Stop-hunt OB sweep depth', minval = 0.0, maxval = 1.0, step = 0.05, group = g_micro, display = display.none)
var float micro_stop_hunt_fvg_sweep_depth = input.float(0.45, 'Stop-hunt FVG sweep depth', minval = 0.0, maxval = 1.0, step = 0.05, group = g_micro, display = display.none)
var float micro_stop_hunt_relvol_min = input.float(1.4, 'Stop-hunt min RelVol', minval = 0.5, step = 0.1, group = g_micro, display = display.none)
var float micro_stop_hunt_invalidation_atr = input.float(0.20, 'Stop-hunt invalidation ATR x', minval = 0.0, step = 0.05, group = g_micro, display = display.none)
var bool micro_stop_hunt_force_close_confirm = input.bool(true, 'Stop-hunt: force close confirm', group = g_micro, display = display.none)
var bool micro_stop_hunt_disable_live_invalid = input.bool(true, 'Stop-hunt: disable live invalidation', group = g_micro, display = display.none)
var int micro_fast_decay_setup_age_max = input.int(3, 'Fast-decay max armed age', minval = 1, maxval = 20, group = g_micro, display = display.none)
var int micro_fast_decay_confirm_age_max = input.int(2, 'Fast-decay max confirmed age', minval = 1, maxval = 20, group = g_micro, display = display.none)
