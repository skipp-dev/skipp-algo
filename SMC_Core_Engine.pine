    plot_swing_levels(-1, trail_dn_x, trail_dn, structure_display_trend, true, d.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_left), d.LineArgs.new(bull_css, line.style_solid, 2), override_right_index = bar_index + 20)

if show_bull_bos or show_bull_choch
    plot_structure(top_x, top, show_bull_bos and bull_bos_sig, show_bull_choch and bull_choch_sig, d.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_down), d.LineArgs.new(bull_css, line.style_solid, 2), keep_history = keep_visual_history_eff)

// Internal structure: lighter dashed rendering
if show_internals
    plot_swing_levels(1, internal_trail_up_x, internal_trail_up, internal_display_trend, true, d.LabelArgs.new(bear_internal_css, #00000000, size = size.tiny, style = label.style_label_left), d.LineArgs.new(bear_internal_css, line.style_dashed), override_right_index = bar_index + 10, text_prefix = 'INT ')
    plot_swing_levels(-1, internal_trail_dn_x, internal_trail_dn, internal_display_trend, true, d.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_left), d.LineArgs.new(bull_internal_css, line.style_dashed), override_right_index = bar_index + 10, text_prefix = 'INT ')

if show_internal_bull_bos or show_internal_bull_choch
    plot_structure(internal_top_x, internal_top, show_internal_bull_bos and internal_bull_bos_sig, show_internal_bull_choch and internal_bull_choch_sig, d.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_down), d.LineArgs.new(bull_internal_css, line.style_dashed), keep_history = keep_visual_history_eff, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

type LongLifecycleState
    bool armed = false
    bool confirmed = false
    int arm_bar_index = na
    int confirm_bar_index = na
    float trigger = na
    float invalidation_level = na
    int entry_origin_source
    int backing_zone_kind
    int backing_zone_id = na
    int backing_zone_touch_count = 0
    int locked_source_kind
    int locked_source_id = na
    float locked_source_top = na
    float locked_source_bottom = na
    int locked_source_touch_count = 0
    int locked_source_last_touch_bar_index = na
    int setup_serial = 0
    string last_invalid_source = 'None'
    float last_invalid_level = na

method clear(LongLifecycleState this) =>
    this.armed := false
    this.confirmed := false
    this.arm_bar_index := na
    this.confirm_bar_index := na
    this.trigger := na
    this.invalidation_level := na
    this.entry_origin_source := LONG_SOURCE_NONE
    this.backing_zone_kind := LONG_SOURCE_NONE
    this.backing_zone_id := na
    this.backing_zone_touch_count := 0
    this.locked_source_kind := LONG_SOURCE_NONE
    this.locked_source_id := na
    this.locked_source_top := na
    this.locked_source_bottom := na
    this.locked_source_touch_count := 0
    this.locked_source_last_touch_bar_index := na
    this

method arm(LongLifecycleState this, int arm_bar_index, float trigger, float invalidation_level, int entry_origin_source, int backing_zone_kind, int backing_zone_id, int backing_zone_touch_count, int locked_source_kind, int locked_source_id, float locked_source_top, float locked_source_bottom, int locked_source_touch_count, int locked_source_last_touch_bar_index) =>
    this.armed := true
    this.confirmed := false
    this.arm_bar_index := arm_bar_index
    this.confirm_bar_index := na
    this.trigger := trigger
    this.invalidation_level := invalidation_level
    this.entry_origin_source := entry_origin_source
    this.backing_zone_kind := backing_zone_kind
    this.backing_zone_id := backing_zone_id
    this.backing_zone_touch_count := backing_zone_touch_count
    this.locked_source_kind := locked_source_kind
    this.locked_source_id := locked_source_id
    this.locked_source_top := locked_source_top
    this.locked_source_bottom := locked_source_bottom
    this.locked_source_touch_count := locked_source_touch_count
    this.locked_source_last_touch_bar_index := locked_source_last_touch_bar_index
    this.setup_serial += 1
    this

method confirm(LongLifecycleState this, int confirm_bar_index) =>
    this.confirmed := true
    this.confirm_bar_index := confirm_bar_index
    this

method sync_locked_tracking(LongLifecycleState this, int backing_zone_kind, int backing_zone_id, int locked_source_kind, int locked_source_id, float locked_source_top, float locked_source_bottom, int locked_source_touch_count, int locked_source_last_touch_bar_index) =>
    this.backing_zone_kind := backing_zone_kind
    this.backing_zone_id := backing_zone_id
    this.backing_zone_touch_count := locked_source_touch_count
    this.locked_source_kind := locked_source_kind
    this.locked_source_id := locked_source_id
    this.locked_source_top := locked_source_top
    this.locked_source_bottom := locked_source_bottom
    this.locked_source_touch_count := locked_source_touch_count
    this.locked_source_last_touch_bar_index := locked_source_last_touch_bar_index
    this

method invalidate(LongLifecycleState this, string reason, float level) =>
    this.last_invalid_source := reason
    this.last_invalid_level := level
    this.clear()

validate_long_state(LongLifecycleState st, bool enabled = true) =>
    if enabled
        if st.confirmed and not st.armed
            runtime.error('Long invariant failed: confirmed requires armed')
        if st.locked_source_kind == LONG_SOURCE_NONE and not na(st.locked_source_id)
            runtime.error('Long invariant failed: NONE source cannot carry id')
        if st.locked_source_kind != LONG_SOURCE_NONE and na(st.locked_source_id)
            runtime.error('Long invariant failed: source kind requires source id')
        if st.backing_zone_kind == LONG_SOURCE_NONE and not na(st.backing_zone_id)
            runtime.error('Long invariant failed: NONE backing zone cannot carry id')
        if st.backing_zone_kind != LONG_SOURCE_NONE and na(st.backing_zone_id) and long_source_is_zone_kind(st.backing_zone_kind)
            runtime.error('Long invariant failed: zone backing kind requires zone id')

// Persistent long-setup storage must exist before the OB/FVG engines run so active backing zones can be protected from cleanup.
var LongLifecycleState long_state = LongLifecycleState.new(false, false, na, na, na, na, LONG_SOURCE_NONE, LONG_SOURCE_NONE, na, 0, LONG_SOURCE_NONE, na, na, na, 0, na, 0, 'None', na)
varip bool long_invalidated_this_bar = false

bool enable_ob_engine = use_ob_engine
int _ob_backing_zone_id = na
if long_state.backing_zone_kind == LONG_SOURCE_OB
    _ob_backing_zone_id := long_state.backing_zone_id
[ob_blocks_bull, ob_blocks_bear, new_ob_bull, _new_ob_bear, ob_broken_bull, _ob_broken_bear, ob_broken_new_bull, _ob_broken_new_bear, ob_discarded_bull, _ob_discarded_bear] = track_obs(swing_length, hh, ll, bull_bos_alert, bull_choch_alert, bear_bos_alert, bear_choch_alert, ob_threshold_min, ob_threshold_max, enabled = enable_ob_engine, capture_profile = collect_ob_profile_current_bar, update_profile_current_bar = collect_ob_profile_current_bar, align_edge_to_value_area = use_ob_profile_effective, align_break_price_to_poc = use_ob_profile_effective, use_soft_confirm = use_ob_soft_confirm, soft_confirm_offset = soft_confirm_offset, keep_broken_max = ob_keep_broken_max, broken_by = active_break_mode, gc_cycle = object_gc_cycle_eff, protected_bull_id = _ob_backing_zone_id)

varip bool live_bull_ob_break = false
varip bool live_bull_fvg_fill = false
var int reclaim_marker_drawn_bar_index = na
var int long_state_marker_drawn_bar_index = na
var int long_ready_marker_drawn_bar_index = na

if barstate.isnew
    live_bull_ob_break := false
    live_bull_fvg_fill := false
    reclaim_marker_drawn_bar_index := na
    long_state_marker_drawn_bar_index := na
    long_ready_marker_drawn_bar_index := na

if barstate.islast
    draw(ob_blocks_bull, ob_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_ob and ob_keep_broken and ob_keep_broken_max > 0
        draw(ob_broken_bull, ob_config_bull_broken, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        delete(ob_broken_bull)

    if barstate.isconfirmed
        delete(ob_discarded_bull)
        array.clear(ob_discarded_bull)

var g_fvg = 'Fair Value Gaps'
var show_fvg = input.bool(true, 'Show Fair Value Gaps', group = g_fvg, inline = 'show', tooltip = 'Display fair value gaps on the chart.')
var fvg_showlast = input.int(DEFAULT_FVG_SHOW_LAST, 'Show last', minval = 1, group = g_fvg, inline = 'show2')
var fvg_extend_until_filled = input.bool(true, 'Extend until filled', group = g_fvg, inline = 'ext')
var fvg_keep_filled = input.bool(true, 'Keep filled', group = g_fvg, inline = 'keep filled')
var fvg_keep_filled_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 1, group = g_fvg, inline = 'keep filled')
var bool show_fvg_debug = input.bool(false, 'Show FVG debug', group = g_fvg)
var bull_fvg_css = input.color(color.new(#00ff68, 90), '', group = g_fvg, inline = 'show')
var bull_fvg_line_css = input.color(color.new(#00ff68, 25), '', group = g_fvg, inline = 'show')
var bull_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bull_fvg_line_css_filled = color.new(bull_fvg_css_filled, 50)
var filter_insignificant_fvgs = input.bool(true, 'Filter: min size', group = g_fvg, inline = 'fvg_min', tooltip = 'Filter out fair value gaps that are too small to matter.')
var min_fvg_size_atr_len = input.int(ATR_LEN_MAIN, 'ATR Length', minval = 1, group = g_fvg, inline = 'fvg_min')
var min_fvg_size_atr_mult = input.float(DEFAULT_FVG_MIN_SIZE_MULT, 'x', minval = 0, step = 0.1, group = g_fvg, inline = 'fvg_min')
float fvg_size_threshold = 0
if filter_insignificant_fvgs
    fvg_size_threshold := smc_lib_atr(min_fvg_size_atr_len) * min_fvg_size_atr_mult
var float fvg_fill_target_pct = input.float(DEFAULT_FVG_FILL_TARGET_PCT, 'Filled at %', minval = 0, maxval = 100, step = 5, group = g_fvg)
float fvg_fill_target_ratio = math.max(0.0, math.min(1.0, fvg_fill_target_pct / 100.0))
var use_fvg_engine = input.bool(true, 'Use FVG engine', group = g_fvg, display = display.none, tooltip = 'Keeps FVG-based long-dip logic and alerts running even if chart rendering is hidden.')

bool enable_fvg_engine = use_fvg_engine
int _fvg_backing_zone_id = na
if long_state.backing_zone_kind == LONG_SOURCE_FVG
    _fvg_backing_zone_id := long_state.backing_zone_id
[bullish_fvg_alert, bearish_fvg_alert, fvgs_bull, fvgs_bear, new_fvg_bull, _new_fvg_bear, filled_fvgs_bull, _filled_fvgs_bear, filled_fvgs_new_bull, _filled_fvgs_new_bear, fvg_discarded_bull, fvg_discarded_bear] = fvgs_objects(active_break_mode, fvg_fill_target_ratio, fvg_size_threshold, enable_fvg_engine, fvg_keep_filled_max, object_gc_cycle_eff, _fvg_backing_zone_id)

var fvg_config_bull = FVGConfig.new(show_box = show_fvg, show_target = show_fvg, show_target_label = true, show_last = fvg_showlast, txt = 'FVG ⬈', show_quality_score = true, extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css, 0, line.style_solid, bull_fvg_css, xloc.bar_index), box_text_args = d.BoxTextArgs.new(bull_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css, line.style_solid, 1, xloc.bar_index), label_args = d.LabelArgs.new(bull_fvg_line_css, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var bool show_fvg_filled = false
if show_fvg and fvg_keep_filled and fvg_keep_filled_max > 0
    show_fvg_filled := true
else
    show_fvg_filled := false
var fvg_config_bull_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_quality_score = false, extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css_filled, 0, line.style_solid, bull_fvg_css_filled, xloc.bar_index), box_text_args = d.BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css_filled, line.style_solid, 1, xloc.bar_index), label_args = d.LabelArgs.new(#00000000, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))

bool bullish_fvg_filled_alert = false
if array.size(filled_fvgs_new_bull) > 0
    bullish_fvg_filled_alert := true
FVG bull_filled_alert_gap = na
if bullish_fvg_filled_alert
    bull_filled_alert_gap := array.get(filled_fvgs_new_bull, array.size(filled_fvgs_new_bull) - 1)
float bull_filled_alert_level = resolve_fvg_alert_level(bull_filled_alert_gap)

if barstate.islast
    draw(fvgs_bull, fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_fvg_filled
        draw(filled_fvgs_bull, fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        delete(filled_fvgs_bull)

    if barstate.isconfirmed
        delete(fvg_discarded_bull)
        array.clear(fvg_discarded_bull)
        delete(fvg_discarded_bear)
        array.clear(fvg_discarded_bear)

fvgs_objects_htf(FVG new_bull, FVG new_bear, bool htf_is_confirmed, float size_threshold, simple ct.LevelBreakMode fill_mode = ct.LevelBreakMode.CLOSE, simple float fill_target_ratio = 0.5, simple int filled_max_keep = 5, simple int gc_cycle = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] htf_buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] htf_buffer_bear_discarded = array.new<FVG>(0)

    if barstate.isfirst and not u.in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    bool htf_update_ok = false
    if fill_mode == ct.LevelBreakMode.HIGHLOW or signal_mode == ct.SignalMode.AGGRESSIVE_LIVE or barstate.isconfirmed
        htf_update_ok := true
    if htf_update_ok
        buffer_bull.update()
        buffer_bear.update()
        buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, htf_buffer_bull_discarded)
        buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, htf_buffer_bear_discarded)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, htf_buffer_bull_discarded)
        buffer_bear.remove_insignificant(size_threshold, htf_buffer_bear_discarded)

    bool htf_insert_ok = true
    if fill_mode == ct.LevelBreakMode.CLOSE
        htf_insert_ok := htf_is_confirmed

    if htf_insert_ok and not na(new_bull)
        buffer_bull.push(new_bull)
    if htf_insert_ok and not na(new_bear)
        buffer_bear.push(new_bear)

    if htf_buffer_bull_discarded.size() > 0
        delete(htf_buffer_bull_discarded)
        array.clear(htf_buffer_bull_discarded)
    if htf_buffer_bear_discarded.size() > 0
        delete(htf_buffer_bear_discarded)
        array.clear(htf_buffer_bear_discarded)

    [buffer_bull, buffer_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, htf_buffer_bull_discarded, htf_buffer_bear_discarded]

var g_htf_fvg = 'Fair Value Gaps (Higher Timeframe)'
var show_htf_fvg = input.bool(true, 'Show Fair Value Gaps (HTF)', group = g_htf_fvg, inline = 'show', tooltip = 'Display fair value gaps on the chart.\nHigher timeframe used for the higher-timeframe FVG overlay.')
var fvg_htf = input.timeframe('1D', '', group = g_htf_fvg, inline = 'show')
var htf_fvg_showlast = input.int(1, 'Show last', minval = 1, group = g_htf_fvg, inline = 'show2')
var htf_fvg_keep_filled = input.bool(true, 'Keep filled', group = g_htf_fvg, inline = 'keep filled')
var htf_fvg_keep_filled_max = input.int(1, '', minval = 1, group = g_htf_fvg, inline = 'keep filled')
int htf_fvg_tf_sec = nz(timeframe.in_seconds(fvg_htf), 0)

if barstate.isfirst and show_htf_fvg
    if chart_tf_sec == 0 or htf_fvg_tf_sec == 0
        runtime.error('HTF FVG requires a time-based chart and a time-based HTF.')
    if htf_fvg_tf_sec <= chart_tf_sec
        runtime.error(str.format('Show FVG (Timeframe): select a timeframe higher than the chart timeframe {0}, currently selected: {1}', timeframe.period, fvg_htf))

var htf_fvg_config_bull = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_showlast, txt = fvg_htf + ' - FVG ⬈', extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css, 0, line.style_solid, bull_fvg_css, xloc = xloc.bar_time), box_text_args = d.BoxTextArgs.new(bull_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css, line.style_solid, 1, xloc = xloc.bar_time), label_args = d.LabelArgs.new(bull_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bull_filled = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_keep_filled_max, txt = '', extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css_filled, 0, line.style_solid, bull_fvg_css_filled, xloc = xloc.bar_time), box_text_args = d.BoxTextArgs.new(bull_fvg_line_css_filled, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css_filled, line.style_solid, 1, xloc = xloc.bar_time), label_args = d.LabelArgs.new(bull_fvg_css_filled, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))

FVG htf_insert_fvg_bull = na
FVG htf_insert_fvg_bear = na
var string last_htf_inserted_bull_key = ''
var string last_htf_inserted_bear_key = ''
htf_bar_changed = timeframe.change(fvg_htf)
bool htf_fvg_confirmed = false
if signal_mode == ct.SignalMode.AGGRESSIVE_LIVE
    htf_fvg_confirmed := true
else if barstate.isconfirmed
    htf_fvg_confirmed := htf_bar_changed or htf_fvg_tf_sec == chart_tf_sec
if show_htf_fvg
    // HTF FVG context is read with lookahead_off so non-live paths only consume completed HTF bars.
    [htf_bull_found, htf_bull_top, htf_bull_btm, htf_bull_left_time, htf_bull_right_time, htf_bull_fill_target, htf_bull_total_vol] =
        request.security(syminfo.tickerid, fvg_htf, _detect_fvg_values_for_htf(1, true, fvg_size_threshold, fvg_fill_target_ratio), gaps = barmerge.gaps_on, lookahead = barmerge.lookahead_off)
    [htf_bear_found, htf_bear_top, htf_bear_btm, htf_bear_left_time, htf_bear_right_time, htf_bear_fill_target, htf_bear_total_vol] =
        request.security(syminfo.tickerid, fvg_htf, _detect_fvg_values_for_htf(-1, true, fvg_size_threshold, fvg_fill_target_ratio), gaps = barmerge.gaps_on, lookahead = barmerge.lookahead_off)
    string bull_htf_key = ''
    if htf_bull_found
        bull_htf_key := u.htf_fvg_key(htf_bull_left_time, htf_bull_right_time, htf_bull_top, htf_bull_btm)
    string bear_htf_key = ''
    if htf_bear_found
        bear_htf_key := u.htf_fvg_key(htf_bear_left_time, htf_bear_right_time, htf_bear_top, htf_bear_btm)
    if htf_fvg_confirmed and htf_bull_found and bull_htf_key != last_htf_inserted_bull_key
        float htf_bull_size = htf_bull_top - htf_bull_btm
        htf_insert_fvg_bull := FVG.new(
             na, 1, ct.LevelBreakMode.CLOSE,
             left_top = chart.point.new(htf_bull_left_time, na, htf_bull_top),
             right_bottom = chart.point.new(htf_bull_right_time, na, htf_bull_btm),
             fvg_fill_target_ratio = fvg_fill_target_ratio,
             fill_target_level = htf_bull_fill_target,
             fill_current_ratio = 0,
             fill_current_level = htf_bull_top,
             total_volume = htf_bull_total_vol)
        htf_insert_fvg_bull.quality_score := math.max(0.0, math.min(1.0, 0.15 + math.min(htf_bull_size / math.max(fvg_size_threshold * 3.0, syminfo.mintick), 1.0) * 0.35 + (htf_bull_total_vol > 0 ? 0.10 : 0.0) + 0.15))
        last_htf_inserted_bull_key := bull_htf_key
    if htf_fvg_confirmed and htf_bear_found and bear_htf_key != last_htf_inserted_bear_key
        float htf_bear_size = htf_bear_top - htf_bear_btm
        htf_insert_fvg_bear := FVG.new(
             na, -1, ct.LevelBreakMode.CLOSE,
             left_top = chart.point.new(htf_bear_left_time, na, htf_bear_top),
             right_bottom = chart.point.new(htf_bear_right_time, na, htf_bear_btm),
             fvg_fill_target_ratio = fvg_fill_target_ratio,
             fill_target_level = htf_bear_fill_target,
             fill_current_ratio = 0,
             fill_current_level = htf_bear_btm,
             total_volume = htf_bear_total_vol)
        htf_insert_fvg_bear.quality_score := math.max(0.0, math.min(1.0, 0.15 + math.min(htf_bear_size / math.max(fvg_size_threshold * 3.0, syminfo.mintick), 1.0) * 0.35 + (htf_bear_total_vol > 0 ? 0.10 : 0.0) + 0.15))
        last_htf_inserted_bear_key := bear_htf_key
[htf_fvg_buffer_bull, htf_fvg_buffer_bear, htf_fvg_buffer_bull_filled, htf_fvg_buffer_bear_filled, htf_fvg_buffer_bull_filled_new, htf_fvg_buffer_bear_filled_new, htf_fvg_buffer_bull_discarded, htf_fvg_buffer_bear_discarded] = fvgs_objects_htf(htf_insert_fvg_bull, htf_insert_fvg_bear, htf_fvg_confirmed, fvg_size_threshold, active_break_mode, fvg_fill_target_ratio, htf_fvg_keep_filled_max, object_gc_cycle_eff)

OrderBlock last_bull_ob = na
if array.size(ob_blocks_bull) > 0
    last_bull_ob := array.get(ob_blocks_bull, array.size(ob_blocks_bull) - 1)
last_bull_ob_break_level = resolve_ob_alert_level(last_bull_ob)
FVG last_bull_fvg_gap = na
if array.size(fvgs_bull) > 0
    last_bull_fvg_gap := array.get(fvgs_bull, array.size(fvgs_bull) - 1)
last_bull_fvg_fill_level = resolve_fvg_alert_level(last_bull_fvg_gap)

last_bull_ob_top = resolve_ob_top_boundary(last_bull_ob)
last_bull_ob_bottom = resolve_ob_bottom_boundary(last_bull_ob)
last_bull_fvg_top = resolve_fvg_top_boundary(last_bull_fvg_gap)
last_bull_fvg_bottom = resolve_fvg_bottom_boundary(last_bull_fvg_gap)

var float touched_bull_ob_top = na
var float touched_bull_ob_bottom = na
var int touched_bull_ob_bar_index = na
var int touched_bull_ob_id = na
var int touched_bull_ob_touch_count = 0
var float touched_bull_fvg_top = na
var float touched_bull_fvg_bottom = na
var int touched_bull_fvg_bar_index = na
var int touched_bull_fvg_id = na
var int touched_bull_fvg_touch_count = 0
int bear_ob_scan_start = math.max(0, array.size(ob_blocks_bear) - long_zone_scan_limit)
int bear_fvg_scan_start = math.max(0, array.size(fvgs_bear) - long_zone_scan_limit)

scan_active_bull_ob() =>
    int _scan_start = math.max(0, array.size(ob_blocks_bull) - long_zone_scan_limit)
    int _best_idx = na
    int _best_id = na
    int _best_recency = na
    bool _best_touch = false
    float _best_quality = na
    float _best_overlap = na
    if array.size(ob_blocks_bull) > 0
        for i = array.size(ob_blocks_bull) - 1 to _scan_start
            _cand = array.get(ob_blocks_bull, i)
            int _c_id = resolve_ob_id(_cand)
            float _c_top = resolve_ob_top_boundary(_cand)
            float _c_bottom = resolve_ob_bottom_boundary(_cand)
            float _c_overlap = math.min(high, _c_top) - math.max(low, _c_bottom)
            bool _c_active = _c_overlap >= 0
            bool _c_touch = not na(touched_bull_ob_id) and _c_id == touched_bull_ob_id and not na(touched_bull_ob_bar_index) and bar_index - touched_bull_ob_bar_index <= long_signal_window
            int _c_recency = resolve_ob_recency_index(_cand)
            float _c_quality = ob_quality_score(_cand)
            bool _prefer = na(_best_idx)
            if _c_active and not _prefer
                _prefer := zone_candidate_preferred(_c_touch, _c_recency, _c_quality, _c_overlap, _c_id, _best_touch, _best_recency, _best_quality, _best_overlap, _best_id)
            if _c_active and _prefer
                _best_idx := i
                _best_id := _c_id
                _best_recency := _c_recency
                _best_touch := _c_touch
                _best_quality := _c_quality
                _best_overlap := _c_overlap
    float _top = na
    float _bottom = na
    float _break_level = na
    int _id = na
    float _quality = 0.0
    int _recency = na
    bool _touch_anchor = false
    if not na(_best_idx)
        _ob = array.get(ob_blocks_bull, _best_idx)
        _top := resolve_ob_top_boundary(_ob)
        _bottom := resolve_ob_bottom_boundary(_ob)
        _break_level := resolve_ob_alert_level(_ob)
        _id := resolve_ob_id(_ob)
        _quality := ob_quality_score(_ob)
        _recency := resolve_ob_recency_index(_ob)
        _touch_anchor := _best_touch
    [_top, _bottom, _break_level, _id, _quality, _recency, _touch_anchor, _best_overlap]

scan_active_bull_fvg() =>
    int _scan_start = math.max(0, array.size(fvgs_bull) - long_zone_scan_limit)
    int _best_idx = na
    int _best_id = na
    int _best_recency = na
    bool _best_touch = false
    float _best_quality = na
    float _best_overlap = na
    if array.size(fvgs_bull) > 0
        for i = array.size(fvgs_bull) - 1 to _scan_start
            _cand = array.get(fvgs_bull, i)
            int _c_id = resolve_fvg_id(_cand)
            float _c_top = resolve_fvg_top_boundary(_cand)
            float _c_bottom = resolve_fvg_bottom_boundary(_cand)
            float _c_overlap = math.min(high, _c_top) - math.max(low, _c_bottom)
            bool _c_active = _c_overlap >= 0
            bool _c_touch = not na(touched_bull_fvg_id) and _c_id == touched_bull_fvg_id and not na(touched_bull_fvg_bar_index) and bar_index - touched_bull_fvg_bar_index <= long_signal_window
            int _c_recency = resolve_fvg_recency_index(_cand)
            float _c_quality = fvg_quality_score(_cand, fvg_size_threshold)
            bool _prefer = na(_best_idx)
            if _c_active and not _prefer
                _prefer := zone_candidate_preferred(_c_touch, _c_recency, _c_quality, _c_overlap, _c_id, _best_touch, _best_recency, _best_quality, _best_overlap, _best_id)
            if _c_active and _prefer
                _best_idx := i
                _best_id := _c_id
                _best_recency := _c_recency
                _best_touch := _c_touch
                _best_quality := _c_quality
                _best_overlap := _c_overlap
    float _top = na
    float _bottom = na
    float _fill_level = na
    int _id = na
    float _quality = 0.0
    int _recency = na
    bool _touch_anchor = false
    if not na(_best_idx)
        _fvg = array.get(fvgs_bull, _best_idx)
        _top := resolve_fvg_top_boundary(_fvg)
        _bottom := resolve_fvg_bottom_boundary(_fvg)
        _fill_level := resolve_fvg_alert_level(_fvg)
        _id := resolve_fvg_id(_fvg)
        _quality := fvg_quality_score(_fvg, fvg_size_threshold)
        _recency := resolve_fvg_recency_index(_fvg)
        _touch_anchor := _best_touch
    [_top, _bottom, _fill_level, _id, _quality, _recency, _touch_anchor, _best_overlap]

[active_bull_ob_top, active_bull_ob_bottom, active_bull_ob_break_level, active_bull_ob_id, active_bull_ob_quality, active_bull_ob_recency, active_bull_ob_touch_anchor, best_bull_ob_overlap] = scan_active_bull_ob()
if state_update_bar_ok and not na(active_bull_ob_id)
    touched_bull_ob_top := active_bull_ob_top
    touched_bull_ob_bottom := active_bull_ob_bottom
    touched_bull_ob_id := active_bull_ob_id
if state_update_bar_ok and not na(active_bull_ob_id) and (na(active_bull_ob_id[1]) or active_bull_ob_id != active_bull_ob_id[1])
    touched_bull_ob_bar_index := bar_index
[active_bull_fvg_top, active_bull_fvg_bottom, active_bull_fvg_fill_level, active_bull_fvg_id, active_bull_fvg_quality, active_bull_fvg_recency, active_bull_fvg_touch_anchor, best_bull_fvg_overlap] = scan_active_bull_fvg()
if state_update_bar_ok and not na(active_bull_fvg_id)
    touched_bull_fvg_top := active_bull_fvg_top
    touched_bull_fvg_bottom := active_bull_fvg_bottom
    touched_bull_fvg_id := active_bull_fvg_id
if state_update_bar_ok and not na(active_bull_fvg_id) and (na(active_bull_fvg_id[1]) or active_bull_fvg_id != active_bull_fvg_id[1])
    touched_bull_fvg_bar_index := bar_index

bool in_bull_ob_zone = not na(active_bull_ob_top) and not na(active_bull_ob_bottom)
bool in_bull_fvg_zone = not na(active_bull_fvg_top) and not na(active_bull_fvg_bottom)
bool prefer_active_ob_zone = not na(active_bull_ob_id)
if not na(active_bull_ob_id) and not na(active_bull_fvg_id)
    prefer_active_ob_zone := prefer_primary_zone(active_bull_ob_touch_anchor, active_bull_ob_recency, active_bull_ob_quality, best_bull_ob_overlap, active_bull_ob_id, active_bull_fvg_touch_anchor, active_bull_fvg_recency, active_bull_fvg_quality, best_bull_fvg_overlap, active_bull_fvg_id)
int active_long_zone_id = na
if not na(active_bull_ob_id) and (na(active_bull_fvg_id) or prefer_active_ob_zone)
    active_long_zone_id := active_bull_ob_id
else if not na(active_bull_fvg_id)
    active_long_zone_id := -active_bull_fvg_id
bool touched_bull_ob_still_active = contains_id(ob_blocks_bull, touched_bull_ob_id)
bool touched_bull_fvg_still_active = contains_id(fvgs_bull, touched_bull_fvg_id)
bool touched_bull_ob_recent = touched_bull_ob_still_active and not na(touched_bull_ob_bar_index) and bar_index - touched_bull_ob_bar_index <= long_signal_window
bool touched_bull_fvg_recent = touched_bull_fvg_still_active and not na(touched_bull_fvg_bar_index) and bar_index - touched_bull_fvg_bar_index <= long_signal_window
OrderBlock touched_bull_ob_block = na
if touched_bull_ob_still_active
    touched_bull_ob_block := get_by_id(ob_blocks_bull, touched_bull_ob_id)
FVG touched_bull_fvg_block = na
if touched_bull_fvg_still_active
    touched_bull_fvg_block := get_by_id(fvgs_bull, touched_bull_fvg_id)
float touched_bull_ob_quality = 0.0
if not na(touched_bull_ob_block)
    touched_bull_ob_quality := ob_quality_score(touched_bull_ob_block)
float touched_bull_fvg_quality = 0.0
if not na(touched_bull_fvg_block)
    touched_bull_fvg_quality := fvg_quality_score(touched_bull_fvg_block, fvg_size_threshold)
bool long_zone_active = in_bull_ob_zone or in_bull_fvg_zone
bool long_zone_active_safe = long_zone_active
int active_long_zone_id_safe = active_long_zone_id
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    long_zone_active_safe := long_zone_active[1]
    active_long_zone_id_safe := active_long_zone_id[1]
bool stretch_watchlist_context_ok_safe = stretch_watchlist_context_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    stretch_watchlist_context_ok_safe := stretch_watchlist_context_ok[1]
var int last_zone_touch_event_bar_index = na
var int last_zone_touch_event_zone_id = na
var int last_ob_zone_touch_bar_index = na
var int last_ob_zone_touch_id = na
var int last_fvg_zone_touch_bar_index = na
var int last_fvg_zone_touch_id = na
bool ob_zone_touch_event = in_bull_ob_zone and (not in_bull_ob_zone[1] or active_bull_ob_id != active_bull_ob_id[1])
bool fvg_zone_touch_event = in_bull_fvg_zone and (not in_bull_fvg_zone[1] or active_bull_fvg_id != active_bull_fvg_id[1])
bool zone_touch_event = ob_zone_touch_event or fvg_zone_touch_event or (long_zone_active and not long_zone_active[1])
if state_update_bar_ok and ob_zone_touch_event
    last_ob_zone_touch_bar_index := bar_index
    last_ob_zone_touch_id := active_bull_ob_id
if state_update_bar_ok and fvg_zone_touch_event
    last_fvg_zone_touch_bar_index := bar_index
    last_fvg_zone_touch_id := active_bull_fvg_id
if state_update_bar_ok and zone_touch_event
    last_zone_touch_event_bar_index := bar_index
    last_zone_touch_event_zone_id := active_long_zone_id
bool zone_touch_event_recent = not na(last_zone_touch_event_bar_index) and bar_index - last_zone_touch_event_bar_index <= long_signal_window
bool ob_zone_touch_event_recent = not na(last_ob_zone_touch_bar_index) and bar_index - last_ob_zone_touch_bar_index <= long_signal_window
bool fvg_zone_touch_event_recent = not na(last_fvg_zone_touch_bar_index) and bar_index - last_fvg_zone_touch_bar_index <= long_signal_window
bool zone_touch_sequence_time_ok = not na(last_zone_touch_event_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_zone_touch_event_bar_index : bar_index > last_zone_touch_event_bar_index)
bool ob_zone_touch_sequence_time_ok = not na(last_ob_zone_touch_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_ob_zone_touch_bar_index : bar_index > last_ob_zone_touch_bar_index)
bool fvg_zone_touch_sequence_time_ok = not na(last_fvg_zone_touch_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_fvg_zone_touch_bar_index : bar_index > last_fvg_zone_touch_bar_index)
bool ob_zone_touch_sequence_ok = ob_zone_touch_event_recent and ob_zone_touch_sequence_time_ok and not na(touched_bull_ob_id) and last_ob_zone_touch_id == touched_bull_ob_id
bool fvg_zone_touch_sequence_ok = fvg_zone_touch_event_recent and fvg_zone_touch_sequence_time_ok and not na(touched_bull_fvg_id) and last_fvg_zone_touch_id == touched_bull_fvg_id
bool generic_zone_touch_sequence_ok = zone_touch_event_recent and zone_touch_sequence_time_ok
bool zone_touch_tracking_active = live_exec ? long_zone_active : long_zone_active_safe
int zone_touch_tracking_id = live_exec ? active_long_zone_id : active_long_zone_id_safe
var int active_zone_touch_count = 0
var int active_zone_touch_id = na
var int last_zone_touch_bar = na
var int active_ob_touch_count = 0
var int active_ob_touch_id = na
var int last_ob_touch_bar = na
var int active_fvg_touch_count = 0
var int active_fvg_touch_id = na
var int last_fvg_touch_bar = na
bool zone_touch_now = zone_touch_tracking_active and not zone_touch_tracking_active[1]
bool ob_touch_now = in_bull_ob_zone and not in_bull_ob_zone[1]
bool fvg_touch_now = in_bull_fvg_zone and not in_bull_fvg_zone[1]
if state_update_bar_ok and zone_touch_now and last_zone_touch_bar != bar_index and not na(zone_touch_tracking_id)
    if zone_touch_tracking_id != active_zone_touch_id
        active_zone_touch_id := zone_touch_tracking_id
        active_zone_touch_count := 1
    else
        active_zone_touch_count += 1
    last_zone_touch_bar := bar_index
if state_update_bar_ok and ob_touch_now and last_ob_touch_bar != bar_index and not na(active_bull_ob_id)
    if active_bull_ob_id != active_ob_touch_id
        active_ob_touch_id := active_bull_ob_id
        active_ob_touch_count := 1
    else
        active_ob_touch_count += 1
    last_ob_touch_bar := bar_index
    touched_bull_ob_touch_count := active_ob_touch_count
if state_update_bar_ok and fvg_touch_now and last_fvg_touch_bar != bar_index and not na(active_bull_fvg_id)
    if active_bull_fvg_id != active_fvg_touch_id
        active_fvg_touch_id := active_bull_fvg_id
        active_fvg_touch_count := 1
    else
        active_fvg_touch_count += 1
    last_fvg_touch_bar := bar_index
    touched_bull_fvg_touch_count := active_fvg_touch_count
bool ob_zone_touch_quality_ok = not block_third_touch_eff or active_ob_touch_count <= max_zone_touches_for_entry
bool fvg_zone_touch_quality_ok = not block_third_touch_eff or active_fvg_touch_count <= max_zone_touches_for_entry
bool zone_touch_quality_ok = not block_third_touch_eff or active_zone_touch_count <= max_zone_touches_for_entry

scan_live_bull_events() =>
    float _ob_alert = last_bull_ob_break_level
    if not na(active_bull_ob_break_level)
        _ob_alert := active_bull_ob_break_level
    float _fvg_alert = last_bull_fvg_fill_level
    if not na(active_bull_fvg_fill_level)
        _fvg_alert := active_bull_fvg_fill_level
    bool _any_ob = array.size(ob_broken_new_bull) > 0
    bool _any_fvg = array.size(filled_fvgs_new_bull) > 0
    OrderBlock _live_broken_ob = _any_ob ? array.get(ob_broken_new_bull, array.size(ob_broken_new_bull) - 1) : na
    float _ob_level = _any_ob ? resolve_ob_alert_level(_live_broken_ob) : _ob_alert
    FVG _live_filled_gap = _any_fvg ? array.get(filled_fvgs_new_bull, array.size(filled_fvgs_new_bull) - 1) : na
    float _fvg_level = _any_fvg ? resolve_fvg_alert_level(_live_filled_gap) : _fvg_alert
    int _best_ob_idx = na
    int _best_fvg_idx = na
    if not _any_ob and array.size(ob_blocks_bull) > 0
        for i = array.size(ob_blocks_bull) - 1 to math.max(0, array.size(ob_blocks_bull) - long_zone_scan_limit)
            _ob_cand = array.get(ob_blocks_bull, i)
            float _ob_cand_level = resolve_ob_alert_level(_ob_cand)
            float _ob_cand_boundary = resolve_ob_bottom_boundary(_ob_cand)
            float _best_ob_boundary = na
            if not na(_best_ob_idx)
                OrderBlock _best_ob = array.get(ob_blocks_bull, _best_ob_idx)
                _best_ob_boundary := resolve_ob_bottom_boundary(_best_ob)
            if low <= _ob_cand_level and (na(_best_ob_idx) or _ob_cand_boundary < _best_ob_boundary)
                _best_ob_idx := i
    if not na(_best_ob_idx)
        _any_ob := true
        OrderBlock _best_live_ob = array.get(ob_blocks_bull, _best_ob_idx)
        _ob_level := resolve_ob_alert_level(_best_live_ob)
    if not _any_fvg and array.size(fvgs_bull) > 0
        for i = array.size(fvgs_bull) - 1 to math.max(0, array.size(fvgs_bull) - long_zone_scan_limit)
            _fvg_cand = array.get(fvgs_bull, i)
            float _fvg_cand_level = resolve_fvg_alert_level(_fvg_cand)
            float _fvg_cand_boundary = resolve_fvg_bottom_boundary(_fvg_cand)
            float _best_fvg_boundary = na
            if not na(_best_fvg_idx)
                FVG _best_fvg = array.get(fvgs_bull, _best_fvg_idx)
                _best_fvg_boundary := resolve_fvg_bottom_boundary(_best_fvg)
            if low <= _fvg_cand_level and (na(_best_fvg_idx) or _fvg_cand_boundary < _best_fvg_boundary)
                _best_fvg_idx := i
    if not na(_best_fvg_idx)
        _any_fvg := true
        FVG _best_live_fvg = array.get(fvgs_bull, _best_fvg_idx)
        _fvg_level := resolve_fvg_alert_level(_best_live_fvg)
    [_any_ob, _ob_level, _any_fvg, _fvg_level]

[any_live_bull_ob_break, bull_ob_live_event_level, any_live_bull_fvg_fill, bull_fvg_live_event_level] = scan_live_bull_events()

compute_context_quality() =>
    int _htf_count = 0
    if mtf_trend_1 > 0
        _htf_count += 1
    if mtf_trend_2 > 0
        _htf_count += 1
    if mtf_trend_3 > 0
        _htf_count += 1
    bool _htf_ok = _htf_count >= 2
    bool _ltf_ok = true
    if use_ltf_for_strict_entry_eff
        _ltf_ok := false
        if strict_ltf_available and ltf_volume_delta >= 0
            _ltf_ok := true
        else if allow_strict_entry_without_ltf and (strict_ltf_unavailable or strict_ltf_unverifiable)
            _ltf_ok := true
    bool _relvol_unavail = false
    if use_rel_volume and not relvol_data_ok and allow_relvol_without_volume_data
        _relvol_unavail := true
    int _vwap_w = 0
    if use_vwap_filter
        _vwap_w := 1
    int _score = 0
    if bullish_trend_safe
        _score += score_weight_structure
    if _htf_ok
        _score += score_weight_htf
    if ema_support_ok
        _score += score_weight_ema
    if adx_strong
        _score += score_weight_adx
    if bull_close_strong
        _score += score_weight_close
    if relvol_score_ok
        _score += score_weight_relvol
    if vwap_filter_ok
        _score += _vwap_w
    int _max = score_weight_structure + score_weight_htf + score_weight_ema + score_weight_adx + score_weight_close + score_weight_relvol + _vwap_w
    int _eff_max = _max
    if _relvol_unavail
        _eff_max -= score_weight_relvol
    int _eff_min = math.min(min_context_quality_score, _eff_max)
    bool _gate_ok = true
    if use_context_quality_score_eff
        _gate_ok := _score >= _eff_min
    [_score, _gate_ok, _htf_ok, _ltf_ok, _eff_min, _eff_max]

compute_bull_reclaim_state() =>
    float _ob_src = live_exec ? high : close
    float _fvg_src = live_exec ? high : close
    float _int_src = live_exec ? high : close
    float _sw_src = live_exec ? high : close
    float _int_level = nz(internal_trail_dn[1], internal_trail_dn)
    float _sw_level = nz(trail_dn[1], trail_dn)
    bool _bar_ok = live_exec ? true : barstate.isconfirmed
    float _ob_top_prev = nz(touched_bull_ob_top[1], touched_bull_ob_top)
    float _fvg_top_prev = nz(touched_bull_fvg_top[1], touched_bull_fvg_top)
    bool _new_ob = not na(touched_bull_ob_id) and (na(touched_bull_ob_id[1]) or touched_bull_ob_id != touched_bull_ob_id[1])
    bool _new_fvg = not na(touched_bull_fvg_id) and (na(touched_bull_fvg_id[1]) or touched_bull_fvg_id != touched_bull_fvg_id[1])
    bool _ob_cross = touched_bull_ob_still_active and not na(touched_bull_ob_top) and _ob_src > touched_bull_ob_top and (_new_ob ? low <= touched_bull_ob_top : nz(_ob_src[1], _ob_src) <= _ob_top_prev)
    bool _fvg_cross = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and _fvg_src > touched_bull_fvg_top and (_new_fvg ? low <= touched_bull_fvg_top : nz(_fvg_src[1], _fvg_src) <= _fvg_top_prev)
    bool _ob_wick = touched_bull_ob_still_active and not na(touched_bull_ob_top) and low <= touched_bull_ob_top and open <= touched_bull_ob_top and _ob_src > touched_bull_ob_top
    bool _fvg_wick = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and low <= touched_bull_fvg_top and open <= touched_bull_fvg_top and _fvg_src > touched_bull_fvg_top
    bool _r_ob = _bar_ok and touched_bull_ob_recent and not na(touched_bull_ob_top) and (_ob_cross or _ob_wick)
    bool _r_fvg = _bar_ok and touched_bull_fvg_recent and not na(touched_bull_fvg_top) and (_fvg_cross or _fvg_wick)
    bool _r_int = _bar_ok and not na(_int_level) and low < _int_level and _int_src > _int_level
    bool _r_sw = _bar_ok and not na(_sw_level) and low < _sw_level and _sw_src > _sw_level
    float _ob_h = na
    if not na(touched_bull_ob_top) and not na(touched_bull_ob_bottom)
        _ob_h := math.max(touched_bull_ob_top - touched_bull_ob_bottom, syminfo.mintick)
    float _fvg_h = na
    if not na(touched_bull_fvg_top) and not na(touched_bull_fvg_bottom)
        _fvg_h := math.max(touched_bull_fvg_top - touched_bull_fvg_bottom, syminfo.mintick)
    float _ob_sweep_lvl = na
    if not na(_ob_h)
        _ob_sweep_lvl := touched_bull_ob_top - _ob_h * effective_ob_reclaim_min_penetration
    float _fvg_sweep_lvl = na
    if not na(_fvg_h)
        _fvg_sweep_lvl := touched_bull_fvg_top - _fvg_h * effective_fvg_reclaim_min_penetration
    bool _ob_sweep = false
    if touched_bull_ob_still_active and not na(_ob_sweep_lvl) and low <= _ob_sweep_lvl
        _ob_sweep := true
    bool _fvg_sweep = false
    if touched_bull_fvg_still_active and not na(_fvg_sweep_lvl) and low <= _fvg_sweep_lvl
        _fvg_sweep := true
    bool _ob_strict = false
    if _r_ob and (not use_strict_sequence_eff or ob_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim_eff or _ob_sweep)
        _ob_strict := true
    bool _fvg_strict = false
    if _r_fvg and (not use_strict_sequence_eff or fvg_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim_eff or _fvg_sweep)
        _fvg_strict := true
    bool _int_strict = false
    if _r_int and (not use_strict_sequence_eff or generic_zone_touch_sequence_ok)
        _int_strict := true
    bool _sw_strict = false
    if _r_sw and (not use_strict_sequence_eff or generic_zone_touch_sequence_ok)
        _sw_strict := true
    bool _any = false
    if _ob_strict or _fvg_strict or _int_strict or _sw_strict
        _any := true
    bool _any_arm = false
    if _ob_strict or _fvg_strict or ((_int_strict or _sw_strict) and long_zone_active)
        _any_arm := true
    [_ob_strict, _fvg_strict, _int_strict, _sw_strict, _any, _any_arm, _int_level, _sw_level, _ob_sweep, _fvg_sweep]

[bull_reclaim_ob_strict, bull_reclaim_fvg_strict, bull_reclaim_internal_low_strict, bull_reclaim_swing_low_strict, bull_reclaim_any, bull_reclaim_any_for_arm, long_reclaim_internal_level, long_reclaim_swing_level, bull_ob_real_sweep, bull_fvg_real_sweep] = compute_bull_reclaim_state()

int zone_since_bars = ta.barssince(zone_touch_event)
int reclaim_since_bars = ta.barssince(bull_reclaim_any)
int internal_choch_since_bars = ta.barssince(internal_bull_choch_sig)
int internal_bos_since_bars = ta.barssince(internal_bull_bos_sig)
int main_bos_since_bars = ta.barssince(bull_bos_sig)

bool zone_recent = false
if not na(zone_since_bars) and zone_since_bars <= long_signal_window
    zone_recent := true
bool reclaim_recent = false
if not na(reclaim_since_bars) and reclaim_since_bars <= long_signal_window
    reclaim_recent := true
bool internal_choch_recent = false
if not na(internal_choch_since_bars) and internal_choch_since_bars <= long_signal_window
    internal_choch_recent := true
bool internal_bos_recent = false
if not na(internal_bos_since_bars) and internal_bos_since_bars <= long_signal_window
    internal_bos_recent := true
bool main_bos_recent = false
if not na(main_bos_since_bars) and main_bos_since_bars <= long_signal_window
    main_bos_recent := true

bool bearish_abort_signal = bear_bos_sig or bear_choch_sig or internal_bear_bos_sig or internal_bear_choch_sig
int bearish_abort_since_bars = ta.barssince(bearish_abort_signal)
bool bearish_abort_recent = false
if not na(bearish_abort_since_bars) and bearish_abort_since_bars <= long_signal_window
    bearish_abort_recent := true
bool long_confirm_bearish_guard_ok = true
if use_strict_confirm_guard
    long_confirm_bearish_guard_ok := not bearish_abort_signal and not bearish_abort_recent

string long_zone_text = 'No Long Zone'
if zone_recent
    long_zone_text := 'Zone touched'
if in_bull_fvg_zone
    long_zone_text := 'In FVG Zone'
if in_bull_ob_zone
    long_zone_text := 'In OB Zone'
if in_bull_ob_zone and in_bull_fvg_zone
    long_zone_text := 'In OB + FVG Zone'

string reclaim_text = 'No Reclaim'
if reclaim_recent
    reclaim_text := 'Reclaim recent'
if bull_reclaim_internal_low_strict
    reclaim_text := 'Internal Low Reclaimed'
if bull_reclaim_swing_low_strict
    reclaim_text := 'Swing Low Reclaimed'
if bull_reclaim_fvg_strict
    reclaim_text := 'FVG Reclaimed'
if bull_reclaim_ob_strict
    reclaim_text := 'OB Reclaimed'

float long_invalidation_buffer = ob_threshold_atr * effective_long_invalidation_atr_mult
float prior_long_trigger_level = nz(ta.highest(high, long_confirm_lookback)[1], high)

// --------------------------------------------------
// Long dip state machine
// 1) stored state
// 2) invalidation rules
// 3) arm setup
// 4) confirm setup
// 5) ready state + visual state
// --------------------------------------------------

bool long_arm_signal = false
bool long_confirm_signal = false
bool long_invalidate_signal = false
string long_setup_text = 'No Setup'
int long_visual_state = 0
string long_visual_text = 'Neutral'
color long_bg_color = na
color long_bar_color = na
int arm_source_kind = LONG_SOURCE_NONE
int long_validation_source = LONG_SOURCE_NONE
string long_setup_source_display = resolve_long_source_text(LONG_SOURCE_NONE)
float arm_invalidation_candidate = low
float arm_trigger_candidate = math.max(high, prior_long_trigger_level)
bool long_confirm_break = false
bool internal_choch_since_arm = false
bool internal_bos_since_arm = false
bool long_confirm_structure_ok = false
bool long_internal_structure_ok = false
bool long_building_state = false
bool long_plan_active = false
float long_stop_level = na
float long_risk_r = na
float long_target_1 = na
float long_target_2 = na
bool long_source_tracked = false
bool long_source_alive = true
bool long_source_lost = false
int arm_backing_zone_kind = LONG_SOURCE_NONE
int arm_backing_zone_id = na
string long_debug_event_source_display = long_setup_source_display
int long_debug_event_touch_count = long_state.backing_zone_touch_count
float long_debug_event_trigger = long_state.trigger
float long_debug_event_invalidation = long_state.invalidation_level

if bull_reclaim_ob_strict
    arm_source_kind := LONG_SOURCE_OB
    arm_invalidation_candidate := touched_bull_ob_bottom
    arm_backing_zone_kind := LONG_SOURCE_OB
    arm_backing_zone_id := touched_bull_ob_id
else if bull_reclaim_fvg_strict
    arm_source_kind := LONG_SOURCE_FVG
    arm_invalidation_candidate := touched_bull_fvg_bottom
    arm_backing_zone_kind := LONG_SOURCE_FVG
    arm_backing_zone_id := touched_bull_fvg_id
else if bull_reclaim_swing_low_strict
    arm_source_kind := LONG_SOURCE_SWING_LOW
    arm_invalidation_candidate := long_reclaim_swing_level
else if bull_reclaim_internal_low_strict
    arm_source_kind := LONG_SOURCE_INTERNAL_LOW
    arm_invalidation_candidate := long_reclaim_internal_level
if arm_source_kind == LONG_SOURCE_SWING_LOW or arm_source_kind == LONG_SOURCE_INTERNAL_LOW
    if in_bull_ob_zone and in_bull_fvg_zone
        bool ob_more_recent = false
        if na(last_fvg_zone_touch_bar_index) or (not na(last_ob_zone_touch_bar_index) and last_ob_zone_touch_bar_index >= last_fvg_zone_touch_bar_index)
            ob_more_recent := true
        arm_backing_zone_kind := LONG_SOURCE_FVG
        arm_backing_zone_id := active_bull_fvg_id
        if ob_more_recent
            arm_backing_zone_kind := LONG_SOURCE_OB
            arm_backing_zone_id := active_bull_ob_id
    else if in_bull_ob_zone
        arm_backing_zone_kind := LONG_SOURCE_OB
        arm_backing_zone_id := active_bull_ob_id
    else if in_bull_fvg_zone
        arm_backing_zone_kind := LONG_SOURCE_FVG
        arm_backing_zone_id := active_bull_fvg_id
    else if touched_bull_ob_recent and not na(touched_bull_ob_id)
        arm_backing_zone_kind := LONG_SOURCE_OB
        arm_backing_zone_id := touched_bull_ob_id
    else if touched_bull_fvg_recent and not na(touched_bull_fvg_id)
        arm_backing_zone_kind := LONG_SOURCE_FVG
        arm_backing_zone_id := touched_bull_fvg_id

// 2) Invalidation
if barstate.isnew
    long_invalidated_this_bar := false

bool close_safe_mode = live_exec or barstate.isconfirmed
int long_setup_age = 0
if long_state.armed and not na(long_state.arm_bar_index)
    long_setup_age := bar_index - long_state.arm_bar_index
int long_confirm_age = 0
if long_state.confirmed and not na(long_state.confirm_bar_index)
    long_confirm_age := bar_index - long_state.confirm_bar_index
bool confirm_is_fresh = false
if long_state.armed and not na(long_state.arm_bar_index) and long_setup_age <= max_bars_arm_to_confirm
    confirm_is_fresh := true
bool ready_is_fresh = false
if long_state.confirmed and not na(long_state.confirm_bar_index) and long_confirm_age <= max_bars_confirm_to_ready
    ready_is_fresh := true
bool micro_setup_fresh_enough = true
if use_microstructure_profiles and micro_is_fast_decay and long_state.armed and not long_state.confirmed
    micro_setup_fresh_enough := long_setup_age <= effective_fast_decay_setup_age_max
bool micro_confirm_fresh_enough = true
if use_microstructure_profiles and micro_is_fast_decay and long_state.confirmed
    micro_confirm_fresh_enough := long_confirm_age <= effective_fast_decay_confirm_age_max
bool micro_freshness_gate_ok = false
if micro_setup_fresh_enough and micro_confirm_fresh_enough
    micro_freshness_gate_ok := true
// Snapshot the currently locked source before any source-upgrade decision.
// A true invalidation of the old source always wins against a same-bar upgrade.
int prev_locked_source_kind = long_state.locked_source_kind
int prev_locked_source_id = long_state.locked_source_id
bool prev_locked_source_tracked = false
if not na(prev_locked_source_id)
    prev_locked_source_tracked := true

OrderBlock prev_locked_bull_ob = na
if prev_locked_source_kind == LONG_SOURCE_OB
    prev_locked_bull_ob := get_by_id(ob_blocks_bull, prev_locked_source_id)
FVG prev_locked_bull_fvg = na
if prev_locked_source_kind == LONG_SOURCE_FVG
    prev_locked_bull_fvg := get_by_id(fvgs_bull, prev_locked_source_id)

float long_locked_source_quality = 0.0
if prev_locked_source_kind == LONG_SOURCE_OB
    long_locked_source_quality := ob_quality_score(prev_locked_bull_ob)
else if prev_locked_source_kind == LONG_SOURCE_FVG
    long_locked_source_quality := fvg_quality_score(prev_locked_bull_fvg, fvg_size_threshold)

bool prev_locked_source_alive = false
if prev_locked_source_kind == LONG_SOURCE_OB
    prev_locked_source_alive := not na(prev_locked_bull_ob)
else if prev_locked_source_kind == LONG_SOURCE_FVG
    prev_locked_source_alive := not na(prev_locked_bull_fvg)

bool prev_locked_source_broken = false
if prev_locked_source_kind == LONG_SOURCE_OB
    prev_locked_source_broken := contains_id(ob_broken_bull, prev_locked_source_id) or contains_id(ob_broken_new_bull, prev_locked_source_id)
else if prev_locked_source_kind == LONG_SOURCE_FVG
    prev_locked_source_broken := contains_id(filled_fvgs_bull, prev_locked_source_id) or contains_id(filled_fvgs_new_bull, prev_locked_source_id)

bool prev_locked_source_lost = false
if (long_state.armed or long_state.confirmed) and prev_locked_source_tracked
    prev_locked_source_lost := not prev_locked_source_alive and not prev_locked_source_broken

bool prev_locked_source_invalid_now = false
if prev_locked_source_tracked
    prev_locked_source_invalid_now := prev_locked_source_broken or prev_locked_source_lost

// A true invalidation of the old source always wins against a same-bar upgrade.
// Only allow an upgrade when the currently locked source is not already invalid on this bar.
bool ob_source_upgrade_ok = false
if allow_armed_source_upgrade and long_state.armed and not long_state.confirmed and not prev_locked_source_invalid_now and bull_reclaim_ob_strict and not na(touched_bull_ob_block)
    if prev_locked_source_kind != LONG_SOURCE_OB or prev_locked_source_id != touched_bull_ob_id
        ob_source_upgrade_ok := touched_bull_ob_quality >= long_locked_source_quality + min_source_upgrade_quality_gain
bool fvg_source_upgrade_ok = false
if allow_armed_source_upgrade and long_state.armed and not long_state.confirmed and not prev_locked_source_invalid_now and bull_reclaim_fvg_strict and not na(touched_bull_fvg_block)
    if prev_locked_source_kind != LONG_SOURCE_FVG or prev_locked_source_id != touched_bull_fvg_id
        fvg_source_upgrade_ok := touched_bull_fvg_quality >= long_locked_source_quality + min_source_upgrade_quality_gain

bool long_source_upgrade_now = false
if ob_source_upgrade_ok or fvg_source_upgrade_ok
    long_source_upgrade_now := true
bool prefer_ob_upgrade = false
if long_source_upgrade_now and ob_source_upgrade_ok
    prefer_ob_upgrade := not fvg_source_upgrade_ok or touched_bull_ob_quality >= touched_bull_fvg_quality
string long_source_upgrade_reason = resolve_long_upgrade_reason(long_source_upgrade_now, prefer_ob_upgrade, ob_source_upgrade_ok, fvg_source_upgrade_ok, touched_bull_ob_quality, touched_bull_fvg_quality, long_locked_source_quality)

[long_locked_source_kind_final, long_locked_source_id_final, long_setup_backing_zone_kind_final, long_setup_backing_zone_id_final] = stage_locked_source_transition(long_source_upgrade_now, prefer_ob_upgrade, prev_locked_source_kind, prev_locked_source_id, long_state.backing_zone_kind, long_state.backing_zone_id, touched_bull_ob_id, touched_bull_fvg_id)
int long_locked_source_touch_count_effective = select_locked_source_touch_count(long_source_upgrade_now, prefer_ob_upgrade, touched_bull_ob_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_touch_count, touched_bull_fvg_id, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_touch_count, long_state.locked_source_touch_count)
int long_locked_source_last_touch_bar_index_effective = long_state.locked_source_last_touch_bar_index
if long_source_upgrade_now and not na(long_locked_source_id_final)
    long_locked_source_last_touch_bar_index_effective := bar_index
bool long_locked_source_alive_now = false
if long_locked_source_kind_final == LONG_SOURCE_OB
    long_locked_source_alive_now := contains_id(ob_blocks_bull, long_locked_source_id_final)
else if long_locked_source_kind_final == LONG_SOURCE_FVG
    long_locked_source_alive_now := contains_id(fvgs_bull, long_locked_source_id_final)
float long_locked_source_top_now = resolve_long_zone_top(long_locked_source_kind_final, long_locked_source_id_final, active_bull_ob_id, active_bull_ob_top, touched_bull_ob_id, touched_bull_ob_top, active_bull_fvg_id, active_bull_fvg_top, touched_bull_fvg_id, touched_bull_fvg_top, long_locked_source_alive_now and not long_source_upgrade_now, prev_locked_source_kind, prev_locked_source_id, long_state.locked_source_top)
float long_locked_source_bottom_now = resolve_long_zone_bottom(long_locked_source_kind_final, long_locked_source_id_final, active_bull_ob_id, active_bull_ob_bottom, touched_bull_ob_id, touched_bull_ob_bottom, active_bull_fvg_id, active_bull_fvg_bottom, touched_bull_fvg_id, touched_bull_fvg_bottom, long_locked_source_alive_now and not long_source_upgrade_now, prev_locked_source_kind, prev_locked_source_id, long_state.locked_source_bottom)
bool long_locked_source_in_zone = false
if long_locked_source_alive_now and not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now)
    long_locked_source_in_zone := math.min(high, long_locked_source_top_now) - math.max(low, long_locked_source_bottom_now) >= 0
bool long_locked_source_touch_now = false
if long_locked_source_in_zone
    long_locked_source_touch_now := not long_locked_source_in_zone[1] or long_locked_source_id_final != long_locked_source_id_final[1] or long_locked_source_kind_final != long_locked_source_kind_final[1]
if state_update_bar_ok and (long_state.armed or long_state.confirmed) and long_locked_source_touch_now and long_locked_source_last_touch_bar_index_effective != bar_index and not na(long_locked_source_id_final)
    long_locked_source_touch_count_effective += 1
    long_locked_source_last_touch_bar_index_effective := bar_index
bool long_locked_source_touch_recent = false
if (long_state.armed or long_state.confirmed) and not na(long_locked_source_last_touch_bar_index_effective)
    long_locked_source_touch_recent := bar_index - long_locked_source_last_touch_bar_index_effective <= long_signal_window
float long_locked_source_zone_height = na
if not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now)
    long_locked_source_zone_height := math.max(long_locked_source_top_now - long_locked_source_bottom_now, syminfo.mintick)
float long_locked_ob_required_sweep_level = na
if long_locked_source_kind_final == LONG_SOURCE_OB and not na(long_locked_source_zone_height)
    long_locked_ob_required_sweep_level := long_locked_source_top_now - long_locked_source_zone_height * effective_ob_reclaim_min_penetration
float long_locked_fvg_required_sweep_level = na
if long_locked_source_kind_final == LONG_SOURCE_FVG and not na(long_locked_source_zone_height)
    long_locked_fvg_required_sweep_level := long_locked_source_top_now - long_locked_source_zone_height * effective_fvg_reclaim_min_penetration
bool long_locked_ob_real_sweep = false
if long_locked_source_kind_final == LONG_SOURCE_OB and long_locked_source_alive_now and not na(long_locked_ob_required_sweep_level)
    long_locked_ob_real_sweep := low <= long_locked_ob_required_sweep_level
bool long_locked_fvg_real_sweep = false
if long_locked_source_kind_final == LONG_SOURCE_FVG and long_locked_source_alive_now and not na(long_locked_fvg_required_sweep_level)
    long_locked_fvg_real_sweep := low <= long_locked_fvg_required_sweep_level
float long_locked_source_top_effective = long_state.locked_source_top
if long_locked_source_alive_now
    long_locked_source_top_effective := long_locked_source_top_now
float long_locked_source_bottom_effective = long_state.locked_source_bottom
if long_locked_source_alive_now
    long_locked_source_bottom_effective := long_locked_source_bottom_now
if long_state.armed or long_state.confirmed or long_source_upgrade_now
    long_state.sync_locked_tracking(long_setup_backing_zone_kind_final, long_setup_backing_zone_id_final, long_locked_source_kind_final, long_locked_source_id_final, long_locked_source_top_effective, long_locked_source_bottom_effective, long_locked_source_touch_count_effective, long_locked_source_last_touch_bar_index_effective)
long_source_tracked := false
if not na(long_state.locked_source_id)
    long_source_tracked := true
long_source_alive := true
if long_source_tracked
    long_source_alive := long_locked_source_alive_now
bool long_source_broken = false
if long_locked_source_kind_final == LONG_SOURCE_OB
    long_source_broken := contains_id(ob_broken_bull, long_locked_source_id_final) or contains_id(ob_broken_new_bull, long_locked_source_id_final)
else if long_locked_source_kind_final == LONG_SOURCE_FVG
    long_source_broken := contains_id(filled_fvgs_bull, long_locked_source_id_final) or contains_id(filled_fvgs_new_bull, long_locked_source_id_final)
long_source_lost := false
if (long_state.armed or long_state.confirmed) and long_source_tracked
    long_source_lost := not long_source_alive and not long_source_broken
bool long_setup_expired = false
if long_state.armed and not long_state.confirmed
    long_setup_expired := long_setup_age > long_setup_expiry_bars
bool long_confirm_expired = false
if long_state.confirmed
    long_confirm_expired := long_confirm_age > long_confirm_expiry_bars
float long_invalidation_break_src = close
if live_exec and effective_use_live_invalidation_break
    long_invalidation_break_src := low
bool long_broken_down = false
if not na(long_state.invalidation_level)
    long_broken_down := long_invalidation_break_src < long_state.invalidation_level - long_invalidation_buffer
bool long_invalidated_now = false
if long_source_broken or long_source_lost
    long_invalidated_now := true
if close_safe_mode
    long_invalidated_now := long_invalidated_now or long_broken_down or long_setup_expired or long_confirm_expired
bool invalidated_prior_setup = false
int long_validation_source_now = resolve_long_validation_source(long_locked_source_kind_final)
string long_setup_source_display_now = compose_long_setup_source_display(long_state.entry_origin_source, long_validation_source_now)

if long_invalidated_now
    long_debug_event_source_display := long_setup_source_display_now
    long_debug_event_touch_count := long_state.backing_zone_touch_count
    long_debug_event_trigger := long_state.trigger
    long_debug_event_invalidation := long_state.invalidation_level
    string long_invalidation_reason = resolve_long_invalidation_reason(long_source_broken, long_source_lost, long_setup_expired, long_confirm_expired, long_validation_source_now, long_state.entry_origin_source, long_setup_source_display_now)
    long_invalidate_signal := long_state.armed or long_state.confirmed
    invalidated_prior_setup := long_invalidate_signal
    long_invalidated_this_bar := long_invalidate_signal
    long_state.invalidate(long_invalidation_reason, long_state.invalidation_level)

// 3) Arm setup
bool armed_prequality_ok = true
if tighten_armed_stage_eff
    armed_prequality_ok := bullish_trend_safe and micro_session_gate_ok and zone_touch_quality_ok and bull_close_strong and ema_support_ok
if bull_reclaim_any_for_arm and (use_strict_sequence_eff ? zone_touch_event_recent : zone_recent) and not long_state.armed and not long_invalidated_this_bar and micro_session_gate_ok and sd_armed_gate_ok and armed_prequality_ok
    int long_arm_backing_zone_touch_count = select_long_arm_backing_zone_touch_count(arm_backing_zone_kind, arm_backing_zone_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_id, touched_bull_ob_touch_count, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_id, touched_bull_fvg_touch_count)
    int long_arm_locked_source_id = resolve_long_zone_id(arm_backing_zone_kind, arm_backing_zone_id)
    float long_arm_locked_source_top = resolve_long_zone_top(arm_backing_zone_kind, arm_backing_zone_id, active_bull_ob_id, active_bull_ob_top, touched_bull_ob_id, touched_bull_ob_top, active_bull_fvg_id, active_bull_fvg_top, touched_bull_fvg_id, touched_bull_fvg_top)
    float long_arm_locked_source_bottom = resolve_long_zone_bottom(arm_backing_zone_kind, arm_backing_zone_id, active_bull_ob_id, active_bull_ob_bottom, touched_bull_ob_id, touched_bull_ob_bottom, active_bull_fvg_id, active_bull_fvg_bottom, touched_bull_fvg_id, touched_bull_fvg_bottom)
    int long_arm_locked_source_last_touch_bar_index = na
    if not na(long_arm_locked_source_id)
        long_arm_locked_source_last_touch_bar_index := bar_index
    long_arm_signal := true
    long_state.arm(bar_index, arm_trigger_candidate, arm_invalidation_candidate, arm_source_kind, arm_backing_zone_kind, arm_backing_zone_id, long_arm_backing_zone_touch_count, arm_backing_zone_kind, long_arm_locked_source_id, long_arm_locked_source_top, long_arm_locked_source_bottom, long_arm_backing_zone_touch_count, long_arm_locked_source_last_touch_bar_index)

// 4) Confirm setup
float long_confirm_break_src = close
if live_exec and effective_use_live_confirm_break
    long_confirm_break_src := high
long_confirm_break := false
if long_state.armed and not long_state.confirmed and not na(long_state.arm_bar_index) and bar_index > long_state.arm_bar_index
    long_confirm_break := long_confirm_break_src > long_state.trigger
internal_choch_since_arm := false
if long_state.armed and not na(long_state.arm_bar_index) and not na(internal_choch_since_bars)
    internal_choch_since_arm := internal_choch_since_bars <= bar_index - long_state.arm_bar_index
internal_bos_since_arm := false
if long_state.armed and not na(long_state.arm_bar_index) and not na(internal_bos_since_bars)
    internal_bos_since_arm := internal_bos_since_bars <= bar_index - long_state.arm_bar_index
long_internal_structure_ok := false
if internal_bull_choch_sig or internal_bull_bos_sig or internal_choch_since_arm or internal_bos_since_arm
    long_internal_structure_ok := true
if long_internal_structure_mode == 'Internal CHoCH only'
    long_internal_structure_ok := false
    if internal_bull_choch_sig or internal_choch_since_arm
        long_internal_structure_ok := true
long_confirm_structure_ok := not require_internal_break_for_confirm_eff
if not long_confirm_structure_ok
    long_confirm_structure_ok := long_internal_structure_ok

// 5) Ready state + visuals
long_plan_active := false
if (long_state.armed or long_state.confirmed) and not na(long_state.trigger) and not na(long_state.invalidation_level)
    long_plan_active := true

compute_overhead_context() =>
    float _stop = na
    if long_plan_active
        _stop := long_state.invalidation_level - ob_threshold_atr * stop_buffer_atr_mult
    float _scan_ref = close
    if long_plan_active and not na(long_state.trigger)
        _scan_ref := long_state.trigger
    float _bear_ob_lvl = na
    if array.size(ob_blocks_bear) > 0
        for i = array.size(ob_blocks_bear) - 1 to bear_ob_scan_start
            _blocker = array.get(ob_blocks_bear, i)
            float _blvl = resolve_ob_alert_level(_blocker)
            if not na(_blvl) and _blvl >= _scan_ref and (na(_bear_ob_lvl) or _blvl < _bear_ob_lvl)
                _bear_ob_lvl := _blvl
    float _bear_fvg_lvl = na
    if array.size(fvgs_bear) > 0
        for i = array.size(fvgs_bear) - 1 to bear_fvg_scan_start
            _fblocker = array.get(fvgs_bear, i)
            float _flvl = resolve_fvg_alert_level(_fblocker)
            if not na(_flvl) and _flvl >= _scan_ref and (na(_bear_fvg_lvl) or _flvl < _bear_fvg_lvl)
                _bear_fvg_lvl := _flvl
    float _overhead = na
    if not na(_bear_ob_lvl) and not na(_bear_fvg_lvl)
        _overhead := math.min(_bear_ob_lvl, _bear_fvg_lvl)
    else
        _overhead := _bear_fvg_lvl
        if not na(_bear_ob_lvl)
            _overhead := _bear_ob_lvl
    float _risk = na
    if long_plan_active and not na(_stop)
        _risk := math.max(long_state.trigger - _stop, syminfo.mintick)
    float _headroom = na
    if not na(_overhead) and long_plan_active
        _headroom := _overhead - long_state.trigger
    bool _overhead_ok = true
    if use_overhead_zone_filter_eff and not na(_headroom) and not na(_risk)
        _overhead_ok := _headroom >= _risk * min_headroom_r
    [_stop, _risk, _headroom, _overhead_ok]

[long_planned_stop_level, planned_risk, headroom_to_overhead, overhead_zone_ok] = compute_overhead_context()
[context_quality_score, context_quality_gate_ok, htf_alignment_ok, strict_entry_ltf_ok, effective_min_context_quality_score, effective_context_quality_max_score] = compute_context_quality()
// [v5.5b] Signal Quality is the primary quality surface; local context quality stays diagnostic only.
bool primary_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_ok
bool best_signal_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_good
bool strict_signal_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_high
// [v5.5b] Lean Context Gates: optional consensus layer on top of the primary Signal Quality gate.
if use_lean_context_gates
    int lean_context_count = 0
    if session_light_ok
        lean_context_count += 1
    if struct_light_trending
        lean_context_count += 1
    if ob_light_bull_ok
        lean_context_count += 1
    if fvg_light_active_ok
        lean_context_count += 1
    // Require at least 2 of 4 lean context gates to pass (soft consensus)
    bool lean_context_consensus_ok = lean_context_count >= 2
    primary_quality_gate_ok := primary_quality_gate_ok and lean_context_consensus_ok
[environment_hard_gate_ok, quality_gate_ok, microstructure_entry_gate_ok, trade_hard_gate_ok, long_environment_focus_display] = compute_long_environment_context(market_regime_gate_ok, vola_regime_gate_safe, primary_quality_gate_ok, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, event_risk_gate_ok)
string freshness_text = describe_long_freshness(long_state.armed, long_state.confirmed, ready_is_fresh, confirm_is_fresh)
string source_state_text = describe_long_source_state(long_source_tracked, long_source_alive, long_source_broken)
long_validation_source := resolve_long_validation_source(long_state.locked_source_kind)
long_setup_source_display := compose_long_setup_source_display(long_state.entry_origin_source, long_validation_source)
int effective_long_active_touch_count = select_effective_long_touch_count(long_state.armed, long_state.confirmed, long_state.backing_zone_touch_count, bull_reclaim_ob_strict, in_bull_ob_zone, in_bull_fvg_zone, active_ob_touch_count, bull_reclaim_fvg_strict, active_fvg_touch_count, active_zone_touch_count)
bool effective_zone_touch_quality_ok = true
if block_third_touch_eff
    effective_zone_touch_quality_ok := effective_long_active_touch_count <= max_zone_touches_for_entry
bool setup_hard_gate_ok = effective_zone_touch_quality_ok
string zone_quality_text = describe_long_zone_quality(long_zone_active, long_state.armed, long_state.confirmed, effective_long_active_touch_count)

compute_alert_text_suffixes() =>
    string _overhead = 'off'
    if use_overhead_zone_filter_eff
        _overhead := 'clear'
        if not na(headroom_to_overhead) and not na(planned_risk)
            _overhead := str.tostring(headroom_to_overhead / planned_risk, '#.##') + 'R'
    string _score = ' | sq=' + str.tostring(lib_sq_score) + '/' + lib_sq_tier
    string _strict = ''
    if use_strict_sequence_eff or use_strict_sweep_for_zone_reclaim_eff or use_strict_confirm_guard
        _strict := ' | strict=on'
    string _env = ' | env=' + long_environment_focus_display + ' | overhead=' + _overhead
    string _micro = ''
    if use_microstructure_profiles
        _micro := ' | micro=' + micro_profile_text + ' | freshness=' + freshness_text + ' | source=' + source_state_text + ' | zone=' + zone_quality_text
    [_overhead, _score, _strict, _env, _micro]

[overhead_text, long_score_detail_suffix, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix] = compute_alert_text_suffixes()
bool confirm_hard_gate_ok = false
if micro_session_gate_ok and micro_freshness_gate_ok
    confirm_hard_gate_ok := true
bool confirm_upgrade_gate_ok = false
if accel_confirm_gate_ok and sd_confirmed_gate_ok
    confirm_upgrade_gate_ok := true
bool confirm_lifecycle_ok = false
if close_safe_mode and long_confirm_break and long_confirm_structure_ok and confirm_is_fresh and long_confirm_bearish_guard_ok
    confirm_lifecycle_ok := true
bool confirm_filters_ok = false
if confirm_hard_gate_ok and confirm_upgrade_gate_ok
    confirm_filters_ok := true
if confirm_lifecycle_ok and confirm_filters_ok
    long_state.confirm(bar_index)
    long_confirm_signal := true

bool long_setup_in_progress = false
if long_state.armed and not long_state.confirmed
    long_setup_in_progress := true
long_building_state := false
if long_state.armed and long_internal_structure_ok and not long_state.confirmed
    long_building_state := true
bool ready_bar_gap_ok = false
if not na(long_state.confirm_bar_index)
    ready_bar_gap_ok := bar_index > long_state.confirm_bar_index
// [v5.5] Scoring over Blocking: when enabled, SCORING-class gates bypass Ready (still apply at Best/Strict)
bool scoring_accel_ready  = use_scoring_over_blocking ? true : accel_ready_gate_ok
bool scoring_sd_ready     = use_scoring_over_blocking ? true : sd_ready_gate_ok
bool scoring_vol_ready    = use_scoring_over_blocking ? true : vol_ready_context_ok
bool scoring_stretch_ready = use_scoring_over_blocking ? true : stretch_ready_context_ok
bool scoring_ddvi_ready   = use_scoring_over_blocking ? true : ddvi_ready_ok_safe
// [v5.5] Count scoring gate failures as quality tier penalty
int scoring_penalty_count = 0
if use_scoring_over_blocking
    if not accel_ready_gate_ok
        scoring_penalty_count += 1
    if not sd_ready_gate_ok
        scoring_penalty_count += 1
    if not vol_ready_context_ok
        scoring_penalty_count += 1
    if not stretch_ready_context_ok
        scoring_penalty_count += 1
    if not ddvi_ready_ok_safe
        scoring_penalty_count += 1
[lifecycle_ready_ok, long_ready_state] = compute_long_ready_state(close_safe_mode, long_state.confirmed, ready_bar_gap_ok, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready_eff, bull_bos_sig, main_bos_recent, setup_hard_gate_ok, trade_hard_gate_ok, environment_hard_gate_ok, quality_gate_ok, scoring_accel_ready, scoring_sd_ready, scoring_vol_ready, scoring_stretch_ready, scoring_ddvi_ready)
bool long_entry_best_state = compute_long_entry_best_state(long_ready_state, best_signal_quality_gate_ok, accel_entry_best_gate_ok, sd_entry_best_gate_ok, vol_entry_best_context_ok_safe, stretch_entry_best_context_ok, ddvi_entry_best_ok_safe)
bool long_entry_strict_state = compute_long_entry_strict_state(long_ready_state, strict_signal_quality_gate_ok, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)
string long_ready_blocker_text = resolve_long_ready_blocker_text(long_ready_state, long_state.confirmed, close_safe_mode, ready_bar_gap_ok, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready_eff, bull_bos_sig, main_bos_recent, setup_hard_gate_ok, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, market_regime_gate_ok, vola_regime_gate_safe, quality_gate_ok, scoring_accel_ready, scoring_sd_ready, scoring_vol_ready, scoring_stretch_ready, scoring_ddvi_ready)
string long_strict_blocker_text = resolve_long_strict_blocker_text(long_entry_strict_state, long_ready_state, long_ready_blocker_text, strict_signal_quality_gate_ok, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)
// Clean is a diagnostic alert/dashboard tier, not lifecycle progression.
bool long_quality_clean_tier = false
if close_safe_mode and bullish_trend_safe and zone_recent and reclaim_recent and long_state.confirmed and setup_hard_gate_ok and trade_hard_gate_ok and environment_hard_gate_ok and quality_gate_ok and bull_close_strong and ema_support_ok and adx_strong and relvol_ok and vwap_filter_ok
    long_quality_clean_tier := true
if long_plan_active
    long_stop_level := long_planned_stop_level
    long_risk_r := math.max(long_state.trigger - long_stop_level, syminfo.mintick)
    long_target_1 := long_state.trigger + long_risk_r * target1_r
    long_target_2 := long_state.trigger + long_risk_r * target2_r

float long_mean_target = na
if long_plan_active and show_mean_target_overlay_eff and not na(stretch_mean)
    if stretch_mean > long_state.trigger
        long_mean_target := stretch_mean

varip int long_ready_state_rt_prev = 0
varip bool long_ready_fired_this_bar = false
if barstate.isnew
    long_ready_state_rt_prev := 0
    if long_ready_state[1]
        long_ready_state_rt_prev := 1
    long_ready_fired_this_bar := false
bool long_ready_signal = false
if long_ready_state and long_ready_state_rt_prev == 0 and not long_ready_fired_this_bar
    long_ready_signal := true
if long_ready_signal
    long_ready_fired_this_bar := true
long_ready_state_rt_prev := 0
if long_ready_state
    long_ready_state_rt_prev := 1

long_setup_text := compose_long_setup_text(long_zone_active, long_state.armed, long_building_state, long_state.confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidated_now, invalidated_prior_setup, long_invalidated_this_bar, long_setup_source_display)

long_visual_state := resolve_long_visual_state(long_zone_active, long_state.armed, long_building_state, long_state.confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidate_signal, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)


// Lifecycle axis stays pure. Quality is shown in separate dashboard rows.
long_visual_text := resolve_long_visual_text(long_visual_state)
long_bg_color := resolve_long_bg_color(long_visual_state, long_color_building)
long_bar_color := resolve_long_bar_color(long_visual_state, long_color_building)
validate_long_state(long_state, show_long_engine_debug_eff)

emit_long_engine_debug_logs() =>
    string _src = long_setup_source_display
    if long_invalidate_signal
        _src := long_debug_event_source_display
    int _tc = long_state.backing_zone_touch_count
    if long_invalidate_signal
        _tc := long_debug_event_touch_count
    float _trg = long_state.trigger
    if long_invalidate_signal
        _trg := long_debug_event_trigger
    float _inv = long_state.invalidation_level
    if long_invalidate_signal
        _inv := long_debug_event_invalidation
    string _summary = compose_long_debug_summary_text(long_engine_debug_mode_eff, long_state.armed, long_state.confirmed, long_ready_state, long_setup_source_display, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_state.backing_zone_touch_count, long_source_upgrade_now, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text)
    if show_long_engine_debug_eff and long_source_upgrade_now
        log.info('{0}', compose_long_engine_event_log(long_engine_debug_mode_eff, 'LONG UPGRADE', _src, _trg, _inv, _tc, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, true, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text))
    if show_long_engine_debug_eff and long_arm_signal
        log.info('{0}', compose_long_engine_event_log(long_engine_debug_mode_eff, 'LONG ARMED', _src, _trg, _inv, _tc, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_source_upgrade_now, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text))
    if show_long_engine_debug_eff and long_confirm_signal
        log.info('{0}', compose_long_engine_event_log(long_engine_debug_mode_eff, 'LONG CONFIRMED', _src, _trg, _inv, _tc, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_source_upgrade_now, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text))
    if show_long_engine_debug_eff and long_ready_signal
        log.info('{0}', compose_long_engine_event_log(long_engine_debug_mode_eff, 'LONG READY', _src, _trg, _inv, _tc, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_source_upgrade_now, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text))
    if show_long_engine_debug_eff and long_invalidate_signal
        log.info('{0}', compose_long_engine_event_log(long_engine_debug_mode_eff, 'LONG INVALID', _src, _trg, _inv, _tc, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_source_upgrade_now, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text))
    _summary

string long_debug_summary_text = emit_long_engine_debug_logs()

if live_exec
    if not live_bull_ob_break and any_live_bull_ob_break
        live_bull_ob_break := true
    if not live_bull_fvg_fill and any_live_bull_fvg_fill
        live_bull_fvg_fill := true

plot(long_zone_active ? 1.0 : 0.0, 'BUS ZoneActive', display = display.none)
plot(long_state.armed ? 1.0 : 0.0, 'BUS Armed', display = display.none)
plot(long_state.confirmed ? 1.0 : 0.0, 'BUS Confirmed', display = display.none)
plot(long_ready_state ? 1.0 : 0.0, 'BUS Ready', display = display.none)
plot(long_entry_best_state ? 1.0 : 0.0, 'BUS EntryBest', display = display.none)
plot(long_entry_strict_state ? 1.0 : 0.0, 'BUS EntryStrict', display = display.none)
plot(long_state.trigger, 'BUS Trigger', display = display.none)
plot(long_state.invalidation_level, 'BUS Invalidation', display = display.none)
plot(lib_sq_score, 'BUS QualityScore', display = display.none)
plot(long_validation_source, 'BUS SourceKind', display = display.none)
plot(long_visual_state, 'BUS StateCode', display = display.none)
plot(pack_bus_trend_set(structure_display_trend, mtf_trend_1, mtf_trend_2, mtf_trend_3), 'BUS TrendPack', display = display.none)
plot(pack_bus_meta(resolve_bus_freshness_code(long_state.armed, long_state.confirmed, ready_is_fresh, confirm_is_fresh), resolve_bus_source_state_code(long_source_tracked, long_source_alive, long_source_broken), resolve_bus_reclaim_code(reclaim_recent, bull_reclaim_internal_low_strict, bull_reclaim_swing_low_strict, bull_reclaim_fvg_strict, bull_reclaim_ob_strict), resolve_bus_zone_code(long_zone_active, in_bull_ob_zone, in_bull_fvg_zone)), 'BUS MetaPack', display = display.none)
plot(pack_bus_four(resolve_bus_session_row(intraday_time_chart, use_trade_session_gate, use_opening_range_gate, session_structure_gate_ok, session_gate_ok), resolve_bus_market_row(use_index_gate, use_sector_gate, use_breadth_symbol_gate, market_symbols_missing, block_on_missing_market_symbol, market_regime_gate_ok, index_gate_effective_ok, sector_gate_effective_ok), resolve_bus_vola_row(use_vola_compression_gate, vola_regime_gate_safe, vola_expansion_now, vola_compression_recent), resolve_bus_micro_session_row(use_microstructure_profiles, intraday_time_chart, micro_session_gate_ok, micro_rth_gate_ok, micro_midday_gate_ok, micro_premarket_gate_ok)), 'BUS HardGatesPackA', display = display.none)
plot(pack_bus_four(resolve_bus_micro_fresh_row(use_microstructure_profiles, micro_freshness_gate_ok), resolve_bus_volume_data_row(volume_current_bar_ok, volume_feed_quality_ok, ltf_sampling_active, ltf_price_ok, ltf_volume_ok, ltf_price_only), resolve_bus_quality_env_row(environment_hard_gate_ok, market_regime_gate_ok, vola_regime_gate_safe), resolve_bus_quality_strict_row(long_entry_strict_state, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)), 'BUS HardGatesPackB', display = display.none)
plot(resolve_bus_event_risk_row(event_risk_gate_ok, not event_risk_gate_ok, event_risk_state == "caution", lib_erl_market_blocked, lib_erl_symbol_blocked, lib_erl_window_state, lib_erl_level), 'BUS EventRiskRow', display = display.none)
plot(pack_bus_four(resolve_bus_close_strength_row(use_strong_close_filter, bull_close_strong), resolve_bus_ema_support_row(show_ema_support, ema_support_ok), resolve_bus_adx_row(use_adx, adx_data_ok, plus_di, minus_di, adx_strong, adx_value, adx_trend_min), resolve_bus_relvol_row(use_rel_volume, relvol_data_ok, allow_relvol_without_volume_data, relvol_ok)), 'BUS QualityPackA', display = display.none)
plot(pack_bus_four(resolve_bus_vwap_row(use_vwap_filter, intraday_time_chart, vwap_session_active, vwap_filter_ok), resolve_bus_context_quality_row(use_context_quality_score_eff, context_quality_gate_ok), resolve_bus_quality_clean_row(long_quality_clean_tier), resolve_bus_quality_score_row(lib_sq_score)), 'BUS QualityPackB', display = display.none)
plot(25.0 * 1000.0 + 100.0, 'BUS QualityBoundsPack', display = display.none)
plot(pack_bus_four(resolve_bus_sd_confluence_row(use_sd_confluence, sd_support_both_recent, sd_bullish_divergence_recent, sd_higher_lows_recent, sd_support_any_recent), resolve_bus_sd_osc_row(use_sd_confluence, sd_value, sd_above_zero, sd_rising, sd_below_zero, sd_falling), resolve_bus_vol_regime_row(use_volatility_regime, vol_regime_trend_ok), resolve_bus_vol_squeeze_row(use_volatility_regime, vol_squeeze_on, vol_squeeze_release_recent, vol_squeeze_recent)), 'BUS ModulePackA', display = display.none)
plot(pack_bus_four(resolve_bus_vol_expand_row(use_volatility_regime, vol_momentum_expanding_long, vol_stack_spread_rising), resolve_bus_stretch_row(use_stretch_context, distance_to_mean_z, in_lower_extreme, lower_extreme_recent, anti_chase_ok_entry_best, anti_chase_ok_ready), resolve_bus_ddvi_row(use_ddvi_context, ddvi_bias_ok, ddvi_bull_divergence_any, ddvi_lower_extreme_context), resolve_bus_ltf_bias_row(show_dashboard_ltf_eff, ltf_sampling_active, ltf_price_ok, ltf_price_only, ltf_bull_share, ltf_bias_hint)), 'BUS ModulePackB', display = display.none)
plot(pack_bus_four(resolve_bus_ltf_delta_row(show_dashboard_ltf_eff, ltf_sampling_active, ltf_price_only, ltf_volume_delta), resolve_bus_objects_row(array.size(ob_blocks_bull), array.size(fvgs_bull)), resolve_bus_swing_row(bullish_trend_safe, bearish_trend_safe), resolve_bus_micro_profile_row(use_microstructure_profiles, micro_profile_text, micro_modifier_text)), 'BUS ModulePackC', display = display.none)
plot(pack_bus_four(resolve_bus_zone_row(long_zone_active, in_bull_ob_zone, in_bull_fvg_zone), resolve_bus_long_triggers_row(long_plan_active), resolve_bus_risk_plan_row(long_plan_active), resolve_bus_debug_flags_row(show_ob_debug_eff, show_fvg_debug_eff, show_long_engine_debug_eff)), 'BUS ModulePackD', display = display.none)
plot(pack_bus_four(resolve_bus_ready_gate_row(long_ready_state, long_state.confirmed, lifecycle_ready_ok, setup_hard_gate_ok, trade_hard_gate_ok, environment_hard_gate_ok, close_safe_mode, ready_bar_gap_ok, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready_eff, bull_bos_sig, main_bos_recent, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, market_regime_gate_ok, vola_regime_gate_safe, quality_gate_ok, accel_ready_gate_ok, sd_ready_gate_ok, vol_ready_context_ok, stretch_ready_context_ok, ddvi_ready_ok_safe), resolve_bus_strict_gate_row(long_entry_strict_state, long_ready_state, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe), resolve_bus_debug_state_row(show_long_engine_debug, long_visual_state, long_state.armed, long_state.confirmed, long_ready_state), resolve_bus_micro_modifier_mask(micro_modifier_text)), 'BUS EnginePack', display = display.none)
plot(long_stop_level, 'BUS StopLevel', display = display.none)
plot(long_target_1, 'BUS Target1', display = display.none)
plot(long_target_2, 'BUS Target2', display = display.none)
// ── v5.5 Lean BUS Plots ──
plot(pack_bus_four(resolve_bus_signal_quality_row(lib_sq_score, lib_sq_tier), resolve_bus_signal_freshness_row(lib_sq_freshness, lib_sq_bias_alignment), resolve_bus_event_risk_light_row(lib_erl_window_state, lib_erl_level, lib_erl_market_blocked, lib_erl_symbol_blocked), resolve_bus_struct_light_row(lib_strl_trend_strength, lib_strl_fresh, lib_strl_last_event)), 'BUS LeanPackA', display = display.none)
plot(pack_bus_four(resolve_bus_ob_light_row(lib_obl_side, lib_obl_fresh, lib_obl_mitigation_state), resolve_bus_fvg_light_row(lib_fvgl_side, lib_fvgl_fresh, lib_fvgl_invalidated), pack_bus_row(lib_scl_context_score, lib_scl_in_killzone ? 1 : 2), pack_bus_row(lib_sq_score, 0)), 'BUS LeanPackB', display = display.none)

// ── Mini Health Badge (v5.5a) ──
var label health_badge = na
if barstate.islast and show_dashboard
    if not na(health_badge)
        label.delete(health_badge)
    string dir_icon   = lib_sq_bias_alignment == "bull" ? "▲" : lib_sq_bias_alignment == "bear" ? "▼" : "◆"
    string tier_icon  = lib_sq_tier == "high" ? "🟢" : lib_sq_tier == "good" ? "🟡" : lib_sq_tier == "ok" ? "🟠" : "🔴"
    string event_icon = event_risk_state == "blocked" ? "⛔" : event_risk_state == "caution" ? "⚡" : "✓"
    string fresh_icon = lib_sq_freshness == "fresh" ? "●" : lib_sq_freshness == "aging" ? "◐" : "○"
    string warn_text  = lib_sq_warnings != "" ? " ⚠ " + lib_sq_warnings : ""
    string data_icon  = lib_erl_provider_status == "ok" ? "✓" : "⚠"
    string badge_text = dir_icon + " " + lib_sq_tier + " " + str.tostring(lib_sq_score) + " " + tier_icon + " | " + event_icon + " | " + fresh_icon + warn_text + " | data:" + data_icon
    color  badge_col  = lib_sq_tier == "high" ? color.new(color.green, 70) : lib_sq_tier == "good" ? color.new(color.teal, 70) : lib_sq_tier == "ok" ? color.new(color.orange, 70) : color.new(color.red, 70)
    health_badge := label.new(bar_index, low, badge_text, color = badge_col, textcolor = color.white, style = label.style_label_up, size = size.tiny)

/////////////////////////////////////////////////////////////////////////////////
//#endregion                      IMPLEMENTATION
/////////////////////////////////////////////////////////////////////////////////
