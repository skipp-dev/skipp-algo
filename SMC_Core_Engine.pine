bool   lib_ats_spike_down      = mp.ATS_SPIKE_DOWN
bool   lib_ats_bullish_seq     = mp.ATS_BULLISH_SEQUENCE
bool   lib_ats_bearish_seq     = mp.ATS_BEARISH_SEQUENCE

// ── Compression / ATR Regime (v5.1) ──
bool   lib_squeeze_on          = mp.SQUEEZE_ON
bool   lib_squeeze_released    = mp.SQUEEZE_RELEASED
string lib_squeeze_momentum    = mp.SQUEEZE_MOMENTUM_BIAS
string lib_atr_regime          = mp.ATR_REGIME
float  lib_atr_ratio           = mp.ATR_RATIO

// ── Event Risk Light (v5.5b canonical exports) ──
string lib_erl_window_state        = mp.EVENT_WINDOW_STATE
string lib_erl_level               = mp.EVENT_RISK_LEVEL
string lib_erl_next_name           = mp.NEXT_EVENT_NAME
string lib_erl_next_time           = mp.NEXT_EVENT_TIME
bool   lib_erl_market_blocked      = mp.MARKET_EVENT_BLOCKED
bool   lib_erl_symbol_blocked      = mp.SYMBOL_EVENT_BLOCKED
string lib_erl_provider_status     = mp.EVENT_PROVIDER_STATUS

// ── Session Context Light (v5.5b canonical exports) ──
string lib_scl_context             = mp.SESSION_CONTEXT
bool   lib_scl_in_killzone         = mp.IN_KILLZONE
string lib_scl_direction_bias      = mp.SESSION_DIRECTION_BIAS
int    lib_scl_context_score       = mp.SESSION_CONTEXT_SCORE
string lib_scl_volatility_state    = mp.SESSION_VOLATILITY_STATE

// ── Order Block Context Light (v5.5a) ──
string lib_obl_side                = mp.PRIMARY_OB_SIDE
float  lib_obl_distance            = mp.PRIMARY_OB_DISTANCE
bool   lib_obl_fresh               = mp.OB_FRESH
int    lib_obl_age_bars            = mp.OB_AGE_BARS
string lib_obl_mitigation_state    = mp.OB_MITIGATION_STATE

// ── FVG Lifecycle Light (v5.5a) ──
string lib_fvgl_side               = mp.PRIMARY_FVG_SIDE
float  lib_fvgl_distance           = mp.PRIMARY_FVG_DISTANCE
float  lib_fvgl_fill_pct           = mp.FVG_FILL_PCT
int    lib_fvgl_maturity_level      = mp.FVG_MATURITY_LEVEL
bool   lib_fvgl_fresh              = mp.FVG_FRESH
bool   lib_fvgl_invalidated        = mp.FVG_INVALIDATED

// ── Structure State Light (v5.5b canonical exports) ──
string lib_strl_last_event         = mp.STRUCTURE_LAST_EVENT
int    lib_strl_event_age_bars     = mp.STRUCTURE_EVENT_AGE_BARS
bool   lib_strl_fresh              = mp.STRUCTURE_FRESH
int    lib_strl_trend_strength     = mp.STRUCTURE_TREND_STRENGTH

// ── Signal Quality (v5.5a) ──
int    lib_sq_score                = mp.SIGNAL_QUALITY_SCORE
string lib_sq_tier                 = mp.SIGNAL_QUALITY_TIER
string lib_sq_warnings             = mp.SIGNAL_WARNINGS
string lib_sq_bias_alignment       = mp.SIGNAL_BIAS_ALIGNMENT
string lib_sq_freshness            = mp.SIGNAL_FRESHNESS

// ── v5.5 Lean Context [PRIMARY] ──
// Signal Quality: generator-computed composite replaces ad-hoc checks
bool   signal_quality_ok         = lib_sq_score >= 25
bool   signal_quality_good       = lib_sq_score >= 50
bool   signal_quality_high       = lib_sq_score >= 75
bool   signal_freshness_ok       = lib_sq_freshness != "stale"
// Structure Light: trend strength from generator
bool   struct_light_trending     = lib_strl_trend_strength >= 30
// OB Context Light: primary OB is bullish + fresh
bool   ob_light_bull_ok          = lib_obl_side == "BULL" and lib_obl_fresh
// FVG Lifecycle Light: primary FVG alive + not invalidated
bool   fvg_light_active_ok       = lib_fvgl_side != "NONE" and not lib_fvgl_invalidated
// Event Risk Light: derived from primary event_risk_gate_ok (avoids duplication)
bool   event_risk_light_hard_block = not event_risk_gate_ok
// Session Context Light: lean session quality
bool   session_light_ok          = lib_scl_context_score >= 2

// ── Legacy context gates REMOVED in v5.5 ──
// 17 gates (flow_quality_ok, compression_entry_ok, atr_regime_ok,
//   zone_context_long_ok, reversal_context_boost, session_context_ok,
//   sweep_context_long_ok, pool_magnet_long_ok, ob_context_long_ok,
//   zone_proj_ok, profile_quality_ok, struct_state_ok, imbalance_ok,
//   session_struct_ok, range_regime_ok, range_profile_ok,
//   session_struct_state_ok) were declared but never consumed.
// They derived from deprecated v5.1-v5.3 fields; pipeline uses
// v5.5 lean context gates above exclusively. Removed to reduce noise.

