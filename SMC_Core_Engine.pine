bool core_plan_visible = (long_ready_state or long_entry_best_state or long_entry_strict_state) and not na(long_state.trigger) and not na(long_state.invalidation_level)
plot(core_plan_visible ? long_state.trigger : na, 'Core Trigger', color = color.new(color.aqua, 0), linewidth = 2, style = plot.style_linebr)
plot(core_plan_visible ? long_state.invalidation_level : na, 'Core Invalidation', color = color.new(color.orange, 0), linewidth = 2, style = plot.style_linebr)
