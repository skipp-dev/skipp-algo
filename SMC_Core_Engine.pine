    bool dynamic_ready_alert_active = false
    if enable_dynamic_alerts and long_ready_signal
        dynamic_ready_alert_active := true
    bool dynamic_confirmed_alert_active = false
    if enable_dynamic_alerts and long_confirm_signal
        dynamic_confirmed_alert_active := true
    bool dynamic_clean_alert_active = false
    if enable_dynamic_alerts and alert_long_clean_event
