var string opening_range_bias_mode = input.string('Above OR Mid', 'Bias', options = ['Above OR Mid', 'Above OR High'], group = g_session, inline = 'or2', display = display.none)

var g_micro = '14. Advanced - Ticker Microstructure'
var bool use_microstructure_profiles = input.bool(true, 'Use ticker microstructure profiles', group = g_micro, display = display.none)
string clean_reclaim_tickers_effective = mp.CLEAN_RECLAIM_TICKERS
string stop_hunt_tickers_effective = mp.STOP_HUNT_PRONE_TICKERS
string midday_dead_tickers_effective = mp.MIDDAY_DEAD_TICKERS
string rth_only_tickers_effective = mp.RTH_ONLY_TICKERS
string weak_premarket_tickers_effective = mp.WEAK_PREMARKET_TICKERS
string weak_afterhours_tickers_effective = mp.WEAK_AFTERHOURS_TICKERS
string fast_decay_tickers_effective = mp.FAST_DECAY_TICKERS
string current_symbol_key = syminfo.ticker
string current_symbol_key_qualified = syminfo.tickerid

// ── Library Freshness Check ──
asof_year  = str.tonumber(str.substring(mp.ASOF_DATE, 0, 4))
asof_month = str.tonumber(str.substring(mp.ASOF_DATE, 5, 7))
asof_day   = str.tonumber(str.substring(mp.ASOF_DATE, 8, 10))
asof_ts    = timestamp(int(asof_year), int(asof_month), int(asof_day), 0, 0, 0)
lib_days_old = math.floor((timenow - asof_ts) / 86400000)
string lib_asof_display = mp.ASOF_TIME != '' ? mp.ASOF_TIME : mp.ASOF_DATE
// Parse hours from ASOF_TIME (ISO-8601: "2026-04-13T19:05:13Z") for sub-day staleness
lib_hours_old = str.length(mp.ASOF_TIME) >= 13 ? lib_days_old * 24 + math.floor((timenow - asof_ts) % 86400000 / 3600000) - int(str.tonumber(str.substring(mp.ASOF_TIME, 11, 13))) : lib_days_old * 24
var label stale_label = na
if barstate.islast and lib_days_old > 2
    if not na(stale_label)
        label.delete(stale_label)
    stale_label := label.new(bar_index, high,
         "⚠️ Library " + str.tostring(lib_days_old) + "d alt",
         color = color.red, textcolor = color.white,
         style = label.style_label_down, size = size.small)

// ── Regime Flags ──
bool lib_regime_blocked = mp.MARKET_REGIME == "RISK_OFF" or mp.TRADE_STATE == "BLOCKED"
bool lib_regime_dimmed  = mp.MARKET_REGIME == "ROTATION" or mp.TRADE_STATE == "DISCOURAGED"

// ── Earnings / Macro Shield ──
bool lib_has_earnings     = str.contains(mp.EARNINGS_TODAY_TICKERS, syminfo.ticker)
bool lib_has_macro_event  = mp.HIGH_IMPACT_MACRO_TODAY

// ── News & Volume Flags ──
bool lib_news_bearish = str.contains(mp.NEWS_BEARISH_TICKERS, syminfo.ticker)
bool lib_news_bullish = str.contains(mp.NEWS_BULLISH_TICKERS, syminfo.ticker)
bool lib_low_volume   = str.contains(mp.VOLUME_LOW_TICKERS, syminfo.ticker)

