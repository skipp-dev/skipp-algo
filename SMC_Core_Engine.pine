plot(cr.resolve_bus_lean_pack_b(lib_obl_side, lib_obl_fresh, lib_obl_mitigation_state, lib_fvgl_side, lib_fvgl_fresh, lib_fvgl_invalidated, lib_scl_context_score, lib_scl_in_killzone, lib_ensemble_quality_score, lib_ensemble_quality_tier, lib_volatility_regime, lib_volatility_model_source), 'BUS LeanPackB', display = display.none)

// ── BUS Quickstart Preset (Plan 1.4 caveat resolution) ──
// Helpers live near the input declaration so the effective_* gate
// chain can consume them. The hidden plots below expose the same
// values as a stable contract for the dashboard and tests. RVOL is
// wired (effective_relvol_good chain); HTF bias / FVG quality / vol
// regime stay BUS-only until their consumer surfaces ship in Q3.
plot(preset_effective_class_code(quickstart_preset),       'BUS PresetClassCode',     display = display.none)
plot(preset_effective_rvol_min(quickstart_preset),         'BUS PresetRvolMin',       display = display.none)
plot(preset_effective_htf_bias_min(quickstart_preset),     'BUS PresetHtfBiasMin',    display = display.none)
plot(preset_effective_fvg_quality_gate(quickstart_preset), 'BUS PresetFvgQualGate',   display = display.none)
plot(preset_effective_vol_regime_default(quickstart_preset),'BUS PresetVolRegimeDef', display = display.none)

// ── Mini Health Badge (v5.5a) ──
var label core_hero_card = na
if barstate.islast and compact_mode
    if not na(core_hero_card)
        label.delete(core_hero_card)
    string core_product_state = resolve_core_product_state(long_visual_state)
    string core_bias_text = cr.resolve_core_bias_text(lib_sq_bias_alignment)
    string core_trust_tier = core_trust_tier_early
    string core_trust_suffix = compose_trust_tier_suffix(core_trust_tier, lib_sq_score, lib_sq_freshness, lib_erl_provider_status, lib_ensemble_quality_tier)
    string core_provider_state = cr.resolve_core_provider_state(lib_erl_provider_status, lib_provider_count, lib_stale_providers)
    string core_trade_threshold = cr.compose_trade_threshold_text(core_trust_tier, lib_sq_score)
    string core_why_now = cr.compose_why_now_text(core_product_state, long_setup_source_display, lib_sq_freshness, lib_sq_warnings, long_ready_blocker_text, long_strict_blocker_text, long_state.trigger)
    bool   core_has_earnings_tomorrow = str.contains(lib_earnings_tomorrow, syminfo.ticker)
    string core_main_risk = cr.compose_main_risk_text(core_product_state, event_risk_state, long_ready_blocker_text, long_strict_blocker_text, long_state.last_invalid_source, lib_sq_warnings, lib_erl_provider_status, core_has_earnings_tomorrow)
    string core_market_event = mp.HIGH_IMPACT_MACRO_TODAY ? (lib_macro_event_name + ' ' + lib_macro_event_time) : 'No event'
    string core_tone_text = lib_tone + ' · Heat ' + str.tostring(lib_global_heat, '#.##')
    string core_hero_text = cr.compose_core_hero_text(core_product_state, core_bias_text, core_trade_threshold, core_trust_tier, core_trust_suffix, core_provider_state, core_why_now, core_main_risk, mp.MARKET_REGIME, lib_regime_blocked, lib_regime_dimmed, lib_asof_display, lib_vix_level, core_market_event, core_tone_text, lib_yield_inverted, lib_sector_leading, is_breaking_news, lib_high_impact_news_count, lib_universe_status_code)
    string core_hero_display = core_hero_text
    if compact_mode
        // WP-OV5: compact hero — Universe badge plus Action, Bias, Confidence, Trust, VIX, Main blocker
        string _cb_action = core_product_state
        if (core_product_state == 'WAIT' or core_product_state == 'BLOCKED') and (lib_regime_blocked or lib_regime_dimmed)
            _cb_action := core_product_state + ' (' + mp.MARKET_REGIME + ')'
        core_hero_display := u.universe_status_badge(lib_universe_status_code) + '\nAction: ' + _cb_action + '\nBias: ' + core_bias_text + '\nConfidence: ' + core_trade_threshold + '\nTrust: ' + (core_trust_suffix != '' ? core_trust_tier + ' (' + core_trust_suffix + ')' : core_trust_tier) + '\nVIX: ' + str.tostring(lib_vix_level, '#.##') + '\n' + u.universe_status_banner(lib_universe_status_code) + '\nMain blocker: ' + core_main_risk
    float core_hero_y = high + nz(atr, high * 0.01) * 1.15
    color core_hero_bg = cr.resolve_core_hero_color(core_product_state, BULL_HERO, BULL_HERO_READY, BEAR_HERO)
    if lib_universe_status_code == 0 or lib_universe_status_code == 1
        core_hero_bg := color.new(color.red, 65)
    else if lib_universe_status_code == 2
        core_hero_bg := color.new(color.orange, 60)
    core_hero_card := label.new(bar_index, core_hero_y, core_hero_display, color = core_hero_bg, textcolor = color.white, style = label.style_label_left, size = size.small)
else if barstate.islast and not na(core_hero_card)
    label.delete(core_hero_card)

// ── Sector Breadth + Macro Bias Context Labels (WP-LF3) ──
var label breadth_badge = na
var label macro_badge = na
if barstate.islast and compact_mode
    if not na(breadth_badge)
        label.delete(breadth_badge)
    if not na(macro_badge)
        label.delete(macro_badge)
    string breadth_pct = str.tostring(lib_sector_breadth * 100, '#') + '% sectors up'
    color breadth_color = lib_sector_breadth >= 0.6 ? color.new(color.green, 60) : lib_sector_breadth <= 0.4 ? color.new(color.red, 60) : color.new(color.gray, 60)
    breadth_badge := label.new(bar_index - 2, high, 'Breadth: ' + breadth_pct, color = breadth_color, textcolor = color.white, style = label.style_label_down, size = size.tiny)
    string macro_text = 'Macro: ' + str.tostring(lib_macro_bias_raw, '#.##')
    color macro_color = lib_macro_bias_raw >= 0.3 ? color.new(color.green, 60) : lib_macro_bias_raw <= -0.3 ? color.new(color.red, 60) : color.new(color.gray, 60)
    macro_badge := label.new(bar_index - 4, high, macro_text, color = macro_color, textcolor = color.white, style = label.style_label_down, size = size.tiny)
else if barstate.islast
    if not na(breadth_badge)
        label.delete(breadth_badge)
    if not na(macro_badge)
        label.delete(macro_badge)

// ── Short Interest Warning Badge (WP-ND1) ──
var label squeeze_badge = na
if barstate.islast and compact_mode and is_squeeze_risk
    if not na(squeeze_badge)
        label.delete(squeeze_badge)
    squeeze_badge := label.new(bar_index - 6, high, '⚠ Squeeze Risk', color = color.new(color.yellow, 60), textcolor = color.black, style = label.style_label_down, size = size.tiny)
else if barstate.islast and not na(squeeze_badge)
    label.delete(squeeze_badge)

var label health_badge = na
if barstate.islast and show_dashboard and not compact_mode
    if not na(health_badge)
        label.delete(health_badge)
    string badge_text = u.universe_status_badge(lib_universe_status_code) + '\n' + u.universe_status_banner(lib_universe_status_code) + '\n' + compose_health_badge_text(lib_sq_bias_alignment, lib_sq_tier, lib_sq_score, event_risk_state, lib_sq_freshness, lib_sq_warnings, lib_erl_provider_status)
    color badge_col = resolve_health_badge_color(lib_sq_tier)
    if lib_universe_status_code == 0 or lib_universe_status_code == 1
        badge_col := color.new(color.red, 65)
    else if lib_universe_status_code == 2
        badge_col := color.new(color.orange, 60)
    health_badge := label.new(bar_index, low, badge_text, color = badge_col, textcolor = color.white, style = label.style_label_up, size = size.tiny)
else if barstate.islast and compact_mode and not na(health_badge)
    label.delete(health_badge)

// ── Alert Conditions (v5.5 MVP + v7.1 lifecycle & structure) ──
string alert_product_state = resolve_core_product_state(long_visual_state)
string alert_trust_tier = core_trust_tier_early
bool alert_trust_degraded = alert_trust_tier == 'Degraded' and (na(alert_trust_tier[1]) or alert_trust_tier[1] != 'Degraded')
bool alert_trust_insufficient = alert_trust_tier == 'Insufficient' and (na(alert_trust_tier[1]) or alert_trust_tier[1] != 'Insufficient')

// Product state transitions
alertcondition(alert_product_state == 'ENTER LONG' and alert_product_state[1] != 'ENTER LONG' and barstate.isconfirmed, 'SMC: Enter Long', 'SMC Trigger is live. Entry level reached.')
alertcondition(alert_product_state == 'READY LONG' and alert_product_state[1] != 'READY LONG' and barstate.isconfirmed, 'SMC: Ready Long', 'SMC Setup is ready. Confirmed reclaim, watching for trigger.')
alertcondition(alert_product_state == 'PREPARE LONG' and alert_product_state[1] != 'PREPARE LONG' and barstate.isconfirmed, 'SMC: Prepare Long', 'SMC Setup is preparing. Zone is active, waiting for confirmation.')
alertcondition(alert_product_state == 'BLOCKED' and alert_product_state[1] != 'BLOCKED' and barstate.isconfirmed, 'SMC: Setup Blocked', 'SMC Setup is now blocked. Invalidation hit or regime issue.')
alertcondition(alert_product_state == 'WAIT' and alert_product_state[1] != 'WAIT' and barstate.isconfirmed, 'SMC: Wait', 'No active setup — back to wait state.')

// Structure break alerts (v7.1) — fire on confirmed bars when BOS or CHoCH occurs
alertcondition(bull_bos_sig and barstate.isconfirmed, 'SMC: Bullish BOS', 'Bullish Break of Structure confirmed. Trend continuation signal.')
alertcondition(bull_choch_sig and barstate.isconfirmed, 'SMC: Bullish CHoCH', 'Bullish Change of Character confirmed. Potential trend reversal to the upside.')
alertcondition(bear_choch_sig and barstate.isconfirmed, 'SMC: Bearish CHoCH', 'Bearish Change of Character confirmed. Potential trend reversal to the downside.')
alertcondition(bear_bos_sig and barstate.isconfirmed, 'SMC: Bearish BOS', 'Bearish Break of Structure confirmed. Downtrend continuation signal.')

// Zone lifecycle alerts (v7.1) — fire on lifecycle state transitions
alertcondition(long_state.armed and not long_state.armed[1] and barstate.isconfirmed, 'SMC: Zone Armed', 'A bullish zone has been armed. Price reclaimed a demand zone — watching for confirmation.')
alertcondition(long_invalidated_now and barstate.isconfirmed, 'SMC: Zone Invalidated', 'Active zone setup invalidated. Price broke below invalidation level.')

// Trust & risk alerts
alertcondition(alert_trust_degraded and barstate.isconfirmed, 'SMC: Trust Degraded', 'Trust tier dropped to degraded')
alertcondition(alert_trust_insufficient and barstate.isconfirmed, 'SMC: Trust Insufficient', 'Trust tier dropped to insufficient')
alertcondition(not event_risk_gate_ok and barstate.isconfirmed, 'SMC: Event Risk Active', 'High-impact macro event blocking trades')
alertcondition(lib_has_macro_event and barstate.islastconfirmedhistory, 'SMC: High Impact Macro Today', 'High impact macro event today. Reduce position sizes.')
alertcondition(lib_has_earnings and barstate.islastconfirmedhistory, 'SMC: Earnings Today', 'This ticker has earnings today. Exercise caution.')

/////////////////////////////////////////////////////////////////////////////////
//#endregion                      IMPLEMENTATION
/////////////////////////////////////////////////////////////////////////////////
