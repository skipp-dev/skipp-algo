var float anti_chase_max_z_best = input.float(0.25, 'Best max z', step = 0.1, group = g_stretch, inline = 'ac1', display = display.none, tooltip = 'Cautious rollout: 0.25. Keeps Entry Best closer to the original dip rather than a late mean chase.')
