    if enable_dynamic_alerts and bull_bos_sig
        dynamic_bull_bos_alert_active := true
    bool dynamic_bull_choch_alert_active = false
    if enable_dynamic_alerts and bull_choch_sig
        dynamic_bull_choch_alert_active := true
    bool dynamic_new_bull_ob_alert_active = false
    if enable_dynamic_alerts and not na(new_ob_bull)
        dynamic_new_bull_ob_alert_active := true
    bool dynamic_new_bull_fvg_alert_active = false
    if enable_dynamic_alerts and bullish_fvg_alert
        dynamic_new_bull_fvg_alert_active := true
    bool dynamic_bull_fvg_filled_alert_active = false
    if enable_dynamic_alerts and bullish_fvg_filled_alert
        dynamic_bull_fvg_filled_alert_active := true
    bool dynamic_live_bull_ob_break_alert_active = false
    if enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_ob_break
        dynamic_live_bull_ob_break_alert_active := true
    bool dynamic_live_bull_fvg_fill_alert_active = false
    if enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_fvg_fill
        dynamic_live_bull_fvg_fill_alert_active := true
    bool dynamic_sd_bull_divergence_alert_active = false
    if enable_dynamic_alerts and use_sd_confluence and sd_bullish_divergence_event
        dynamic_sd_bull_divergence_alert_active := true
    bool dynamic_sd_higher_lows_alert_active = false
    if enable_dynamic_alerts and use_sd_confluence and sd_higher_lows_event
        dynamic_sd_higher_lows_alert_active := true
    [dynamic_bull_bos_alert_active, dynamic_bull_choch_alert_active, dynamic_new_bull_ob_alert_active, dynamic_new_bull_fvg_alert_active, dynamic_bull_fvg_filled_alert_active, dynamic_live_bull_ob_break_alert_active, dynamic_live_bull_fvg_fill_alert_active, dynamic_sd_bull_divergence_alert_active, dynamic_sd_higher_lows_alert_active]

compute_long_dynamic_alert_gates(bool enable_dynamic_alerts, bool long_invalidate_signal, bool alert_long_entry_strict_event, bool alert_long_entry_best_event, bool long_ready_signal, bool long_confirm_signal, bool alert_long_clean_event, bool alert_long_early_event, bool alert_long_armed_event, bool long_arm_signal, bool alert_long_watchlist_event) =>
