if state_update_bar_ok and not na(active_bull_fvg_id) and (na(active_bull_fvg_id[1]) or active_bull_fvg_id != active_bull_fvg_id[1])
    touched_bull_fvg_bar_index := bar_index

bool in_bull_ob_zone = not na(active_bull_ob_top) and not na(active_bull_ob_bottom)
bool in_bull_fvg_zone = not na(active_bull_fvg_top) and not na(active_bull_fvg_bottom)
bool prefer_active_ob_zone = not na(active_bull_ob_id)
if not na(active_bull_ob_id) and not na(active_bull_fvg_id)
    prefer_active_ob_zone := prefer_primary_zone(active_bull_ob_touch_anchor, active_bull_ob_recency, active_bull_ob_quality, best_bull_ob_overlap, active_bull_ob_id, active_bull_fvg_touch_anchor, active_bull_fvg_recency, active_bull_fvg_quality, best_bull_fvg_overlap, active_bull_fvg_id)
int active_long_zone_id = na
if not na(active_bull_ob_id) and (na(active_bull_fvg_id) or prefer_active_ob_zone)
    active_long_zone_id := active_bull_ob_id
else if not na(active_bull_fvg_id)
    active_long_zone_id := -active_bull_fvg_id
bool touched_bull_ob_still_active = contains_id(ob_blocks_bull, touched_bull_ob_id)
bool touched_bull_fvg_still_active = contains_id(fvgs_bull, touched_bull_fvg_id)
bool touched_bull_ob_recent = touched_bull_ob_still_active and not na(touched_bull_ob_bar_index) and bar_index - touched_bull_ob_bar_index <= long_signal_window
bool touched_bull_fvg_recent = touched_bull_fvg_still_active and not na(touched_bull_fvg_bar_index) and bar_index - touched_bull_fvg_bar_index <= long_signal_window
OrderBlock touched_bull_ob_block = na
if touched_bull_ob_still_active
    touched_bull_ob_block := get_by_id(ob_blocks_bull, touched_bull_ob_id)
FVG touched_bull_fvg_block = na
if touched_bull_fvg_still_active
    touched_bull_fvg_block := get_by_id(fvgs_bull, touched_bull_fvg_id)
float touched_bull_ob_quality = 0.0
if not na(touched_bull_ob_block)
    touched_bull_ob_quality := ob_quality_score(touched_bull_ob_block)
float touched_bull_fvg_quality = 0.0
if not na(touched_bull_fvg_block)
    touched_bull_fvg_quality := fvg_quality_score(touched_bull_fvg_block, fvg_size_threshold)
bool long_zone_active = in_bull_ob_zone or in_bull_fvg_zone
bool long_zone_active_safe = long_zone_active
int active_long_zone_id_safe = active_long_zone_id
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    long_zone_active_safe := long_zone_active[1]
    active_long_zone_id_safe := active_long_zone_id[1]
bool stretch_watchlist_context_ok_safe = stretch_watchlist_context_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    stretch_watchlist_context_ok_safe := stretch_watchlist_context_ok[1]
var int last_zone_touch_event_bar_index = na
var int last_zone_touch_event_zone_id = na
var int last_ob_zone_touch_bar_index = na
var int last_ob_zone_touch_id = na
var int last_fvg_zone_touch_bar_index = na
var int last_fvg_zone_touch_id = na
bool ob_zone_touch_event = in_bull_ob_zone and (not in_bull_ob_zone[1] or active_bull_ob_id != active_bull_ob_id[1])
bool fvg_zone_touch_event = in_bull_fvg_zone and (not in_bull_fvg_zone[1] or active_bull_fvg_id != active_bull_fvg_id[1])
bool zone_touch_event = ob_zone_touch_event or fvg_zone_touch_event or (long_zone_active and not long_zone_active[1])
if state_update_bar_ok and ob_zone_touch_event
    last_ob_zone_touch_bar_index := bar_index
    last_ob_zone_touch_id := active_bull_ob_id
if state_update_bar_ok and fvg_zone_touch_event
    last_fvg_zone_touch_bar_index := bar_index
    last_fvg_zone_touch_id := active_bull_fvg_id
if state_update_bar_ok and zone_touch_event
    last_zone_touch_event_bar_index := bar_index
    last_zone_touch_event_zone_id := active_long_zone_id
bool zone_touch_event_recent = not na(last_zone_touch_event_bar_index) and bar_index - last_zone_touch_event_bar_index <= long_signal_window
bool ob_zone_touch_event_recent = not na(last_ob_zone_touch_bar_index) and bar_index - last_ob_zone_touch_bar_index <= long_signal_window
bool fvg_zone_touch_event_recent = not na(last_fvg_zone_touch_bar_index) and bar_index - last_fvg_zone_touch_bar_index <= long_signal_window
bool zone_touch_sequence_time_ok = not na(last_zone_touch_event_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_zone_touch_event_bar_index : bar_index > last_zone_touch_event_bar_index)
bool ob_zone_touch_sequence_time_ok = not na(last_ob_zone_touch_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_ob_zone_touch_bar_index : bar_index > last_ob_zone_touch_bar_index)
bool fvg_zone_touch_sequence_time_ok = not na(last_fvg_zone_touch_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_fvg_zone_touch_bar_index : bar_index > last_fvg_zone_touch_bar_index)
bool ob_zone_touch_sequence_ok = ob_zone_touch_event_recent and ob_zone_touch_sequence_time_ok and not na(touched_bull_ob_id) and last_ob_zone_touch_id == touched_bull_ob_id
bool fvg_zone_touch_sequence_ok = fvg_zone_touch_event_recent and fvg_zone_touch_sequence_time_ok and not na(touched_bull_fvg_id) and last_fvg_zone_touch_id == touched_bull_fvg_id
bool generic_zone_touch_sequence_ok = zone_touch_event_recent and zone_touch_sequence_time_ok
bool zone_touch_tracking_active = live_exec ? long_zone_active : long_zone_active_safe
int zone_touch_tracking_id = live_exec ? active_long_zone_id : active_long_zone_id_safe
var int active_zone_touch_count = 0
var int active_zone_touch_id = na
var int last_zone_touch_bar = na
var int active_ob_touch_count = 0
var int active_ob_touch_id = na
var int last_ob_touch_bar = na
var int active_fvg_touch_count = 0
var int active_fvg_touch_id = na
var int last_fvg_touch_bar = na
bool zone_touch_now = zone_touch_tracking_active and not zone_touch_tracking_active[1]
bool ob_touch_now = in_bull_ob_zone and not in_bull_ob_zone[1]
bool fvg_touch_now = in_bull_fvg_zone and not in_bull_fvg_zone[1]
if state_update_bar_ok and zone_touch_now and last_zone_touch_bar != bar_index and not na(zone_touch_tracking_id)
    if zone_touch_tracking_id != active_zone_touch_id
        active_zone_touch_id := zone_touch_tracking_id
        active_zone_touch_count := 1
    else
        active_zone_touch_count += 1
    last_zone_touch_bar := bar_index
if state_update_bar_ok and ob_touch_now and last_ob_touch_bar != bar_index and not na(active_bull_ob_id)
    if active_bull_ob_id != active_ob_touch_id
        active_ob_touch_id := active_bull_ob_id
        active_ob_touch_count := 1
    else
        active_ob_touch_count += 1
    last_ob_touch_bar := bar_index
    touched_bull_ob_touch_count := active_ob_touch_count
if state_update_bar_ok and fvg_touch_now and last_fvg_touch_bar != bar_index and not na(active_bull_fvg_id)
    if active_bull_fvg_id != active_fvg_touch_id
        active_fvg_touch_id := active_bull_fvg_id
        active_fvg_touch_count := 1
    else
        active_fvg_touch_count += 1
    last_fvg_touch_bar := bar_index
    touched_bull_fvg_touch_count := active_fvg_touch_count
bool ob_zone_touch_quality_ok = not block_third_touch_eff or active_ob_touch_count <= max_zone_touches_for_entry
bool fvg_zone_touch_quality_ok = not block_third_touch_eff or active_fvg_touch_count <= max_zone_touches_for_entry
bool zone_touch_quality_ok = not block_third_touch_eff or active_zone_touch_count <= max_zone_touches_for_entry

scan_live_bull_events() =>
    float _ob_alert = last_bull_ob_break_level
    if not na(active_bull_ob_break_level)
        _ob_alert := active_bull_ob_break_level
    float _fvg_alert = last_bull_fvg_fill_level
    if not na(active_bull_fvg_fill_level)
        _fvg_alert := active_bull_fvg_fill_level
    bool _any_ob = array.size(ob_broken_new_bull) > 0
    bool _any_fvg = array.size(filled_fvgs_new_bull) > 0
    OrderBlock _live_broken_ob = _any_ob ? array.get(ob_broken_new_bull, array.size(ob_broken_new_bull) - 1) : na
    float _ob_level = _any_ob ? resolve_ob_alert_level(_live_broken_ob) : _ob_alert
    FVG _live_filled_gap = _any_fvg ? array.get(filled_fvgs_new_bull, array.size(filled_fvgs_new_bull) - 1) : na
    float _fvg_level = _any_fvg ? resolve_fvg_alert_level(_live_filled_gap) : _fvg_alert
    int _best_ob_idx = na
    int _best_fvg_idx = na
    if not _any_ob and array.size(ob_blocks_bull) > 0
        for i = array.size(ob_blocks_bull) - 1 to math.max(0, array.size(ob_blocks_bull) - long_zone_scan_limit)
            _ob_cand = array.get(ob_blocks_bull, i)
            float _ob_cand_level = resolve_ob_alert_level(_ob_cand)
            float _ob_cand_boundary = resolve_ob_bottom_boundary(_ob_cand)
            float _best_ob_boundary = na
            if not na(_best_ob_idx)
                OrderBlock _best_ob = array.get(ob_blocks_bull, _best_ob_idx)
                _best_ob_boundary := resolve_ob_bottom_boundary(_best_ob)
            if low <= _ob_cand_level and (na(_best_ob_idx) or _ob_cand_boundary < _best_ob_boundary)
                _best_ob_idx := i
    if not na(_best_ob_idx)
        _any_ob := true
        OrderBlock _best_live_ob = array.get(ob_blocks_bull, _best_ob_idx)
        _ob_level := resolve_ob_alert_level(_best_live_ob)
    if not _any_fvg and array.size(fvgs_bull) > 0
        for i = array.size(fvgs_bull) - 1 to math.max(0, array.size(fvgs_bull) - long_zone_scan_limit)
            _fvg_cand = array.get(fvgs_bull, i)
            float _fvg_cand_level = resolve_fvg_alert_level(_fvg_cand)
            float _fvg_cand_boundary = resolve_fvg_bottom_boundary(_fvg_cand)
            float _best_fvg_boundary = na
            if not na(_best_fvg_idx)
                FVG _best_fvg = array.get(fvgs_bull, _best_fvg_idx)
                _best_fvg_boundary := resolve_fvg_bottom_boundary(_best_fvg)
            if low <= _fvg_cand_level and (na(_best_fvg_idx) or _fvg_cand_boundary < _best_fvg_boundary)
                _best_fvg_idx := i
    if not na(_best_fvg_idx)
        _any_fvg := true
        FVG _best_live_fvg = array.get(fvgs_bull, _best_fvg_idx)
        _fvg_level := resolve_fvg_alert_level(_best_live_fvg)
    [_any_ob, _ob_level, _any_fvg, _fvg_level]

[any_live_bull_ob_break, bull_ob_live_event_level, any_live_bull_fvg_fill, bull_fvg_live_event_level] = scan_live_bull_events()

compute_context_quality() =>
    int _htf_count = 0
    if mtf_trend_1 > 0
        _htf_count += 1
    if mtf_trend_2 > 0
        _htf_count += 1
    if mtf_trend_3 > 0
        _htf_count += 1
    // Plan 1.4 W2 — HTF bias floor is the preset's effective count, never
    // below the user's own min_htf_alignment_count. math.max guarantees the
    // preset can only raise the bar (Custom returns 0 → no-op).
    int _htf_floor = math.max(min_htf_alignment_count, preset_effective_htf_align_count(quickstart_preset))
    bool _htf_ok = _htf_count >= _htf_floor
    bool _ltf_ok = true
    if use_ltf_for_strict_entry_eff
        _ltf_ok := false
        if strict_ltf_available and ltf_volume_delta >= 0
            _ltf_ok := true
        else if allow_strict_entry_without_ltf and (strict_ltf_unavailable or strict_ltf_unverifiable)
            _ltf_ok := true
    bool _relvol_unavail = false
    if use_rel_volume and not relvol_data_ok and allow_relvol_without_volume_data
        _relvol_unavail := true
    int _vwap_w = 0
    if use_vwap_filter
        _vwap_w := 1
    int _score = 0
    if bullish_trend_safe
        _score += score_weight_structure
    if _htf_ok
        _score += score_weight_htf
    if ema_support_ok
        _score += score_weight_ema
    if adx_strong
        _score += score_weight_adx
    if bull_close_strong
        _score += score_weight_close
    if relvol_score_ok
        _score += score_weight_relvol
    if vwap_filter_ok
        _score += _vwap_w
    int _max = score_weight_structure + score_weight_htf + score_weight_ema + score_weight_adx + score_weight_close + score_weight_relvol + _vwap_w
    int _eff_max = _max
    if _relvol_unavail
        _eff_max -= score_weight_relvol
    int _eff_min = math.min(min_context_quality_score, _eff_max)
    bool _gate_ok = true
    if use_context_quality_score_eff
        _gate_ok := _score >= _eff_min
    [_score, _gate_ok, _htf_ok, _ltf_ok, _eff_min, _eff_max]

compute_bull_reclaim_state() =>
    float _ob_src = live_exec ? high : close
    float _fvg_src = live_exec ? high : close
    float _int_src = live_exec ? high : close
    float _sw_src = live_exec ? high : close
    float _int_level = nz(internal_trail_dn[1], internal_trail_dn)
    float _sw_level = nz(trail_dn[1], trail_dn)
    bool _bar_ok = live_exec ? true : barstate.isconfirmed
    float _ob_top_prev = nz(touched_bull_ob_top[1], touched_bull_ob_top)
    float _fvg_top_prev = nz(touched_bull_fvg_top[1], touched_bull_fvg_top)
    bool _new_ob = not na(touched_bull_ob_id) and (na(touched_bull_ob_id[1]) or touched_bull_ob_id != touched_bull_ob_id[1])
    bool _new_fvg = not na(touched_bull_fvg_id) and (na(touched_bull_fvg_id[1]) or touched_bull_fvg_id != touched_bull_fvg_id[1])
    bool _ob_cross = touched_bull_ob_still_active and not na(touched_bull_ob_top) and _ob_src > touched_bull_ob_top and (_new_ob ? low <= touched_bull_ob_top : nz(_ob_src[1], _ob_src) <= _ob_top_prev)
    bool _fvg_cross = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and _fvg_src > touched_bull_fvg_top and (_new_fvg ? low <= touched_bull_fvg_top : nz(_fvg_src[1], _fvg_src) <= _fvg_top_prev)
    bool _ob_wick = touched_bull_ob_still_active and not na(touched_bull_ob_top) and low <= touched_bull_ob_top and open <= touched_bull_ob_top and _ob_src > touched_bull_ob_top
    bool _fvg_wick = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and low <= touched_bull_fvg_top and open <= touched_bull_fvg_top and _fvg_src > touched_bull_fvg_top
    bool _r_ob = _bar_ok and touched_bull_ob_recent and not na(touched_bull_ob_top) and (_ob_cross or _ob_wick)
    bool _r_fvg = _bar_ok and touched_bull_fvg_recent and not na(touched_bull_fvg_top) and (_fvg_cross or _fvg_wick)
    bool _r_int = _bar_ok and not na(_int_level) and low < _int_level and _int_src > _int_level
    bool _r_sw = _bar_ok and not na(_sw_level) and low < _sw_level and _sw_src > _sw_level
    float _ob_h = na
    if not na(touched_bull_ob_top) and not na(touched_bull_ob_bottom)
        _ob_h := math.max(touched_bull_ob_top - touched_bull_ob_bottom, syminfo.mintick)
    float _fvg_h = na
    if not na(touched_bull_fvg_top) and not na(touched_bull_fvg_bottom)
        _fvg_h := math.max(touched_bull_fvg_top - touched_bull_fvg_bottom, syminfo.mintick)
    float _ob_sweep_lvl = na
    if not na(_ob_h)
        _ob_sweep_lvl := touched_bull_ob_top - _ob_h * effective_ob_reclaim_min_penetration
    float _fvg_sweep_lvl = na
    if not na(_fvg_h)
        _fvg_sweep_lvl := touched_bull_fvg_top - _fvg_h * effective_fvg_reclaim_min_penetration
    bool _ob_sweep = false
    if touched_bull_ob_still_active and not na(_ob_sweep_lvl) and low <= _ob_sweep_lvl
        _ob_sweep := true
    bool _fvg_sweep = false
    if touched_bull_fvg_still_active and not na(_fvg_sweep_lvl) and low <= _fvg_sweep_lvl
        _fvg_sweep := true
    bool _ob_strict = false
    if _r_ob and (not use_strict_sequence_eff or ob_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim_eff or _ob_sweep)
        _ob_strict := true
    bool _fvg_strict = false
    if _r_fvg and (not use_strict_sequence_eff or fvg_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim_eff or _fvg_sweep)
        _fvg_strict := true
    bool _int_strict = false
    if _r_int and (not use_strict_sequence_eff or generic_zone_touch_sequence_ok)
        _int_strict := true
    bool _sw_strict = false
    if _r_sw and (not use_strict_sequence_eff or generic_zone_touch_sequence_ok)
        _sw_strict := true
    bool _any = false
    if _ob_strict or _fvg_strict or _int_strict or _sw_strict
        _any := true
    bool _any_arm = false
    if _ob_strict or _fvg_strict or ((_int_strict or _sw_strict) and long_zone_active)
        _any_arm := true
    [_ob_strict, _fvg_strict, _int_strict, _sw_strict, _any, _any_arm, _int_level, _sw_level, _ob_sweep, _fvg_sweep]

[bull_reclaim_ob_strict, bull_reclaim_fvg_strict, bull_reclaim_internal_low_strict, bull_reclaim_swing_low_strict, bull_reclaim_any, bull_reclaim_any_for_arm, long_reclaim_internal_level, long_reclaim_swing_level, bull_ob_real_sweep, bull_fvg_real_sweep] = compute_bull_reclaim_state()

int zone_since_bars = ta.barssince(zone_touch_event)
int reclaim_since_bars = ta.barssince(bull_reclaim_any)
int internal_choch_since_bars = ta.barssince(internal_bull_choch_sig)
int internal_bos_since_bars = ta.barssince(internal_bull_bos_sig)
int main_bos_since_bars = ta.barssince(bull_bos_sig)

bool zone_recent = false
if not na(zone_since_bars) and zone_since_bars <= long_signal_window
    zone_recent := true
bool reclaim_recent = false
if not na(reclaim_since_bars) and reclaim_since_bars <= long_signal_window
    reclaim_recent := true
bool internal_choch_recent = false
if not na(internal_choch_since_bars) and internal_choch_since_bars <= long_signal_window
    internal_choch_recent := true
bool internal_bos_recent = false
if not na(internal_bos_since_bars) and internal_bos_since_bars <= long_signal_window
    internal_bos_recent := true
bool main_bos_recent = false
if not na(main_bos_since_bars) and main_bos_since_bars <= long_signal_window
    main_bos_recent := true

bool bearish_abort_signal = bear_bos_sig or bear_choch_sig or internal_bear_bos_sig or internal_bear_choch_sig
int bearish_abort_since_bars = ta.barssince(bearish_abort_signal)
bool bearish_abort_recent = false
if not na(bearish_abort_since_bars) and bearish_abort_since_bars <= long_signal_window
    bearish_abort_recent := true
bool long_confirm_bearish_guard_ok = true
if use_strict_confirm_guard
    long_confirm_bearish_guard_ok := not bearish_abort_signal and not bearish_abort_recent

string long_zone_text = 'No Long Zone'
if zone_recent
    long_zone_text := 'Zone touched'
if in_bull_fvg_zone
    long_zone_text := 'In FVG Zone'
if in_bull_ob_zone
    long_zone_text := 'In OB Zone'
if in_bull_ob_zone and in_bull_fvg_zone
    long_zone_text := 'In OB + FVG Zone'

string reclaim_text = 'No Reclaim'
if reclaim_recent
    reclaim_text := 'Reclaim recent'
if bull_reclaim_internal_low_strict
    reclaim_text := 'Internal Low Reclaimed'
if bull_reclaim_swing_low_strict
    reclaim_text := 'Swing Low Reclaimed'
if bull_reclaim_fvg_strict
    reclaim_text := 'FVG Reclaimed'
if bull_reclaim_ob_strict
    reclaim_text := 'OB Reclaimed'

float long_invalidation_buffer = ob_threshold_atr * effective_long_invalidation_atr_mult
float prior_long_trigger_level = nz(ta.highest(high, long_confirm_lookback)[1], high)

// --------------------------------------------------
// Long dip state machine
// 1) stored state
// 2) invalidation rules
// 3) arm setup
// 4) confirm setup
// 5) ready state + visual state
// --------------------------------------------------

bool long_arm_signal = false
bool long_confirm_signal = false
bool long_invalidate_signal = false
string long_setup_text = 'No Setup'
int long_visual_state = 0
string long_visual_text = 'Neutral'
color long_bg_color = na
color long_bar_color = na
int arm_source_kind = LONG_SOURCE_NONE
int long_validation_source = LONG_SOURCE_NONE
string long_setup_source_display = resolve_long_source_text(LONG_SOURCE_NONE)
float arm_invalidation_candidate = low
float arm_trigger_candidate = math.max(high, prior_long_trigger_level)
bool long_confirm_break = false
bool internal_choch_since_arm = false
bool internal_bos_since_arm = false
bool long_confirm_structure_ok = false
bool long_internal_structure_ok = false
bool long_building_state = false
bool long_plan_active = false
float long_stop_level = na
float long_risk_r = na
float long_target_1 = na
float long_target_2 = na
bool long_source_tracked = false
bool long_source_alive = true
bool long_source_lost = false
int arm_backing_zone_kind = LONG_SOURCE_NONE
int arm_backing_zone_id = na
string long_debug_event_source_display = long_setup_source_display
int long_debug_event_touch_count = long_state.backing_zone_touch_count
float long_debug_event_trigger = long_state.trigger
float long_debug_event_invalidation = long_state.invalidation_level

[arm_source_kind, arm_invalidation_candidate, arm_backing_zone_kind, arm_backing_zone_id] = resolve_long_arm_source_state(bull_reclaim_ob_strict, touched_bull_ob_bottom, touched_bull_ob_id, bull_reclaim_fvg_strict, touched_bull_fvg_bottom, touched_bull_fvg_id, bull_reclaim_swing_low_strict, long_reclaim_swing_level, bull_reclaim_internal_low_strict, long_reclaim_internal_level, in_bull_ob_zone, in_bull_fvg_zone, last_ob_zone_touch_bar_index, last_fvg_zone_touch_bar_index, active_bull_ob_id, active_bull_fvg_id, touched_bull_ob_recent, touched_bull_fvg_recent, arm_invalidation_candidate)

// 2) Invalidation
if barstate.isnew
    long_invalidated_this_bar := false

bool close_safe_mode = live_exec or barstate.isconfirmed
[long_setup_age, long_confirm_age, confirm_is_fresh, ready_is_fresh, micro_setup_fresh_enough, micro_confirm_fresh_enough, micro_freshness_gate_ok] = compute_long_freshness_state(long_state.armed, long_state.confirmed, bar_index, long_state.arm_bar_index, long_state.confirm_bar_index, max_bars_arm_to_confirm, max_bars_confirm_to_ready, use_microstructure_profiles, micro_is_fast_decay, effective_fast_decay_setup_age_max, effective_fast_decay_confirm_age_max)
// Snapshot the currently locked source before any source-upgrade decision.
// A true invalidation of the old source always wins against a same-bar upgrade.
int prev_locked_source_kind = long_state.locked_source_kind
int prev_locked_source_id = long_state.locked_source_id

OrderBlock prev_locked_bull_ob = na
if prev_locked_source_kind == LONG_SOURCE_OB
    prev_locked_bull_ob := get_by_id(ob_blocks_bull, prev_locked_source_id)
FVG prev_locked_bull_fvg = na
if prev_locked_source_kind == LONG_SOURCE_FVG
    prev_locked_bull_fvg := get_by_id(fvgs_bull, prev_locked_source_id)

float long_locked_source_quality = 0.0
if prev_locked_source_kind == LONG_SOURCE_OB
    long_locked_source_quality := ob_quality_score(prev_locked_bull_ob)
else if prev_locked_source_kind == LONG_SOURCE_FVG
    long_locked_source_quality := fvg_quality_score(prev_locked_bull_fvg, fvg_size_threshold)

bool prev_locked_ob_alive = prev_locked_source_kind == LONG_SOURCE_OB and not na(prev_locked_bull_ob)
bool prev_locked_fvg_alive = prev_locked_source_kind == LONG_SOURCE_FVG and not na(prev_locked_bull_fvg)
bool prev_locked_ob_broken = prev_locked_source_kind == LONG_SOURCE_OB and (contains_id(ob_broken_bull, prev_locked_source_id) or contains_id(ob_broken_new_bull, prev_locked_source_id))
bool prev_locked_fvg_broken = prev_locked_source_kind == LONG_SOURCE_FVG and (contains_id(filled_fvgs_bull, prev_locked_source_id) or contains_id(filled_fvgs_new_bull, prev_locked_source_id))
[prev_locked_source_tracked, prev_locked_source_alive, prev_locked_source_broken, prev_locked_source_lost, prev_locked_source_invalid_now] = resolve_long_source_runtime_state(prev_locked_source_kind, prev_locked_source_id, prev_locked_ob_alive, prev_locked_fvg_alive, prev_locked_ob_broken, prev_locked_fvg_broken, long_state.armed, long_state.confirmed)

// A true invalidation of the old source always wins against a same-bar upgrade.
// Only allow an upgrade when the currently locked source is not already invalid on this bar.
[ob_source_upgrade_ok, fvg_source_upgrade_ok, long_source_upgrade_now, prefer_ob_upgrade] = compute_long_source_upgrade_state(allow_armed_source_upgrade, long_state.armed, long_state.confirmed, prev_locked_source_invalid_now, prev_locked_source_kind, prev_locked_source_id, bull_reclaim_ob_strict, not na(touched_bull_ob_block), touched_bull_ob_id, touched_bull_ob_quality, bull_reclaim_fvg_strict, not na(touched_bull_fvg_block), touched_bull_fvg_id, touched_bull_fvg_quality, long_locked_source_quality, min_source_upgrade_quality_gain)
string long_source_upgrade_reason = resolve_long_upgrade_reason(long_source_upgrade_now, prefer_ob_upgrade, ob_source_upgrade_ok, fvg_source_upgrade_ok, touched_bull_ob_quality, touched_bull_fvg_quality, long_locked_source_quality)

[long_locked_source_kind_final, long_locked_source_id_final, long_setup_backing_zone_kind_final, long_setup_backing_zone_id_final] = stage_locked_source_transition(long_source_upgrade_now, prefer_ob_upgrade, prev_locked_source_kind, prev_locked_source_id, long_state.backing_zone_kind, long_state.backing_zone_id, touched_bull_ob_id, touched_bull_fvg_id)
int long_locked_source_touch_count_effective = select_locked_source_touch_count(long_source_upgrade_now, prefer_ob_upgrade, touched_bull_ob_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_touch_count, touched_bull_fvg_id, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_touch_count, long_state.locked_source_touch_count)
int long_locked_source_last_touch_bar_index_effective = long_state.locked_source_last_touch_bar_index
if long_source_upgrade_now and not na(long_locked_source_id_final)
    long_locked_source_last_touch_bar_index_effective := bar_index
bool long_locked_ob_alive_now = long_locked_source_kind_final == LONG_SOURCE_OB and contains_id(ob_blocks_bull, long_locked_source_id_final)
bool long_locked_fvg_alive_now = long_locked_source_kind_final == LONG_SOURCE_FVG and contains_id(fvgs_bull, long_locked_source_id_final)
bool long_locked_ob_broken_now = long_locked_source_kind_final == LONG_SOURCE_OB and (contains_id(ob_broken_bull, long_locked_source_id_final) or contains_id(ob_broken_new_bull, long_locked_source_id_final))
bool long_locked_fvg_broken_now = long_locked_source_kind_final == LONG_SOURCE_FVG and (contains_id(filled_fvgs_bull, long_locked_source_id_final) or contains_id(filled_fvgs_new_bull, long_locked_source_id_final))
[long_source_tracked_now, long_locked_source_alive_now, long_source_broken_now, long_source_lost_now, long_source_invalid_now] = resolve_long_source_runtime_state(long_locked_source_kind_final, long_locked_source_id_final, long_locked_ob_alive_now, long_locked_fvg_alive_now, long_locked_ob_broken_now, long_locked_fvg_broken_now, long_state.armed, long_state.confirmed)
float long_locked_source_top_now = resolve_long_zone_top(long_locked_source_kind_final, long_locked_source_id_final, active_bull_ob_id, active_bull_ob_top, touched_bull_ob_id, touched_bull_ob_top, active_bull_fvg_id, active_bull_fvg_top, touched_bull_fvg_id, touched_bull_fvg_top, long_locked_source_alive_now and not long_source_upgrade_now, prev_locked_source_kind, prev_locked_source_id, long_state.locked_source_top)
float long_locked_source_bottom_now = resolve_long_zone_bottom(long_locked_source_kind_final, long_locked_source_id_final, active_bull_ob_id, active_bull_ob_bottom, touched_bull_ob_id, touched_bull_ob_bottom, active_bull_fvg_id, active_bull_fvg_bottom, touched_bull_fvg_id, touched_bull_fvg_bottom, long_locked_source_alive_now and not long_source_upgrade_now, prev_locked_source_kind, prev_locked_source_id, long_state.locked_source_bottom)
bool long_locked_source_in_zone = false
if long_locked_source_alive_now and not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now)
    long_locked_source_in_zone := math.min(high, long_locked_source_top_now) - math.max(low, long_locked_source_bottom_now) >= 0
bool long_locked_source_touch_now = false
if long_locked_source_in_zone
    long_locked_source_touch_now := not long_locked_source_in_zone[1] or long_locked_source_id_final != long_locked_source_id_final[1] or long_locked_source_kind_final != long_locked_source_kind_final[1]
if state_update_bar_ok and (long_state.armed or long_state.confirmed) and long_locked_source_touch_now and long_locked_source_last_touch_bar_index_effective != bar_index and not na(long_locked_source_id_final)
    long_locked_source_touch_count_effective += 1
    long_locked_source_last_touch_bar_index_effective := bar_index
bool long_locked_source_touch_recent = false
if (long_state.armed or long_state.confirmed) and not na(long_locked_source_last_touch_bar_index_effective)
    long_locked_source_touch_recent := bar_index - long_locked_source_last_touch_bar_index_effective <= long_signal_window
float long_locked_source_zone_height = na
if not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now)
    long_locked_source_zone_height := math.max(long_locked_source_top_now - long_locked_source_bottom_now, syminfo.mintick)
float long_locked_ob_required_sweep_level = na
if long_locked_source_kind_final == LONG_SOURCE_OB and not na(long_locked_source_zone_height)
    long_locked_ob_required_sweep_level := long_locked_source_top_now - long_locked_source_zone_height * effective_ob_reclaim_min_penetration
float long_locked_fvg_required_sweep_level = na
if long_locked_source_kind_final == LONG_SOURCE_FVG and not na(long_locked_source_zone_height)
    long_locked_fvg_required_sweep_level := long_locked_source_top_now - long_locked_source_zone_height * effective_fvg_reclaim_min_penetration
bool long_locked_ob_real_sweep = false
if long_locked_source_kind_final == LONG_SOURCE_OB and long_locked_source_alive_now and not na(long_locked_ob_required_sweep_level)
    long_locked_ob_real_sweep := low <= long_locked_ob_required_sweep_level
bool long_locked_fvg_real_sweep = false
if long_locked_source_kind_final == LONG_SOURCE_FVG and long_locked_source_alive_now and not na(long_locked_fvg_required_sweep_level)
    long_locked_fvg_real_sweep := low <= long_locked_fvg_required_sweep_level
float long_locked_source_top_effective = long_state.locked_source_top
if long_locked_source_alive_now
    long_locked_source_top_effective := long_locked_source_top_now
float long_locked_source_bottom_effective = long_state.locked_source_bottom
if long_locked_source_alive_now
    long_locked_source_bottom_effective := long_locked_source_bottom_now
if long_state.armed or long_state.confirmed or long_source_upgrade_now
    long_state.sync_locked_tracking(long_setup_backing_zone_kind_final, long_setup_backing_zone_id_final, long_locked_source_kind_final, long_locked_source_id_final, long_locked_source_top_effective, long_locked_source_bottom_effective, long_locked_source_touch_count_effective, long_locked_source_last_touch_bar_index_effective)
long_source_tracked := long_source_tracked_now
long_source_alive := long_locked_source_alive_now
long_source_lost := long_source_lost_now
bool long_source_broken = long_source_broken_now
float long_invalidation_break_src = close
if live_exec and effective_use_live_invalidation_break
    long_invalidation_break_src := low
[long_setup_expired, long_confirm_expired, long_broken_down, long_invalidated_now] = resolve_long_invalidation_state(long_state.armed, long_state.confirmed, long_setup_age, long_setup_expiry_bars, long_confirm_age, long_confirm_expiry_bars, close_safe_mode, long_invalidation_break_src, long_state.invalidation_level, long_invalidation_buffer, long_source_broken, long_source_lost)
bool invalidated_prior_setup = false
int long_validation_source_now = resolve_long_validation_source(long_locked_source_kind_final)
string long_setup_source_display_now = compose_long_setup_source_display(long_state.entry_origin_source, long_validation_source_now)

if long_invalidated_now
    long_debug_event_source_display := long_setup_source_display_now
    long_debug_event_touch_count := long_state.backing_zone_touch_count
    long_debug_event_trigger := long_state.trigger
    long_debug_event_invalidation := long_state.invalidation_level
    string long_invalidation_reason = resolve_long_invalidation_reason(long_source_broken, long_source_lost, long_setup_expired, long_confirm_expired, long_validation_source_now, long_state.entry_origin_source, long_setup_source_display_now)
    long_invalidate_signal := long_state.armed or long_state.confirmed
    invalidated_prior_setup := long_invalidate_signal
    long_invalidated_this_bar := long_invalidate_signal
    long_state.invalidate(long_invalidation_reason, long_state.invalidation_level)

// 3) Arm setup
bool armed_prequality_ok = compute_long_arm_prequality_ok(tighten_armed_stage_eff, bullish_trend_safe, micro_session_gate_ok, zone_touch_quality_ok, bull_close_strong, ema_support_ok)
bool long_should_arm = compute_long_arm_should_trigger(bull_reclaim_any_for_arm, use_strict_sequence_eff, zone_touch_event_recent, zone_recent, long_state.armed, long_invalidated_this_bar, micro_session_gate_ok, sd_armed_gate_ok, armed_prequality_ok)
if long_should_arm
    [long_arm_backing_zone_touch_count, long_arm_locked_source_id, long_arm_locked_source_top, long_arm_locked_source_bottom, long_arm_locked_source_last_touch_bar_index] = resolve_long_arm_transition_payload(arm_backing_zone_kind, arm_backing_zone_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_id, touched_bull_ob_touch_count, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_id, touched_bull_fvg_touch_count, active_bull_ob_id, active_bull_ob_top, active_bull_ob_bottom, active_bull_fvg_id, active_bull_fvg_top, active_bull_fvg_bottom, touched_bull_ob_top, touched_bull_ob_bottom, touched_bull_fvg_top, touched_bull_fvg_bottom, bar_index)
    long_arm_signal := true
    long_state.arm(bar_index, arm_trigger_candidate, arm_invalidation_candidate, arm_source_kind, arm_backing_zone_kind, arm_backing_zone_id, long_arm_backing_zone_touch_count, arm_backing_zone_kind, long_arm_locked_source_id, long_arm_locked_source_top, long_arm_locked_source_bottom, long_arm_backing_zone_touch_count, long_arm_locked_source_last_touch_bar_index)

// 4) Confirm setup
[long_confirm_break_src, long_confirm_break] = resolve_long_confirm_break_state(live_exec, effective_use_live_confirm_break, close, high, long_state.armed, long_state.confirmed, bar_index, long_state.arm_bar_index, long_state.trigger)
[internal_choch_since_arm, internal_bos_since_arm, long_internal_structure_ok, long_confirm_structure_ok] = resolve_long_confirm_structure_state(long_state.armed, bar_index, long_state.arm_bar_index, internal_choch_since_bars, internal_bos_since_bars, internal_bull_choch_sig, internal_bull_bos_sig, long_internal_structure_mode, require_internal_break_for_confirm_eff)

// 5) Ready state + visuals
long_plan_active := compute_long_plan_state(long_state.armed, long_state.confirmed, long_state.trigger, long_state.invalidation_level)
[long_planned_stop_level, planned_risk, headroom_to_overhead, overhead_zone_ok] = compute_long_overhead_context(long_plan_active, close, long_state.trigger, long_state.invalidation_level, ob_threshold_atr, stop_buffer_atr_mult, ob_blocks_bear, bear_ob_scan_start, fvgs_bear, bear_fvg_scan_start, use_overhead_zone_filter_eff, min_headroom_r)
[context_quality_score, context_quality_gate_ok, htf_alignment_ok, strict_entry_ltf_ok, effective_min_context_quality_score, effective_context_quality_max_score] = compute_context_quality()
// [v5.5b] Signal Quality is the primary quality surface; local context quality stays diagnostic only.
bool primary_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_ok
bool best_signal_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_good
bool strict_signal_quality_gate_ok = not use_lean_signal_quality_gate or signal_quality_high
// [v5.5b] Lean Context Gates: optional consensus layer on top of the primary Signal Quality gate.
if use_lean_context_gates
    int lean_context_count = 0
    if session_light_ok
        lean_context_count += 1
    if struct_light_trending
        lean_context_count += 1
    if ob_light_bull_ok
        lean_context_count += 1
    if fvg_light_active_ok
        lean_context_count += 1
    // Require at least 2 of 4 lean context gates to pass (soft consensus)
    bool lean_context_consensus_ok = lean_context_count >= 2
    primary_quality_gate_ok := primary_quality_gate_ok and lean_context_consensus_ok
[environment_hard_gate_ok, quality_gate_ok, microstructure_entry_gate_ok, trade_hard_gate_ok, long_environment_focus_display] = compute_long_environment_context(market_regime_gate_ok, vola_regime_gate_safe, primary_quality_gate_ok, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, event_risk_gate_ok)
string freshness_text = describe_long_freshness(long_state.armed, long_state.confirmed, ready_is_fresh, confirm_is_fresh)
string source_state_text = describe_long_source_state(long_source_tracked, long_source_alive, long_source_broken)
long_validation_source := resolve_long_validation_source(long_state.locked_source_kind)
long_setup_source_display := compose_long_setup_source_display(long_state.entry_origin_source, long_validation_source)
int effective_long_active_touch_count = select_effective_long_touch_count(long_state.armed, long_state.confirmed, long_state.backing_zone_touch_count, bull_reclaim_ob_strict, in_bull_ob_zone, in_bull_fvg_zone, active_ob_touch_count, bull_reclaim_fvg_strict, active_fvg_touch_count, active_zone_touch_count)
bool effective_zone_touch_quality_ok = true
if block_third_touch_eff
    effective_zone_touch_quality_ok := effective_long_active_touch_count <= max_zone_touches_for_entry
bool setup_hard_gate_ok = effective_zone_touch_quality_ok
string zone_quality_text = describe_long_zone_quality(long_zone_active, long_state.armed, long_state.confirmed, effective_long_active_touch_count)
[overhead_text, long_score_detail_suffix, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix] = compose_long_alert_text_suffixes(use_overhead_zone_filter_eff, headroom_to_overhead, planned_risk, lib_sq_score, lib_sq_tier, use_strict_sequence_eff, use_strict_sweep_for_zone_reclaim_eff, use_strict_confirm_guard, use_microstructure_profiles, micro_profile_text, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display)
[confirm_hard_gate_ok, confirm_upgrade_gate_ok, confirm_lifecycle_ok, confirm_filters_ok, long_should_confirm] = compute_long_confirm_transition_state(close_safe_mode, long_confirm_break, long_confirm_structure_ok, confirm_is_fresh, long_confirm_bearish_guard_ok, micro_session_gate_ok, micro_freshness_gate_ok, accel_confirm_gate_ok, sd_confirmed_gate_ok)
if long_should_confirm
    long_state.confirm(bar_index)
    long_confirm_signal := true

[long_building_state, ready_bar_gap_ok, scoring_accel_ready, scoring_sd_ready, scoring_vol_ready, scoring_stretch_ready, scoring_ddvi_ready, lifecycle_ready_ok, long_ready_state] = resolve_long_ready_projection_state(long_state.armed, long_internal_structure_ok, long_state.confirmed, long_state.confirm_bar_index, bar_index, use_scoring_over_blocking, accel_ready_gate_ok, sd_ready_gate_ok, vol_ready_context_ok, stretch_ready_context_ok, ddvi_ready_ok_safe, close_safe_mode, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready_eff, bull_bos_sig, main_bos_recent, setup_hard_gate_ok, trade_hard_gate_ok, environment_hard_gate_ok, quality_gate_ok)
[long_entry_best_state, long_entry_strict_state] = resolve_long_entry_projection_state(long_ready_state, best_signal_quality_gate_ok, accel_entry_best_gate_ok, sd_entry_best_gate_ok, vol_entry_best_context_ok_safe, stretch_entry_best_context_ok, ddvi_entry_best_ok_safe, strict_signal_quality_gate_ok, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)
[long_ready_blocker_text, long_strict_blocker_text] = resolve_long_execution_blocker_state(long_ready_state, long_state.confirmed, close_safe_mode, ready_bar_gap_ok, long_confirm_expired, ready_is_fresh, long_confirm_bearish_guard_ok, require_main_break_for_ready_eff, bull_bos_sig, main_bos_recent, setup_hard_gate_ok, trade_hard_gate_ok, environment_hard_gate_ok, session_structure_gate_ok, micro_session_gate_ok, micro_freshness_gate_ok, overhead_zone_ok, market_regime_gate_ok, vola_regime_gate_safe, quality_gate_ok, scoring_accel_ready, scoring_sd_ready, scoring_vol_ready, scoring_stretch_ready, scoring_ddvi_ready, long_entry_strict_state, strict_signal_quality_gate_ok, strict_entry_ltf_ok, htf_alignment_ok, accel_strict_entry_gate_ok, sd_entry_strict_gate_ok, vol_entry_strict_context_ok_safe, stretch_entry_strict_context_ok, ddvi_entry_strict_ok_safe)

// ── Trust enforcement (WP-3C) ──────────────────────────────────
// Suppress entry signals when measurement trust is Insufficient.
// Degraded trust is surfaced as a warning but does NOT suppress entry —
// the operator retains full discretion at that level.
string core_trust_tier_early = resolve_trust_tier(lib_sq_tier, lib_sq_freshness, lib_erl_provider_status)
bool trust_allows_entry = core_trust_tier_early != 'Insufficient'
if not trust_allows_entry
    long_entry_best_state := false
    long_entry_strict_state := false
    long_strict_blocker_text := 'Blocked: Trust Insufficient'

bool long_quality_clean_tier = resolve_long_clean_tier(close_safe_mode, bullish_trend_safe, zone_recent, reclaim_recent, long_state.confirmed, setup_hard_gate_ok, trade_hard_gate_ok, environment_hard_gate_ok, quality_gate_ok, bull_close_strong, ema_support_ok, adx_strong, relvol_ok, vwap_filter_ok)
[long_stop_level, long_risk_r, long_target_1, long_target_2] = compute_long_risk_plan_state(long_plan_active, long_planned_stop_level, planned_risk, long_state.trigger, target1_r, target2_r)
[bus_trigger_level, bus_invalidation_level, bus_stop_level, bus_target_1, bus_target_2] = resolve_long_bus_plan_levels(long_plan_active, long_state.trigger, long_state.invalidation_level, long_stop_level, long_target_1, long_target_2)

float long_mean_target = na
if long_plan_active and show_mean_target_overlay_eff and not na(stretch_mean)
    if stretch_mean > long_state.trigger
        long_mean_target := stretch_mean

varip int long_ready_state_rt_prev = 0
varip bool long_ready_fired_this_bar = false
bool long_ready_signal = false
[long_ready_state_rt_prev, long_ready_fired_this_bar, long_ready_signal] = obv.resolve_long_ready_signal_state(long_ready_state, long_ready_state[1], long_ready_state_rt_prev, long_ready_fired_this_bar, barstate.isnew)

long_setup_text := compose_long_setup_text(long_zone_active, long_state.armed, long_building_state, long_state.confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidated_now, invalidated_prior_setup, long_invalidated_this_bar, long_setup_source_display)

long_visual_state := resolve_long_visual_state(long_zone_active, long_state.armed, long_building_state, long_state.confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidate_signal, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)


// Lifecycle axis stays pure. Quality is shown in separate dashboard rows.
long_visual_text := resolve_long_visual_state_label(long_visual_state)
long_bg_color := resolve_long_bg_color(long_visual_state, long_color_building)
long_bar_color := resolve_long_bar_color(long_visual_state, long_color_building)
validate_long_state(long_state, show_long_engine_debug_eff)

string long_debug_summary_text = obv.emit_long_engine_debug_logs(show_long_engine_debug_eff, long_engine_debug_mode_eff, long_source_upgrade_now, long_arm_signal, long_confirm_signal, long_ready_signal, long_invalidate_signal, long_state.armed, long_state.confirmed, long_ready_state, long_setup_source_display, long_debug_event_source_display, long_state.backing_zone_touch_count, long_debug_event_touch_count, long_state.trigger, long_debug_event_trigger, long_state.invalidation_level, long_debug_event_invalidation, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_source_upgrade_reason, long_state.last_invalid_source, long_ready_blocker_text, long_strict_blocker_text)

if live_exec
    if not live_bull_ob_break and any_live_bull_ob_break
        live_bull_ob_break := true
    if not live_bull_fvg_fill and any_live_bull_fvg_fill
        live_bull_fvg_fill := true

// BUS Schema Version — Dashboard validates this on every bar
plot(7001, 'BUS SchemaVersion', display = display.none)
plot(long_zone_active ? 1.0 : 0.0, 'BUS ZoneActive', display = display.none)
