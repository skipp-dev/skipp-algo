            bool _c_active = _c_overlap >= 0
            bool _c_touch = not na(touched_bull_fvg_id) and _c_id == touched_bull_fvg_id and not na(touched_bull_fvg_bar_index) and bar_index - touched_bull_fvg_bar_index <= long_signal_window
            int _c_recency = resolve_fvg_recency_index(_cand)
            float _c_quality = fvg_quality_score(_cand, fvg_size_threshold)
            bool _prefer = na(_best_idx)
            if _c_active and not _prefer
                _prefer := zone_candidate_preferred(_c_touch, _c_recency, _c_quality, _c_overlap, _c_id, _best_touch, _best_recency, _best_quality, _best_overlap, _best_id)
            if _c_active and _prefer
                _best_idx := i
