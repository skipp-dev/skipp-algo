else if preset_is_pro
    require_main_break_for_ready_eff := true

bool use_ltf_for_strict_entry_eff = use_ltf_for_strict_entry
if preset_is_easy
    use_ltf_for_strict_entry_eff := false
else if preset_is_pro
    use_ltf_for_strict_entry_eff := true

bool performance_mode_light = performance_mode == 'Light'
bool performance_mode_balanced = performance_mode == 'Balanced'
bool performance_mode_pro = performance_mode == 'Pro'
bool performance_mode_debug = performance_mode == 'Debug'
bool render_visible_only_eff = false
if performance_mode_light
    render_visible_only_eff := true
else if performance_mode_balanced
    render_visible_only_eff := render_visible_only

bool keep_visual_history_eff = keep_visual_history
if performance_mode_debug
    keep_visual_history_eff := true
else if performance_mode_light
    keep_visual_history_eff := false

int object_gc_cycle_eff = object_gc_cycle
if performance_mode_light
    if object_gc_cycle == 0
        object_gc_cycle_eff := 100
    else
        object_gc_cycle_eff := math.min(object_gc_cycle, 100)
else if performance_mode_pro
    if object_gc_cycle == 0
        object_gc_cycle_eff := 0
    else
        object_gc_cycle_eff := math.max(object_gc_cycle, 250)
else if performance_mode_debug
    if object_gc_cycle == 0
        object_gc_cycle_eff := 0
    else
        object_gc_cycle_eff := math.max(object_gc_cycle, 500)

int max_ltf_ratio_eff = max_ltf_ratio
if performance_mode_light
    max_ltf_ratio_eff := math.min(max_ltf_ratio, 30)
else if performance_mode_pro
    max_ltf_ratio_eff := math.max(max_ltf_ratio, 120)
else if performance_mode_debug
    max_ltf_ratio_eff := math.max(max_ltf_ratio, 180)

int max_ltf_samples_per_bar_eff = max_ltf_samples_per_bar
if performance_mode_light
    max_ltf_samples_per_bar_eff := math.min(max_ltf_samples_per_bar, 120)
else if performance_mode_pro
    max_ltf_samples_per_bar_eff := math.max(max_ltf_samples_per_bar, 500)
else if performance_mode_debug
    max_ltf_samples_per_bar_eff := math.max(max_ltf_samples_per_bar, 800)

bool show_dashboard_ltf_eff = show_dashboard_ltf
if performance_mode_light
    show_dashboard_ltf_eff := false
else if performance_mode_debug
    show_dashboard_ltf_eff := true

int long_marker_history_limit_eff = long_marker_history_limit
if performance_mode_light
    long_marker_history_limit_eff := math.min(long_marker_history_limit, 25)
else if performance_mode_pro
    long_marker_history_limit_eff := math.max(long_marker_history_limit, 150)
else if performance_mode_debug
    long_marker_history_limit_eff := math.max(long_marker_history_limit, 250)

string long_engine_debug_mode_eff = long_engine_debug_mode
if performance_mode_light
    long_engine_debug_mode_eff := 'Compact'
else if performance_mode_debug
    long_engine_debug_mode_eff := 'Full'

// [v5.5a] Compact / Shared-Script Mode overrides: Hero-Surface UX
// Suppresses all debug overlays + secondary visual overlays.
// Filter logic is unchanged — only rendering affected.
bool show_ob_debug_eff = show_ob_debug
bool show_fvg_debug_eff = show_fvg_debug
bool show_long_engine_debug_eff = show_long_engine_debug
bool show_microstructure_debug_eff = show_microstructure_debug
bool show_strict_debug_markers_eff = show_strict_debug_markers
bool show_ema_support_eff = show_ema_support
bool show_session_vwap_eff = show_session_vwap
bool show_mean_target_overlay_eff = show_mean_target_overlay
if compact_mode
    show_ob_debug_eff := false
    show_fvg_debug_eff := false
    show_long_engine_debug_eff := false
    show_microstructure_debug_eff := false
    show_strict_debug_markers_eff := false
    show_dashboard_ltf_eff := false
    long_engine_debug_mode_eff := 'Compact'
    show_ema_support_eff := false
    show_session_vwap_eff := false
    show_mean_target_overlay_eff := false

active_break_mode = ct.LevelBreakMode.HIGHLOW
if signal_mode == ct.SignalMode.CONFIRMED_ONLY
    active_break_mode := ct.LevelBreakMode.CLOSE
string signal_mode_text = 'live rt-only'
if signal_mode == ct.SignalMode.CONFIRMED_ONLY
    signal_mode_text := 'confirmed'
int visible_left_time = na
int visible_right_time = na
if render_visible_only_eff
    visible_left_time := chart.left_visible_bar_time
    visible_right_time := chart.right_visible_bar_time

float soft_confirm_offset = smc_lib_atr(soft_confirm_offset_atr_len) * soft_confirm_offset_atr_mult
ob_threshold_atr = smc_lib_atr(ATR_LEN_MAIN)
ob_threshold_min = ob_threshold_atr * ob_filter_min_mult
ob_threshold_max = ob_threshold_atr * ob_filter_max_mult

float nonzero_volume_cum = ta.cum((not na(volume) and volume > 0) ? 1.0 : 0.0)
float nonzero_volume_bars = nonzero_volume_cum - nz(nonzero_volume_cum[volume_quality_lookback], 0.0)
float summed_volume_cum = ta.cum(nz(volume, 0))
float summed_volume = summed_volume_cum - nz(summed_volume_cum[volume_quality_lookback], 0.0)
bool volume_current_bar_ok = not na(volume) and volume > 0
bool volume_feed_quality_ok = summed_volume > 0 and nonzero_volume_bars >= min_nonzero_volume_bars
bool volume_data_ok = volume_current_bar_ok and volume_feed_quality_ok
bool use_ob_profile_effective = use_ob_profile and volume_feed_quality_ok
bool collect_ob_profile_current_bar = use_ob_profile_effective and volume_current_bar_ok

var label volume_quality_warning = na
if barstate.islast
    if not volume_current_bar_ok or not volume_feed_quality_ok
        string profile_warning_text = 'OB profiles are on'
        if not use_ob_profile
            profile_warning_text := 'OB profiles are already off'
        else if not volume_feed_quality_ok
            profile_warning_text := 'OB profiles are paused from weak feed'
        else if not volume_current_bar_ok
            profile_warning_text := 'OB profiles keep last valid shape'
        string relvol_warning_text = 'RelVol can stay blocked'
        if not use_rel_volume
            relvol_warning_text := 'RelVol is off'
        else if volume_current_bar_ok
            if allow_relvol_without_volume_data
                relvol_warning_text := 'RelVol can fall back'
        else if allow_relvol_without_volume_data
            relvol_warning_text := 'RelVol falls back on this bar'
        else
            relvol_warning_text := 'RelVol is blocked on this bar'
        string strict_warning_text = use_ltf_for_strict_entry_eff ? 'Strict and LTF delta stay limited' : 'Strict LTF is off'
        string volume_warning_text = str.format('Volume data quality is limited\n{0}; {1}; {2}', profile_warning_text, relvol_warning_text, strict_warning_text)
        if na(volume_quality_warning)
            volume_quality_warning := label.new(bar_index, close, volume_warning_text, color = color.orange, textcolor = color.white, style = label.style_label_left, size = size.small)
        else
            label.set_xy(volume_quality_warning, bar_index, close)
            label.set_text(volume_quality_warning, volume_warning_text)
    else if not na(volume_quality_warning)
        label.delete(volume_quality_warning)
        volume_quality_warning := na

var ProfileConfig profile_config_bull = ProfileConfig.new(poc_label_text = 'OB - POC ⬈', extend = ob_extend_until_broken, show_labels = true, args_poc_line = d.LineArgs.new(bull_ob_css_line, line.style_dashed, xloc = xloc.bar_index), args_poc_label = d.LabelArgs.new(bull_ob_css_line, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal))
var OrderBlockConfig ob_config_bull = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = d.BoxArgs.new(bg_color = bull_ob_css, border_color = #00000000, xloc = xloc.bar_index), txt_args = d.BoxTextArgs.new(color.green, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull)
var ProfileConfig profile_config_bull_broken = ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = d.LineArgs.new(bull_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_index), args_poc_label = d.LabelArgs.new(#00000000))
var OrderBlockConfig ob_config_bull_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = d.BoxArgs.new(bg_color = bull_ob_css_broken, border_color = #00000000, xloc = xloc.bar_index), txt_args = d.BoxTextArgs.new(bull_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull_broken)
ob_config_bull.show_profile := use_ob_profile_effective
ob_config_bull_broken.show_profile := use_ob_profile_effective

int chart_tf_sec = nz(timeframe.in_seconds(), 0)
bool intraday_time_chart = chart_tf_sec > 0 and chart_tf_sec < 86400
string current_symbol_key = syminfo.ticker
string current_symbol_key_qualified = syminfo.tickerid
bool micro_is_clean_reclaim = use_microstructure_profiles and u.csv_has_symbol_token(clean_reclaim_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_stop_hunt = use_microstructure_profiles and u.csv_has_symbol_token(stop_hunt_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_midday_dead = use_microstructure_profiles and u.csv_has_symbol_token(midday_dead_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_rth_only = use_microstructure_profiles and u.csv_has_symbol_token(rth_only_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_weak_premarket = use_microstructure_profiles and u.csv_has_symbol_token(weak_premarket_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_weak_afterhours = use_microstructure_profiles and u.csv_has_symbol_token(weak_afterhours_tickers_effective, current_symbol_key, current_symbol_key_qualified)
bool micro_is_fast_decay = use_microstructure_profiles and u.csv_has_symbol_token(fast_decay_tickers_effective, current_symbol_key, current_symbol_key_qualified)
string micro_profile_text = 'Default'
if micro_is_stop_hunt
    micro_profile_text := 'Stop-Hunt Sensitive'
else if micro_is_clean_reclaim
    micro_profile_text := 'Clean Reclaim'
else if micro_is_rth_only
    micro_profile_text := 'RTH Only'
else if micro_is_midday_dead
    micro_profile_text := 'Midday Dead'
else if micro_is_fast_decay
    micro_profile_text := 'Fast Decay'
string micro_modifier_text = ''
if micro_is_stop_hunt and micro_profile_text != 'Stop-Hunt Sensitive'
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Stop-Hunt'
    else
        micro_modifier_text := 'Stop-Hunt'
if micro_is_clean_reclaim and micro_profile_text != 'Clean Reclaim'
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Clean Reclaim'
    else
        micro_modifier_text := 'Clean Reclaim'
if micro_is_fast_decay and micro_profile_text != 'Fast Decay'
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Fast Decay'
    else
        micro_modifier_text := 'Fast Decay'
if micro_is_rth_only and micro_profile_text != 'RTH Only'
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', RTH Only'
    else
        micro_modifier_text := 'RTH Only'
if micro_is_midday_dead and micro_profile_text != 'Midday Dead'
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Midday Dead'
    else
        micro_modifier_text := 'Midday Dead'
if micro_is_weak_premarket
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Weak Premarket'
    else
        micro_modifier_text := 'Weak Premarket'
if micro_is_weak_afterhours
    if str.length(micro_modifier_text) > 0
        micro_modifier_text += ', Weak Afterhours'
    else
        micro_modifier_text := 'Weak Afterhours'
auto_selected_ltf = u.auto_ltf_timeframe(chart_tf_sec)
effective_ltf_timeframe = ltf_timeframe
if ltf_auto_select
    effective_ltf_timeframe := auto_selected_ltf
int effective_ltf_tf_sec = nz(timeframe.in_seconds(effective_ltf_timeframe), 0)
ltf_timeframe_valid = chart_tf_sec > 0 and str.length(effective_ltf_timeframe) > 0 and effective_ltf_tf_sec > 0 and effective_ltf_tf_sec < chart_tf_sec
int ltf_ratio = na
if effective_ltf_tf_sec > 0
    ltf_ratio := int(math.floor(chart_tf_sec / effective_ltf_tf_sec))
bool ltf_needed_for_logic = false
if (show_dashboard and show_dashboard_ltf_eff) or use_ltf_for_strict_entry_eff
    ltf_needed_for_logic := true
bool ltf_needed_for_messages = false
if enable_dynamic_alerts and use_ltf_for_dynamic_alerts
    ltf_needed_for_messages := true
bool ltf_needed = false
if ltf_needed_for_logic or ltf_needed_for_messages
    ltf_needed := true
bool ltf_ratio_ok = false
if not na(ltf_ratio) and ltf_ratio > 0 and ltf_ratio <= max_ltf_ratio_eff
    ltf_ratio_ok := true
bool ltf_sample_count_ok = false
if not na(ltf_ratio) and ltf_ratio <= max_ltf_samples_per_bar_eff
    ltf_sample_count_ok := true
ltf_sampling_active = false
if enable_ltf_sampling and ltf_timeframe_valid and ltf_needed and ltf_ratio_ok and ltf_sample_count_ok
    ltf_sampling_active := true
if barstate.isfirst and enable_ltf_sampling and ltf_timeframe_valid and (not ltf_ratio_ok or not ltf_sample_count_ok)
    log.warning(str.format('LTF sampling disabled: ratio chart/ltf = {0} exceeds configured limits. Chart TF={1}s, LTF={2}s, max_ratio={3}, max_samples={4}', ltf_ratio, chart_tf_sec, effective_ltf_tf_sec, max_ltf_ratio_eff, max_ltf_samples_per_bar_eff))
int marker_gap_reference_seconds = marker_gap_reference_minutes * 60
int effective_reclaim_marker_gap = u.scaled_marker_gap(reclaim_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_confirm_marker_gap = u.scaled_marker_gap(confirm_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_ready_marker_gap = u.scaled_marker_gap(ready_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)

[ltf_opens_raw, ltf_closes_raw, ltf_volumes_raw] = if ltf_sampling_active
    request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, [open, close, volume], calc_bars_count = 1)
else
    [array.new<float>(0), array.new<float>(0), array.new<float>(0)]
int ltf_open_count = ltf_opens_raw.size()
int ltf_close_count = ltf_closes_raw.size()
int ltf_volume_count = ltf_volumes_raw.size()
bool ltf_price_ok = false
if ltf_sampling_active and ltf_open_count > 0 and ltf_open_count == ltf_close_count
    ltf_price_ok := true
bool ltf_volume_ok = false
if ltf_price_ok and ltf_volume_count > 0 and ltf_volume_count == ltf_open_count
    ltf_volume_ok := true
bool ltf_price_only = false
if ltf_price_ok and not ltf_volume_ok
    ltf_price_only := true
float[] ltf_opens = array.new<float>(0)
if ltf_price_ok
    ltf_opens := ltf_opens_raw
float[] ltf_closes = array.new<float>(0)
if ltf_price_ok
    ltf_closes := ltf_closes_raw
float[] ltf_volumes = array.new<float>(0)
if ltf_volume_ok
    ltf_volumes := ltf_volumes_raw
[ltf_sample_count_raw, ltf_bull_share_raw, ltf_volume_delta_raw] = u.ltf_stats(ltf_opens, ltf_closes, ltf_volumes)
ltf_sample_count = 0
if ltf_price_ok
    ltf_sample_count := ltf_sample_count_raw
float ltf_bull_share = float(na)
if ltf_price_ok
    ltf_bull_share := ltf_bull_share_raw
float ltf_volume_delta = float(na)
if ltf_volume_ok
    ltf_volume_delta := ltf_volume_delta_raw
bool strict_ltf_available = false
if ltf_sampling_active and ltf_volume_ok
    strict_ltf_available := true
bool strict_ltf_unavailable = false
if use_ltf_for_strict_entry_eff and not strict_ltf_available
    strict_ltf_unavailable := true
bool strict_ltf_unverifiable = false
if use_ltf_for_strict_entry_eff and not barstate.isrealtime and not strict_ltf_available
    strict_ltf_unverifiable := true
var label strict_ltf_warning = na
if barstate.islast
    if strict_ltf_unavailable and not allow_strict_entry_without_ltf
        string strict_ltf_reason_text = 'LTF sampling is unavailable'
        if not enable_ltf_sampling
            strict_ltf_reason_text := 'LTF sampling is turned off'
        else if not ltf_timeframe_valid
            strict_ltf_reason_text := 'LTF timeframe is unavailable on this chart'
        else if not ltf_ratio_ok or not ltf_sample_count_ok
            strict_ltf_reason_text := 'LTF sampling is guarded by ratio/sample limits'
        else if not ltf_price_ok
            strict_ltf_reason_text := 'LTF intrabars are unavailable on this bar/history window'
        else if not ltf_volume_ok
            strict_ltf_reason_text := 'LTF volume is unavailable on this bar'
        string strict_ltf_warning_text = str.format('Strict entry is blocked\n{0}\nAdjust chart/LTF settings or enable the strict-entry fallback', strict_ltf_reason_text)
        if na(strict_ltf_warning)
            strict_ltf_warning := label.new(bar_index, high, strict_ltf_warning_text, color = color.new(color.red, 0), textcolor = color.white, style = label.style_label_upper_left, size = size.small)
        else
            label.set_xy(strict_ltf_warning, bar_index, high)
            label.set_text(strict_ltf_warning, strict_ltf_warning_text)
    else if not na(strict_ltf_warning)
        label.delete(strict_ltf_warning)
        strict_ltf_warning := na

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
float session_vwap_raw = ta.vwap(hlc3)
float session_vwap = float(na)
if intraday_time_chart
    session_vwap := session_vwap_raw
bool vwap_session_active = false
if intraday_time_chart and not na(time(timeframe.period, vwap_session))
    vwap_session_active := true
bool trade_entry_session_active = false
if intraday_time_chart and not na(time(timeframe.period, trade_entry_session))
    trade_entry_session_active := true
bool micro_midday_block_active = false
if intraday_time_chart and not na(time(timeframe.period, micro_midday_block_session))
    micro_midday_block_active := true
bool micro_premarket_active = false
if intraday_time_chart and not na(time(timeframe.period, micro_premarket_session))
    micro_premarket_active := true
bool micro_afterhours_active = false
if intraday_time_chart and not na(time(timeframe.period, micro_afterhours_session))
    micro_afterhours_active := true
bool session_gate_ok = true
if use_trade_session_gate and intraday_time_chart and block_entries_outside_session
    session_gate_ok := trade_entry_session_active
int opening_range_bars = 1
if chart_tf_sec > 0
    opening_range_bars := math.max(1, int(math.ceil(opening_range_minutes * 60.0 / chart_tf_sec)))
var float opening_range_high = na
var float opening_range_low = na
var int regular_session_open_bar = na
bool regular_session_just_opened = false
if vwap_session_active and not vwap_session_active[1]
    regular_session_just_opened := true
if regular_session_just_opened
    regular_session_open_bar := bar_index
    opening_range_high := high
    opening_range_low := low
else if vwap_session_active and not na(regular_session_open_bar)
    int bars_since_regular_open = bar_index - regular_session_open_bar
    if bars_since_regular_open < opening_range_bars
        if na(opening_range_high)
            opening_range_high := high
        else
            opening_range_high := math.max(opening_range_high, high)
        if na(opening_range_low)
            opening_range_low := low
        else
            opening_range_low := math.min(opening_range_low, low)
bool opening_range_ready = false
if vwap_session_active and not na(regular_session_open_bar) and bar_index - regular_session_open_bar >= opening_range_bars and not na(opening_range_high) and not na(opening_range_low)
    opening_range_ready := true
float opening_range_mid = float(na)
if opening_range_ready
    opening_range_mid := math.avg(opening_range_high, opening_range_low)
bool opening_range_gate_ok = true
if use_opening_range_gate and intraday_time_chart and vwap_session_active
    opening_range_gate_ok := false
    if opening_range_ready
        if opening_range_bias_mode == 'Above OR High'
            opening_range_gate_ok := close > opening_range_high
        else
            opening_range_gate_ok := close > opening_range_mid
bool session_structure_gate_ok = session_gate_ok and opening_range_gate_ok
bool micro_rth_gate_ok = true
if micro_is_rth_only and intraday_time_chart
    micro_rth_gate_ok := vwap_session_active
bool micro_midday_gate_ok = true
if micro_is_midday_dead and intraday_time_chart
    micro_midday_gate_ok := not micro_midday_block_active
bool micro_premarket_gate_ok = true
if micro_is_weak_premarket and intraday_time_chart
    micro_premarket_gate_ok := not micro_premarket_active
bool micro_afterhours_gate_ok = true
if micro_is_weak_afterhours and intraday_time_chart
    micro_afterhours_gate_ok := not micro_afterhours_active
bool micro_session_gate_ok = true
if use_microstructure_profiles and intraday_time_chart
    micro_session_gate_ok := micro_rth_gate_ok and micro_midday_gate_ok and micro_premarket_gate_ok and micro_afterhours_gate_ok
bool vwap_filter_ok = true
if use_vwap_filter and intraday_time_chart and vwap_session_active
    vwap_filter_ok := not na(session_vwap) and close >= session_vwap

plot(show_session_vwap_eff and intraday_time_chart ? session_vwap : na, 'Session VWAP', color = color.new(color.blue, 0), linewidth = 2)

plot(show_ema_support_eff ? ema_fast : na, 'EMA Fast', color = color.new(color.lime, 0), linewidth = 2)
plot(show_ema_support_eff ? ema_slow : na, 'EMA Slow', color = color.new(color.teal, 0), linewidth = 2)

[plus_di, minus_di, adx_value] = ta.dmi(adx_len, adx_len)
bool adx_data_ok = false
if not na(adx_value) and not na(plus_di) and not na(minus_di)
    adx_data_ok := true
float rel_volume_ma_raw = ta.sma(volume, relvol_len)
bool relvol_data_ok = false
if volume_current_bar_ok and not na(rel_volume_ma_raw) and rel_volume_ma_raw > 0
    relvol_data_ok := true
float rel_volume_ma = float(na)
if relvol_data_ok
    rel_volume_ma := rel_volume_ma_raw
float rel_volume = float(na)
if relvol_data_ok
    rel_volume := volume / rel_volume_ma

bar_range = math.max(high - low, syminfo.mintick)
bull_close_in_range = (close - low) / bar_range
float atr_now = smc_lib_atr(ATR_LEN_MAIN)
float atr_baseline = ta.sma(atr_now, vola_baseline_len)
float range_baseline = ta.sma(bar_range, vola_baseline_len)
bool vola_compression_now = false
if not na(atr_baseline) and not na(range_baseline) and atr_baseline > 0 and range_baseline > 0 and atr_now <= atr_baseline * compression_ratio_max and bar_range <= range_baseline * compression_ratio_max
    vola_compression_now := true
int compression_since_bars = ta.barssince(vola_compression_now)
bool vola_compression_recent = false
if not na(compression_since_bars) and compression_since_bars <= compression_recent_bars
    vola_compression_recent := true

bool bull_close_strong = true
if use_strong_close_filter
    bull_close_strong := bull_close_in_range >= min_close_in_range_pct
string close_state_text = 'off'
if use_strong_close_filter
    if bull_close_strong
        close_state_text := 'Strong Close'
    else
        close_state_text := 'Weak Close'
bool vola_expansion_now = false
if not na(range_baseline) and range_baseline > 0 and bar_range >= range_baseline * expansion_range_mult and bull_close_strong
    vola_expansion_now := true
bool vola_regime_gate_ok = true
if use_vola_compression_gate
    vola_regime_gate_ok := vola_compression_recent
    if require_expansion_on_confirm_or_ready
        vola_regime_gate_ok := vola_regime_gate_ok and vola_expansion_now

bool ema_support_ok = true
if show_ema_support
    ema_support_ok := false
    if close >= ema_fast and ema_fast >= ema_slow and ema_fast > ema_fast[1]
        ema_support_ok := true
string ema_state_text = 'off'
if show_ema_support
    if ema_support_ok
        ema_state_text := 'OK'
    else
        ema_state_text := 'No'
string vwap_state_text = 'off'
if use_vwap_filter
    if not intraday_time_chart
        vwap_state_text := 'n/a'
    else if not vwap_session_active
        vwap_state_text := 'off session'
    else if na(session_vwap)
        vwap_state_text := 'n/a'
    else if close >= session_vwap
        vwap_state_text := 'Above VWAP'
    else
        vwap_state_text := 'Below VWAP'

bool adx_strong = true
if use_adx
    adx_strong := false
    if adx_data_ok and adx_value >= adx_strong_min and plus_di >= minus_di
        adx_strong := true
string adx_state_text = 'off'
if use_adx
    if not adx_data_ok
        adx_state_text := 'n/a'
    else if plus_di < minus_di
        adx_state_text := 'Bearish pressure'
    else if adx_value < adx_trend_min
        adx_state_text := 'Sideways'
    else if adx_value < adx_strong_min
        adx_state_text := 'Trend building'
    else
        adx_state_text := 'Trend'

float accel_fast_raw = u.lr_slope_pct(close, accel_len_fast)
float accel_mid1_raw = u.lr_slope_pct(close, accel_len_mid1)
float accel_mid2_raw = u.lr_slope_pct(close, accel_len_mid2)
float accel_slow_raw = u.lr_slope_pct(close, accel_len_slow)
float accel_raw = u.weighted_avg4(accel_fast_raw, accel_mid1_raw, accel_mid2_raw, accel_slow_raw, 1.5, 1.25, 1.0, 0.75)
float accel_value = ta.ema(accel_raw, accel_smooth_len)
bool accel_above_zero = false
if not na(accel_value) and accel_value > accel_cross_threshold
    accel_above_zero := true
bool accel_below_zero = false
if not na(accel_value) and accel_value < accel_cross_threshold
    accel_below_zero := true
bool accel_rising = false
if not na(accel_value) and accel_value > accel_value[1]
    accel_rising := true
bool accel_below_zero_rising = false
if accel_below_zero and accel_rising
    accel_below_zero_rising := true
bool accel_cross_up = ta.crossover(accel_value, accel_cross_threshold)
int accel_cross_since_bars = ta.barssince(accel_cross_up)
bool accel_cross_up_recent = false
if not na(accel_cross_since_bars) and accel_cross_since_bars <= accel_recent_cross_bars
    accel_cross_up_recent := true
float accel_value_safe = accel_value
bool accel_below_zero_rising_safe = accel_below_zero_rising
bool accel_cross_up_safe = accel_cross_up
bool accel_cross_up_recent_safe = accel_cross_up_recent
if accel_close_safe_only and not barstate.isconfirmed
    accel_value_safe := nz(accel_value[1], accel_value)
    accel_below_zero_rising_safe := false
    accel_cross_up_safe := false
    accel_cross_up_recent_safe := false
    if bar_index > 0
        accel_below_zero_rising_safe := accel_below_zero_rising[1]
        accel_cross_up_safe := accel_cross_up[1]
        accel_cross_up_recent_safe := accel_cross_up_recent[1]
bool accel_pullback_exhaustion_long = false
if use_accel_module
    accel_pullback_exhaustion_long := accel_below_zero_rising_safe
bool accel_zero_cross_up = false
if accel_cross_up_safe
    accel_zero_cross_up := true
bool accel_reaccel_confirm_long = false
if use_accel_module
    accel_reaccel_confirm_long := accel_cross_up_safe
bool accel_recent_cross_long = false
if accel_cross_up_recent_safe
    accel_recent_cross_long := true
bool accel_mode_early_only = false
if accel_integration_mode == 'Early only'
    accel_mode_early_only := true
bool accel_mode_strict_entries_only = false
if accel_integration_mode == 'Strict entries only'
    accel_mode_strict_entries_only := true
bool accel_early_context_ok = true
if use_accel_module and accel_use_for_early
    accel_early_context_ok := accel_below_zero_rising_safe or accel_cross_up_recent_safe
bool accel_ready_context_ok = true
if use_accel_module and accel_use_for_ready
    accel_ready_context_ok := accel_below_zero_rising_safe or accel_cross_up_recent_safe
bool accel_entry_best_context_ok = true
if use_accel_module and accel_use_for_entry_best
    accel_entry_best_context_ok := accel_below_zero_rising_safe or accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_entry_strict_context_ok = true
if use_accel_module and accel_use_for_entry_strict
    accel_entry_strict_context_ok := accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_early_gate_ok = true
if not accel_early_context_ok
    accel_early_gate_ok := false
bool accel_confirm_gate_ok = true
if use_accel_module and not accel_mode_early_only and not accel_mode_strict_entries_only
    accel_confirm_gate_ok := accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_ready_gate_ok = true
if use_accel_module and not accel_mode_strict_entries_only
    if require_accel_above_zero_for_ready
        accel_ready_gate_ok := (not na(accel_value_safe) and accel_value_safe > accel_cross_threshold) or accel_cross_up_recent_safe
    else
        accel_ready_gate_ok := accel_ready_context_ok
bool accel_entry_best_gate_ok = true
if use_accel_module
    if not accel_entry_best_context_ok
        accel_entry_best_gate_ok := false
bool accel_strict_entry_gate_ok = true
if use_accel_module
    if not accel_entry_strict_context_ok
        accel_strict_entry_gate_ok := false

float sd_raw = u.sd_lr2_pct(close, sd_lr_len)
float sd_value = ta.ema(sd_raw, sd_smooth_len)
bool sd_above_zero = false
if not na(sd_value) and sd_value > 0
    sd_above_zero := true
bool sd_below_zero = false
if not na(sd_value) and sd_value < 0
    sd_below_zero := true
bool sd_rising = false
if not na(sd_value) and sd_value > sd_value[1]
    sd_rising := true
bool sd_falling = false
if not na(sd_value) and sd_value < sd_value[1]
    sd_falling := true

var float last_price_pivot_low = na
var float last_sd_at_price_pivot_low = na
var int last_price_pivot_low_bar = na
bool sd_bullish_divergence_event = false
float price_pivot_low = ta.pivotlow(low, sd_pivot_len, sd_pivot_len)
if not na(price_pivot_low)
    float new_price_pivot_low = price_pivot_low
    float new_sd_at_price_pivot_low = sd_value[sd_pivot_len]
    int new_price_pivot_low_bar = bar_index - sd_pivot_len
    sd_bullish_divergence_event :=
         not na(last_price_pivot_low) and
         not na(last_sd_at_price_pivot_low) and
         new_price_pivot_low < last_price_pivot_low and
         new_sd_at_price_pivot_low > last_sd_at_price_pivot_low
    last_price_pivot_low := new_price_pivot_low
    last_sd_at_price_pivot_low := new_sd_at_price_pivot_low
    last_price_pivot_low_bar := new_price_pivot_low_bar

int sd_bull_div_since_bars = ta.barssince(sd_bullish_divergence_event)
bool sd_bullish_divergence_recent = false
if not na(sd_bull_div_since_bars) and sd_bull_div_since_bars <= sd_recent_window
    sd_bullish_divergence_recent := true

var float last_sd_pivot_low = na
var int sd_higher_low_streak = 0
bool sd_higher_lows_event = false
float sd_pivot_low = ta.pivotlow(sd_value, sd_pivot_len, sd_pivot_len)
if not na(sd_pivot_low)
    float new_sd_pivot_low = sd_pivot_low
    if not na(last_sd_pivot_low) and new_sd_pivot_low > last_sd_pivot_low
        sd_higher_low_streak += 1
    else
        sd_higher_low_streak := 0
    last_sd_pivot_low := new_sd_pivot_low
    sd_higher_lows_event := sd_higher_low_streak >= sd_higher_low_steps_required

int sd_higher_lows_since_bars = ta.barssince(sd_higher_lows_event)
bool sd_higher_lows_recent = false
if not na(sd_higher_lows_since_bars) and sd_higher_lows_since_bars <= sd_recent_window
    sd_higher_lows_recent := true

bool sd_support_any_recent = false
if sd_bullish_divergence_recent or sd_higher_lows_recent
    sd_support_any_recent := true
bool sd_support_both_recent = false
if sd_bullish_divergence_recent and sd_higher_lows_recent
    sd_support_both_recent := true
bool sd_ready_context_ok = sd_support_any_recent
if sd_require_osc_rising_for_ready
    sd_ready_context_ok := sd_support_any_recent and sd_rising
bool sd_armed_gate_ok = true
if use_sd_confluence and sd_require_for_armed
    if not sd_support_any_recent
        sd_armed_gate_ok := false
bool sd_early_gate_ok = true
if use_sd_confluence and sd_require_for_early
    if not sd_support_any_recent
        sd_early_gate_ok := false
bool sd_confirmed_gate_ok = true
if use_sd_confluence and sd_require_for_confirmed
    if not sd_support_any_recent
        sd_confirmed_gate_ok := false
bool sd_ready_gate_ok = true
if use_sd_confluence and sd_require_for_ready
    if not sd_ready_context_ok
        sd_ready_gate_ok := false
bool sd_entry_best_context_ok = true
if not sd_support_any_recent
    sd_entry_best_context_ok := false
if sd_require_for_ready
    if not sd_ready_context_ok
        sd_entry_best_context_ok := false
bool sd_entry_best_gate_ok = true
if use_sd_confluence and sd_require_for_entry_best
    if not sd_entry_best_context_ok
        sd_entry_best_gate_ok := false
bool sd_entry_strict_context_ok = true
if not sd_support_any_recent
    sd_entry_strict_context_ok := false
if sd_require_both_for_entry_strict
    if not sd_support_both_recent
        sd_entry_strict_context_ok := false
if sd_require_for_ready
    if not sd_ready_context_ok
        sd_entry_strict_context_ok := false
bool sd_entry_strict_gate_ok = true
if use_sd_confluence
    if not sd_entry_strict_context_ok
        sd_entry_strict_gate_ok := false

float effective_ob_reclaim_min_penetration = 0.0
effective_ob_reclaim_min_penetration := ob_reclaim_min_penetration
float effective_fvg_reclaim_min_penetration = 0.0
effective_fvg_reclaim_min_penetration := fvg_reclaim_min_penetration
float effective_relvol_good = 0.0
effective_relvol_good := relvol_good
float effective_long_invalidation_atr_mult = 0.0
effective_long_invalidation_atr_mult := long_invalidation_atr_mult
bool effective_use_live_confirm_break = true
if not use_live_confirm_break
    effective_use_live_confirm_break := false
bool effective_use_live_invalidation_break = true
if not use_live_invalidation_break
    effective_use_live_invalidation_break := false
int effective_fast_decay_setup_age_max = 0
effective_fast_decay_setup_age_max := long_setup_expiry_bars
int effective_fast_decay_confirm_age_max = 0
effective_fast_decay_confirm_age_max := long_confirm_expiry_bars
if use_microstructure_profiles and micro_is_stop_hunt
    effective_ob_reclaim_min_penetration := math.max(effective_ob_reclaim_min_penetration, micro_stop_hunt_ob_sweep_depth)
    effective_fvg_reclaim_min_penetration := math.max(effective_fvg_reclaim_min_penetration, micro_stop_hunt_fvg_sweep_depth)
    effective_relvol_good := math.max(effective_relvol_good, micro_stop_hunt_relvol_min)
    effective_long_invalidation_atr_mult := math.max(effective_long_invalidation_atr_mult, micro_stop_hunt_invalidation_atr)
    if micro_stop_hunt_force_close_confirm
        effective_use_live_confirm_break := false
    if micro_stop_hunt_disable_live_invalid
        effective_use_live_invalidation_break := false
if use_microstructure_profiles and micro_is_fast_decay
    effective_fast_decay_setup_age_max := math.min(effective_fast_decay_setup_age_max, micro_fast_decay_setup_age_max)
    effective_fast_decay_confirm_age_max := math.min(effective_fast_decay_confirm_age_max, micro_fast_decay_confirm_age_max)

bool relvol_ok = true
if use_rel_volume
    if not relvol_data_ok
        relvol_ok := allow_relvol_without_volume_data
    else
        relvol_ok := false
        if not na(rel_volume) and rel_volume >= effective_relvol_good
            relvol_ok := true
bool relvol_score_ok = true
if use_rel_volume
    relvol_score_ok := false
    if relvol_data_ok and not na(rel_volume) and rel_volume >= effective_relvol_good
        relvol_score_ok := true
string relvol_value_text = 'n/a'
if not na(rel_volume)
    string relvol_value_label = str.tostring(rel_volume, '#.##') + 'x'
    relvol_value_text := relvol_value_label
string relvol_text = 'off'
if use_rel_volume
    if not relvol_data_ok
        if allow_relvol_without_volume_data
            relvol_text := 'fallback'
        else
            relvol_text := 'blocked'
    else
        relvol_text := relvol_value_text

compute_vol_regime() =>
    float _ma1q = u.qema_like(close, vol_ma_len_1)
    float _ma2q = u.qema_like(close, vol_ma_len_2)
    float _ma3q = u.qema_like(close, vol_ma_len_3)
    float _ma4q = u.qema_like(close, vol_ma_len_4)
    float _ma1e = ta.ema(close, vol_ma_len_1)
    float _ma2e = ta.ema(close, vol_ma_len_2)
    float _ma3e = ta.ema(close, vol_ma_len_3)
    float _ma4e = ta.ema(close, vol_ma_len_4)
    float _ma1 = _ma1e
    if vol_ma_mode == 'QEMA-like'
        _ma1 := _ma1q
    float _ma2 = _ma2e
    if vol_ma_mode == 'QEMA-like'
        _ma2 := _ma2q
    float _ma3 = _ma3e
    if vol_ma_mode == 'QEMA-like'
        _ma3 := _ma3q
    float _ma4 = _ma4e
    if vol_ma_mode == 'QEMA-like'
        _ma4 := _ma4q
    bool _stack_order = false
    if _ma1 > _ma2 and _ma2 > _ma3 and _ma3 > _ma4
        _stack_order := true
    bool _stack_slopes = false
    if _ma1 > _ma1[1] and _ma2 > _ma2[1] and _ma3 > _ma3[1] and _ma4 > _ma4[1]
        _stack_slopes := true
    float _gap12 = math.max(_ma1 - _ma2, 0.0)
    float _gap23 = math.max(_ma2 - _ma3, 0.0)
    float _gap34 = math.max(_ma3 - _ma4, 0.0)
    float _spread_pct = 100.0 * (_gap12 + _gap23 + _gap34) / math.max(math.abs(close), syminfo.mintick)
    bool _spread_rising = false
    if not na(_spread_pct) and _spread_pct > _spread_pct[1]
        _spread_rising := true
    float _mom_raw = ta.roc(close, vol_momentum_len)
    float _mom = ta.ema(_mom_raw, vol_momentum_smooth)
    bool _mom_expanding = false
    if not na(_mom) and _mom > 0 and _mom > _mom[1]
        _mom_expanding := true
    float _bb_basis = ta.sma(close, vol_bb_len)
    float _bb_dev = ta.stdev(close, vol_bb_len) * vol_bb_mult
    float _bb_upper = _bb_basis + _bb_dev
    float _bb_lower = _bb_basis - _bb_dev
    float _kc_basis = ta.ema(close, vol_kc_len)
    float _kc_range = ta.atr(vol_kc_len) * vol_kc_mult
    float _kc_upper = _kc_basis + _kc_range
    float _kc_lower = _kc_basis - _kc_range
    bool _squeeze = false
    if _bb_upper < _kc_upper and _bb_lower > _kc_lower
        _squeeze := true
    bool _released = false
    if not _squeeze and _squeeze[1]
        _released := true
    int _sq_since = ta.barssince(_squeeze)
    bool _sq_recent = false
    if not na(_sq_since) and _sq_since <= vol_squeeze_recent_bars
        _sq_recent := true
    int _rel_since = ta.barssince(_released)
    bool _rel_recent = false
    if not na(_rel_since) and _rel_since <= vol_release_recent_bars
        _rel_recent := true
    bool _trend_ok = false
    if _stack_order and (not vol_require_all_stack_slopes or _stack_slopes)
        _trend_ok := true
    [_stack_slopes, _spread_rising, _mom_expanding, _squeeze, _released, _sq_recent, _rel_recent, _trend_ok]

[vol_bull_stack_slopes, vol_stack_spread_rising, vol_momentum_expanding_long, vol_squeeze_on, vol_squeeze_released, vol_squeeze_recent, vol_squeeze_release_recent, vol_regime_trend_ok] = compute_vol_regime()

bool vol_watchlist_context_ok = true
if use_volatility_regime
    if not vol_regime_trend_ok
        vol_watchlist_context_ok := false
    if vol_require_squeeze_for_watchlist
        vol_watchlist_context_ok := vol_watchlist_context_ok and (vol_squeeze_on or vol_squeeze_recent or vol_squeeze_release_recent)

bool vol_ready_context_ok = true
if use_volatility_regime
    vol_ready_context_ok := false
    if vol_regime_trend_ok and vol_momentum_expanding_long and vol_stack_spread_rising
        vol_ready_context_ok := true
    if vol_require_squeeze_for_ready
        vol_ready_context_ok := vol_ready_context_ok and (vol_squeeze_on or vol_squeeze_recent or vol_squeeze_release_recent)

bool vol_entry_best_context_ok = true
if use_volatility_regime
    if not vol_ready_context_ok
        vol_entry_best_context_ok := false
    if vol_require_release_for_entry_best
        vol_entry_best_context_ok := vol_entry_best_context_ok and vol_squeeze_release_recent

bool vol_entry_strict_context_ok = true
if use_volatility_regime
    vol_entry_strict_context_ok := false
    if vol_entry_best_context_ok and vol_bull_stack_slopes
        vol_entry_strict_context_ok := true
    if vol_require_release_for_entry_strict
        vol_entry_strict_context_ok := vol_entry_strict_context_ok and vol_squeeze_release_recent

bool vol_watchlist_context_ok_safe = true
if not vol_watchlist_context_ok
    vol_watchlist_context_ok_safe := false
bool vol_entry_best_context_ok_safe = true
if not vol_entry_best_context_ok
    vol_entry_best_context_ok_safe := false
bool vol_entry_strict_context_ok_safe = true
if not vol_entry_strict_context_ok
    vol_entry_strict_context_ok_safe := false
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    if bar_index > 0
        vol_watchlist_context_ok_safe := vol_watchlist_context_ok[1]
        vol_entry_best_context_ok_safe := vol_entry_best_context_ok[1]
        vol_entry_strict_context_ok_safe := vol_entry_strict_context_ok[1]

float stretch_mean = ta.sma(close, stretch_len)
float stretch_std = ta.stdev(close, stretch_len)
float stretch_lower_threshold = float(na)
if not na(stretch_mean) and not na(stretch_std)
    stretch_lower_threshold := stretch_mean - lower_extreme_z * stretch_std
bool in_lower_extreme = false
if not na(stretch_lower_threshold) and low <= stretch_lower_threshold
    in_lower_extreme := true
int lower_extreme_since_bars = ta.barssince(in_lower_extreme)
bool lower_extreme_recent = false
if not na(lower_extreme_since_bars) and lower_extreme_since_bars <= lower_extreme_recent_bars
    lower_extreme_recent := true
float distance_to_mean_z = float(na)
if not na(stretch_mean) and not na(stretch_std) and stretch_std > 0
    distance_to_mean_z := (close - stretch_mean) / stretch_std
bool anti_chase_ok_ready = true
if use_stretch_context and not na(distance_to_mean_z)
    anti_chase_ok_ready := distance_to_mean_z <= anti_chase_max_z_ready
bool anti_chase_ok_entry_best = true
if use_stretch_context and not na(distance_to_mean_z)
    anti_chase_ok_entry_best := distance_to_mean_z <= anti_chase_max_z_best
bool anti_chase_ok_entry_strict = true
if use_stretch_context and not na(distance_to_mean_z)
    anti_chase_ok_entry_strict := distance_to_mean_z <= anti_chase_max_z_strict
bool stretch_watchlist_context_ok = true
if use_stretch_context and stretch_require_lower_extreme_for_watchlist
    stretch_watchlist_context_ok := in_lower_extreme or lower_extreme_recent
bool stretch_ready_context_ok = true
if use_stretch_context
    stretch_ready_context_ok := anti_chase_ok_ready
    if stretch_require_lower_extreme_for_ready
        stretch_ready_context_ok := stretch_ready_context_ok and (in_lower_extreme or lower_extreme_recent)
bool stretch_entry_best_context_ok = true
if use_stretch_context
    stretch_entry_best_context_ok := stretch_ready_context_ok and anti_chase_ok_entry_best
    if stretch_require_lower_extreme_for_entry_best
        stretch_entry_best_context_ok := stretch_entry_best_context_ok and (in_lower_extreme or lower_extreme_recent)
bool stretch_entry_strict_context_ok = true
if use_stretch_context
    stretch_entry_strict_context_ok := stretch_entry_best_context_ok and anti_chase_ok_entry_strict
    if stretch_require_lower_extreme_for_entry_strict
        stretch_entry_strict_context_ok := stretch_entry_strict_context_ok and (in_lower_extreme or lower_extreme_recent)

float ddvi_plus = na
float ddvi_minus = na
float ddvi_advx = na
float ddvi = na
float ddvi_bb_basis = na
float ddvi_bb_upper = na
float ddvi_bb_lower = na
bool ddvi_strong_bull = false
bool ddvi_hidden_bull = false
bool ddvi_event_bar_ok = barstate.isconfirmed
if not ddvi_close_safe_only and signal_mode == ct.SignalMode.AGGRESSIVE_LIVE
    ddvi_event_bar_ok := true
[ddvi_plus_raw, ddvi_minus_raw, ddvi_advx_raw] = smc_lib_dmi(ddvi_di_length, ddvi_advx_smooth)
float ddvi_raw = ddvi_plus_raw - ddvi_minus_raw
float ddvi_ma_raw = smc_lib_get_ma(ddvi_ma_select, ddvi_raw, ddvi_ma_len)
[ddvi_bb_basis_raw, ddvi_bb_upper_raw, ddvi_bb_lower_raw] = smc_lib_bb(ddvi_ma_raw, ddvi_bb_len, ddvi_bb_mult, ddvi_bb_ma_select)
[ddvi_strong_bull_raw, _, _, _, _, _, ddvi_hidden_bull_raw, _, _, _] = smc_lib_detect_divergence(ddvi_ma_raw, ddvi_pivot_left, ddvi_pivot_right, ddvi_div_min_range, ddvi_div_max_range, low, high, ddvi_eq_zone_len, ddvi_eq_zone_dev_mult, ddvi_eq_zone_atr_mult)
ddvi_plus := ddvi_plus_raw
ddvi_minus := ddvi_minus_raw
ddvi_advx := ddvi_advx_raw
ddvi := ddvi_ma_raw
ddvi_bb_basis := ddvi_bb_basis_raw
ddvi_bb_upper := ddvi_bb_upper_raw
ddvi_bb_lower := ddvi_bb_lower_raw
ddvi_strong_bull := ddvi_strong_bull_raw
ddvi_hidden_bull := ddvi_hidden_bull_raw

bool ddvi_bias_cross_up_raw = ta.crossover(ddvi_ma_raw, 0)
bool ddvi_recover_from_lower_extreme_raw = ta.crossover(ddvi_ma_raw, ddvi_bb_lower_raw)
bool ddvi_bias_bull = false
if use_ddvi_context and not na(ddvi) and ddvi > 0
    ddvi_bias_bull := true
bool ddvi_bias_rising = false
if use_ddvi_context and not na(ddvi) and not na(ddvi[1]) and ddvi > ddvi[1]
    ddvi_bias_rising := true
bool ddvi_bias_cross_up = false
if use_ddvi_context and ddvi_event_bar_ok and not na(ddvi) and ddvi_bias_cross_up_raw
    ddvi_bias_cross_up := true
bool ddvi_bias_ok = false
if ddvi_bias_bull and ddvi_bias_rising
    ddvi_bias_ok := true
bool ddvi_bias_transition_ok = false
if ddvi_bias_cross_up or (ddvi_bias_bull and ddvi_bias_rising)
    ddvi_bias_transition_ok := true
bool ddvi_lower_extreme_now = false
if use_ddvi_context and not na(ddvi) and not na(ddvi_bb_lower) and ddvi <= ddvi_bb_lower
    ddvi_lower_extreme_now := true
int ddvi_lower_extreme_since = ta.barssince(ddvi_lower_extreme_now)
bool ddvi_lower_extreme_recent = false
if use_ddvi_context and not na(ddvi_lower_extreme_since) and ddvi_lower_extreme_since <= ddvi_lower_extreme_lookback
    ddvi_lower_extreme_recent := true
bool ddvi_recover_from_lower_extreme = false
if use_ddvi_context and ddvi_event_bar_ok and not na(ddvi) and not na(ddvi_bb_lower) and ddvi_recover_from_lower_extreme_raw
    ddvi_recover_from_lower_extreme := true
bool ddvi_lower_extreme_context = false
if ddvi_lower_extreme_now or ddvi_lower_extreme_recent or ddvi_recover_from_lower_extreme
    ddvi_lower_extreme_context := true
bool hidden_bull_divergence = false
if use_ddvi_context and use_ddvi_hidden_bull and ddvi_hidden_bull
    hidden_bull_divergence := true
bool strong_bull_divergence = false
if use_ddvi_context and use_ddvi_strong_bull and ddvi_strong_bull
    strong_bull_divergence := true
bool ddvi_bull_divergence_any = false
if hidden_bull_divergence or strong_bull_divergence
    ddvi_bull_divergence_any := true
bool ddvi_watchlist_ok = true
if use_ddvi_context
    ddvi_watchlist_ok := ddvi_lower_extreme_context or ddvi_bias_rising
bool ddvi_ready_ok = true
if use_ddvi_context
    ddvi_ready_ok := ddvi_recover_from_lower_extreme or (ddvi_bias_rising and not ddvi_lower_extreme_now)
bool ddvi_entry_best_ok = true
if use_ddvi_context
    ddvi_entry_best_ok := ddvi_ready_ok and (ddvi_bias_transition_ok or hidden_bull_divergence or strong_bull_divergence)
bool ddvi_entry_strict_ok = true
if use_ddvi_context
    ddvi_entry_strict_ok := ddvi_entry_best_ok and ddvi_bias_ok and not ddvi_lower_extreme_now
if ddvi_close_safe_only and not barstate.isconfirmed
    if bar_index > 0
        ddvi_watchlist_ok := ddvi_watchlist_ok[1]
        ddvi_ready_ok := ddvi_ready_ok[1]
        ddvi_entry_best_ok := ddvi_entry_best_ok[1]
        ddvi_entry_strict_ok := ddvi_entry_strict_ok[1]
bool ddvi_watchlist_ok_safe = ddvi_watchlist_ok
bool ddvi_ready_ok_safe = ddvi_ready_ok
bool ddvi_entry_best_ok_safe = ddvi_entry_best_ok
bool ddvi_entry_strict_ok_safe = ddvi_entry_strict_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    if bar_index > 0
        ddvi_watchlist_ok_safe := ddvi_watchlist_ok[1]
        ddvi_ready_ok_safe := ddvi_ready_ok[1]
        ddvi_entry_best_ok_safe := ddvi_entry_best_ok[1]
        ddvi_entry_strict_ok_safe := ddvi_entry_strict_ok[1]

mtf_trend_1 = get_confirmed_structure_trend(mtf_trend_tf1, swing_length)
mtf_trend_2 = get_confirmed_structure_trend(mtf_trend_tf2, swing_length)
mtf_trend_3 = get_confirmed_structure_trend(mtf_trend_tf3, swing_length)
[index_missing_calc, index_gate_ok_calc] = u.external_trend_gate(index_gate_symbol, market_gate_fast_len, market_gate_slow_len)
[sector_missing_calc, sector_gate_ok_calc] = u.external_trend_gate(sector_gate_symbol, market_gate_fast_len, market_gate_slow_len)
string breadth_gate_symbol_effective = str.trim(breadth_gate_symbol)
bool breadth_missing_calc = false
bool breadth_gate_ok_calc = true
if use_breadth_symbol_gate
    if str.length(breadth_gate_symbol_effective) > 0
        [breadth_missing_calc_value, breadth_gate_ok_calc_value] = u.external_breadth_gate(breadth_gate_symbol_effective, breadth_gate_mode, breadth_gate_len)
        breadth_missing_calc := breadth_missing_calc_value
        breadth_gate_ok_calc := breadth_gate_ok_calc_value
    else
        breadth_missing_calc := true
        breadth_gate_ok_calc := false
bool index_missing = use_index_gate and index_missing_calc
bool index_gate_ok_raw = true
if use_index_gate
    index_gate_ok_raw := index_gate_ok_calc
bool sector_missing = use_sector_gate and sector_missing_calc
bool sector_gate_ok_raw = true
if use_sector_gate
    sector_gate_ok_raw := sector_gate_ok_calc
bool breadth_missing = use_breadth_symbol_gate and breadth_missing_calc
bool breadth_gate_ok_raw = true
if use_breadth_symbol_gate
    breadth_gate_ok_raw := breadth_gate_ok_calc
bool market_symbols_missing = false
if (use_index_gate and index_missing) or (use_sector_gate and sector_missing) or (use_breadth_symbol_gate and breadth_missing)
    market_symbols_missing := true
bool index_gate_effective_ok = true
if use_index_gate
    index_gate_effective_ok := index_gate_ok_raw
    if index_missing
        index_gate_effective_ok := not block_on_missing_market_symbol
bool sector_gate_effective_ok = true
if use_sector_gate
    sector_gate_effective_ok := sector_gate_ok_raw
