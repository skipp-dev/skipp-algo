    '\n' + compose_long_debug_upgrade_text(long_source_upgrade_reason)

compose_long_debug_newline_last_invalid_text(string long_last_invalid_source) =>
    '\n' + compose_long_debug_last_invalid_text(long_last_invalid_source)

compose_long_debug_levels_text(float long_setup_trigger, float long_invalidation_level, string overhead_text) =>
    'trig=' + u.format_level(long_setup_trigger) + ' | inv=' + u.format_level(long_invalidation_level) + ' | overhead=' + overhead_text

compose_long_debug_event_context_text(int long_setup_backing_zone_touch_count, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display) =>
    'touch=' + str.tostring(long_setup_backing_zone_touch_count) + ' | ' + compose_long_debug_fresh_source_text(freshness_text, source_state_text) + ' | ' + compose_long_debug_zone_env_text(zone_quality_text, long_environment_focus_display)

compose_long_debug_label_full_mode_text(string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, string long_ready_blocker_text, string long_strict_blocker_text, float long_setup_trigger, float long_invalidation_level, string overhead_text) =>
    '\n' + compose_long_debug_fresh_source_text(freshness_text, source_state_text) + '\n' + compose_long_debug_zone_env_text(zone_quality_text, long_environment_focus_display) + '\n' + compose_long_debug_ready_strict_text(long_ready_blocker_text, long_strict_blocker_text) + '\n' + compose_long_debug_levels_text(long_setup_trigger, long_invalidation_level, overhead_text)

compose_long_debug_event_state_text(bool debug_mode_full, int long_setup_backing_zone_touch_count, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, string long_ready_blocker_text, string long_strict_blocker_text) =>
    string event_state_text = ' | ' + compose_long_debug_ready_strict_text(long_ready_blocker_text, long_strict_blocker_text)
    if debug_mode_full
        event_state_text := ' | ' + compose_long_debug_event_context_text(long_setup_backing_zone_touch_count, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display) + event_state_text
    event_state_text

compose_long_debug_primary_line(bool debug_mode_full, string long_setup_source_display, int long_setup_backing_zone_touch_count, string long_ready_blocker_text, string long_strict_blocker_text) =>
    string primary_line = compose_long_debug_compact_text(long_setup_source_display, long_ready_blocker_text, long_strict_blocker_text)
    if debug_mode_full
        primary_line := compose_long_debug_source_touch_text(long_setup_source_display, long_setup_backing_zone_touch_count)
    primary_line

compose_long_debug_label_header_text(string long_engine_debug_mode, string long_setup_text, string long_visual_text) =>
    'Long Engine (' + long_engine_debug_mode + ')\nsetup=' + long_setup_text + ' | visual=' + long_visual_text

compose_long_debug_event_header_text(string event_name, string long_setup_source_display, float long_setup_trigger, float long_invalidation_level) =>
    event_name + ' | src=' + long_setup_source_display + ' | trig=' + u.format_level(long_setup_trigger) + ' | inv=' + u.format_level(long_invalidation_level)

resolve_long_engine_debug_label_display_text(string long_engine_debug_mode, string long_setup_text, string long_visual_text, string long_setup_source_display, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, string overhead_text, float long_setup_trigger, float long_invalidation_level, int long_setup_backing_zone_touch_count, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    bool debug_mode_full = debug_mode_is_full(long_engine_debug_mode)
    string debug_text = compose_long_debug_label_header_text(long_engine_debug_mode, long_setup_text, long_visual_text)
    debug_text += '\n' + compose_long_debug_primary_line(debug_mode_full, long_setup_source_display, long_setup_backing_zone_touch_count, long_ready_blocker_text, long_strict_blocker_text)
    if debug_mode_full
        debug_text += compose_long_debug_label_full_mode_text(freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_ready_blocker_text, long_strict_blocker_text, long_setup_trigger, long_invalidation_level, overhead_text)
    if long_source_upgrade_now
        debug_text += compose_long_debug_newline_upgrade_text(long_source_upgrade_reason)
    if long_last_invalid_source != 'None'
        debug_text += compose_long_debug_newline_last_invalid_text(long_last_invalid_source)
    debug_text

compose_long_engine_debug_label_text(string long_engine_debug_mode, string long_setup_text, string long_visual_text, string long_setup_source_display, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, string overhead_text, float long_setup_trigger, float long_invalidation_level, int long_setup_backing_zone_touch_count, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    resolve_long_engine_debug_label_display_text(long_engine_debug_mode, long_setup_text, long_visual_text, long_setup_source_display, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, overhead_text, long_setup_trigger, long_invalidation_level, long_setup_backing_zone_touch_count, long_source_upgrade_now, long_source_upgrade_reason, long_last_invalid_source, long_ready_blocker_text, long_strict_blocker_text)

resolve_long_engine_event_log_display_text(string long_engine_debug_mode, string event_name, string long_setup_source_display, float long_setup_trigger, float long_invalidation_level, int long_setup_backing_zone_touch_count, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display, bool long_source_upgrade_now, string long_source_upgrade_reason, string long_last_invalid_source, string long_ready_blocker_text, string long_strict_blocker_text) =>
    bool debug_mode_full = debug_mode_is_full(long_engine_debug_mode)
    string event_text = compose_long_debug_event_header_text(event_name, long_setup_source_display, long_setup_trigger, long_invalidation_level)
    event_text += compose_long_debug_event_state_text(debug_mode_full, long_setup_backing_zone_touch_count, freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, long_ready_blocker_text, long_strict_blocker_text)
    if long_source_upgrade_now
        event_text += compose_long_debug_pipe_upgrade_text(long_source_upgrade_reason)
    if long_last_invalid_source != 'None'
        event_text += compose_long_debug_pipe_reason_text(long_last_invalid_source)
    event_text

resolve_long_upgrade_edge_text(bool ob_source_upgrade_ok, bool fvg_source_upgrade_ok) =>
    string edge_text = 'beat locked source confluence'
    if ob_source_upgrade_ok and fvg_source_upgrade_ok
        edge_text := 'won tie on stronger confluence'
    edge_text

compose_long_upgrade_reason_text(string target_source_text, string edge_text, float quality_gain) =>
    target_source_text + ' ' + edge_text + ' +' + str.tostring(quality_gain, '#.##') + 'Q'

resolve_long_upgrade_reason(bool long_source_upgrade_now, bool prefer_ob_upgrade, bool ob_source_upgrade_ok, bool fvg_source_upgrade_ok, float touched_bull_ob_quality, float touched_bull_fvg_quality, float long_locked_source_quality) =>
    string upgrade_reason = 'none'
    if long_source_upgrade_now
        int target_source_kind = LONG_SOURCE_FVG
        if prefer_ob_upgrade
            target_source_kind := LONG_SOURCE_OB
        string target_source_text = resolve_long_source_text(target_source_kind)
        float target_quality = touched_bull_fvg_quality
        if prefer_ob_upgrade
            target_quality := touched_bull_ob_quality
        float quality_gain = math.max(target_quality - long_locked_source_quality, 0.0)
        string edge_text = resolve_long_upgrade_edge_text(ob_source_upgrade_ok, fvg_source_upgrade_ok)
        upgrade_reason := compose_long_upgrade_reason_text(target_source_text, edge_text, quality_gain)
    upgrade_reason

resolve_long_confirm_freshness_text(bool ready_is_fresh) =>
    string freshness_text = 'confirm stale'
    if ready_is_fresh
        freshness_text := 'confirm fresh'
    freshness_text

resolve_long_armed_freshness_text(bool confirm_is_fresh) =>
    string freshness_text = 'armed stale'
    if confirm_is_fresh
        freshness_text := 'armed fresh'
    freshness_text

resolve_long_source_state_text(bool long_source_alive, bool long_source_broken) =>
    string source_state_text = 'source lost'
    if long_source_alive
        source_state_text := 'source alive'
    else if long_source_broken
        source_state_text := 'source invalid'
    source_state_text

resolve_long_zone_quality_text(int effective_long_active_touch_count) =>
    string zone_quality_text = 'crowded'
    if effective_long_active_touch_count <= 1
        zone_quality_text := 'fresh touch'
    else if effective_long_active_touch_count == 2
        zone_quality_text := '2nd touch'
    zone_quality_text

describe_long_freshness(bool long_setup_armed, bool long_setup_confirmed, bool ready_is_fresh, bool confirm_is_fresh) =>
    string freshness_text = 'n/a'
    if long_setup_confirmed
        freshness_text := resolve_long_confirm_freshness_text(ready_is_fresh)
    else if long_setup_armed
        freshness_text := resolve_long_armed_freshness_text(confirm_is_fresh)
    freshness_text

describe_long_source_state(bool long_source_tracked, bool long_source_alive, bool long_source_broken) =>
    string source_state_text = 'n/a'
    if long_source_tracked
        source_state_text := resolve_long_source_state_text(long_source_alive, long_source_broken)
    source_state_text

select_effective_long_touch_count(bool long_setup_armed, bool long_setup_confirmed, int long_setup_backing_zone_touch_count, bool bull_reclaim_ob_strict, bool in_bull_ob_zone, bool in_bull_fvg_zone, int active_ob_touch_count, bool bull_reclaim_fvg_strict, int active_fvg_touch_count, int active_zone_touch_count) =>
    int effective_touch_count = active_zone_touch_count
    if long_setup_armed or long_setup_confirmed
        effective_touch_count := long_setup_backing_zone_touch_count
    else if bull_reclaim_ob_strict or (in_bull_ob_zone and not in_bull_fvg_zone)
        effective_touch_count := active_ob_touch_count
    else if bull_reclaim_fvg_strict or (in_bull_fvg_zone and not in_bull_ob_zone)
        effective_touch_count := active_fvg_touch_count
    effective_touch_count

describe_long_zone_quality(bool long_zone_active, bool long_setup_armed, bool long_setup_confirmed, int effective_long_active_touch_count) =>
    string zone_quality_text = 'n/a'
    if long_zone_active or long_setup_armed or long_setup_confirmed
        zone_quality_text := resolve_long_zone_quality_text(effective_long_active_touch_count)
    zone_quality_text

resolve_long_overhead_alert_text(bool use_overhead_zone_filter, float headroom_to_overhead, float planned_risk) =>
    string overhead_text = 'off'
    if use_overhead_zone_filter
        overhead_text := 'clear'
        if not na(headroom_to_overhead) and not na(planned_risk)
            overhead_text := str.tostring(headroom_to_overhead / planned_risk, '#.##') + 'R'
    overhead_text

compose_long_score_detail_suffix(int signal_quality_score, string signal_quality_tier) =>
    ' | sq=' + str.tostring(signal_quality_score) + '/' + signal_quality_tier

resolve_long_strict_alert_suffix(bool use_strict_sequence, bool use_strict_sweep_for_zone_reclaim, bool use_strict_confirm_guard) =>
    string strict_suffix = ''
    if use_strict_sequence or use_strict_sweep_for_zone_reclaim or use_strict_confirm_guard
        strict_suffix := ' | strict=on'
    strict_suffix

compose_long_environment_alert_suffix(string long_environment_focus_display, string overhead_text) =>
    ' | env=' + long_environment_focus_display + ' | overhead=' + overhead_text

compose_long_micro_alert_suffix(string micro_profile_text, string freshness_text, string source_state_text, string zone_quality_text) =>
    ' | micro=' + micro_profile_text + ' | freshness=' + freshness_text + ' | source=' + source_state_text + ' | zone=' + zone_quality_text

compose_long_alert_text_suffixes(bool use_overhead_zone_filter, float headroom_to_overhead, float planned_risk, int signal_quality_score, string signal_quality_tier, bool use_strict_sequence, bool use_strict_sweep_for_zone_reclaim, bool use_strict_confirm_guard, bool use_microstructure_profiles, string micro_profile_text, string freshness_text, string source_state_text, string zone_quality_text, string long_environment_focus_display) =>
    string overhead_text = resolve_long_overhead_alert_text(use_overhead_zone_filter, headroom_to_overhead, planned_risk)
    string score_suffix = compose_long_score_detail_suffix(signal_quality_score, signal_quality_tier)
    string strict_suffix = resolve_long_strict_alert_suffix(use_strict_sequence, use_strict_sweep_for_zone_reclaim, use_strict_confirm_guard)
    string environment_suffix = compose_long_environment_alert_suffix(long_environment_focus_display, overhead_text)
    string micro_suffix = ''
    if use_microstructure_profiles
        micro_suffix := compose_long_micro_alert_suffix(micro_profile_text, freshness_text, source_state_text, zone_quality_text)
    [overhead_text, score_suffix, strict_suffix, environment_suffix, micro_suffix]

// Long state codes:
// -1 invalidated, 0 no setup, 1 in zone, 2 armed, 3 building, 4 confirmed, 5 ready, 6 entry best, 7 entry strict.
// Source-state semantics: tracked = locked source id exists, alive = source still resolves, broken = explicit mitigation/fill break, lost = tracked but no longer resolvable and not broken.
resolve_long_state_code(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar, bool long_invalidate_signal = false) =>
    bool invalid_state = (long_setup_armed or long_setup_confirmed or long_invalidate_signal or invalidated_prior_setup or long_invalidated_now or long_invalidated_this_bar) and (long_invalidated_now or long_invalidated_this_bar)
    if invalid_state
        -1
    else if long_entry_strict_state
        7
    else if long_entry_best_state
        6
    else if long_ready_state
        5
    else if long_setup_confirmed
        4
    else if long_building_state
        3
    else if long_setup_armed
        2
    else if long_zone_active
        1
    else
        0

resolve_long_setup_state_label(int state_code) =>
    string setup_label = 'No Setup'
    if state_code == -1
        setup_label := 'Invalidated'
    else if state_code == 1
        setup_label := 'In Zone'
    else if state_code == 2
        setup_label := 'Armed'
    else if state_code == 3
        setup_label := 'Building'
    else if state_code == 4
        setup_label := 'Confirmed'
    else if state_code == 5
        setup_label := 'Ready'
    else if state_code == 6
        setup_label := 'Entry Best'
    else if state_code == 7
        setup_label := 'Entry Strict'
    setup_label

long_setup_state_has_source_display(int state_code) =>
    bool has_source_display = false
    if state_code >= 2 and state_code <= 7
        has_source_display := true
    has_source_display

compose_long_setup_state_text(int state_code, string long_setup_source_display) =>
    string setup_text = resolve_long_setup_state_label(state_code)
    if long_setup_state_has_source_display(state_code)
        setup_text := setup_text + ' | ' + long_setup_source_display
    setup_text

resolve_long_setup_state_code(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar) =>
    resolve_long_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)

resolve_long_setup_display_text(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidated_now, bool invalidated_prior_setup, bool long_invalidated_this_bar, string long_setup_source_display) =>
    int state_code = resolve_long_setup_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)
    compose_long_setup_state_text(state_code, long_setup_source_display)

compose_long_setup_text(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidated_now, bool invalidated_prior_setup, bool long_invalidated_this_bar, string long_setup_source_display) =>
    resolve_long_setup_display_text(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidated_now, invalidated_prior_setup, long_invalidated_this_bar, long_setup_source_display)

resolve_long_visual_state_code(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidate_signal, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar) =>
    resolve_long_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar, long_invalidate_signal)

resolve_long_visual_state(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidate_signal, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar) =>
    resolve_long_visual_state_code(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidate_signal, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)

resolve_long_visual_state_label(int long_visual_state) =>
    string visual_text = 'Ready'
    if long_visual_state == -1
        visual_text := 'Fail'
    else if long_visual_state == 0
        visual_text := 'Neutral'
    else if long_visual_state == 1
        visual_text := 'In Zone'
    else if long_visual_state == 2
        visual_text := 'Armed'
    else if long_visual_state == 3
        visual_text := 'Building'
    else if long_visual_state == 4
        visual_text := 'Confirmed'
    visual_text

resolve_long_bg_color(int long_visual_state, color long_color_building) =>
    color bg_color = na
    if long_visual_state == -1
        bg_color := color.new(long_color_invalid, 90)
    else if long_visual_state == 1
        bg_color := color.new(long_color_zone, 92)
    else if long_visual_state == 2
        bg_color := color.new(long_color_reclaim, 88)
    else if long_visual_state == 3
        bg_color := color.new(long_color_building, 84)
    else if long_visual_state == 4
        bg_color := color.new(long_color_confirmed, 88)
    else if long_visual_state == 5
        bg_color := color.new(long_color_ready, 82)
    else if long_visual_state == 6
        bg_color := color.new(long_color_ready, 74)
    else if long_visual_state >= 7
        bg_color := color.new(long_color_ready, 66)
    bg_color

resolve_long_bar_color(int long_visual_state, color long_color_building) =>
    color bar_color = na
    if long_visual_state == -1
        bar_color := color.new(long_color_invalid, 0)
    else if long_visual_state == 1
        bar_color := color.new(long_color_zone, 45)
    else if long_visual_state == 2
        bar_color := color.new(long_color_reclaim, 25)
    else if long_visual_state == 3
        bar_color := color.new(long_color_building, 5)
    else if long_visual_state == 4
        bar_color := color.new(long_color_confirmed, 0)
    else if long_visual_state == 5
        bar_color := color.new(long_color_ready, 0)
    else if long_visual_state == 6
        bar_color := color.new(long_color_ready, 0)
    else if long_visual_state >= 7
        bar_color := color.new(BULL_HERO_READY, 0)
    bar_color

resolve_event_risk_state(bool market_event_blocked, bool symbol_event_blocked, string event_window_state, string event_risk_level) =>
    string risk_state = 'clear'
    if market_event_blocked or symbol_event_blocked
        risk_state := 'blocked'
    else if event_window_state == 'COOLDOWN' or (event_window_state == 'PRE_EVENT' and (event_risk_level == 'HIGH' or event_risk_level == 'ELEVATED'))
        risk_state := 'caution'
    risk_state

compose_health_badge_text(string signal_bias_alignment, string signal_quality_tier, int signal_quality_score, string event_risk_state, string signal_freshness, string signal_warnings, string provider_status) =>
    string dir_icon = '◆'
    if signal_bias_alignment == 'bull'
        dir_icon := '▲'
    else if signal_bias_alignment == 'bear'
        dir_icon := '▼'
    string tier_icon = '🔴'
    if signal_quality_tier == 'high'
        tier_icon := '🟢'
    else if signal_quality_tier == 'good'
        tier_icon := '🟡'
    else if signal_quality_tier == 'ok'
        tier_icon := '🟠'
    string event_icon = '✓'
    if event_risk_state == 'blocked'
        event_icon := '⛔'
    else if event_risk_state == 'caution'
        event_icon := '⚡'
    string fresh_icon = '○'
    if signal_freshness == 'fresh'
        fresh_icon := '●'
    else if signal_freshness == 'aging'
        fresh_icon := '◐'
    string warning_suffix = ''
    if signal_warnings != ''
        warning_suffix := ' ⚠ ' + signal_warnings
    string data_icon = '⚠'
    if provider_status == 'ok'
        data_icon := '✓'
    dir_icon + ' ' + signal_quality_tier + ' ' + str.tostring(signal_quality_score) + ' ' + tier_icon + ' | ' + event_icon + ' | ' + fresh_icon + warning_suffix + ' | data:' + data_icon

resolve_health_badge_color(string signal_quality_tier) =>
    color badge_color = color.new(BEAR_PRIMARY, 70)
    if signal_quality_tier == 'high'
        badge_color := color.new(BULL_PRIMARY, 70)
    else if signal_quality_tier == 'good'
        badge_color := color.new(BULL_HERO_READY, 70)
    else if signal_quality_tier == 'ok'
        badge_color := color.new(long_color_reclaim, 70)
    badge_color

resolve_core_product_state(int long_visual_state) =>
    string product_state = 'WAIT'
    if long_visual_state == -1
        product_state := 'BLOCKED'
    else if long_visual_state >= 6
        product_state := 'ENTER LONG'
    else if long_visual_state == 5
        product_state := 'READY LONG'
    else if long_visual_state >= 2
        product_state := 'PREPARE LONG'
    product_state

resolve_trust_tier(string signal_quality_tier, string signal_freshness, string provider_status) =>
    string trust_tier = 'Insufficient'
    if provider_status != 'ok' or signal_freshness == 'stale'
        trust_tier := signal_quality_tier == 'high' or signal_quality_tier == 'good' or signal_quality_tier == 'ok' ? 'Degraded' : 'Insufficient'
    else if signal_quality_tier == 'high' and signal_freshness == 'fresh'
        trust_tier := 'High'
    else if signal_quality_tier == 'high' or signal_quality_tier == 'good' or signal_quality_tier == 'ok'
        trust_tier := 'Guarded'
    trust_tier

compose_trust_tier_suffix(string trust_tier, int sq_score, string sq_freshness, string provider_status, string ensemble_quality_tier) =>
    string suffix = ''
    if trust_tier == 'High'
        suffix := 'score ' + str.tostring(sq_score) + ', data fresh'
    else if trust_tier == 'Guarded'
        suffix := sq_freshness == 'aging' ? 'score ' + str.tostring(sq_score) + ', data aging' : 'score ' + str.tostring(sq_score) + ', quality ' + ensemble_quality_tier
    else if trust_tier == 'Degraded'
        if provider_status != 'ok'
            suffix := 'provider: ' + provider_status
        else
            suffix := 'data stale'
    else
        suffix := 'no measurement data'
    suffix

