var bool stretch_require_lower_extreme_for_watchlist = input.bool(false, 'Watchlist prefers lower extreme', group = g_stretch, display = display.none, tooltip = 'Recommended off for rollout. Watchlist stays broader while stronger stretch filters are reserved for higher-conviction states.')
var bool stretch_require_lower_extreme_for_ready = input.bool(false, 'Ready requires lower extreme context', group = g_stretch, display = display.none, tooltip = 'Stacked rollout recommendation: off. Keep anti-chase active for Ready, but reserve mandatory lower-extreme context for Entry Best and Entry Strict.')
var bool stretch_require_lower_extreme_for_entry_best = input.bool(false, 'Entry Best requires lower extreme context', group = g_stretch, display = display.none, tooltip = 'Stacked rollout recommendation: off. Anti-chase stays active, but Best no longer needs a fresh lower-extreme context on top of acceleration, DDVI, and regime filters.')
var bool stretch_require_lower_extreme_for_entry_strict = input.bool(true, 'Entry Strict requires lower extreme context', group = g_stretch, display = display.none, tooltip = 'Recommended on. Strict should stay fully tied to real lower-extreme mean-reversion setups.')
