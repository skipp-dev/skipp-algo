    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, invalidated_active, long_invalidated_alert_key, long_invalidated_alert_name, compose_long_invalidated_alert_detail(long_last_invalid_source, long_micro_alert_suffix, long_score_detail_suffix), long_last_invalid_level, -1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, strict_active, long_entry_strict_alert_key, long_entry_strict_alert_name, compose_long_entry_strict_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_strict_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, best_active, long_entry_best_alert_key, long_entry_best_alert_name, compose_long_entry_best_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_best_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, ready_active, long_ready_alert_key, long_ready_alert_name, compose_long_ready_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, clean_active, long_clean_alert_key, long_clean_alert_name, compose_long_clean_alert_detail(long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_clean_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, confirmed_active, long_confirmed_alert_key, long_confirmed_alert_name, compose_long_confirmed_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, early_active, long_early_alert_key, long_early_alert_name, compose_long_early_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_early_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, armed_plus_active, long_armed_plus_alert_key, long_armed_plus_alert_name, compose_long_armed_plus_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, armed_active, long_armed_alert_key, long_armed_alert_name, compose_long_armed_alert_detail(long_setup_source_display, long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, watchlist_active, long_watchlist_alert_key, long_watchlist_alert_name, compose_long_watchlist_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_watchlist_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys

resolve_ob_alert_level(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.break_price
    level

resolve_fvg_alert_level(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.fill_target_level
    level

resolve_ob_top_boundary(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.left_top.price
    level

resolve_ob_bottom_boundary(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.right_bottom.price
    level

resolve_fvg_top_boundary(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.left_top.price
    level

resolve_fvg_bottom_boundary(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.right_bottom.price
    level

resolve_ob_recency_index(OrderBlock block) =>
    int idx = na
    if not na(block)
        idx := block.right_bottom.index
    idx

resolve_fvg_recency_index(FVG gap) =>
    int idx = na
    if not na(gap)
        idx := gap.right_bottom.index
    idx

resolve_ob_id(OrderBlock block) =>
    int val = na
    if not na(block)
        val := block.id
    val

resolve_fvg_id(FVG gap) =>
    int val = na
    if not na(gap)
        val := gap.id
    val

update_latched_flag(bool current_latched, bool event_active, bool live_mode, bool bar_confirmed) =>
    current_latched or (live_mode ? event_active : bar_confirmed and event_active)



var g_mode = 'Execution Mode'
var ct.SignalMode signal_mode = input.enum(ct.SignalMode.CONFIRMED_ONLY, 'Signal Mode', group = g_mode, tooltip = 'Confirmed only is the safer non-repainting mode. Aggressive live allows intrabar high/low driven updates and alerts, so states can change before candle close, are not fully reconstructable after reload, and should be treated as realtime-only until the bar confirms.', display = display.status_line)
var string long_user_preset = input.string('Standard', 'User Preset', options = ['Easy', 'Standard', 'Pro'], group = g_mode, tooltip = 'Easy keeps the long engine permissive and easier to operate. Standard preserves the current balanced workflow. Pro enables stricter lifecycle and execution gating for cleaner but rarer setups.', display = display.status_line)
var bool compact_mode = input.bool(false, 'Compact / Shared-Script Mode', group = g_mode, tooltip = 'Hero-Surface UX for sharing or solo operation. Suppresses: all debug overlays (OB, FVG, Engine, Microstructure, Strict markers), LTF dashboard details, EMA support lines, session VWAP line, mean-target overlay. Keeps active: Direction, Lifecycle markers, Signal Quality, Event Status, Bias, Warnings, Health Badge, Risk Levels. Filter logic is not affected — only visual elements are suppressed.')

var g_ltf = 'Lower Timeframe'
