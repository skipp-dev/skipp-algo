bool lib_universe_initialized = mp.UNIVERSE_TICKERS != ""
bool lib_ticker_in_universe = lib_universe_initialized and u.csv_has_symbol_token(mp.UNIVERSE_TICKERS, current_symbol_key, current_symbol_key_qualified)

