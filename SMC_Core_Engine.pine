var g_stretch = '22. Advanced - Stretch / Mean Reversion Context'
var bool use_stretch_context = input.bool(true, 'Use stretch context', group = g_stretch, display = display.none, tooltip = 'Preset guide:\nStacked rollout = Watchlist lower-extreme off, Ready lower-extreme off, Best off, Strict on, anti-chase active.\nBalanced = turn Ready lower-extreme on if you want more genuine deep-pullback bias.\nTight = keep Strict at 0.00 or below and keep Best tied to lower-extreme context.')
var int stretch_len = input.int(100, 'Mean / StdDev length', minval = 20, group = g_stretch, inline = 'dist1', display = display.none, tooltip = 'Recommended start: 100. Shorter reacts faster, longer is smoother and more stable.')
