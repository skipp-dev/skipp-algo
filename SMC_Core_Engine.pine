bool use_strict_sweep_for_zone_reclaim_eff = use_strict_sweep_for_zone_reclaim
if preset_is_easy
    use_strict_sweep_for_zone_reclaim_eff := false

bool block_third_touch_eff = block_third_touch
if preset_is_easy
