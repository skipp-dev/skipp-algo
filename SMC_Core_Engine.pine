_detect_fvg_object(int mode, bool enabled, float size_threshold = 0, ct.LevelBreakMode fill_mode = ct.LevelBreakMode.CLOSE, float fill_target_ratio = 0.5) =>
    float top = low[mode == 1 ? 0 : 2]
    float btm = high[mode == 1 ? 2 : 0]
    float size = top - btm

    if enabled and barstate.isconfirmed and size > size_threshold
        FVG new_fvg = FVG.new(na, mode, fill_mode,
         left_top = chart.point.new(time[2], bar_index[2], top),
         right_bottom = chart.point.new(time_close, bar_index, btm),
         fvg_fill_target_ratio = fill_target_ratio,
         fill_target_level = mode == 1 ? top - fill_target_ratio * size : btm + fill_target_ratio * size,
         fill_current_ratio = 0,
         fill_current_level = mode == 1 ? top : btm,
         total_volume = volume[2] + volume[1] + volume)
        new_fvg.quality_score := math.max(0.0, math.min(1.0, 0.15 + math.min(size / math.max(size_threshold * 3.0, syminfo.mintick), 1.0) * 0.35 + (new_fvg.total_volume > 0 ? 0.10 : 0.0) + 0.15))
        [true, new_fvg]
    else
        [false, na]

_detect_fvg_values_for_htf(int mode, bool enabled, float size_threshold = 0, float fill_target_ratio = 0.5) =>
    float top = low[mode == 1 ? 0 : 2]
    float btm = high[mode == 1 ? 2 : 0]
    float size = top - btm
    bool found = enabled and barstate.isconfirmed and size > size_threshold
    int left_time = found ? time[2] : na
    int right_time = found ? time_close : na
    float fill_target = found ? (mode == 1 ? top - fill_target_ratio * size : btm + fill_target_ratio * size) : na
    float total_vol = found ? volume[2] + volume[1] + volume : na
    [found, top, btm, left_time, right_time, fill_target, total_vol]

method clear_filled(FVG[] fvgs, FVG[] filled_buffer, FVG[] filled_new_buffer, int keep_history = 5, FVG[] discard_buffer = na, int protected_id = na) =>
    FVG[] moved_fvgs = array.new<FVG>(0)
    filled_new_buffer.clear()

    if na(keep_history) or keep_history <= 0
        filled_buffer.clear()

    if fvgs.size() > 0 and not na(filled_buffer)
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            bool is_protected = not na(protected_id) and fvg.id == protected_id
            if not is_protected and fvg.filled
                moved = fvgs.remove(i)
                moved_fvgs.unshift(moved)

    for moved in moved_fvgs
        filled_buffer.push(moved)
        filled_new_buffer.push(moved)

    if keep_history > 0
        while filled_buffer.size() > keep_history
            if not na(discard_buffer)
                discard_buffer.push(filled_buffer.shift())
            else
                filled_buffer.shift()

    fvgs

method update(FVG this) =>
    bool filled_by_close = this.fill_mode == ct.LevelBreakMode.CLOSE
    if not this.filled and (not filled_by_close or barstate.isconfirmed)
        if this.dir == 1
            fill_src = filled_by_close ? close : low
            if this.fill_current_level > fill_src
                this.filled := this.fill_target_level > fill_src
                this.fill_current_level := math.min(this.fill_current_level, fill_src)
                this.fill_current_ratio := (this.left_top.price - this.fill_current_level) / (this.left_top.price - this.right_bottom.price)
                if this.filled
                    this.fill_time := time_close
                    this.fill_index := bar_index + 1
                true
            else
                false
        else
            fill_src = this.fill_mode == ct.LevelBreakMode.CLOSE ? close : high
            if this.fill_current_level < fill_src
                this.filled := this.fill_target_level < fill_src
                this.fill_current_level := math.max(this.fill_current_level, fill_src)
                this.fill_current_ratio := (this.fill_current_level - this.right_bottom.price) / (this.left_top.price - this.right_bottom.price)
                if this.filled
                    this.fill_time := time_close
                    this.fill_index := bar_index + 1
                true
            else
                false
    else
        false

method update(FVG[] fvgs) =>
    if fvgs.size() > 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            fvg.update()
    fvgs

method hide(FVG this) =>
    if not na(this) and not this.hidden
        if not na(this.plot_box)
            this.plot_box.hide()
        if not na(this.plot_fill_target_level)
            this.plot_fill_target_level.hide()
        if not na(this.plot_fill_target_label)
            this.plot_fill_target_label.hide()
        this.hidden := true
    this

method delete(FVG this) =>
    if not na(this)
        if not na(this.plot_box)
            this.plot_box.delete()
        if not na(this.plot_fill_target_level)
            this.plot_fill_target_level.delete()
        if not na(this.plot_fill_target_label)
            this.plot_fill_target_label.delete()
        this.plot_box := na
        this.plot_fill_target_level := na
        this.plot_fill_target_label := na
        this.hidden := false
    this

method delete(FVG[] fvgs) =>
    if not na(fvgs)
        for fvg in fvgs
            fvg.delete()
    fvgs

method remove_insignificant(FVG[] fvgs, float size_threshold, FVG[] removed_buffer = na, int protected_id = na) =>
    if fvgs.size() > 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            size = fvg.left_top.price - fvg.right_bottom.price
            bool is_protected = not na(protected_id) and fvg.id == protected_id
            if not is_protected and size < size_threshold
                log.info("clearing out old FVG to free memory (top: {0} | bottom: {1}) with size ({2}) below threshold ({3})", fvg.left_top.price, fvg.right_bottom.price, size, size_threshold)
                if not na(removed_buffer)
                    removed_buffer.push(fvg)
                fvg.delete()
                fvgs.remove(i)
    fvgs

fvg_quality_score(FVG fvg, float size_threshold = 0.0) =>
    if na(fvg)
        0.0
    else
        float gap_size = math.max(fvg.left_top.price - fvg.right_bottom.price, syminfo.mintick)
        float normalized_gap = size_threshold > 0 ? math.min(gap_size / math.max(size_threshold * 3.0, syminfo.mintick), 1.0) : 0.5
        float unfilled_component = 1.0 - math.max(0.0, math.min(1.0, nz(fvg.fill_current_ratio, 0.0)))
        float score = 0.15
        score += normalized_gap * 0.35
        score += unfilled_component * 0.25
        score += not fvg.filled ? 0.15 : 0.0
        score += nz(fvg.total_volume, 0.0) > 0 ? 0.10 : 0.0
        math.max(0.0, math.min(1.0, score))

fvgs_objects(simple ct.LevelBreakMode fill_mode = ct.LevelBreakMode.CLOSE, float fill_target_ratio = 0.5, float size_threshold = 0, simple bool enabled = true, simple int filled_max_keep = 5, simple int gc_cycle = na, int protected_bull_id = na, int protected_bear_id = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] buffer_bear_discarded = array.new<FVG>(0)
    var int next_id = 0

    if barstate.isfirst and not u.in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    [bullish_fvg_alert, new_bull] = _detect_fvg_object(1, enabled, size_threshold, fill_mode, fill_target_ratio)
    [bearish_fvg_alert, new_bear] = _detect_fvg_object(-1, enabled, size_threshold, fill_mode, fill_target_ratio)

    buffer_bull.update()
    buffer_bear.update()

    buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, buffer_bull_discarded, protected_bull_id)
    buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, buffer_bear_discarded, protected_bear_id)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, buffer_bull_discarded, protected_bull_id)
        buffer_bear.remove_insignificant(size_threshold, buffer_bear_discarded, protected_bear_id)

    if bullish_fvg_alert
        next_id += 1
        new_bull.id := next_id
        buffer_bull.push(new_bull)
    if bearish_fvg_alert
        next_id += 1
        new_bear.id := next_id
        buffer_bear.push(new_bear)

    if buffer_bull_discarded.size() > 0
        delete(buffer_bull_discarded)
        array.clear(buffer_bull_discarded)
    if buffer_bear_discarded.size() > 0
        delete(buffer_bear_discarded)
        array.clear(buffer_bear_discarded)

    [bullish_fvg_alert, bearish_fvg_alert, buffer_bull, buffer_bear, new_bull, new_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, buffer_bull_discarded, buffer_bear_discarded]

method draw(FVG this, FVGConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    visible_match = na(visible_left) or na(visible_right) or this.overlaps_window(visible_left, visible_right, config.extend_until_filled)

    if not visible_match
        if not na(this.plot_box) and not this.hidden
            this.hide()
        this
    else

        if barstate.islast and not na(this) and (config.show_box or config.show_target)
            float fvg_quality = config.show_quality_score ? fvg_quality_score(this, this.left_top.price - this.right_bottom.price) : 0.0
            txt_quality = config.show_quality_score and fvg_quality > 0 ? str.format('(Q {0,number,percent})', fvg_quality) : ''
            txt = str.format('{0}{1}', config.show_text ? config.txt + ' ' : '', config.show_target_label ? '' : txt_quality)

            xloc_bartime = config.box_args.xloc == xloc.bar_time
            int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
            int fill_right_time = effective_live_event_time(this.fill_time, math.max(this.left_top.time, this.right_bottom.time))
            int left = not na(left_override) ? left_override : xloc_bartime ? this.left_top.time : this.left_top.index
            int right = na
            if not na(right_override)
                right := right_override
            else if config.extend_until_filled
                if this.filled
                    right := xloc_bartime ? fill_right_time : this.fill_index - 1
                else
                    right := xloc_bartime ? current_bar_right_time() : math.max(this.left_top.index + config.extend_bars, bar_index)
            else if this.filled
                right := xloc_bartime ? math.min(fill_right_time, base_right_time) : math.min(this.fill_index - 1, math.max(this.left_top.index + config.extend_bars, this.right_bottom.index))
            else
                right := xloc_bartime ? base_right_time : math.max(this.left_top.index + config.extend_bars, this.right_bottom.index)

            chart.point plot_left_top = d.create_point(left, this.left_top.price, config.box_args.xloc)
            chart.point plot_right_bottom = d.create_point(right, this.right_bottom.price, config.box_args.xloc)

            if config.show_box
                if na(this.plot_box)
                    this.plot_box := d.SmcBox.new(plot_left_top, plot_right_bottom, config.show_target_label ? '' : txt)
                else
                    this.plot_box.left_top := plot_left_top
                    this.plot_box.right_bottom := plot_right_bottom

                this.plot_box.draw(config.box_args, config.box_text_args, extend_only, force_overlay)
                if this.filled
                    this.plot_box.plot.set_text(txt)

            if config.show_target
                if na(this.plot_fill_target_level)
                    this.plot_fill_target_level := d.create_line(left, this.fill_target_level, right, this.fill_target_level, config.line_args.xloc)
                else
                    this.plot_fill_target_level.start.update(left, this.fill_target_level, config.line_args.xloc)
                    this.plot_fill_target_level.end.update(right, this.fill_target_level, config.line_args.xloc)
                this.plot_fill_target_level.draw(config.line_args, extend_only, force_overlay)

            if config.show_target_label
                txt_target = str.format('{0}{1}', config.show_text ? config.txt + ' ' : '', txt_quality)
                if na(this.plot_fill_target_label)
                    this.plot_fill_target_label := d.create_label(right, this.fill_target_level, config.label_args.xloc, txt_target)
                else
                    this.plot_fill_target_label.point.update(right, this.fill_target_level, config.label_args.xloc)
                    this.plot_fill_target_label.txt := txt_target
                this.plot_fill_target_label.draw(config.label_args, force_overlay)

            if this.filled and fill_right_time <= current_bar_right_time()
                if not na(this.plot_box)
                    this.plot_box.apply_style(config.box_args, config.box_text_args)
                if not na(this.plot_fill_target_level)
                    this.plot_fill_target_level.apply_style(config.line_args)
                if not na(this.plot_fill_target_label)
                    this.plot_fill_target_label.apply_style(config.label_args)

            this.hidden := false

    this

method draw(FVG[] fvgs, FVGConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    if na(fvgs) ? false : (config.show_box or config.show_target) and fvgs.size() > 0
        count = 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            visible_match = na(visible_left) or na(visible_right) or fvg.overlaps_window(visible_left, visible_right, config.extend_until_filled)
            if visible_match and count < config.show_last
                fvg.draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
                count += 1
            else
                if not na(fvg.plot_box) and not fvg.hidden
                    fvg.hide()
    fvgs

/////////////////////////////////////////////////////////////////////////////////
//#endregion                EMBEDDED SMC SUBSET
/////////////////////////////////////////////////////////////////////////////////

// Signal / state contract
// - *_raw      : raw condition, may be intrabar/transient
// - *_safe     : non-repainting / close-safe projection used outside live mode
// - *_event    : edge-triggered event on this bar
// - *_latched  : intrabar-persisted event/state until bar close
// - *_state    : continuous state, not necessarily edge-triggered
// - In CONFIRMED_ONLY mode, decisions should be reconstructable after reload.
// - In AGGRESSIVE_LIVE mode, intrabar transitions may occur before close and are realtime-only.

/////////////////////////////////////////////////////////////////////////////////
//#region                         IMPLEMENTATION
/////////////////////////////////////////////////////////////////////////////////

const int ATR_LEN_MAIN = 50
const int ATR_LEN_PROFILE = 200
const int ATR_LEN_PIVOT_FILTER = 3
const int DEFAULT_SWING_LENGTH = 50
const int DEFAULT_INTERNAL_LENGTH = 5
const int DEFAULT_OB_SHOW_LAST = 2
const int DEFAULT_FVG_SHOW_LAST = 2
const int DEFAULT_KEEP_HISTORY = 1
const float DEFAULT_OB_FILTER_MIN_MULT = 0.5
const float DEFAULT_OB_FILTER_MAX_MULT = 2.5
const float DEFAULT_FVG_MIN_SIZE_MULT = 0.5
const float DEFAULT_FVG_FILL_TARGET_PCT = 60.0
const string DEFAULT_LTF_TIMEFRAME = '1'
const string DEFAULT_TREND_TF_0 = '120'
const string DEFAULT_TREND_TF_1 = '240'
const string DEFAULT_TREND_TF_2 = '1D'
const string DEFAULT_TREND_TF_3 = '1W'
const string TXT_RECLAIM_OB = 'Reclaim OB'
const string TXT_RECLAIM_FVG = 'Reclaim FVG'
const string TXT_RECLAIM_SWING = 'Reclaim Swing Low'
const string TXT_RECLAIM_INTERNAL = 'Reclaim Internal Low'
const string TXT_LONG_ARMED = 'Long Armed'
const string TXT_LONG_CONFIRMED = 'Long Confirmed'
const string TXT_LONG_READY = 'Long Ready'
const string TXT_LONG_INVALIDATED = 'Long Invalidated'
const string TXT_INT_REVERSAL = 'INT Reversal'
const string TXT_INT_BREAK = 'INT Break'
const string TXT_TREND_CONFIRM = 'Trend Confirm'

status_bg(int state) =>
    color bg = color.new(color.green, 60)
    if state <= -1
        bg := color.new(color.red, 75)
    else if state == 0
        bg := color.new(color.gray, 80)
    else if state == 1
        bg := color.new(color.aqua, 80)
    else if state == 2
        bg := color.new(color.orange, 72)
    else if state == 3
        bg := color.new(color.yellow, 68)
    else if state == 4
        bg := color.new(color.lime, 72)
    bg


get_structure_display_trend_only(simple int structure_len) =>
    [trend, bull_bos_alert, bull_choch_alert, _, _, _, _, _, bear_bos_alert, bear_choch_alert, _, _, _, _, _, _] = detect_structure(structure_len, filter_insignificant_internal_breaks = true)
    bool structure_break_detected = bull_bos_alert or bull_choch_alert or bear_bos_alert or bear_choch_alert
    not na(ta.barssince(structure_break_detected)) ? trend : 0

// HTF trend confirmation is sampled without lookahead so the dashboard state stays tied to closed HTF bars.
get_confirmed_structure_trend(string trend_tf, simple int structure_len) =>
    request.security(syminfo.tickerid, trend_tf, get_structure_display_trend_only(structure_len)[1], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

build_dynamic_alert_message(bool enabled, bool condition, string event_name, string detail, float level, int direction, float ltf_bull_share, float ltf_volume_delta, bool ltf_price_only_context, string mode_text) =>
    if enabled and condition
        direction_text = direction > 0 ? 'bullish' : direction < 0 ? 'bearish' : 'neutral'
        action_text = cr.resolve_core_alert_action_name(event_name)
        share_text = na(ltf_bull_share) ? 'n/a' : ltf_price_only_context ? str.format('{0,number,percent} (price-only)', ltf_bull_share) : str.format('{0,number,percent}', ltf_bull_share)
        delta_text = ltf_price_only_context ? 'no-vol' : na(ltf_volume_delta) ? 'n/a' : str.format('{0,number,percent}', ltf_volume_delta)
        str.format('SMC | {0} | action={1} | event={2} | {3} | dir={4} | level={5} | tf={6} | mode={7} | ltf_bull_share={8} | ltf_volume_delta={9}', syminfo.ticker, action_text, event_name, detail, direction_text, u.format_level(level), timeframe.period, mode_text, share_text, delta_text)
    else
        ''

// T-1 (Temporal-Numerical Audit 2026-04-24): bar-close gate.
// Vorher: `alert.freq_all` + kein `barstate.isconfirmed`-Guard ließ dynamische
// Long-Alerts (Strict/Best/Ready/Confirmed/Clean/Early/Armed/Watchlist) intrabar
// feuern und mutierte `seen_keys` schon vor dem Close, wodurch ein
// Bar-Close-Alert dann unterdrückt wurde. Jetzt: nur am bestätigten Bar-Close.
emit_dynamic_alert_if_allowed(string seen_keys, bool event_active, string seen_key, string event_name, string detail, float level, int direction, float ltf_bull_share, float ltf_volume_delta, bool ltf_price_only_context, string mode_text) =>
    next_seen_keys = seen_keys
    if event_active and barstate.isconfirmed and not str.contains(seen_keys, seen_key)
        next_seen_keys := seen_keys + seen_key
        alert(build_dynamic_alert_message(true, true, event_name, detail, level, direction, ltf_bull_share, ltf_volume_delta, ltf_price_only_context, mode_text), alert.freq_once_per_bar_close)
    next_seen_keys

emit_priority_long_dynamic_alerts(string seen_keys, bool already_sent, bool invalidated_active, bool strict_active, bool best_active, bool ready_active, bool confirmed_active, bool clean_active, bool early_active, bool armed_plus_active, bool armed_active, bool watchlist_active, string long_invalidated_alert_key, string long_invalidated_alert_name, string long_entry_strict_alert_key, string long_entry_strict_alert_name, string long_entry_best_alert_key, string long_entry_best_alert_name, string long_ready_alert_key, string long_ready_alert_name, string long_confirmed_alert_key, string long_confirmed_alert_name, string long_clean_alert_key, string long_clean_alert_name, string long_early_alert_key, string long_early_alert_name, string long_armed_plus_alert_key, string long_armed_plus_alert_name, string long_armed_alert_key, string long_armed_alert_name, string long_watchlist_alert_key, string long_watchlist_alert_name, string long_setup_source_display, string long_strict_alert_suffix, string long_environment_alert_suffix, string long_micro_alert_suffix, string long_score_detail_suffix, string signal_mode_text, float ltf_bull_share_context, float ltf_volume_delta_context, bool ltf_price_only_context, string long_last_invalid_source, float long_last_invalid_level, float long_trigger_level, float long_invalidation_level, float long_entry_strict_alert_level, float long_entry_best_alert_level, float long_clean_alert_level, float long_early_alert_level, float long_watchlist_alert_level) =>
    string next_seen_keys = seen_keys
    if invalidated_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, true, long_invalidated_alert_key, long_invalidated_alert_name, cr.compose_long_invalidated_alert_detail(long_last_invalid_source, long_micro_alert_suffix, long_score_detail_suffix), long_last_invalid_level, -1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if strict_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_entry_strict_alert_key, long_entry_strict_alert_name, cr.compose_long_entry_strict_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_strict_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if best_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_entry_best_alert_key, long_entry_best_alert_name, cr.compose_long_entry_best_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_best_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if ready_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_ready_alert_key, long_ready_alert_name, cr.compose_long_ready_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if confirmed_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_confirmed_alert_key, long_confirmed_alert_name, cr.compose_long_confirmed_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if clean_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_clean_alert_key, long_clean_alert_name, cr.compose_long_clean_alert_detail(long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_clean_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if early_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_early_alert_key, long_early_alert_name, cr.compose_long_early_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_early_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if armed_plus_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_armed_plus_alert_key, long_armed_plus_alert_name, cr.compose_long_armed_plus_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if armed_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_armed_alert_key, long_armed_alert_name, cr.compose_long_armed_alert_detail(long_setup_source_display, long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    else if watchlist_active
        next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, not already_sent, long_watchlist_alert_key, long_watchlist_alert_name, cr.compose_long_watchlist_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_watchlist_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys

emit_linear_long_dynamic_alerts(string seen_keys, bool invalidated_active, bool strict_active, bool best_active, bool ready_active, bool clean_active, bool confirmed_active, bool early_active, bool armed_plus_active, bool armed_active, bool watchlist_active, string long_invalidated_alert_key, string long_invalidated_alert_name, string long_entry_strict_alert_key, string long_entry_strict_alert_name, string long_entry_best_alert_key, string long_entry_best_alert_name, string long_ready_alert_key, string long_ready_alert_name, string long_clean_alert_key, string long_clean_alert_name, string long_confirmed_alert_key, string long_confirmed_alert_name, string long_early_alert_key, string long_early_alert_name, string long_armed_plus_alert_key, string long_armed_plus_alert_name, string long_armed_alert_key, string long_armed_alert_name, string long_watchlist_alert_key, string long_watchlist_alert_name, string long_setup_source_display, string long_strict_alert_suffix, string long_environment_alert_suffix, string long_micro_alert_suffix, string long_score_detail_suffix, string signal_mode_text, float ltf_bull_share_context, float ltf_volume_delta_context, bool ltf_price_only_context, string long_last_invalid_source, float long_last_invalid_level, float long_trigger_level, float long_invalidation_level, float long_entry_strict_alert_level, float long_entry_best_alert_level, float long_clean_alert_level, float long_early_alert_level, float long_watchlist_alert_level) =>
    string next_seen_keys = seen_keys
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, invalidated_active, long_invalidated_alert_key, long_invalidated_alert_name, cr.compose_long_invalidated_alert_detail(long_last_invalid_source, long_micro_alert_suffix, long_score_detail_suffix), long_last_invalid_level, -1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, strict_active, long_entry_strict_alert_key, long_entry_strict_alert_name, cr.compose_long_entry_strict_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_strict_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, best_active, long_entry_best_alert_key, long_entry_best_alert_name, cr.compose_long_entry_best_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_best_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, ready_active, long_ready_alert_key, long_ready_alert_name, cr.compose_long_ready_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, clean_active, long_clean_alert_key, long_clean_alert_name, cr.compose_long_clean_alert_detail(long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_clean_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, confirmed_active, long_confirmed_alert_key, long_confirmed_alert_name, cr.compose_long_confirmed_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_trigger_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, early_active, long_early_alert_key, long_early_alert_name, cr.compose_long_early_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_early_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, armed_plus_active, long_armed_plus_alert_key, long_armed_plus_alert_name, cr.compose_long_armed_plus_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, armed_active, long_armed_alert_key, long_armed_alert_name, cr.compose_long_armed_alert_detail(long_setup_source_display, long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys := emit_dynamic_alert_if_allowed(next_seen_keys, watchlist_active, long_watchlist_alert_key, long_watchlist_alert_name, cr.compose_long_watchlist_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_watchlist_alert_level, 1, ltf_bull_share_context, ltf_volume_delta_context, ltf_price_only_context, signal_mode_text)
    next_seen_keys

resolve_ob_alert_level(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.break_price
    level

resolve_fvg_alert_level(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.fill_target_level
    level

compute_long_plan_state(bool long_setup_armed, bool long_setup_confirmed, float long_trigger, float long_invalidation_level) =>
    ll.compute_long_plan_state(long_setup_armed, long_setup_confirmed, long_trigger, long_invalidation_level)

compute_long_overhead_context(bool long_plan_active, float close_price, float long_trigger, float long_invalidation_level, float ob_threshold_atr, float stop_buffer_atr_mult, OrderBlock[] ob_blocks_bear_param, int bear_ob_scan_start, FVG[] fvgs_bear_param, int bear_fvg_scan_start, bool use_overhead_zone_filter, float min_headroom_r) =>
    float helper_planned_stop_level = na
    if long_plan_active
        helper_planned_stop_level := long_invalidation_level - ob_threshold_atr * stop_buffer_atr_mult
    float helper_scan_ref = close_price
    if long_plan_active and not na(long_trigger)
        helper_scan_ref := long_trigger
    float helper_bear_ob_lvl = na
    if array.size(ob_blocks_bear_param) > 0
        for i = array.size(ob_blocks_bear_param) - 1 to bear_ob_scan_start
            helper_blocker = array.get(ob_blocks_bear_param, i)
            float helper_blocker_level = resolve_ob_alert_level(helper_blocker)
            if not na(helper_blocker_level) and helper_blocker_level >= helper_scan_ref and (na(helper_bear_ob_lvl) or helper_blocker_level < helper_bear_ob_lvl)
                helper_bear_ob_lvl := helper_blocker_level
    float helper_bear_fvg_lvl = na
    if array.size(fvgs_bear_param) > 0
        for i = array.size(fvgs_bear_param) - 1 to bear_fvg_scan_start
            helper_fblocker = array.get(fvgs_bear_param, i)
            float helper_fblocker_level = resolve_fvg_alert_level(helper_fblocker)
            if not na(helper_fblocker_level) and helper_fblocker_level >= helper_scan_ref and (na(helper_bear_fvg_lvl) or helper_fblocker_level < helper_bear_fvg_lvl)
                helper_bear_fvg_lvl := helper_fblocker_level
    float helper_overhead_level = na
    if not na(helper_bear_ob_lvl) and not na(helper_bear_fvg_lvl)
        helper_overhead_level := math.min(helper_bear_ob_lvl, helper_bear_fvg_lvl)
    else
        helper_overhead_level := helper_bear_fvg_lvl
        if not na(helper_bear_ob_lvl)
            helper_overhead_level := helper_bear_ob_lvl
    float helper_planned_risk = na
    if long_plan_active and not na(helper_planned_stop_level)
        helper_planned_risk := math.max(long_trigger - helper_planned_stop_level, syminfo.mintick)
    float helper_headroom_to_overhead = na
    if long_plan_active and not na(helper_overhead_level)
        helper_headroom_to_overhead := helper_overhead_level - long_trigger
    bool helper_overhead_zone_ok = true
    if use_overhead_zone_filter and not na(helper_headroom_to_overhead) and not na(helper_planned_risk)
        helper_overhead_zone_ok := helper_headroom_to_overhead >= helper_planned_risk * min_headroom_r
    [helper_planned_stop_level, helper_planned_risk, helper_headroom_to_overhead, helper_overhead_zone_ok]

compute_long_risk_plan_state(bool long_plan_active, float long_planned_stop_level, float planned_risk, float long_trigger, float target1_r, float target2_r) =>
    ll.compute_long_risk_plan_state(long_plan_active, long_planned_stop_level, planned_risk, long_trigger, target1_r, target2_r)

resolve_long_bus_plan_levels(bool long_plan_active, float long_trigger, float long_invalidation_level, float long_stop_level, float long_target_1, float long_target_2) =>
    ll.resolve_long_bus_plan_levels(long_plan_active, long_trigger, long_invalidation_level, long_stop_level, long_target_1, long_target_2)

resolve_ob_top_boundary(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.left_top.price
    level

resolve_ob_bottom_boundary(OrderBlock block) =>
    float level = na
    if not na(block)
        level := block.right_bottom.price
    level

resolve_fvg_top_boundary(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.left_top.price
    level

resolve_fvg_bottom_boundary(FVG gap) =>
    float level = na
    if not na(gap)
        level := gap.right_bottom.price
    level

resolve_ob_recency_index(OrderBlock block) =>
    int idx = na
    if not na(block)
        idx := block.right_bottom.index
    idx

resolve_fvg_recency_index(FVG gap) =>
    int idx = na
    if not na(gap)
        idx := gap.right_bottom.index
    idx

resolve_ob_id(OrderBlock block) =>
    int val = na
    if not na(block)
        val := block.id
    val

resolve_fvg_id(FVG gap) =>
    int val = na
    if not na(gap)
        val := gap.id
    val

update_latched_flag(bool current_latched, bool event_active, bool live_mode, bool bar_confirmed) =>
    current_latched or (live_mode ? event_active : bar_confirmed and event_active)



var g_mode = '1. Core Setup'
var ct.SignalMode signal_mode = input.enum(ct.SignalMode.CONFIRMED_ONLY, 'Signal Mode', group = g_mode, tooltip = 'Choose between safer closed-bar confirmation and faster realtime updates. Confirmed only is the safer non-repainting mode. Aggressive live allows intrabar high/low driven updates and alerts, so states can change before candle close, are not fully reconstructable after reload, and should be treated as realtime-only until the bar confirms.', display = display.status_line)
var string long_user_preset = input.string('Standard', 'Trading Style', options = ['Easy', 'Standard', 'Pro'], group = g_mode, tooltip = 'Primary Lite operating layer. Easy keeps the long engine permissive and easier to operate. Standard preserves the current balanced workflow. Pro enables stricter lifecycle and execution gating for cleaner but rarer setups.', display = display.status_line)
var bool compact_mode = input.bool(true, 'Focus View', group = g_mode, tooltip = 'Default first-run surface for solo operation or sharing. Suppresses debug overlays and keeps a single decision-first surface. Engine logic is unchanged; only the visible surface is reduced.')
var string color_theme = input.string('Standard', 'Color Theme', options = ['Standard', 'Colorblind Safe'], group = g_mode, tooltip = 'Standard uses the classic red/green palette. Colorblind Safe replaces bull/bear colors with a blue/orange palette optimised for deuteranopia and protanopia. Warning/stale colors are unchanged.')

// ── Quickstart Presets (Plan 1.4) ─────────────────────────────
// Ticker-class presets seeded from the calibration benchmark
// (`zone_priority_calibration.json`). Selecting a preset publishes the
// active class on the status line so downstream consumers and the
// dashboard can read it; existing inputs stay user-editable so power
// users keep full control. Conditional `active=` gating of the
// individual inputs lands in W1 once the preset \u2192 input mapping is
// covered by tests.
//
//   MEGA_TECH      \u2014 AAPL, MSFT, GOOGL, NVDA, META, AMZN
//                    Recommend RVOL >= 1.3, tighter ETH window,
//                    htf_bias_min = 0.7, FVG quality gate = high.
//                    Calibration evidence: AMZN/1H Grade A
//                    (84% HR, ECE 0.035).
//   FIN_SERVICES   \u2014 JPM, BAC, GS, MS
//                    Recommend FOMC event-gate ON, earnings
//                    kill-switch ON, vol_regime threshold tighter.
//                    Calibration evidence: JPM/15m Grade A (82.6% HR).
//   ENERGY         \u2014 XOM, CVX, COP, OXY
//                    Recommend Vol-Regime default HIGH, OIL
//                    event-gate ON, larger ATR-based zones.
//                    Higher intraday vol \u2014 calibration uses regime split.
//   CUSTOM         \u2014 Existing inputs apply as-is (default).
var string quickstart_preset = input.string('Custom', 'Quickstart Preset', options = ['Custom', 'Mega-Cap US Tech', 'Financial Services', 'Energy'], group = g_mode, tooltip = 'Plan 1.4 preset library. Pick a ticker class to load curated defaults backed by the calibration benchmark.\n\nMega-Cap US Tech (AAPL/MSFT/GOOGL/NVDA/META/AMZN) \u2014 RVOL >= 1.3, tight ETH window, FVG quality gate high. Evidence: AMZN/1H Grade A (84% HR, ECE 0.035).\n\nFinancial Services (JPM/BAC/GS/MS) \u2014 FOMC event-gate, earnings kill-switch, tighter vol threshold. Evidence: JPM/15m Grade A (82.6% HR).\n\nEnergy (XOM/CVX/COP/OXY) \u2014 Vol-Regime default HIGH, OIL event-gate, larger ATR zones.\n\nCustom keeps the existing inputs as-is.', display = display.status_line)

// Plan 1.4 W1 — effective-defaults helpers must be declared before
// their first consumer (the effective_relvol_good chain in the gate
// section). The matching BUS plots stay grouped with the rest of the
// BUS contract further down so the surface stays readable.
//
// Encoded values (see preset tooltip for evidence):
//   Mega-Cap US Tech    -> rvol_min 1.30, htf_bias_min 0.70, fvg_quality 2 (high), vol_regime_default 0 (NORMAL)
//   Financial Services  -> rvol_min 1.20, htf_bias_min 0.60, fvg_quality 1 (med),  vol_regime_default 0 (NORMAL)
//   Energy              -> rvol_min 1.10, htf_bias_min 0.55, fvg_quality 1 (med),  vol_regime_default 1 (HIGH)
//   Custom              -> 0/0/0/0 (consumers fall back to their own input defaults)
preset_effective_rvol_min(string preset) =>
    preset == 'Mega-Cap US Tech'   ? 1.30 : preset == 'Financial Services' ? 1.20 : preset == 'Energy' ? 1.10 : 0.0

preset_effective_htf_bias_min(string preset) =>
    preset == 'Mega-Cap US Tech'   ? 0.70 : preset == 'Financial Services' ? 0.60 : preset == 'Energy' ? 0.55 : 0.0

// Plan 1.4 W2 — Translate the float bias-min into the count of
// bullish HTFs (0..3) that the context-quality helper actually checks.
// Mapping: ceil(bias_min * 3). Custom returns 0 (no-op floor).
//   Energy 0.55 -> 2  (matches default)
//   Financial Services 0.60 -> 2  (matches default)
//   Mega-Cap US Tech 0.70 -> 3  (stricter than default; needs full HTF stack)
preset_effective_htf_align_count(string preset) =>
    int(math.ceil(preset_effective_htf_bias_min(preset) * 3.0))

preset_effective_fvg_quality_gate(string preset) =>
    preset == 'Mega-Cap US Tech'   ? 2 : preset == 'Financial Services' ? 1 : preset == 'Energy' ? 1 : 0

preset_effective_vol_regime_default(string preset) =>
    preset == 'Energy' ? 1 : 0

preset_effective_class_code(string preset) =>
    preset == 'Mega-Cap US Tech'   ? 1 : preset == 'Financial Services' ? 2 : preset == 'Energy' ? 3 : 0


// ── Central color palette (WP-OV4) ────────────────────────────
var color BULL_PRIMARY     = color_theme == 'Colorblind Safe' ? #1f77b4 : #089981
var color BEAR_PRIMARY     = color_theme == 'Colorblind Safe' ? #ff7f0e : #f23645
var color BULL_ZONE        = color_theme == 'Colorblind Safe' ? color.new(#1f77b4, 80) : color.new(#089981, 80)
var color BEAR_ZONE        = color_theme == 'Colorblind Safe' ? color.new(#ff7f0e, 80) : color.new(#f23645, 80)
var color BULL_HERO        = color_theme == 'Colorblind Safe' ? color.new(#1f77b4, 55) : color.new(color.green, 55)
var color BULL_HERO_READY  = color_theme == 'Colorblind Safe' ? color.new(#1f77b4, 60) : color.new(color.teal, 60)
var color BEAR_HERO        = color_theme == 'Colorblind Safe' ? color.new(#ff7f0e, 60) : color.new(color.red, 60)

var g_output = '2. Output'
var bool show_dashboard = input.bool(true, 'Show Decision Brief', group = g_output, tooltip = 'Shows the linked decision brief surface. The core remains the only Lite-primary surface; this toggle adds explanatory context only.')
var bool enable_dynamic_alerts = input.bool(true, 'Enable dynamic alerts', group = g_output, tooltip = 'Sends real-time alert messages for lifecycle state transitions (armed, confirmed, ready, entry). Disable to silence all dynamic alert output while keeping the visual surface unchanged.')

var g_trade_plan = '3. Trade Plan'
var float target1_r = input.float(1.0, 'Target 1 (R)', minval = 0.25, step = 0.25, group = g_trade_plan, tooltip = 'First take-profit target as a multiple of risk (R = entry to invalidation distance).')
var float target2_r = input.float(2.0, 'Target 2 (R)', minval = 0.5, step = 0.25, group = g_trade_plan, tooltip = 'Second take-profit target as a multiple of risk. Shown on the trade plan overlay when enabled.')

var g_session_gate = '4. Session Gate'
var bool use_trade_session_gate = input.bool(true, 'Use Trade Session Gate', group = g_session_gate, inline = 'trade1', tooltip = 'Restricts lifecycle advances to the configured trading session window. Outside the window, new setups are blocked but existing positions are not affected.')

var g_runtime = '5. Runtime Budget'
var string performance_mode = input.string('Balanced', 'Performance Mode', options = ['Light', 'Balanced', 'Pro', 'Debug'], group = g_runtime, tooltip = 'Light cuts rendering and lower-timeframe workload. Balanced preserves the manual limits. Pro raises object and sampling budgets. Debug keeps the richest diagnostics and history.', display = display.status_line)

var g_ltf = '6. Advanced - Lower Timeframe'
var bool enable_ltf_sampling = input.bool(true, 'Use lower timeframe sampling', group = g_ltf, display = display.none, tooltip = 'Uses request.security_lower_tf() to summarize intrabar participation and pressure.')
var bool use_ltf_for_strict_entry = input.bool(true, 'Use LTF for strict entry', group = g_ltf, display = display.none, tooltip = 'Keeps lower-timeframe sampling active for strict-entry filters even when the dashboard and dynamic alerts are off.')
var bool allow_strict_entry_without_ltf = input.bool(false, 'Allow strict entry without LTF when unavailable', group = g_ltf, display = display.none, tooltip = 'Optional fallback. When enabled, strict-entry alerts may still trigger when lower-timeframe sampling is unavailable or unverifiable on the current chart. Strict normally prefers confirmed LTF volume context; this fallback relaxes only that sub-requirement while the remaining strict gates stay active.')
var bool use_ltf_for_dynamic_alerts = input.bool(false, 'Use LTF in dynamic alerts', group = g_ltf, display = display.none, tooltip = 'When off, dynamic alert messages do not force lower-timeframe sampling just for message decoration.')
var bool ltf_auto_select = input.bool(true, 'Auto-select lower timeframe', group = g_ltf, display = display.none)
var string ltf_timeframe = input.timeframe(DEFAULT_LTF_TIMEFRAME, 'Lower timeframe', group = g_ltf, display = display.status_line)
var float ltf_bias_hint = input.float(0.55, 'Bull share hint', minval = 0.5, maxval = 1.0, step = 0.05, group = g_ltf, display = display.none)

var g_mtf = '7. Advanced - Higher Timeframe Trend'
// Trend-stack intent: ICT-standard 3-layer hierarchy (4H / 1D / 1W) with
// an adaptive IPDA dach-TF, factor-~4 spacing between adjacent layers.
// See docs/smc_improvement_plan_addendum_2_8_mtf_scope_2026-04-21.md for
// the deliberate decision against a Flux-style 7-TF bias stack.
//
// Addendum 2.8 Phase 3 (W14-W20) — optional 2H 4th layer scaffolded
// behind a feature-flag, default OFF. Promotion is gated on the Q4 W13
// A/B verdict (G1 ≥3pp uplift / G2 Brier ≤0.02 / G3 ≥30 events per
// bucket). When the gate fires GO, only `enable_trend_tf_0` defaults
// flip to true; calibration weights then absorb the 4th layer in
// `smc_core/scoring.py`. Until then the input renders inactive and
// the engine stays on the published 3-layer stack.
var bool enable_trend_tf_0 = input.bool(false, 'Enable 2H pre-trend layer (Q4-gated)', group = g_mtf, display = display.none, tooltip = 'Addendum 2.8 Phase 3 scaffold. Default OFF until the Q4 W13 A/B-Gate (3 cumulative thresholds in scripts/plan_2_8_q4_gate_evaluator.py) returns GO. Enabling without a green gate is unsupported because per-family calibrated weights for the 2H layer are not yet published; the 4th icon would render uncalibrated.')
var string mtf_trend_tf0 = input.timeframe(DEFAULT_TREND_TF_0, 'Trend TF 0 (optional 2H)', group = g_mtf, inline = 'mtf0', display = display.none, tooltip = 'Optional pre-layer between Chart-TF and Trend TF 1 (default 2H). Only consumed when "Enable 2H pre-trend layer (Q4-gated)" is on. See docs/smc_improvement_plan_addendum_2_8_mtf_scope_2026-04-21.md §6 Phase 3.')
var string mtf_trend_tf1 = input.timeframe(DEFAULT_TREND_TF_1, 'Trend TF 1', group = g_mtf, inline = 'mtf1', display = display.none, tooltip = 'Trend Stack layer 1 (default 4H). Part of the ICT-standard 3-layer hierarchy 4H -> 1D -> 1W, factor-~4 spacing. Intentional over Flux-style 7-TF bias stacks: each layer is calibrated per-family x per-context. Custom TFs keep display but skip calibrated weights.')
var string mtf_trend_tf2 = input.timeframe(DEFAULT_TREND_TF_2, 'Trend TF 2', group = g_mtf, inline = 'mtf2', display = display.none, tooltip = 'Trend Stack layer 2 (default 1D). Swing-context anchor on top of the intraday Chart-TF. Changing away from the default disables per-layer calibrated contribution.')
var string mtf_trend_tf3 = input.timeframe(DEFAULT_TREND_TF_3, 'Trend TF 3', group = g_mtf, inline = 'mtf3', display = display.none, tooltip = 'Trend Stack layer 3 (default 1W). Macro-bias anchor. An adaptive IPDA dach-TF (D -> W -> M) sits above this layer automatically (see smc_core/htf_context.py::select_ipda_htf).')

var g_dashboard = '8. Advanced - Dashboard Detail'
var bool show_dashboard_ltf = input.bool(true, 'Show LTF details', group = g_dashboard, display = display.none)

var g_alerts = '9. Advanced - Alerts'
var bool enable_live_break_alerts = input.bool(true, 'Enable intrabar live break alerts', group = g_alerts, display = display.none)
var string dynamic_long_alert_mode = input.string('Priority', 'Dynamic long alerts', options = ['Priority', 'All lifecycle'], group = g_alerts, display = display.none, tooltip = 'Priority sends only the highest long lifecycle message per bar. All lifecycle allows multiple long lifecycle messages on the same bar.')

