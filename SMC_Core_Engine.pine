resolve_bus_signal_quality_row(int sq_score, string sq_tier) =>
    if sq_tier == "high"
        pack_bus_row(5, 4)
    else if sq_tier == "good"
        pack_bus_row(4, 3)
    else if sq_tier == "ok"
        pack_bus_row(3, 2)
    else
        pack_bus_row(2, 1)

resolve_bus_signal_freshness_row(string sq_freshness, string sq_bias) =>
    int fresh_code = sq_freshness == "fresh" ? 5 : sq_freshness == "aging" ? 3 : 1
    int bias_code = sq_bias == "bull" ? 1 : sq_bias == "bear" ? 2 : sq_bias == "mixed" ? 3 : 4
    pack_bus_row(fresh_code, bias_code)

resolve_bus_event_risk_light_row(string erl_window, string erl_level, bool erl_market_blocked, bool erl_symbol_blocked) =>
    if erl_market_blocked
        pack_bus_row(-1, 1)
    else if erl_symbol_blocked
        pack_bus_row(-1, 6)
    else if erl_window == "ACTIVE"
        pack_bus_row(2, 2)
    else if erl_window == "PRE_EVENT" and (erl_level == "ELEVATED" or erl_level == "HIGH")
        pack_bus_row(2, 3)
    else if erl_window == "COOLDOWN"
        pack_bus_row(3, 4)
    else
        pack_bus_row(5, 5)

resolve_bus_struct_light_row(int trend_strength, bool fresh, string last_event) =>
    int event_code = last_event == "BOS_BULL" ? 1 : last_event == "CHOCH_BULL" ? 2 : last_event == "BOS_BEAR" ? 3 : last_event == "CHOCH_BEAR" ? 4 : 5
    if trend_strength >= 60 and fresh
        pack_bus_row(5, event_code)
    else if trend_strength >= 30
        pack_bus_row(4, event_code)
    else
        pack_bus_row(2, event_code)

resolve_bus_ob_light_row(string ob_side, bool ob_fresh, string ob_mitig) =>
    if ob_side == "BULL" and ob_fresh
        pack_bus_row(5, ob_mitig == "fresh" ? 1 : ob_mitig == "touched" ? 2 : 3)
    else if ob_side == "BULL"
        pack_bus_row(3, 2)
    else if ob_side == "BEAR"
        pack_bus_row(2, 4)
    else
        pack_bus_row(3, 5)

resolve_bus_fvg_light_row(string fvg_side, bool fvg_fresh, bool fvg_invalidated) =>
    if fvg_invalidated
        pack_bus_row(2, 1)
    else if fvg_side == "BULL" and fvg_fresh
        pack_bus_row(5, 2)
    else if fvg_side == "BULL"
        pack_bus_row(4, 3)
    else if fvg_side == "BEAR"
        pack_bus_row(2, 4)
    else
        pack_bus_row(3, 5)

