var int ddvi_advx_smooth = input.int(14, 'ADVX Smooth', minval = 1, group = g_ddvi_ctx, inline = 'd1', display = display.none)
var ct.SmcLibMovingAverage ddvi_ma_select = input.enum(ct.SmcLibMovingAverage.SMA, 'DDVI MA', group = g_ddvi_ctx, inline = 'd2', display = display.none)
var int ddvi_ma_len = input.int(5, 'Length', minval = 1, group = g_ddvi_ctx, inline = 'd2', display = display.none)
var ct.SmcLibMovingAverage ddvi_bb_ma_select = input.enum(ct.SmcLibMovingAverage.SMA, 'DDVI BB MA', group = g_ddvi_ctx, inline = 'bb', display = display.none)
var int ddvi_bb_len = input.int(100, 'BB Length', minval = 5, group = g_ddvi_ctx, inline = 'bb', display = display.none)
var float ddvi_bb_mult = input.float(1.5, 'BB Stdev', minval = 0.1, step = 0.1, group = g_ddvi_ctx, inline = 'bb', display = display.none)
var int ddvi_lower_extreme_lookback = input.int(12, 'Lower extreme context bars', minval = 1, maxval = 50, group = g_ddvi_ctx, display = display.none, tooltip = 'Stacked rollout recommendation: 12. This keeps DDVI context alive long enough for Watchlist and Ready without forcing DDVI to remain at the absolute lower extreme.')
var bool use_ddvi_hidden_bull = input.bool(true, 'Use hidden bull divergence', group = g_ddvi_ctx, inline = 'div', display = display.none, tooltip = 'Recommended on. Hidden bull divergence is the most natural DDVI continuation signal for long-dip entries.')
var bool use_ddvi_strong_bull = input.bool(true, 'Use strong bull divergence', group = g_ddvi_ctx, inline = 'div', display = display.none, tooltip = 'Stacked rollout recommendation: on. Strong bull divergence can upgrade DDVI into Entry Best without forcing Strict to rely on a second divergence engine on top of SD.')
var int ddvi_pivot_left = input.int(5, 'Pivot Left', minval = 1, group = g_ddvi_ctx, inline = 'p1', display = display.none)
var int ddvi_pivot_right = input.int(3, 'Right', minval = 1, group = g_ddvi_ctx, inline = 'p1', display = display.none)
var int ddvi_div_min_range = input.int(5, 'Div Min', minval = 1, group = g_ddvi_ctx, inline = 'p2', display = display.none)
var int ddvi_div_max_range = input.int(60, 'Max', minval = 2, group = g_ddvi_ctx, inline = 'p2', display = display.none)
var int ddvi_eq_zone_len = input.int(14, 'Equal zone length', minval = 1, group = g_ddvi_ctx, inline = 'p3', display = display.none)
var float ddvi_eq_zone_atr_mult = input.float(0.2, 'Price ATR x', minval = 0.0, step = 0.1, group = g_ddvi_ctx, inline = 'p3', display = display.none)
var float ddvi_eq_zone_dev_mult = input.float(0.2, 'DDVI Dev x', minval = 0.0, step = 0.01, group = g_ddvi_ctx, inline = 'p3', display = display.none)
var bool ddvi_close_safe_only = input.bool(true, 'DDVI events close-safe only', group = g_ddvi_ctx, display = display.none, tooltip = 'Recommended on. Keeps DDVI event gating aligned with the rest of the close-safe SMC flow.')

var g_struct = '24. Advanced - Market Structure'
var bool show_Structure = input.bool(false, 'Show Market Structure', group = g_struct, display = display.none, tooltip = 'Display market structure.')
var string show_bull = input.string('All', 'Bullish Structure', options = ['All', 'BOS', 'CHoCH'], group = g_struct, inline = 'bull', display = display.none)
var color bull_css = color_theme == 'Colorblind Safe' ? #1f77b4 : input.color(#089981, '', group = g_struct, inline = 'bull', display = display.none)
var color bear_css = color_theme == 'Colorblind Safe' ? #ff7f0e : input.color(#f23645, '', group = g_struct, inline = 'bear', display = display.none)
var bool show_swing_points = input.bool(false, 'Show Swing Points (HH/LH/HL/LL)', group = g_struct, inline = 'swings', display = display.none, tooltip = 'Display swing points as labels on the chart.')
var int swing_length = input.int(DEFAULT_SWING_LENGTH, 'Swing Size', minval = 10, group = g_struct, inline = 'swings', display = display.none)
var bool show_internals = input.bool(false, 'Show Internal Structure', group = g_struct, inline = 'internals', display = display.none)
var int internal_length = input.int(DEFAULT_INTERNAL_LENGTH, 'Internal Size', minval = 3, group = g_struct, inline = 'internals', display = display.none)
var bool show_latest_swings_levels = input.bool(true, 'Show Strong/Weak High/Low', group = g_struct, display = display.none, tooltip = 'Highlight the most recent strong and weak highs/lows on the chart.')

var bool show_bull_bos = show_Structure and (show_bull == 'All' or show_bull == 'BOS')
var bool show_bull_choch = show_Structure and (show_bull == 'All' or show_bull == 'CHoCH')

var g_ob = '25. Advanced - Order Blocks'
var show_ob = input.bool(true, 'Show Order Blocks', group = g_ob, inline = 'OB', display = display.none, tooltip = 'Display swing order blocks on the chart.\n\nThis controls how many recent swing order blocks are shown.')
var bull_ob_css = input.color(color.new(#3668f2, 80), '', group = g_ob, inline = 'OB', display = display.none)
var bull_ob_css_line = input.color(color.new(#3668f2, 15), '', group = g_ob, inline = 'OB', display = display.none)
var ob_showlast = input.int(DEFAULT_OB_SHOW_LAST, 'Show last', minval = 1, group = g_ob, inline = 'OB', display = display.none)
var bool show_ob_debug = input.bool(false, 'Show OB debug', group = g_ob, display = display.none)
var bool show_fvg_debug = input.bool(false, 'Show FVG debug', group = 'Fair Value Gaps', display = display.none)
var ob_filter_min_mult = input.float(DEFAULT_OB_FILTER_MIN_MULT, 'Size Filter (ATR x) Min', minval = 0, step = 0.1, group = g_ob, inline = 'OB Filter', display = display.none)
var ob_filter_max_mult = input.float(DEFAULT_OB_FILTER_MAX_MULT, 'Max', minval = 1, step = 0.1, group = g_ob, inline = 'OB Filter', display = display.none, tooltip = 'Order Block size filter based on ATR multiples. Blocks smaller than the minimum or larger than the maximum are ignored.')
var show_ob_id = false
var ob_extend_until_broken = input.bool(true, 'Extend until broken', group = g_ob, display = display.none)
var ob_keep_broken = input.bool(true, 'Keep broken', group = g_ob, inline = 'keep broken', display = display.none)
var ob_keep_broken_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 0, group = g_ob, inline = 'keep broken', display = display.none)
var bull_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken', display = display.none)
var bull_ob_line_css_broken = color.new(bull_ob_css_broken, 50)
var use_ob_profile = input.bool(true, 'Use profiles', group = g_ob, display = display.none, tooltip = 'Narrows the box to the value area and can align the break price to the profile POC.')
var use_ob_soft_confirm = input.bool(true, 'Use soft confirm', inline = 'soft confirm', group = g_ob, display = display.none, tooltip = 'A block may confirm early if price interacts with the break area and then exits in trend direction.')
var soft_confirm_offset_atr_len = ATR_LEN_MAIN
var soft_confirm_offset_atr_mult = 1.0
var use_retracements_with_FVG_out = input.bool(true, 'Use retracements with FVG-out as trend-supporting OB', group = g_ob, display = display.none, tooltip = 'Allows certain failed extensions with FVG confirmation to become valid continuation order blocks.')
var use_ob_engine = input.bool(true, 'Use OB engine', group = g_ob, display = display.none, tooltip = 'Keeps OB-based long-dip logic and alerts running even if chart rendering is hidden.')

// ── Ticker Heat → OB Opacity Modifier (WP-LF4) ──
if barstate.isfirst and ticker_heat_adj != 0
    bull_ob_css := color.new(bull_ob_css, math.max(5, math.min(95, color.t(bull_ob_css) - ticker_heat_adj)))

// ── Breaking News → OB Opacity Minimum (WP-NW5) ──
if barstate.isfirst and is_breaking_news
    bull_ob_css := color.new(bull_ob_css, math.min(95, color.t(bull_ob_css) + 15))

// ── Institutional Confirmation → OB Opacity Modifier (WP-ND4) ──
if barstate.isfirst and is_inst_accumulation
    bull_ob_css := color.new(bull_ob_css, math.max(5, color.t(bull_ob_css) - 5))
if barstate.isfirst and is_inst_distribution
    bull_ob_css := color.new(bull_ob_css, math.min(95, color.t(bull_ob_css) + 5))

bool preset_is_easy = long_user_preset == 'Easy'
bool preset_is_standard = long_user_preset == 'Standard'
