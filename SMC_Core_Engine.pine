var int lower_extreme_recent_bars = input.int(12, 'Lower extreme recent bars', minval = 1, maxval = 100, group = g_stretch, inline = 'dist2', display = display.none, tooltip = 'Recommended start: 12. This keeps stretch context alive briefly after the actual lower-extreme touch.')
