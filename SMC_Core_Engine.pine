var bool keep_visual_history = input.bool(false, 'Keep structure label history', group = g_perf, display = display.none, tooltip = 'When off, high-frequency structure, pivot and equal-level labels do not accumulate indefinitely.')
var int object_gc_cycle = input.int(250, 'Object GC Cycle', minval = 0, group = g_perf, display = display.none, tooltip = 'Runs periodic cleanup of insignificant OB/FVG objects. Set to 0 to disable GC.')
var int max_ltf_ratio = input.int(60, 'Max LTF Ratio', minval = 2, maxval = 500, group = g_perf, display = display.none, tooltip = 'Disables lower timeframe sampling if chart_tf / ltf_tf exceeds this ratio.')
var int max_ltf_samples_per_bar = input.int(300, 'Max LTF Samples / Bar', minval = 10, maxval = 1000, group = g_perf, display = display.none, tooltip = 'Additional guardrail for lower timeframe array size per chart bar.')

var g_data = '11. Advanced - Data Quality'
var int volume_quality_lookback = input.int(50, 'Volume Quality Lookback', minval = 5, group = g_data, display = display.none)
var int min_nonzero_volume_bars = input.int(10, 'Min Non-Zero Volume Bars', minval = 1, group = g_data, display = display.none)
var bool allow_relvol_without_volume_data = input.bool(false, 'Ignore RelVol when volume unavailable', group = g_data, display = display.none, tooltip = 'Optional fallback. When enabled, non-strict stages do not fail solely because the feed provides sparse or zero volume. RelVol falls back, DDVI watchlist/ready/best gates stop hard-blocking, and score thresholds shrink by the unavailable RelVol component. Strict still prefers confirmed volume-backed context, but can be partially relaxed when the dedicated strict-entry LTF fallback is also enabled.')

