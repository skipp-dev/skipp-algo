{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Daemon Runbook",
      "type": "link",
      "url": "https://github.com/skippALGO/skipp-algo/blob/main/services/live_overlay_daemon/README.md",
      "targetBlank": true
    },
    {
      "title": "Grafana Alert Rules",
      "type": "link",
      "url": "https://github.com/skippALGO/skipp-algo/blob/main/services/live_overlay_daemon/infra/grafana/alert-rules.yaml",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "live_overlay_health_status_ok{job=\"live_overlay\"}*2 + live_overlay_health_status_idle_market_closed{job=\"live_overlay\"}",
          "legendFormat": "Health state"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "STARTING", "color": "yellow"},
                "1": {"text": "IDLE (MARKET CLOSED)", "color": "semi-dark-orange"},
                "2": {"text": "OK", "color": "green"}
              }
            }
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      }
    },
    {
      "title": "Workers Healthy",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "live_overlay_workers_healthy{job=\"live_overlay\"}", "legendFormat": "Workers"}],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DEGRADED", "color": "red"}, "1": {"text": "OK", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "live_overlay_uptime_seconds{job=\"live_overlay\"}", "legendFormat": "Uptime"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 360},
              {"color": "green", "value": 3600}
            ]
          }
        }
      }
    },
    {
      "title": "Overlay Symbols",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "live_overlay_overlay_symbols{job=\"live_overlay\"}", "legendFormat": "Symbols"}],
      "options": {
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "EMPTY", "color": "red"}
              }
            }
          ]
        }
      }
    },
    {
      "title": "Bar Symbols",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "live_overlay_bar_symbols{job=\"live_overlay\"}", "legendFormat": "Bar symbols"}],
      "options": {
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "EMPTY", "color": "red"}
              }
            }
          ]
        }
      }
    },
    {
      "title": "Bar Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "live_overlay_bar_count{job=\"live_overlay\"}", "legendFormat": "Bar count"}],
      "options": {
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(live_overlay_smc_live_requests_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "smc_live total"},
        {"expr": "rate(live_overlay_smc_live_success_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "success"},
        {"expr": "rate(live_overlay_smc_live_auth_denied{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "auth denied"},
        {"expr": "rate(live_overlay_smc_live_cache_miss_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "cache miss"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps", "noValue": "MARKET CLOSED"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "auth denied"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "cache miss"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          }
        ]
      }
    },
    {
      "title": "Overlay & Bar Age",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "live_overlay_overlay_age_seconds{job=\"live_overlay\"}", "legendFormat": "overlay age"},
        {"expr": "live_overlay_last_bar_age_seconds{job=\"live_overlay\"} or vector(0)", "legendFormat": "last bar age"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 1800, "color": "yellow"}, {"value": 3600, "color": "red"}]},
          "custom": {"thresholdsStyle": {"mode": "line"}}
        }
      }
    },
    {
      "title": "Compute Cycle Errors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "rate(live_overlay_full_compute_cycle_errors{job=\"live_overlay\"}[$__rate_interval]) or vector(0)", "legendFormat": "full compute errors"},
        {"expr": "rate(live_overlay_flow_patch_cycle_errors{job=\"live_overlay\"}[$__rate_interval]) or vector(0)", "legendFormat": "flow patch errors"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1e-09}]},
          "custom": {"thresholdsStyle": {"mode": "area"}}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "full compute errors"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "flow patch errors"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          }
        ]
      }
    },
    {
      "title": "Feed Health Counters",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "rate(live_overlay_feed_reconnect_attempts{job=\"live_overlay\"}[$__rate_interval])", "legendFormat": "reconnects/s"},
        {"expr": "rate(live_overlay_feed_bento_errors{job=\"live_overlay\"}[$__rate_interval])", "legendFormat": "bento errors/s"},
        {"expr": "rate(live_overlay_feed_unexpected_errors{job=\"live_overlay\"}[$__rate_interval])", "legendFormat": "unexpected errors/s"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {"defaults": {"unit": "cps"}}
    },
    {
      "title": "Feed Circuit Breakers (Total)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 20},
      "targets": [
        {"expr": "live_overlay_feed_circuit_breakers{job=\"live_overlay\"}", "legendFormat": "circuit breakers"}
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "0", "color": "green"}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      }
    },
    {
      "title": "Feed Partial Restarts (Total)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 20},
      "targets": [
        {"expr": "live_overlay_feed_partial_restarts{job=\"live_overlay\"}", "legendFormat": "partial restarts"}
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      }
    },
    {
      "title": "Worker Liveness",
      "type": "state-timeline",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "live_overlay_worker_live_feed_alive{job=\"live_overlay\"}", "legendFormat": "live_feed"},
        {"expr": "live_overlay_worker_overlay_refresh_alive{job=\"live_overlay\"} or vector(0)", "legendFormat": "overlay_refresh"},
        {"expr": "live_overlay_worker_flow_refresh_alive{job=\"live_overlay\"} or vector(0)", "legendFormat": "flow_refresh"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [{"type": "value", "options": {"0": {"text": "DEAD"}, "1": {"text": "ALIVE"}}}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "title": "Success Rate (%)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 26},
      "targets": [
        {
          "expr": "(100 * sum(rate(live_overlay_smc_live_success_total{job=\"live_overlay\"}[$__rate_interval])) / clamp_min(sum(rate(live_overlay_smc_live_requests_total{job=\"live_overlay\"}[$__rate_interval])), 1e-9)) and on() (max(live_overlay_market_open{job=\"live_overlay\"}) == 1)",
          "legendFormat": "success_rate"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "MARKET CLOSED",
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 99}
            ]
          }
        }
      }
    },
    {
      "title": "Market-open Request Health",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 26},
      "targets": [
        {
          "expr": "(max(live_overlay_market_open{job=\"live_overlay\"}) * (1 + ((sum(rate(live_overlay_smc_live_requests_total{job=\"live_overlay\"}[$__rate_interval])) > bool 0.001) or vector(0)))) or vector(0)",
          "legendFormat": "open_req_health"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "MARKET_CLOSED", "color": "gray"},
                "1": {"text": "OPEN_NO_TRAFFIC", "color": "yellow"},
                "2": {"text": "TRAFFIC_OK", "color": "green"}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "gray", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 2}
            ]
          }
        }
      }
    },
    {
      "title": "Restarts (24h)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 26},
      "targets": [
        {
          "expr": "resets(live_overlay_uptime_seconds{job=\"live_overlay\"}[24h])",
          "legendFormat": "restarts"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      }
    },
    {
      "title": "Failure Mix",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {"expr": "rate(live_overlay_smc_live_auth_denied{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "auth denied"},
        {"expr": "rate(live_overlay_smc_live_cache_miss_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "cache miss"},
        {"expr": "rate(live_overlay_smc_live_bad_tf_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "bad tf"},
        {"expr": "rate(live_overlay_smc_live_errors_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "errors"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "MARKET CLOSED",
          "unit": "reqps",
          "custom": {"stacking": {"mode": "normal", "group": "A"}}
        }
      }
    },
    {
      "title": "Overlay Freshness Budget (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "100 * live_overlay_overlay_age_seconds{job=\"live_overlay\"} / clamp_min(live_overlay_max_stale_seconds{job=\"live_overlay\"}, 1)",
          "legendFormat": "stale_budget_used"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 100}
            ]
          }
        }
      }
    },
    {
      "title": "Readiness Components Timeline",
      "type": "state-timeline",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "targets": [
        {"expr": "live_overlay_feed_healthy{job=\"live_overlay\"}", "legendFormat": "feed_healthy"},
        {"expr": "live_overlay_workers_healthy{job=\"live_overlay\"}", "legendFormat": "workers_healthy"},
        {"expr": "live_overlay_overlay_fresh{job=\"live_overlay\"} or vector(0)", "legendFormat": "overlay_fresh"},
        {"expr": "live_overlay_market_open{job=\"live_overlay\"}", "legendFormat": "market_open"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [{"type": "value", "options": {"0": {"text": "NO"}, "1": {"text": "YES"}}}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "title": "Stale Responses (served)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "targets": [
        {
          "expr": "rate(live_overlay_smc_live_stale_served_total{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)",
          "legendFormat": "stale served/s"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "MARKET CLOSED",
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      }
    },
    {
      "title": "smc_live Latency Avg (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
      "targets": [
        {
          "expr": "(rate(live_overlay_smc_live_latency_sum_ms{job=\"live_overlay\"}[$__rate_interval]) / clamp_min(rate(live_overlay_smc_live_latency_count{job=\"live_overlay\"}[$__rate_interval]), 1e-9)) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)",
          "legendFormat": "avg latency"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "MARKET CLOSED",
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 150},
              {"color": "orange", "value": 300},
              {"color": "red", "value": 500}
            ]
          }
        }
      }
    },
    {
      "title": "smc_live Latency Buckets (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
      "targets": [
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_50{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=50ms"},
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_100{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=100ms"},
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_250{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=250ms"},
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_500{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=500ms"},
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_1000{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=1000ms"},
        {"expr": "rate(live_overlay_smc_live_latency_bucket_le_inf{job=\"live_overlay\"}[$__rate_interval]) and on(job) (live_overlay_market_open{job=\"live_overlay\"} == 1)", "legendFormat": "<=inf"}
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "MARKET CLOSED",
          "unit": "reqps",
          "custom": {"stacking": {"mode": "none", "group": "A"}}
        }
      }
    },
    {
      "title": "External Integrations",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 56},
      "collapsed": false,
      "panels": []
    },
    {
      "title": "UptimeRobot Bridge",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 57},
      "targets": [
        {
