//@version=6

// Product role: pro execution surface on the frozen 8-channel executable contract.
// Product scope: this strategy executes long-only setups from the linked SMC Core long-dip specialist.
//   Short-parity execution requires a separate strategy track; it is not an implicit promise of this surface.
// Visible setup controls tune only wrapper behavior; linked core outputs stay in explicit operator-only expert-mapping groups.

// Strategy orders are staged on confirmed bars via process_orders_on_close, so the backtest path does not rely on intrabar lookahead.
strategy("SMC Execution", overlay = true, pyramiding = 0, process_orders_on_close = true)

var string g_setup = "1. Execution Setup"
var string g_trade_plan = "2. Trade Plan"
var string g_bus_entry = "3. Expert Mapping - Entry States"
var string g_bus_plan = "4. Expert Mapping - Trade Plan"

entry_mode = input.string("Strict", "Execution Stage", options = ["Armed", "Confirmed", "Ready", "Best", "Strict"], group = g_setup, tooltip = "Choose which linked core stage is allowed to stage the execution trigger.")
min_quality_score = input.float(0.0, "Minimum Quality Score", step = 0.25, group = g_setup, tooltip = "Minimum quality score required before the linked core setup can stage an execution plan.")
use_take_profit = input.bool(true, "Use Take Profit", group = g_trade_plan, tooltip = "Stage a take-profit target on top of the linked core execution trigger and invalidation plan.")
take_profit_r = input.float(2.0, "Take Profit (R)", minval = 0.0, step = 0.25, group = g_trade_plan, tooltip = "Take-profit distance in R measured from execution trigger to invalidation.")

src_armed = input.source(close, "BUS Armed", group = g_bus_entry, tooltip = "Bind these expert-mapping inputs top-to-bottom to the matching linked core outputs from SMC Core.")
src_confirmed = input.source(close, "BUS Confirmed", group = g_bus_entry)
src_ready = input.source(close, "BUS Ready", group = g_bus_entry)
src_entry_best = input.source(close, "BUS EntryBest", group = g_bus_entry)
src_entry_strict = input.source(close, "BUS EntryStrict", group = g_bus_entry)
src_quality_score = input.source(close, "BUS QualityScore", group = g_bus_entry)
src_trigger = input.source(close, "BUS Trigger", group = g_bus_plan, tooltip = "Bind these plan inputs after the state group so the linked execution plan stays deterministic.")
src_invalidation = input.source(close, "BUS Invalidation", group = g_bus_plan)

state_on(float value) =>
    not na(value) and value > 0.5

bool armed = state_on(src_armed)
bool confirmed = state_on(src_confirmed)
bool ready = state_on(src_ready)
bool entry_best = state_on(src_entry_best)
bool entry_strict = state_on(src_entry_strict)

bool selected_state = false
if entry_mode == "Armed"
    selected_state := armed
else if entry_mode == "Confirmed"
    selected_state := confirmed
else if entry_mode == "Ready"
    selected_state := ready
else if entry_mode == "Best"
    selected_state := entry_best
else
    selected_state := entry_strict

bool risk_levels_ok = not na(src_trigger) and not na(src_invalidation) and src_trigger > src_invalidation
bool quality_ok = na(src_quality_score) ? false : src_quality_score >= min_quality_score
// Entry/exit logic is evaluated from confirmed BUS inputs; no intrabar lookahead is used in this strategy wrapper.
bool can_stage_entry = selected_state and quality_ok and risk_levels_ok

float risk_per_unit = risk_levels_ok ? src_trigger - src_invalidation : na
float take_profit_price = na
if use_take_profit and risk_levels_ok
    take_profit_price := src_trigger + risk_per_unit * take_profit_r

var float active_entry_stop = na
var float active_invalidation = na
var float active_take_profit = na

if strategy.position_size <= 0
    if can_stage_entry
        strategy.entry("L", strategy.long, stop = src_trigger)
    else
        strategy.cancel("L")

if strategy.position_size > 0 and strategy.position_size[1] <= 0
    active_entry_stop := src_trigger
    active_invalidation := src_invalidation
    active_take_profit := use_take_profit ? take_profit_price : na

if strategy.position_size > 0
    float exit_stop = na(active_invalidation) ? src_invalidation : active_invalidation
    float exit_limit = use_take_profit ? active_take_profit : na
    if not na(exit_stop)
        strategy.exit("L Exit", "L", stop = exit_stop, limit = exit_limit)
else
    active_entry_stop := na
    active_invalidation := na
    active_take_profit := na

plot(src_trigger, "Execution Trigger", color = color.new(color.aqua, 0), linewidth = 2, style = plot.style_linebr)
plot(src_invalidation, "Execution Invalidation", color = color.new(color.orange, 0), linewidth = 2, style = plot.style_linebr)
plot(use_take_profit ? (strategy.position_size > 0 ? active_take_profit : take_profit_price) : na, "Execution Take Profit", color = color.new(color.green, 0), linewidth = 1, style = plot.style_linebr)