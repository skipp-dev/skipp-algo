// ────────────────────────────────────────────────────────────────
//  CHOCH + BOS  ·  Market Structure Indicator
//  Extracted from QuickALGO v6.3.5  ·  Pine Script v6
//  Detects Change-of-Character (ChoCH) and Break-of-Structure (BOS)
//  with optional Volume Filter, EMA overlay and Swing Level lines.
// ────────────────────────────────────────────────────────────────
//@version=6
indicator("CHOCH + BOS", overlay=true, max_labels_count=500)

// ─── Constants ───────────────────────────────────────────────
string GRP_STRUCT = "Market Structure"
string GRP_VOL    = "Volume Filter"
string GRP_EMA    = "EMA / ATR"
string GRP_VIS    = "Visibility"

// ─── Inputs: Market Structure ────────────────────────────────
swingL          = input.int(5,         "Swing Left (L)",           minval=1, maxval=20, group=GRP_STRUCT)
swingR          = input.int(3,         "Swing Right (R)",          minval=1, maxval=20, group=GRP_STRUCT, tooltip="Lower R values detect new levels faster.")
swingMaxAgeBars = input.int(0,         "Swing Max Age (bars)",     minval=0, maxval=2000, group=GRP_STRUCT, tooltip="0 = no expiry.")
breakoutSource  = input.string("Close","Breakout Source",          options=["Close", "Wick"], group=GRP_STRUCT, tooltip="Close: candle must close beyond level. Wick: high/low cross is enough.")
structureLogic  = input.string("Standard", "Structure Logic",      options=["Standard", "SMC+Sweep"], group=GRP_STRUCT, tooltip="Standard: reversal via trend break. SMC+Sweep: adds failed-breakout reclaims (Turtle Soup).")
barCloseOnly    = input.bool(true,     "Confirm on bar close only", group=GRP_STRUCT, tooltip="Ignore intra-bar signals — only fire on confirmed closes.")

// ─── Inputs: Volume Filter ──────────────────────────────────
useVolFilter    = input.bool(true,     "Volume Filter",            group=GRP_VOL)
volSmaLen       = input.int(20,        "Volume SMA Length",        minval=2, group=GRP_VOL)
volMult         = input.float(1.20,    "Volume Multiplier",        minval=0.1, step=0.05, group=GRP_VOL, tooltip="Signal requires volume > SMA × this multiplier.")
chochReqVol     = input.bool(true,     "ChoCH Requires Volume",   group=GRP_VOL, tooltip="When ON, ChoCH signals without volume are suppressed. BOS labels still show.")

// ─── Inputs: EMA / ATR ──────────────────────────────────────
emaFastLen      = input.int(21,        "EMA Fast",                 minval=1, group=GRP_EMA)
emaSlowLen      = input.int(55,        "EMA Slow",                 minval=1, group=GRP_EMA)
atrLen          = input.int(14,        "ATR Length",               minval=1, group=GRP_EMA)

// ─── Inputs: Visibility ─────────────────────────────────────
showBullChoch   = input.bool(true,     "Bull ChoCH labels",       group=GRP_VIS)
showBearChoch   = input.bool(true,     "Bear ChoCH labels",       group=GRP_VIS)
showBullBos     = input.bool(true,     "Bull BOS labels",         group=GRP_VIS)
showBearBos     = input.bool(true,     "Bear BOS labels",         group=GRP_VIS)
showSwingLines  = input.bool(true,     "Swing High/Low lines",    group=GRP_VIS)
showEma         = input.bool(true,     "EMA lines",               group=GRP_VIS)
showBgState     = input.bool(true,     "Background structure tint",group=GRP_VIS)
showVolInfo     = input.bool(false,    "Volume info on labels",    group=GRP_VIS)

// ─── Helpers ─────────────────────────────────────────────────
f_fmtVol(v) =>
    na(v) ? "—" : v >= 1e9 ? (str.tostring(v / 1e9, "#.###") + "B") : v >= 1e6 ? (str.tostring(v / 1e6, "#.###") + "M") : v >= 1e3 ? (str.tostring(v / 1e3, "#.###") + "K") : str.tostring(v, "#")

// ─── Core: EMA / ATR ────────────────────────────────────────
emaF = ta.ema(close, emaFastLen)
emaS = ta.ema(close, emaSlowLen)
atr  = ta.atr(atrLen)

// ─── Core: Volume ────────────────────────────────────────────
volSma     = ta.sma(volume, volSmaLen)
volOk      = (not useVolFilter) or (not na(volume) and volume > volSma * volMult)
volRatio   = (not na(volume) and not na(volSma) and volSma > 0) ? volume / volSma : 0.0

// ─── Core: Swing Detection ──────────────────────────────────
var float lastSwingHigh    = na
var float lastSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

ph = ta.pivothigh(high, swingL, swingR)
pl = ta.pivotlow(low,  swingL, swingR)

if not na(ph)
    lastSwingHigh    := ph
    lastSwingHighBar := bar_index
if not na(pl)
    lastSwingLow     := pl
    lastSwingLowBar  := bar_index

// Age expiry
if swingMaxAgeBars > 0
    if not na(lastSwingHighBar) and (bar_index - lastSwingHighBar > swingMaxAgeBars)
        lastSwingHigh    := na
        lastSwingHighBar := na
    if not na(lastSwingLowBar) and (bar_index - lastSwingLowBar > swingMaxAgeBars)
        lastSwingLow     := na
        lastSwingLowBar  := na

// ─── Core: Breakout Detection ────────────────────────────────
bool breakHigh = false
bool breakLow  = false

// Pre-calculate wick crosses (avoids conditional ta.* warning)
bool _xoWick = ta.crossover(high,  lastSwingHigh)
bool _xuWick = ta.crossunder(low,  lastSwingLow)

if breakoutSource == "Close"
    breakHigh := close > lastSwingHigh and close[1] <= lastSwingHigh
    breakLow  := close < lastSwingLow  and close[1] >= lastSwingLow
else // Wick
    if not na(lastSwingHigh)
        breakHigh := _xoWick
    if not na(lastSwingLow)
        breakLow  := _xuWick

breakoutLong  = not na(lastSwingHigh) and breakHigh
breakoutShort = not na(lastSwingLow)  and breakLow

// ─── Core: SMC+Sweep (Turtle Soup) ──────────────────────────
bool sweepHigh  = false
bool reclaimLow = false

// Pre-calc crosses
bool cx_sweepHigh  = ta.crossunder(low,  lastSwingHigh)
bool cx_reclaimLow = ta.crossover(high,  lastSwingLow)

if structureLogic == "SMC+Sweep" and not na(lastSwingHigh) and not na(lastSwingLow)
    if breakoutSource == "Close"
        // Sweep High: wick poked above level but close fell back below
        sweepHigh  := close < lastSwingHigh and high > lastSwingHigh and close[1] > lastSwingHigh
        // Reclaim Low: wick dipped below level but close came back above
        reclaimLow := close > lastSwingLow  and low  < lastSwingLow  and close[1] < lastSwingLow
    else
        sweepHigh  := cx_sweepHigh
        reclaimLow := cx_reclaimLow

// ─── Core: Structure State Machine ──────────────────────────
var int structState = 0   // 0=Neutral  1=Bullish  -1=Bearish
bool isChoCH_Long  = false
bool isBOS_Long    = false
bool isChoCH_Short = false
bool isBOS_Short   = false

if structureLogic == "Standard"
    if breakoutLong
        if structState == -1
            isChoCH_Long := true
        else
            isBOS_Long   := true
        structState := 1
    if breakoutShort
        if structState == 1
            isChoCH_Short := true
        else
            isBOS_Short   := true
        structState := -1
else  // SMC+Sweep
    if breakoutLong
        if structState == -1
            isChoCH_Long := true
        else
            isBOS_Long   := true
        structState := 1
    if breakoutShort
        if structState == 1
            isChoCH_Short := true
        else
            isBOS_Short   := true
        structState := -1
    // Turtle-soup reclaims also fire ChoCH
    if reclaimLow
        isChoCH_Long  := true
    if sweepHigh
        isChoCH_Short := true

// ─── Gating: Bar-Close + Volume ──────────────────────────────
bool confirmed = (not barCloseOnly) or barstate.isconfirmed

// Volume-gated ChoCH (BOS always passes — it's continuation)
bool chochVolOk = (not chochReqVol) or volOk

bool sigChoCH_L = isChoCH_Long  and confirmed and chochVolOk
bool sigChoCH_S = isChoCH_Short and confirmed and chochVolOk
bool sigBOS_L   = isBOS_Long    and confirmed
bool sigBOS_S   = isBOS_Short   and confirmed

// ─── Volume label suffix ─────────────────────────────────────
string volSuffix = showVolInfo ? ("\n" + f_fmtVol(volume) + " (" + str.tostring(volRatio, "#.##") + "×)") : ""

// ─── Plot: Labels ────────────────────────────────────────────
plotshape(showBullBos   and sigBOS_L,   title="BOS  ▲",  style=shape.labelup,   location=location.belowbar, size=size.small, text="BOS",   textcolor=color.white, color=color.new(color.green, 50))
plotshape(showBullChoch and sigChoCH_L, title="ChoCH ▲", style=shape.labelup,   location=location.belowbar, size=size.small, text="ChoCH", textcolor=color.white, color=color.new(color.purple, 0))
plotshape(showBearBos   and sigBOS_S,   title="BOS  ▼",  style=shape.labeldown, location=location.abovebar, size=size.small, text="BOS",   textcolor=color.white, color=color.new(color.red, 50))
plotshape(showBearChoch and sigChoCH_S, title="ChoCH ▼", style=shape.labeldown, location=location.abovebar, size=size.small, text="ChoCH", textcolor=color.white, color=color.new(color.maroon, 0))

// Volume detail label (optional — uses label.new for multi-line)
if showVolInfo and (sigChoCH_L or sigChoCH_S or sigBOS_L or sigBOS_S)
    string _tag = sigChoCH_L ? "ChoCH ▲" : sigChoCH_S ? "ChoCH ▼" : sigBOS_L ? "BOS ▲" : "BOS ▼"
    string _txt = _tag + "\nVol " + f_fmtVol(volume) + " (" + str.tostring(volRatio, "#.##") + "×)"
    _col = sigChoCH_L ? color.purple : sigChoCH_S ? color.maroon : sigBOS_L ? color.new(color.green, 50) : color.new(color.red, 50)
    _loc = (sigChoCH_L or sigBOS_L) ? label.style_label_up : label.style_label_down
    _y   = (sigChoCH_L or sigBOS_L) ? low : high
    label.new(bar_index, _y, _txt, style=_loc, textcolor=color.white, color=_col, size=size.small)

// ─── Plot: Swing Level Lines ─────────────────────────────────
plot(showSwingLines ? lastSwingHigh : na, title="Swing High", color=color.new(color.red,   60), style=plot.style_stepline_diamond, linewidth=1)
plot(showSwingLines ? lastSwingLow  : na, title="Swing Low",  color=color.new(color.green, 60), style=plot.style_stepline_diamond, linewidth=1)

// ─── Plot: EMA Lines ─────────────────────────────────────────
plot(showEma ? emaF : na, title="EMA Fast", color=color.new(color.blue,   30), linewidth=1)
plot(showEma ? emaS : na, title="EMA Slow", color=color.new(color.orange, 30), linewidth=1)

// ─── Plot: Background Structure Tint ─────────────────────────
bgCol = structState == 1 ? color.new(color.green, 92) : structState == -1 ? color.new(color.red, 92) : na
bgcolor(showBgState ? bgCol : na, title="Structure Bias")

// ─── Alerts ──────────────────────────────────────────────────
alertcondition(sigChoCH_L, title="Bull ChoCH", message="ChoCH ▲ Bullish reversal detected")
alertcondition(sigChoCH_S, title="Bear ChoCH", message="ChoCH ▼ Bearish reversal detected")
alertcondition(sigBOS_L,   title="Bull BOS",   message="BOS ▲ Bullish continuation")
alertcondition(sigBOS_S,   title="Bear BOS",   message="BOS ▼ Bearish continuation")
alertcondition(sigChoCH_L or sigChoCH_S, title="Any ChoCH", message="ChoCH detected — structure reversal")
alertcondition(sigBOS_L   or sigBOS_S,   title="Any BOS",   message="BOS detected — structure continuation")

// ─── Info Table ──────────────────────────────────────────────
var table infoTbl = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    stateStr  = structState == 1 ? "BULLISH" : structState == -1 ? "BEARISH" : "NEUTRAL"
    stateCol  = structState == 1 ? color.green : structState == -1 ? color.red : color.gray
    table.cell(infoTbl, 0, 0, "Structure",  text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 1, 0, stateStr,     text_color=stateCol,   text_size=size.small)
    table.cell(infoTbl, 0, 1, "Swing High", text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 1, 1, na(lastSwingHigh) ? "—" : str.tostring(lastSwingHigh, format.mintick), text_color=color.red, text_size=size.small)
    table.cell(infoTbl, 0, 2, "Swing Low",  text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 1, 2, na(lastSwingLow) ? "—" : str.tostring(lastSwingLow, format.mintick), text_color=color.green, text_size=size.small)
    table.cell(infoTbl, 0, 3, "Vol Ratio",  text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 1, 3, str.tostring(volRatio, "#.##") + "×", text_color=volOk ? color.green : color.orange, text_size=size.small)
    table.cell(infoTbl, 0, 4, "Logic",      text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 1, 4, structureLogic + " / " + breakoutSource, text_color=color.white, text_size=size.small)
