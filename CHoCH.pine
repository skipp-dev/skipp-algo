//@version=6
strategy("CHOCH-Strategy (Structure Only)", overlay=true, initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0, commission_type=strategy.commission.percent, commission_value=0.01)

//====================
// Market Structure Inputs
//====================
grp = "Market Structure (BOS/ChoCH)"
ms_swingL = input.int(2, "Swing L", minval=1, maxval=30, group=grp, tooltip="Linke Pivotbars. Kleiner = schnellere Erkennung, mehr Noise.")
ms_swingR = input.int(1, "Swing R", minval=1, maxval=30, group=grp, tooltip="Rechte Pivotbars. 1 = schnellste Bestätigung (1 Bar Delay statt 2).")
ms_maxAge = input.int(0, "Swing max age (bars, 0=off)", minval=0, maxval=5000, group=grp)

ms_breakSrc = input.string("Wick", "Breakout source", options=["Close","Wick"], group=grp)
ms_logic    = input.string("SMC+Sweep", "Structure logic", options=["Standard","SMC+Sweep"], group=grp)

ms_mode = input.string("Ping", "ChoCH mode", options=["Ping","Verify","Ping+Verify"], group=grp)

ms_showTags = input.bool(true, "Show BOS/ChoCH tags", group=grp)
ms_showPing = input.bool(false, "Show Ping markers", group=grp)
showBearChoch = input.bool(true, "Show BEAR ChoCH (Ping/Verify)", group=grp)

//====================
// Early Signal Inputs
//====================
grpEarly = "Early Signals (Anticipation)"
ms_useAnticipation = input.bool(true, "Enable Anticipation signals", group=grpEarly, tooltip="Frühwarnung wenn Preis sich einem Swing-Level nähert.")
ms_proxPct         = input.float(0.15, "Proximity %", minval=0.01, maxval=2.0, step=0.05, group=grpEarly, tooltip="Distanz zum Swing-Level in % ab der Anticipation feuert.")
ms_showAnticipation = input.bool(true, "Show Anticipation markers", group=grpEarly)

grpMom = "Momentum Pre-CHoCH"
ms_useMomentum   = input.bool(true, "Enable Momentum Pre-CHoCH", group=grpMom, tooltip="RSI-Divergenz + Volume-Spike als Frühindikator vor dem Strukturbruch.")
ms_rsiLen        = input.int(7, "RSI Length", minval=2, maxval=30, group=grpMom)
ms_rsiDivBars    = input.int(5, "RSI Divergence lookback", minval=2, maxval=20, group=grpMom, tooltip="Bars zurückschauen für Preis/RSI Divergenz.")
ms_volMulti      = input.float(1.5, "Volume spike multiplier", minval=1.0, maxval=5.0, step=0.1, group=grpMom, tooltip="Volume > X * SMA(20) = Spike.")
ms_showMomentum  = input.bool(true, "Show Momentum Pre-CHoCH markers", group=grpMom)

//====================
// Swings (stable levels)
//====================
var float ms_lastHi = na
var float ms_lastLo = na
var int   ms_lastHiBar = na
var int   ms_lastLoBar = na

ph = ta.pivothigh(high, ms_swingL, ms_swingR)
pl = ta.pivotlow(low,  ms_swingL, ms_swingR)

if not na(ph)
    ms_lastHi := ph
    ms_lastHiBar := bar_index - ms_swingR

if not na(pl)
    ms_lastLo := pl
    ms_lastLoBar := bar_index - ms_swingR

// expiry
if ms_maxAge > 0
    if not na(ms_lastHiBar) and (bar_index - ms_lastHiBar > ms_maxAge)
        ms_lastHi := na
        ms_lastHiBar := na
    if not na(ms_lastLoBar) and (bar_index - ms_lastLoBar > ms_maxAge)
        ms_lastLo := na
        ms_lastLoBar := na

//====================
// Breakouts (event flags)
//====================
bool ms_breakHi = false
bool ms_breakLo = false

ms_xHi_all = ta.crossover(high, nz(ms_lastHi, high))
ms_xLo_all = ta.crossunder(low,  nz(ms_lastLo, low))
bool ms_xHi = not na(ms_lastHi) and ms_xHi_all
bool ms_xLo = not na(ms_lastLo) and ms_xLo_all

if ms_breakSrc == "Wick"
    ms_breakHi := ms_xHi
    ms_breakLo := ms_xLo
else
    ms_breakHi := not na(ms_lastHi) and close > ms_lastHi and close[1] <= ms_lastHi
    ms_breakLo := not na(ms_lastLo) and close < ms_lastLo and close[1] >= ms_lastLo

bool ms_breakoutLong  = ms_breakHi
bool ms_breakoutShort = ms_breakLo

//====================
// SMC+Sweep (reclaimLow / sweepHigh)
//====================
bool ms_sweepHigh  = false
bool ms_reclaimLow = false

// Hoist crosses to avoid conditional-execution warnings
ms_crossunder_low_hi = ta.crossunder(low,  nz(ms_lastHi, low))
ms_crossover_high_lo = ta.crossover(high, nz(ms_lastLo, high))
bool ms_cx_sweepHigh  = not na(ms_lastHi) and ms_crossunder_low_hi
bool ms_cx_reclaimLow = not na(ms_lastLo) and ms_crossover_high_lo

if ms_breakSrc == "Close"
    // SweepHigh: wick above lastHi but CLOSE back below (failed breakout)
    if not na(ms_lastHi)
        ms_sweepHigh := (high > ms_lastHi) and (close < ms_lastHi) and (close[1] > ms_lastHi)
    // ReclaimLow: wick below lastLo but CLOSE back above (failed breakdown)
    if not na(ms_lastLo)
        ms_reclaimLow := (low < ms_lastLo) and (close > ms_lastLo) and (close[1] < ms_lastLo)
else
    // Wick mode: simple cross events (more frequent; SkippALGO-like)
    ms_sweepHigh  := not na(ms_lastHi) and ms_cx_sweepHigh
    ms_reclaimLow := not na(ms_lastLo) and ms_cx_reclaimLow

//====================
// Structure state + events
//====================
var int ms_state = 0  // 1 bull, -1 bear, 0 neutral

bool ms_pingL = false
bool ms_pingS = false
bool ms_bosL  = false
bool ms_bosS  = false

if ms_breakoutLong
    ms_pingL := (ms_state == -1)
    ms_bosL  := not ms_pingL
    ms_state := 1

if ms_breakoutShort
    ms_pingS := (ms_state == 1)
    ms_bosS  := not ms_pingS
    ms_state := -1

if ms_logic == "SMC+Sweep"
    if ms_reclaimLow
        ms_pingL := true
    if ms_sweepHigh
        ms_pingS := true

//====================
// Ping level freeze + verify
//====================
var float ms_pingHiLevel = na
var float ms_pingLoLevel = na

if ms_pingL
    ms_pingHiLevel := ms_lastHi
if ms_pingS
    ms_pingLoLevel := ms_lastLo

// ── Same-Bar Verify (schneller als Next-Bar) ──
// Prüft ob der Ping-Bar SELBST schon über/unter dem Level schließt
bool ms_verifyL_samebar = ms_pingL and not na(ms_pingHiLevel) and close > ms_pingHiLevel
bool ms_verifyS_samebar = ms_pingS and not na(ms_pingLoLevel) and close < ms_pingLoLevel

// Legacy next-bar verify (Fallback)
bool ms_verifyL_close = ms_pingL[1] and not na(ms_pingHiLevel[1]) and close > ms_pingHiLevel[1]
bool ms_verifyS_close = ms_pingS[1] and not na(ms_pingLoLevel[1]) and close < ms_pingLoLevel[1]

// Combined: Same-bar OR next-bar (frühestmöglich)
bool ms_verifyL = ms_verifyL_samebar or ms_verifyL_close
bool ms_verifyS = ms_verifyS_samebar or ms_verifyS_close

// Wick-based verify (SkippALGO-like)
bool bearVerifyWickS = ms_pingS[1] and not na(ms_pingLoLevel[1]) and low < ms_pingLoLevel[1]

bool ms_isChoCH_L = false
bool ms_isChoCH_S = false

if ms_mode == "Ping"
    ms_isChoCH_L := ms_pingL
    ms_isChoCH_S := ms_pingS
else if ms_mode == "Verify"
    ms_isChoCH_L := ms_verifyL
    ms_isChoCH_S := ms_verifyS
else
    ms_isChoCH_L := (ms_pingL or ms_verifyL)
    ms_isChoCH_S := (ms_pingS or ms_verifyS)

//====================
// A) Anticipation: Preis nähert sich Swing-Level
//====================
float _proxDistHi = not na(ms_lastHi) ? math.abs(close - ms_lastHi) / ms_lastHi * 100 : 999.0
float _proxDistLo = not na(ms_lastLo) ? math.abs(close - ms_lastLo) / ms_lastLo * 100 : 999.0

// Bullish anticipation: Preis nähert sich lastHi von unten UND Struktur ist bearish (= potentieller CHoCH)
bool ms_anticipL = ms_useAnticipation and ms_state == -1 and not na(ms_lastHi) and close < ms_lastHi and _proxDistHi <= ms_proxPct and close > close[1]
// Bearish anticipation: Preis nähert sich lastLo von oben UND Struktur ist bullish
bool ms_anticipS = ms_useAnticipation and ms_state == 1  and not na(ms_lastLo) and close > ms_lastLo and _proxDistLo <= ms_proxPct and close < close[1]

// Suppress anticipation when CHoCH already fired same bar
ms_anticipL := ms_anticipL and not ms_isChoCH_L and not ms_bosL
ms_anticipS := ms_anticipS and not ms_isChoCH_S and not ms_bosS

//====================
// C) Momentum Pre-CHoCH: RSI-Divergenz + Volume-Spike
//====================
_rsi = ta.rsi(close, ms_rsiLen)
_volSma = ta.sma(volume, 20)
_volSpike = volume > _volSma * ms_volMulti

// Bullish RSI divergence: Preis macht lower low, RSI macht higher low
_priceLowerLow = low < ta.lowest(low, ms_rsiDivBars)[1]
_rsiHigherLow  = _rsi > ta.lowest(_rsi, ms_rsiDivBars)[1]
bool _bullRsiDiv = _priceLowerLow and _rsiHigherLow

// Bearish RSI divergence: Preis macht higher high, RSI macht lower high
_priceHigherHigh = high > ta.highest(high, ms_rsiDivBars)[1]
_rsiLowerHigh    = _rsi < ta.highest(_rsi, ms_rsiDivBars)[1]
bool _bearRsiDiv = _priceHigherHigh and _rsiLowerHigh

// Pre-CHoCH: Divergenz + Volume-Spike + passende Strukturseite
bool ms_preCHoCH_L = ms_useMomentum and ms_state == -1 and _bullRsiDiv and _volSpike and not na(ms_lastHi)
bool ms_preCHoCH_S = ms_useMomentum and ms_state == 1  and _bearRsiDiv and _volSpike and not na(ms_lastLo)

// Suppress when CHoCH or Anticipation already fired
ms_preCHoCH_L := ms_preCHoCH_L and not ms_isChoCH_L and not ms_bosL and not ms_anticipL
ms_preCHoCH_S := ms_preCHoCH_S and not ms_isChoCH_S and not ms_bosS and not ms_anticipS

//====================
// Visuals
//====================
plotshape(ms_showTags and ms_isChoCH_L, "ChoCH L", style=shape.labelup,   location=location.belowbar, text="Bullish\nCHoCH", size=size.tiny, color=color.new(color.purple, 0), textcolor=color.white)
plotshape(ms_showTags and ms_isChoCH_S, "ChoCH S", style=shape.labeldown, location=location.abovebar, text="Bearish\nCHoCH", size=size.tiny, color=color.new(color.maroon, 0), textcolor=color.white)
plotshape(ms_showTags and ms_bosL,      "BOS L",   style=shape.labelup,   location=location.belowbar, text="BOS",   size=size.tiny, color=color.new(color.green, 0),  textcolor=color.white)
plotshape(ms_showTags and ms_bosS,      "BOS S",   style=shape.labeldown, location=location.abovebar, text="BOS",   size=size.tiny, color=color.new(color.red, 0),    textcolor=color.white)

plotchar(ms_showPing and ms_pingL, "Ping L", "?", location=location.belowbar, size=size.tiny, color=color.new(color.yellow, 0))
plotchar(ms_showPing and ms_pingS, "Ping S", "?", location=location.abovebar, size=size.tiny, color=color.new(color.yellow, 0))

// Bearish ChoCH debug (Ping + Verify)
bearChochPingEvt   = ms_pingS
bearChochVerifyEvt = ms_verifyS

plotchar(showBearChoch and bearChochPingEvt,   title="ChoCH S Ping",   char="v", location=location.abovebar, size=size.tiny)
plotchar(showBearChoch and bearChochVerifyEvt, title="ChoCH S Verify", char="V", location=location.abovebar, size=size.tiny)

plotshape(showBearChoch and bearChochPingEvt, title="ChoCH S (Ping)", style=shape.labeldown,
    location=location.abovebar, size=size.tiny, text="ChoCH↓", textcolor=color.white, color=color.new(color.maroon, 0))

plotshape(showBearChoch and bearChochVerifyEvt, title="Bearish CHoCH (Verify)", style=shape.labeldown,
    location=location.abovebar, size=size.small, text="ChoCH✓↓", textcolor=color.white, color=color.new(color.red, 0))

// ── Anticipation markers ──
plotshape(ms_showAnticipation and ms_anticipL, "Anticip L", style=shape.diamond, location=location.belowbar, size=size.tiny, color=color.new(color.aqua, 0), text="A↑", textcolor=color.aqua)
plotshape(ms_showAnticipation and ms_anticipS, "Anticip S", style=shape.diamond, location=location.abovebar, size=size.tiny, color=color.new(color.orange, 0), text="A↓", textcolor=color.orange)

// ── Momentum Pre-CHoCH markers ──
plotshape(ms_showMomentum and ms_preCHoCH_L, "Pre-CHoCH L", style=shape.triangleup,   location=location.belowbar, size=size.tiny, color=color.new(color.lime, 0), text="M↑", textcolor=color.lime)
plotshape(ms_showMomentum and ms_preCHoCH_S, "Pre-CHoCH S", style=shape.triangledown, location=location.abovebar, size=size.tiny, color=color.new(color.fuchsia, 0), text="M↓", textcolor=color.fuchsia)

// ── Background highlight for early signals ──
bgcolor(ms_anticipL ? color.new(color.aqua, 92) : ms_anticipS ? color.new(color.orange, 92) : na, title="Anticipation BG")
bgcolor(ms_preCHoCH_L ? color.new(color.lime, 92) : ms_preCHoCH_S ? color.new(color.fuchsia, 92) : na, title="Pre-CHoCH BG")

//====================
// Strategy: trade on CHoCH + BOS + Early signals
//====================
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

// Full signals: CHoCH/BOS = full entry
bool bullSignal = ms_isChoCH_L or ms_bosL
bool bearSignal = ms_isChoCH_S or ms_bosS

// Early signals: Anticipation or Momentum Pre-CHoCH = early entry
bool earlyBull = ms_anticipL or ms_preCHoCH_L
bool earlyBear = ms_anticipS or ms_preCHoCH_S

// Close opposite + enter (full signals)
if bullSignal
    if inShort
        strategy.close("SHORT", comment="Bullish CHoCH")
    if not inLong
        strategy.entry("LONG", strategy.long, comment="Bullish CHoCH")

if bearSignal
    if inLong
        strategy.close("LONG", comment="Bearish CHoCH")
    if not inShort
        strategy.entry("SHORT", strategy.short, comment="Bearish CHoCH")

// Early entries (only when not already positioned)
if earlyBull and not inLong and not bullSignal
    strategy.entry("LONG", strategy.long, comment=ms_anticipL ? "Anticipation↑" : "Pre-CHoCH↑")

if earlyBear and not inShort and not bearSignal
    strategy.entry("SHORT", strategy.short, comment=ms_anticipS ? "Anticipation↓" : "Pre-CHoCH↓")