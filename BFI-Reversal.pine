//@version=6
indicator("BFI Reversal", "BFI-R", overlay=true, max_bars_back=500, max_labels_count=300)

// =====================
// Presets and base inputs
// =====================
groupPreset = "Reversal Mode"
modePreset = input.string("Early Reversal Balanced", "Signal Mode", options=["Early Reversal Balanced", "Early Reversal Aggressive", "Continuation Breakout"], group=groupPreset)
assetProfileInput = input.string("Auto", "Asset Profile", options=["Auto", "Stocks", "Crypto"], group=groupPreset)

groupBase = "Structure"
prdInput = input.int(5, "Pivot Period", minval=2, group=groupBase)
boLenInput = input.int(200, "Max Structure Length", minval=30, maxval=300, group=groupBase)
zoneWidthPctInput = input.float(3.0, "Zone Width %", minval=0.5, maxval=10.0, step=0.1, group=groupBase)
mintestInput = input.int(2, "Minimum Number of Tests", minval=1, group=groupBase)
clusterCandidateLimitInput = input.int(24, "Cluster Candidate Limit", minval=4, maxval=60, group=groupBase)
confirmLookbackInput = input.int(3, "Trigger Lookback Bars", minval=1, maxval=20, group=groupBase)
setupExpiryBarsInput = input.int(6, "Setup Expiry Bars", minval=1, maxval=20, group=groupBase)

groupFlow = "Flow and Score"
lowerTf = input.timeframe("1", "Lower Timeframe", group=groupFlow)
lookback = input.int(20, "Relative Lookback", minval=2, group=groupFlow)
minRelVolInput = input.float(1.50, "Min Relative Volume", minval=0.1, step=0.05, group=groupFlow)
minRelActInput = input.float(1.20, "Min Relative Activity", minval=0.1, step=0.05, group=groupFlow)
minRelSizeInput = input.float(0.80, "Min Relative AvgSize", minval=0.1, step=0.05, group=groupFlow)
minDeltaAbsPctInput = input.float(0.05, "Min Absolute Delta %", minval=0.0, maxval=1.0, step=0.01, group=groupFlow)
setupScoreThresholdInput = input.int(4, "Setup Score Threshold", minval=1, maxval=10, group=groupFlow)
confirmScoreThresholdInput = input.int(3, "Confirm Score Threshold", minval=1, maxval=10, group=groupFlow)

groupFollowThrough = "Follow-Through"
followThroughWindowBarsInput = input.int(3, "Follow-Through Window Bars", minval=1, maxval=10, group=groupFollowThrough)
followThroughScoreThresholdInput = input.int(3, "Follow-Through Score Threshold", minval=1, maxval=6, group=groupFollowThrough)
minCloseInRangePctInput = input.float(0.65, "Min Close In Range %", minval=0.5, maxval=1.0, step=0.05, group=groupFollowThrough)
requireVwapHoldInput = input.bool(true, "Require VWAP Hold", group=groupFollowThrough)
eventVwapStartInput = input.string("Setup Bar", "Event VWAP Start", options=["Setup Bar", "Bar After Setup"], group=groupFollowThrough)
confirmScoreModeInput = input.string("Setup Score", "Confirm Score Source", options=["Setup Score", "Current Bar"], group=groupFollowThrough)
requireRetraceFilterInput = input.bool(true, "Require Retrace Filter", group=groupFollowThrough)
bullMaxRetracePctInput = input.float(0.30, "Bull Max Retrace %", minval=0.0, maxval=1.0, step=0.05, group=groupFollowThrough)
bearMaxRetracePctInput = input.float(0.40, "Bear Max Retrace %", minval=0.0, maxval=1.0, step=0.05, group=groupFollowThrough)
continuationRetestWidthFactorInput = input.float(0.50, "Continuation Retest Width Factor", minval=0.10, maxval=1.00, step=0.05, group=groupFollowThrough)

groupFootprint = "Footprint"
requireFootprintConfirmInput = input.bool(false, "Require Footprint Confirm", group=groupFootprint)
requireFootprintSetupInput = input.bool(false, "Require Footprint Setup", group=groupFootprint)
requireFootprintSupportSignalInput = input.bool(false, "Require Footprint Support Signal", group=groupFootprint)
requireContextForSetupInput = input.bool(true, "Require Reversal Context For Setup", group=groupFootprint)
useFootprintDeltaImprovementInput = input.bool(true, "Use Footprint Delta Improvement", group=groupFootprint)
requireImbalanceStackConfirmInput = input.bool(false, "Require Imbalance Stack Confirm", group=groupFootprint)
requireFootprintStructureConfirmInput = input.bool(false, "Require POC/VA Confirm", group=groupFootprint)
footprintTriggerModeInput = input.string("POC + VAH/VAL", "Footprint Trigger Mode", options=["Price Only", "POC", "VAH/VAL", "POC + VAH/VAL"], group=groupFootprint)
footprintTicksPerRowInput = input.int(25, "Footprint Ticks Per Row", minval=1, group=groupFootprint)
footprintValueAreaPctInput = input.int(70, "Footprint Value Area %", minval=1, maxval=100, group=groupFootprint)
footprintImbalancePctInput = input.int(300, "Footprint Imbalance %", minval=1, group=groupFootprint)
minImbalanceStackInput = input.int(2, "Min Imbalance Stack", minval=1, maxval=10, group=groupFootprint)
footprintSetupMinDeltaPctInput = input.float(0.02, "Setup Min Footprint Delta %", minval=0.0, maxval=1.0, step=0.01, group=groupFootprint)
minFootprintDeltaPctInput = input.float(0.05, "Min Footprint Delta %", minval=0.0, maxval=1.0, step=0.01, group=groupFootprint)
absorptionCounterDeltaLimitPctInput = input.float(0.10, "Absorption Counter Delta Limit %", minval=0.0, maxval=1.0, step=0.01, group=groupFootprint)

groupAts = "ATS"
smoothLen = input.int(5, "ATS Smoothing Length", minval=1, group=groupAts)
baselineLen = input.int(20, "ATS Baseline Length", minval=5, group=groupAts)
changePctThreshInput = input.float(5.0, "ATS Change Threshold %", minval=0.1, step=0.1, group=groupAts)
spikeZThreshInput = input.float(1.5, "ATS Spike Z Threshold", minval=0.1, step=0.1, group=groupAts)
atsSpikeSequenceLength = input.int(2, "ATS Spike Sequence Length", minval=2, maxval=10, group=groupAts)

groupViz = "Visuals"
showSetupMarkers = input.bool(true, "Show Setup Markers", group=groupViz)
showConfirmedMarkers = input.bool(true, "Show Confirmed Markers", group=groupViz)
showDashboard = input.bool(true, "Show Status Table", group=groupViz)
colorBars = input.bool(true, "Color Bars", group=groupViz)
bullColor = input.color(color.lime, "Bullish Color", group=groupViz)
bearColor = input.color(color.red, "Bearish Color", group=groupViz)
neutralColor = input.color(color.gray, "Neutral Color", group=groupViz)
int prd = prdInput
int boLen = boLenInput
float zoneWidthPct = zoneWidthPctInput
int mintest = mintestInput
int clusterCandidateLimit = clusterCandidateLimitInput
int confirmLookback = confirmLookbackInput
int setupExpiryBars = setupExpiryBarsInput
float minRelVol = minRelVolInput
float minRelAct = minRelActInput
float minRelSize = minRelSizeInput
float minDeltaAbsPct = minDeltaAbsPctInput
int setupScoreThreshold = setupScoreThresholdInput
int confirmScoreThreshold = confirmScoreThresholdInput
int followThroughWindowBars = followThroughWindowBarsInput
int followThroughScoreThreshold = followThroughScoreThresholdInput
float minCloseInRangePct = minCloseInRangePctInput
bool requireVwapHold = requireVwapHoldInput
string eventVwapStartMode = eventVwapStartInput
string confirmScoreMode = confirmScoreModeInput
bool requireRetraceFilter = requireRetraceFilterInput
float bullMaxRetracePct = bullMaxRetracePctInput
float bearMaxRetracePct = bearMaxRetracePctInput
float continuationRetestWidthFactor = continuationRetestWidthFactorInput
bool requireFootprintConfirm = requireFootprintConfirmInput
bool requireFootprintSetup = requireFootprintSetupInput
bool requireFootprintSupportSignal = requireFootprintSupportSignalInput
bool requireContextForSetup = requireContextForSetupInput
bool useFootprintDeltaImprovement = useFootprintDeltaImprovementInput
bool requireImbalanceStackConfirm = requireImbalanceStackConfirmInput
bool requireFootprintStructureConfirm = requireFootprintStructureConfirmInput
string footprintTriggerMode = footprintTriggerModeInput
int minImbalanceStack = minImbalanceStackInput
float footprintSetupMinDeltaPct = footprintSetupMinDeltaPctInput
float minFootprintDeltaPct = minFootprintDeltaPctInput
float absorptionCounterDeltaLimitPct = absorptionCounterDeltaLimitPctInput
float changePctThresh = changePctThreshInput
float spikeZThresh = spikeZThreshInput
float zoneWidth = zoneWidthPct / 100.0
string assetProfile = assetProfileInput == "Auto" ? (syminfo.type == "crypto" ? "Crypto" : "Stocks") : assetProfileInput
bool isContinuationMode = modePreset == "Continuation Breakout"
bool startEventVwapOnSetupBar = eventVwapStartMode == "Setup Bar"
bool confirmUsesSetupScore = confirmScoreMode == "Setup Score"

if modePreset == "Early Reversal Balanced"
    prd := math.min(prd, 4)
    boLen := math.min(boLen, 140)
    clusterCandidateLimit := math.min(clusterCandidateLimit, 20)
    minRelVol := math.min(minRelVol, 1.25)
    minRelAct := math.min(minRelAct, 1.05)
    minRelSize := math.min(minRelSize, 0.75)
    minDeltaAbsPct := math.min(minDeltaAbsPct, 0.03)
    changePctThresh := math.min(changePctThresh, 3.5)
    spikeZThresh := math.min(spikeZThresh, 1.2)
    setupScoreThreshold := math.min(setupScoreThreshold, 4)
    confirmScoreThreshold := math.min(confirmScoreThreshold, 3)
    followThroughWindowBars := math.min(followThroughWindowBars, 3)
    followThroughScoreThreshold := math.min(followThroughScoreThreshold, 3)
    minCloseInRangePct := math.max(minCloseInRangePct, 0.60)
    bullMaxRetracePct := math.min(bullMaxRetracePct, 0.35)
    bearMaxRetracePct := math.min(bearMaxRetracePct, 0.40)
    footprintSetupMinDeltaPct := math.min(footprintSetupMinDeltaPct, 0.03)
    minFootprintDeltaPct := math.min(minFootprintDeltaPct, 0.04)
    absorptionCounterDeltaLimitPct := math.min(absorptionCounterDeltaLimitPct, 0.12)
    confirmLookback := math.min(confirmLookback, 3)
    setupExpiryBars := math.min(setupExpiryBars, 6)
    eventVwapStartMode := "Setup Bar"
    confirmScoreMode := "Setup Score"
    requireContextForSetup := true
    requireFootprintSupportSignal := false
    continuationRetestWidthFactor := math.max(continuationRetestWidthFactor, 0.50)
else if modePreset == "Early Reversal Aggressive"
    prd := math.min(prd, 3)
    boLen := math.min(boLen, 100)
    clusterCandidateLimit := math.min(clusterCandidateLimit, 16)
    minRelVol := math.min(minRelVol, 1.10)
    minRelAct := math.min(minRelAct, 1.00)
    minRelSize := math.min(minRelSize, 0.65)
    minDeltaAbsPct := math.min(minDeltaAbsPct, 0.01)
    changePctThresh := math.min(changePctThresh, 2.5)
    spikeZThresh := math.min(spikeZThresh, 1.0)
    setupScoreThreshold := math.min(setupScoreThreshold, 3)
    confirmScoreThreshold := math.min(confirmScoreThreshold, 2)
    followThroughWindowBars := math.min(followThroughWindowBars, 2)
    followThroughScoreThreshold := math.min(followThroughScoreThreshold, 2)
    minCloseInRangePct := math.max(minCloseInRangePct, 0.55)
    bullMaxRetracePct := math.min(bullMaxRetracePct, 0.45)
    bearMaxRetracePct := math.min(bearMaxRetracePct, 0.50)
    footprintSetupMinDeltaPct := math.min(footprintSetupMinDeltaPct, 0.02)
    minFootprintDeltaPct := math.min(minFootprintDeltaPct, 0.02)
    absorptionCounterDeltaLimitPct := math.min(absorptionCounterDeltaLimitPct, 0.15)
    confirmLookback := math.min(confirmLookback, 2)
    setupExpiryBars := math.min(setupExpiryBars, 5)
    eventVwapStartMode := "Bar After Setup"
    confirmScoreMode := "Current Bar"
    requireContextForSetup := true
    requireFootprintSupportSignal := false
    continuationRetestWidthFactor := math.max(continuationRetestWidthFactor, 0.45)
else
    prd := math.max(prd, 5)
    boLen := math.max(boLen, 180)
    clusterCandidateLimit := math.min(clusterCandidateLimit, 12)
    minRelVol := math.max(minRelVol, 1.50)
    minRelAct := math.max(minRelAct, 1.20)
    minRelSize := math.max(minRelSize, 0.80)
    minDeltaAbsPct := math.max(minDeltaAbsPct, 0.05)
    changePctThresh := math.max(changePctThresh, 5.0)
    spikeZThresh := math.max(spikeZThresh, 1.5)
    setupScoreThreshold := math.max(setupScoreThreshold, 5)
    confirmScoreThreshold := math.max(confirmScoreThreshold, 4)
    followThroughWindowBars := math.max(followThroughWindowBars, 3)
    followThroughScoreThreshold := math.max(followThroughScoreThreshold, 4)
    minCloseInRangePct := math.max(minCloseInRangePct, 0.70)
    bullMaxRetracePct := math.min(bullMaxRetracePct, 0.25)
    bearMaxRetracePct := math.min(bearMaxRetracePct, 0.30)
    footprintSetupMinDeltaPct := math.max(footprintSetupMinDeltaPct, 0.03)
    minFootprintDeltaPct := math.max(minFootprintDeltaPct, 0.05)
    absorptionCounterDeltaLimitPct := math.min(absorptionCounterDeltaLimitPct, 0.10)
    confirmLookback := math.max(confirmLookback, 3)
    setupExpiryBars := math.max(setupExpiryBars, 6)
    eventVwapStartMode := "Bar After Setup"
    confirmScoreMode := "Current Bar"
    requireContextForSetup := true
    requireFootprintSupportSignal := true
    continuationRetestWidthFactor := math.min(continuationRetestWidthFactor, 0.35)

if assetProfile == "Stocks"
    minRelVol := math.max(minRelVol, 1.20)
    minRelAct := math.max(minRelAct, 1.05)
    minCloseInRangePct := math.max(minCloseInRangePct, 0.65)
    bullMaxRetracePct := math.min(bullMaxRetracePct, 0.30)
    bearMaxRetracePct := math.min(bearMaxRetracePct, 0.35)
    followThroughScoreThreshold := math.max(followThroughScoreThreshold, 3)
    footprintSetupMinDeltaPct := math.max(footprintSetupMinDeltaPct, 0.02)
    minFootprintDeltaPct := math.max(minFootprintDeltaPct, 0.04)
else
    minRelVol := math.max(minRelVol, 1.10)
    minRelAct := math.max(minRelAct, 1.00)
    minCloseInRangePct := math.max(minCloseInRangePct, 0.55)
    bullMaxRetracePct := math.max(bullMaxRetracePct, 0.35)
    bearMaxRetracePct := math.max(bearMaxRetracePct, 0.45)
    followThroughWindowBars := math.max(followThroughWindowBars, 3)
    footprintSetupMinDeltaPct := math.min(footprintSetupMinDeltaPct, 0.02)
    minFootprintDeltaPct := math.min(minFootprintDeltaPct, 0.03)

// =====================
// Dynamic width
// =====================
lll = math.max(math.min(bar_index, 300), 1)
h_ = ta.highest(high, lll)
l_ = ta.lowest(low, lll)
chwidth = (h_ - l_) * zoneWidth

// =====================
// Pivot storage
// =====================
ph = ta.pivothigh(high, prd, prd)
pl = ta.pivotlow(low, prd, prd)

var phval = array.new_float(0)
var phloc = array.new_int(0)
var plval = array.new_float(0)
var plloc = array.new_int(0)

if not na(ph)
    array.unshift(phval, ph)
    array.unshift(phloc, bar_index - prd)
    if array.size(phval) > 1
        for x = array.size(phloc) - 1 to 1
            if bar_index - array.get(phloc, x) > boLen
                array.pop(phloc)
                array.pop(phval)

if not na(pl)
    array.unshift(plval, pl)
    array.unshift(plloc, bar_index - prd)
    if array.size(plval) > 1
        for x = array.size(plloc) - 1 to 1
            if bar_index - array.get(plloc, x) > boLen
                array.pop(plloc)
                array.pop(plval)

// =====================
// Build support / resistance zones from clustered pivots
// =====================
find_best_cluster_level(array<float> pivotValues, array<int> pivotLocs, float width, int minTests, bool preferUpper) =>
    float bestLevel = na
    int bestClusterCount = 0
    int bestLatestLoc = 0
    if array.size(pivotValues) >= minTests
        int candidateCount = math.min(array.size(pivotValues), clusterCandidateLimit)
        for candidateIndex = 0 to candidateCount - 1
            float candidateLevel = array.get(pivotValues, candidateIndex)
            int clusterCount = 0
            int latestLoc = 0
            for x = 0 to array.size(pivotValues) - 1
                float pivotValue = array.get(pivotValues, x)
                int pivotLoc = array.get(pivotLocs, x)
                bool inCluster = preferUpper ? (pivotValue <= candidateLevel and pivotValue >= candidateLevel - width) : (pivotValue >= candidateLevel and pivotValue <= candidateLevel + width)
                if inCluster
                    clusterCount += 1
                    latestLoc := math.max(latestLoc, pivotLoc)
            bool betterCount = clusterCount > bestClusterCount
            bool betterRecency = clusterCount == bestClusterCount and latestLoc > bestLatestLoc
            bool betterLevel = clusterCount == bestClusterCount and latestLoc == bestLatestLoc and (na(bestLevel) or (preferUpper ? candidateLevel > bestLevel : candidateLevel < bestLevel))
            if clusterCount >= minTests and (na(bestLevel) or betterCount or betterRecency or betterLevel)
                bestLevel := candidateLevel
                bestClusterCount := clusterCount
                bestLatestLoc := latestLoc
    bestLevel

float resistanceLevel = na
resistanceLevel := find_best_cluster_level(phval, phloc, chwidth, mintest, true)

float supportLevel = na
supportLevel := find_best_cluster_level(plval, plloc, chwidth, mintest, false)

// =====================
// Original breakout context retained as a score component
// =====================
float bomax = na
int bullBreakTests = 0
hgst = ta.highest(high, prd)[1]

if array.size(phval) >= mintest and close > open and close > hgst
    bomax := array.get(phval, 0)
    int xx = 0
    for x = 0 to array.size(phval) - 1
        if array.get(phval, x) >= close
            break
        xx := x
        bomax := math.max(bomax, array.get(phval, x))
    if xx >= mintest and open <= bomax
        for x = 0 to xx
            if array.get(phval, x) <= bomax and array.get(phval, x) >= bomax - chwidth
                bullBreakTests += 1
        if bullBreakTests < mintest or hgst >= bomax
            bomax := na

bullRaw = not na(bomax) and bullBreakTests >= mintest

float bomin = na
int bearBreakTests = 0
lwst = ta.lowest(low, prd)[1]

if array.size(plval) >= mintest and close < open and close < lwst
    bomin := array.get(plval, 0)
    int xx1 = 0
    for x = 0 to array.size(plval) - 1
        if array.get(plval, x) <= close
            break
        xx1 := x
        bomin := math.min(bomin, array.get(plval, x))
    if xx1 >= mintest and open >= bomin
        for x = 0 to xx1
            if array.get(plval, x) >= bomin and array.get(plval, x) <= bomin + chwidth
                bearBreakTests += 1
        if bearBreakTests < mintest or lwst <= bomin
            bomin := na

bearRaw = not na(bomin) and bearBreakTests >= mintest

// =====================
// Lower timeframe flow proxy
// =====================
array<float> ltfVols = request.security_lower_tf(syminfo.tickerid, lowerTf, volume)
array<float> ltfOpens = request.security_lower_tf(syminfo.tickerid, lowerTf, open)
array<float> ltfCloses = request.security_lower_tf(syminfo.tickerid, lowerTf, close)

int activeBars = 0
float deltaProxy = 0.0

if array.size(ltfVols) > 0
    for i = 0 to array.size(ltfVols) - 1
        float v = array.get(ltfVols, i)
        float o = array.get(ltfOpens, i)
        float c = array.get(ltfCloses, i)
        if v > 0
            activeBars += 1
        if c > o
            deltaProxy += v
        else if c < o
            deltaProxy -= v

activeBarsF = float(activeBars)
avgSizeProxyRaw = activeBars > 0 ? volume / activeBarsF : na

volAvg = ta.sma(volume, lookback)
actAvg = ta.sma(activeBarsF, lookback)
sizeAvg = ta.sma(avgSizeProxyRaw, lookback)

relVol = volAvg > 0 ? volume / volAvg : na
relAct = actAvg > 0 ? activeBarsF / actAvg : na
relSize = sizeAvg > 0 ? avgSizeProxyRaw / sizeAvg : na
barDeltaPct = volume > 0 ? deltaProxy / volume : na

footprint reqFootprint = request.footprint(footprintTicksPerRowInput, footprintValueAreaPctInput, footprintImbalancePctInput)
hasFootprint = not na(reqFootprint)
footprintTotalVolume = hasFootprint ? footprint.total_volume(reqFootprint) : na
footprintDeltaVolume = hasFootprint ? footprint.delta(reqFootprint) : na
footprintDeltaPct = hasFootprint and footprintTotalVolume > 0 ? footprintDeltaVolume / footprintTotalVolume : na
positiveFootprintOk = not na(footprintDeltaPct) and footprintDeltaPct >= minFootprintDeltaPct
negativeFootprintOk = not na(footprintDeltaPct) and footprintDeltaPct <= -minFootprintDeltaPct
footprintSetupBullBias = not na(footprintDeltaPct) and footprintDeltaPct >= footprintSetupMinDeltaPct
footprintSetupBearBias = not na(footprintDeltaPct) and footprintDeltaPct <= -footprintSetupMinDeltaPct

volume_row footprintPocRow = hasFootprint ? reqFootprint.poc() : na
volume_row footprintVahRow = hasFootprint ? reqFootprint.vah() : na
volume_row footprintValRow = hasFootprint ? reqFootprint.val() : na
float footprintPocUpper = hasFootprint ? footprintPocRow.up_price() : na
float footprintPocLower = hasFootprint ? footprintPocRow.down_price() : na
float footprintVahUpper = hasFootprint ? footprintVahRow.up_price() : na
float footprintValLower = hasFootprint ? footprintValRow.down_price() : na
array<volume_row> footprintRows = hasFootprint ? reqFootprint.rows() : array.new<volume_row>()

int buyImbalanceRows = 0
int sellImbalanceRows = 0
int buyImbalanceStack = 0
int sellImbalanceStack = 0
int currentBuyStack = 0
int currentSellStack = 0
int lowerHalfBuyImbalances = 0
int upperHalfSellImbalances = 0
float footprintMidPrice = (high + low) * 0.5

if array.size(footprintRows) > 0
    for row in footprintRows
        bool buyImbalance = row.has_buy_imbalance()
        bool sellImbalance = row.has_sell_imbalance()
        float rowMidPrice = (row.up_price() + row.down_price()) * 0.5

        if buyImbalance
            buyImbalanceRows += 1
            currentBuyStack += 1
            currentSellStack := 0
            buyImbalanceStack := math.max(buyImbalanceStack, currentBuyStack)
            if rowMidPrice <= footprintMidPrice
                lowerHalfBuyImbalances += 1
        else
            currentBuyStack := 0

        if sellImbalance
            sellImbalanceRows += 1
            currentSellStack += 1
            currentBuyStack := 0
            sellImbalanceStack := math.max(sellImbalanceStack, currentSellStack)
            if rowMidPrice >= footprintMidPrice
                upperHalfSellImbalances += 1
        else
            currentSellStack := 0

bullImbalanceStackOk = buyImbalanceStack >= minImbalanceStack
bearImbalanceStackOk = sellImbalanceStack >= minImbalanceStack
footprintBiasText = positiveFootprintOk ? "BULL" : negativeFootprintOk ? "BEAR" : buyImbalanceRows > sellImbalanceRows ? "BULL LEAN" : sellImbalanceRows > buyImbalanceRows ? "BEAR LEAN" : "MIXED"
footprintBiasDirection = positiveFootprintOk ? 1 : negativeFootprintOk ? -1 : buyImbalanceRows > sellImbalanceRows ? 1 : sellImbalanceRows > buyImbalanceRows ? -1 : 0
bullishFootprintBiasCondition = footprintBiasDirection == 1
bearishFootprintBiasCondition = footprintBiasDirection == -1

// =====================
// ATS and flow conditions
// =====================
avgSizeProxy = ta.ema(avgSizeProxyRaw, smoothLen)
baselineMean = ta.sma(avgSizeProxy, baselineLen)
baselineStd = ta.stdev(avgSizeProxy, baselineLen)
changePct = not na(avgSizeProxy[1]) and avgSizeProxy[1] > 0 ? ((avgSizeProxy / avgSizeProxy[1]) - 1.0) * 100.0 : na
zScore = baselineStd > 0 ? (avgSizeProxy - baselineMean) / baselineStd : na

rising = not na(changePct) and changePct >= changePctThresh
falling = not na(changePct) and changePct <= -changePctThresh
spikeUp = not na(zScore) and zScore >= spikeZThresh and rising
spikeDown = not na(zScore) and zScore <= -spikeZThresh and falling

var int consecutiveSpikeUp = 0
var int consecutiveSpikeDown = 0
consecutiveSpikeUp := spikeUp ? nz(consecutiveSpikeUp[1]) + 1 : 0
consecutiveSpikeDown := spikeDown ? nz(consecutiveSpikeDown[1]) + 1 : 0

bullishAtsSpikeUpSignal = spikeUp
bearishAtsSpikeDownSignal = spikeDown
bullishAtsSpikeSequenceSignal = consecutiveSpikeUp >= atsSpikeSequenceLength and nz(consecutiveSpikeUp[1]) < atsSpikeSequenceLength
bearishAtsSpikeSequenceSignal = consecutiveSpikeDown >= atsSpikeSequenceLength and nz(consecutiveSpikeDown[1]) < atsSpikeSequenceLength

atsTurnUp = rising or spikeUp or (not na(changePct) and not na(changePct[1]) and changePct > changePct[1] and changePct > 0)
atsTurnDown = falling or spikeDown or (not na(changePct) and not na(changePct[1]) and changePct < changePct[1] and changePct < 0)

relVolOk = not na(relVol) and relVol >= minRelVol
relActOk = not na(relAct) and relAct >= minRelAct
relSizeOk = not na(relSize) and relSize >= minRelSize
positiveDeltaOk = not na(barDeltaPct) and barDeltaPct >= minDeltaAbsPct
negativeDeltaOk = not na(barDeltaPct) and barDeltaPct <= -minDeltaAbsPct

// =====================
// Reversal structure and score model
// =====================
barRange = math.max(high - low, syminfo.mintick)
bullishWickReject = close >= low + barRange * 0.60
bearishWickReject = close <= low + barRange * 0.40

bullishSweepReclaim = not na(supportLevel) and low < supportLevel and close > supportLevel and close > open
bearishSweepReclaim = not na(resistanceLevel) and high > resistanceLevel and close < resistanceLevel and close < open
bullStructureOk = isContinuationMode ? bullRaw : bullishSweepReclaim
bearStructureOk = isContinuationMode ? bearRaw : bearishSweepReclaim
float bullAnchorLevel = isContinuationMode ? bomax : supportLevel
float bearAnchorLevel = isContinuationMode ? bomin : resistanceLevel

bullishDeltaImprovement = bullStructureOk and not na(barDeltaPct) and not na(barDeltaPct[1]) and barDeltaPct > barDeltaPct[1]
bearishDeltaImprovement = bearStructureOk and not na(barDeltaPct) and not na(barDeltaPct[1]) and barDeltaPct < barDeltaPct[1]
bullishFootprintDeltaImprovement = useFootprintDeltaImprovement and bullStructureOk and not na(footprintDeltaPct) and not na(footprintDeltaPct[1]) and footprintDeltaPct > footprintDeltaPct[1]
bearishFootprintDeltaImprovement = useFootprintDeltaImprovement and bearStructureOk and not na(footprintDeltaPct) and not na(footprintDeltaPct[1]) and footprintDeltaPct < footprintDeltaPct[1]
bullishFootprintAbsorption = bullishSweepReclaim and hasFootprint and lowerHalfBuyImbalances >= minImbalanceStack and footprintDeltaPct >= -absorptionCounterDeltaLimitPct and (na(footprintPocUpper) or footprintPocUpper >= low + barRange * 0.5)
bearishFootprintAbsorption = bearishSweepReclaim and hasFootprint and upperHalfSellImbalances >= minImbalanceStack and footprintDeltaPct <= absorptionCounterDeltaLimitPct and (na(footprintPocLower) or footprintPocLower <= low + barRange * 0.5)
bullishFootprintContinuation = bullRaw and hasFootprint and bullImbalanceStackOk and positiveFootprintOk and (na(footprintPocUpper) or close >= footprintPocUpper)
bearishFootprintContinuation = bearRaw and hasFootprint and bearImbalanceStackOk and negativeFootprintOk and (na(footprintPocLower) or close <= footprintPocLower)
bullishFootprintSupportSignal = isContinuationMode ? bullishFootprintContinuation : bullishFootprintAbsorption
bearishFootprintSupportSignal = isContinuationMode ? bearishFootprintContinuation : bearishFootprintAbsorption
bullFootprintSignalOk = footprintSetupBullBias or bullishFootprintDeltaImprovement or bullishFootprintSupportSignal
bearFootprintSignalOk = footprintSetupBearBias or bearishFootprintDeltaImprovement or bearishFootprintSupportSignal
bullFootprintSetupOk = (not requireFootprintSetup or bullFootprintSignalOk) and (not requireFootprintSupportSignal or bullishFootprintSupportSignal)
bearFootprintSetupOk = (not requireFootprintSetup or bearFootprintSignalOk) and (not requireFootprintSupportSignal or bearishFootprintSupportSignal)
bool bullReversalContextActive = bullStructureOk and bullFootprintSignalOk
bool bearReversalContextActive = bearStructureOk and bearFootprintSignalOk

int bullScore = 0
int bearScore = 0

if relVolOk
    bullScore += 1
    bearScore += 1
if relActOk
    bullScore += 1
    bearScore += 1
if relSizeOk
    bullScore += 1
    bearScore += 1
if positiveDeltaOk or bullishDeltaImprovement
    bullScore += 1
if negativeDeltaOk or bearishDeltaImprovement
    bearScore += 1
if footprintSetupBullBias or bullishFootprintDeltaImprovement or bullishFootprintSupportSignal
    bullScore += 1
if footprintSetupBearBias or bearishFootprintDeltaImprovement or bearishFootprintSupportSignal
    bearScore += 1
if bullishWickReject
    bullScore += 1
if bearishWickReject
    bearScore += 1
if atsTurnUp
    bullScore += 1
if atsTurnDown
    bearScore += 1
if spikeUp
    bullScore += 1
if spikeDown
    bearScore += 1

bullSetupCondition = bullStructureOk and bullScore >= setupScoreThreshold and bullFootprintSetupOk and (not requireContextForSetup or bullReversalContextActive)
bearSetupCondition = bearStructureOk and bearScore >= setupScoreThreshold and bearFootprintSetupOk and (not requireContextForSetup or bearReversalContextActive)

priorBullTriggerLevel = nz(ta.highest(high, confirmLookback)[1], high)
priorBearTriggerLevel = nz(ta.lowest(low, confirmLookback)[1], low)

// =====================
// Two-stage setup / confirmation state
// =====================
var bool bullSetupArmed = false
var bool bearSetupArmed = false
var int bullSetupAge = 0
var int bearSetupAge = 0
var int bullSetupScoreStored = 0
var int bearSetupScoreStored = 0
var float bullTrigger = na
var float bearTrigger = na
var float bullStoredLevel = na
var float bearStoredLevel = na
var float bullStoredWidth = na
var float bearStoredWidth = na
var float bullEventHigh = na
var float bullEventLow = na
var float bearEventHigh = na
var float bearEventLow = na
var float bullEventCumPv = na
var float bullEventCumVol = na
var float bearEventCumPv = na
var float bearEventCumVol = na
var float bullEventPocUpper = na
var float bullEventPocLower = na
var float bullEventVahUpper = na
var float bullEventValLower = na
var float bearEventPocUpper = na
var float bearEventPocLower = na
var float bearEventVahUpper = na
var float bearEventValLower = na
var float bullFootprintTriggerLevel = na
var float bearFootprintTriggerLevel = na

bullSetupSignal = false
bearSetupSignal = false
bullConfirmedSignal = false
bearConfirmedSignal = false
float bullConfirmScoreValue = confirmUsesSetupScore ? float(bullSetupScoreStored) : float(bullScore)
float bearConfirmScoreValue = confirmUsesSetupScore ? float(bearSetupScoreStored) : float(bearScore)

if bullSetupArmed
    bullSetupAge += 1
    bool bullContinuationInvalidated = isContinuationMode and not na(bullStoredLevel) and (close < bullStoredLevel - bullStoredWidth or (close < bullStoredLevel and low < bullStoredLevel - bullStoredWidth * 0.5))
    bool bullReversalInvalidated = not isContinuationMode and not na(bullStoredLevel) and close < bullStoredLevel - bullStoredWidth
    if bullSetupAge > setupExpiryBars or bullContinuationInvalidated or bullReversalInvalidated
        bullSetupArmed := false
        bullSetupAge := 0
        bullSetupScoreStored := 0
        bullTrigger := na
        bullStoredLevel := na
        bullStoredWidth := na
        bullEventHigh := na
        bullEventLow := na
        bullEventCumPv := na
        bullEventCumVol := na
        bullEventPocUpper := na
        bullEventPocLower := na
        bullEventVahUpper := na
        bullEventValLower := na
        bullFootprintTriggerLevel := na

if bearSetupArmed
    bearSetupAge += 1
    bool bearContinuationInvalidated = isContinuationMode and not na(bearStoredLevel) and (close > bearStoredLevel + bearStoredWidth or (close > bearStoredLevel and high > bearStoredLevel + bearStoredWidth * 0.5))
    bool bearReversalInvalidated = not isContinuationMode and not na(bearStoredLevel) and close > bearStoredLevel + bearStoredWidth
    if bearSetupAge > setupExpiryBars or bearContinuationInvalidated or bearReversalInvalidated
        bearSetupArmed := false
        bearSetupAge := 0
        bearSetupScoreStored := 0
        bearTrigger := na
        bearStoredLevel := na
        bearStoredWidth := na
        bearEventHigh := na
        bearEventLow := na
        bearEventCumPv := na
        bearEventCumVol := na
        bearEventPocUpper := na
        bearEventPocLower := na
        bearEventVahUpper := na
        bearEventValLower := na
        bearFootprintTriggerLevel := na

if bullSetupCondition and not bullSetupArmed
    bullSetupSignal := true
    bullSetupArmed := true
    bullSetupAge := 0
    bullSetupScoreStored := bullScore
    bullStoredLevel := bullAnchorLevel
    bullStoredWidth := isContinuationMode ? math.max(syminfo.mintick, math.min(chwidth, barRange) * continuationRetestWidthFactor) : chwidth
    bullEventPocUpper := footprintPocUpper
    bullEventPocLower := footprintPocLower
    bullEventVahUpper := footprintVahUpper
    bullEventValLower := footprintValLower
    bullFootprintTriggerLevel := footprintTriggerMode == "Price Only" ? na : footprintTriggerMode == "POC" ? footprintPocUpper : footprintTriggerMode == "VAH/VAL" ? footprintVahUpper : math.max(nz(footprintPocUpper, high), nz(footprintVahUpper, high))
    bullTrigger := na(bullFootprintTriggerLevel) ? math.max(high, priorBullTriggerLevel) : math.max(math.max(high, priorBullTriggerLevel), bullFootprintTriggerLevel)
    bullEventHigh := high
    bullEventLow := low
    bullEventCumPv := startEventVwapOnSetupBar ? hlc3 * volume : na
    bullEventCumVol := startEventVwapOnSetupBar ? volume : na

if bearSetupCondition and not bearSetupArmed
    bearSetupSignal := true
    bearSetupArmed := true
    bearSetupAge := 0
    bearSetupScoreStored := bearScore
    bearStoredLevel := bearAnchorLevel
    bearStoredWidth := isContinuationMode ? math.max(syminfo.mintick, math.min(chwidth, barRange) * continuationRetestWidthFactor) : chwidth
    bearEventPocUpper := footprintPocUpper
    bearEventPocLower := footprintPocLower
    bearEventVahUpper := footprintVahUpper
    bearEventValLower := footprintValLower
    bearFootprintTriggerLevel := footprintTriggerMode == "Price Only" ? na : footprintTriggerMode == "POC" ? footprintPocLower : footprintTriggerMode == "VAH/VAL" ? footprintValLower : math.min(nz(footprintPocLower, low), nz(footprintValLower, low))
    bearTrigger := na(bearFootprintTriggerLevel) ? math.min(low, priorBearTriggerLevel) : math.min(math.min(low, priorBearTriggerLevel), bearFootprintTriggerLevel)
    bearEventHigh := high
    bearEventLow := low
    bearEventCumPv := startEventVwapOnSetupBar ? hlc3 * volume : na
    bearEventCumVol := startEventVwapOnSetupBar ? volume : na

bool bullAccumulateEventVwap = bullSetupArmed and not bullSetupSignal and (startEventVwapOnSetupBar or bullSetupAge > 0)
bool bearAccumulateEventVwap = bearSetupArmed and not bearSetupSignal and (startEventVwapOnSetupBar or bearSetupAge > 0)

if bullSetupArmed and not bullSetupSignal
    bullEventHigh := na(bullEventHigh) ? high : math.max(bullEventHigh, high)
    bullEventLow := na(bullEventLow) ? low : math.min(bullEventLow, low)
    if bullAccumulateEventVwap
        bullEventCumPv := nz(bullEventCumPv) + hlc3 * volume
        bullEventCumVol := nz(bullEventCumVol) + volume

if bearSetupArmed and not bearSetupSignal
    bearEventHigh := na(bearEventHigh) ? high : math.max(bearEventHigh, high)
    bearEventLow := na(bearEventLow) ? low : math.min(bearEventLow, low)
    if bearAccumulateEventVwap
        bearEventCumPv := nz(bearEventCumPv) + hlc3 * volume
        bearEventCumVol := nz(bearEventCumVol) + volume

bullCloseInRange = barRange > 0 ? (close - low) / barRange >= minCloseInRangePct : false
bearCloseInRange = barRange > 0 ? (high - close) / barRange >= minCloseInRangePct : false
bullEventVwap = not na(bullEventCumVol) and bullEventCumVol > 0 ? bullEventCumPv / bullEventCumVol : na
bearEventVwap = not na(bearEventCumVol) and bearEventCumVol > 0 ? bearEventCumPv / bearEventCumVol : na
bullAboveVwap = not na(bullEventVwap) and close >= bullEventVwap
bearBelowVwap = not na(bearEventVwap) and close <= bearEventVwap
bullRetraceSpan = not na(bullEventHigh) and not na(bullStoredLevel) ? math.max(bullEventHigh - bullStoredLevel, syminfo.mintick) : na
bearRetraceSpan = not na(bearStoredLevel) and not na(bearEventLow) ? math.max(bearStoredLevel - bearEventLow, syminfo.mintick) : na
bullRetracePct = not na(bullRetraceSpan) ? math.max(bullEventHigh - low, 0.0) / bullRetraceSpan : na
bearRetracePct = not na(bearRetraceSpan) ? math.max(high - bearEventLow, 0.0) / bearRetraceSpan : na
bullRetraceOk = not na(bullRetracePct) and bullRetracePct <= bullMaxRetracePct
bearRetraceOk = not na(bearRetracePct) and bearRetracePct <= bearMaxRetracePct
bullFootprintStructureOk = footprintTriggerMode == "Price Only" ? true : footprintTriggerMode == "POC" ? (not na(bullEventPocUpper) and close > bullEventPocUpper) : footprintTriggerMode == "VAH/VAL" ? (not na(bullEventVahUpper) and close > bullEventVahUpper) : (not na(bullEventPocUpper) and not na(bullEventVahUpper) and close > math.max(bullEventPocUpper, bullEventVahUpper))
bearFootprintStructureOk = footprintTriggerMode == "Price Only" ? true : footprintTriggerMode == "POC" ? (not na(bearEventPocLower) and close < bearEventPocLower) : footprintTriggerMode == "VAH/VAL" ? (not na(bearEventValLower) and close < bearEventValLower) : (not na(bearEventPocLower) and not na(bearEventValLower) and close < math.min(bearEventPocLower, bearEventValLower))

int bullFollowThroughScore = 0
int bearFollowThroughScore = 0

if not na(bullTrigger) and close > bullTrigger
    bullFollowThroughScore += 1
if not na(bearTrigger) and close < bearTrigger
    bearFollowThroughScore += 1
if bullCloseInRange
    bullFollowThroughScore += 1
if bearCloseInRange
    bearFollowThroughScore += 1
if relVolOk
    bullFollowThroughScore += 1
    bearFollowThroughScore += 1
if positiveDeltaOk
    bullFollowThroughScore += 1
if negativeDeltaOk
    bearFollowThroughScore += 1
if bullRetraceOk
    bullFollowThroughScore += 1
if bearRetraceOk
    bearFollowThroughScore += 1
if bullAboveVwap
    bullFollowThroughScore += 1
if bearBelowVwap
    bearFollowThroughScore += 1
if positiveFootprintOk
    bullFollowThroughScore += 1
if negativeFootprintOk
    bearFollowThroughScore += 1
if bullImbalanceStackOk
    bullFollowThroughScore += 1
if bearImbalanceStackOk
    bearFollowThroughScore += 1
if bullFootprintStructureOk
    bullFollowThroughScore += 1
if bearFootprintStructureOk
    bearFollowThroughScore += 1
if bullishFootprintDeltaImprovement or bullishFootprintSupportSignal
    bullFollowThroughScore += 1
if bearishFootprintDeltaImprovement or bearishFootprintSupportSignal
    bearFollowThroughScore += 1

bullFollowThroughOk = bullSetupArmed and bullSetupAge > 0 and bullSetupAge <= followThroughWindowBars and bullFollowThroughScore >= followThroughScoreThreshold and (not requireVwapHold or bullAboveVwap) and (not requireRetraceFilter or bullRetraceOk) and (not requireFootprintConfirm or positiveFootprintOk) and (not requireImbalanceStackConfirm or bullImbalanceStackOk) and (not requireFootprintStructureConfirm or bullFootprintStructureOk)
bearFollowThroughOk = bearSetupArmed and bearSetupAge > 0 and bearSetupAge <= followThroughWindowBars and bearFollowThroughScore >= followThroughScoreThreshold and (not requireVwapHold or bearBelowVwap) and (not requireRetraceFilter or bearRetraceOk) and (not requireFootprintConfirm or negativeFootprintOk) and (not requireImbalanceStackConfirm or bearImbalanceStackOk) and (not requireFootprintStructureConfirm or bearFootprintStructureOk)

if bullSetupArmed and not na(bullTrigger) and close > bullTrigger and bullConfirmScoreValue >= confirmScoreThreshold and bullFollowThroughOk
    bullConfirmedSignal := true
    bullSetupArmed := false
    bullSetupAge := 0
    bullSetupScoreStored := 0
    bullTrigger := na
    bullStoredLevel := na
    bullStoredWidth := na
    bullEventHigh := na
    bullEventLow := na
    bullEventCumPv := na
    bullEventCumVol := na
    bullEventPocUpper := na
    bullEventPocLower := na
    bullEventVahUpper := na
    bullEventValLower := na
    bullFootprintTriggerLevel := na

if bearSetupArmed and not na(bearTrigger) and close < bearTrigger and bearConfirmScoreValue >= confirmScoreThreshold and bearFollowThroughOk
    bearConfirmedSignal := true
    bearSetupArmed := false
    bearSetupAge := 0
    bearSetupScoreStored := 0
    bearTrigger := na
    bearStoredLevel := na
    bearStoredWidth := na
    bearEventHigh := na
    bearEventLow := na
    bearEventCumPv := na
    bearEventCumVol := na
    bearEventPocUpper := na
    bearEventPocLower := na
    bearEventVahUpper := na
    bearEventValLower := na
    bearFootprintTriggerLevel := na

// =====================
// Visuals
// =====================
setupBarColor = bullConfirmedSignal ? color.new(bullColor, 0) : bearConfirmedSignal ? color.new(bearColor, 0) : bullSetupArmed ? color.new(bullColor, 55) : bearSetupArmed ? color.new(bearColor, 55) : na
barcolor(colorBars ? setupBarColor : na)

plotshape(showSetupMarkers and bullSetupSignal, title="Bullish Reversal Setup", location=location.belowbar, style=shape.arrowup, size=size.tiny, color=color.new(bullColor, 0), text="SET")
plotshape(showSetupMarkers and bearSetupSignal, title="Bearish Reversal Setup", location=location.abovebar, style=shape.arrowdown, size=size.tiny, color=color.new(bearColor, 0), text="SET")
plotshape(showConfirmedMarkers and bullConfirmedSignal, title="Bullish Reversal Confirmed", location=location.belowbar, style=shape.flag, size=size.small, color=bullColor, text="REV")
plotshape(showConfirmedMarkers and bearConfirmedSignal, title="Bearish Reversal Confirmed", location=location.abovebar, style=shape.flag, size=size.small, color=bearColor, text="REV")

plotshape(spikeUp, title="ATS Spike Up", style=shape.triangleup, location=location.belowbar, color=bullColor, text="ATS")
plotshape(spikeDown, title="ATS Spike Down", style=shape.triangledown, location=location.abovebar, color=bearColor, text="ATS")

// =====================
// Compact status table
// =====================
var table dash = table.new(position.top_right, 2, 11, border_width=0)
if showDashboard and barstate.islast
    table.clear(dash, 0, 0, 1, 10)
    color dashboardText = color.new(chart.fg_color, 65)
    color dashboardMuted = color.new(chart.fg_color, 82)
    color dashboardBg = color.new(color.black, 100)
    color atsColor = spikeUp ? bullColor : spikeDown ? bearColor : rising ? color.new(bullColor, 0) : falling ? color.new(bearColor, 0) : neutralColor
    string signalText = bullConfirmedSignal ? "BULL CONFIRMED" : bearConfirmedSignal ? "BEAR CONFIRMED" : bullSetupSignal ? "BULL SETUP" : bearSetupSignal ? "BEAR SETUP" : bullSetupArmed ? "BULL ARMED" : bearSetupArmed ? "BEAR ARMED" : "NONE"
    color signalColor = bullConfirmedSignal or bullSetupArmed or bullSetupSignal ? bullColor : bearConfirmedSignal or bearSetupArmed or bearSetupSignal ? bearColor : neutralColor
    string spikeStreakText = consecutiveSpikeUp > 0 ? "UP " + str.tostring(consecutiveSpikeUp) : consecutiveSpikeDown > 0 ? "DOWN " + str.tostring(consecutiveSpikeDown) : "0"
    string reversalSetupText = bullSetupSignal ? "BULL" : bearSetupSignal ? "BEAR" : bullSetupArmed ? "BULL ARMED" : bearSetupArmed ? "BEAR ARMED" : "NONE"
    color reversalSetupColor = bullSetupSignal or bullSetupArmed ? bullColor : bearSetupSignal or bearSetupArmed ? bearColor : neutralColor
    string reversalConfirmedText = bullConfirmedSignal ? "BULL" : bearConfirmedSignal ? "BEAR" : "NONE"
    color reversalConfirmedColor = bullConfirmedSignal ? bullColor : bearConfirmedSignal ? bearColor : neutralColor
    string footprintText = hasFootprint ? str.tostring(footprintDeltaPct * 100.0, "#.0") + "%" : "NA"
    color footprintColor = positiveFootprintOk ? bullColor : negativeFootprintOk ? bearColor : neutralColor
    string assetProfileText = assetProfile + " / " + eventVwapStartMode
    color biasColor = footprintBiasText == "BULL" or footprintBiasText == "BULL LEAN" ? bullColor : footprintBiasText == "BEAR" or footprintBiasText == "BEAR LEAN" ? bearColor : neutralColor

    table.cell(dash, 0, 0, "BFI-R", text_color=dashboardText, bgcolor=dashboardBg)
    table.cell(dash, 1, 0, signalText, text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 0, 1, "Profile", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 1, assetProfileText, text_color=dashboardText, bgcolor=dashboardBg)
    table.cell(dash, 0, 2, "ATS", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 2, str.tostring(avgSizeProxy, "#.00"), text_color=atsColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 3, "ATS Change %", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 3, str.tostring(changePct, "#.0"), text_color=atsColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 4, "ATS State", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 4, spikeUp ? "SPIKE UP" : spikeDown ? "SPIKE DOWN" : rising ? "RISING" : falling ? "FALLING" : "NEUTRAL", text_color=atsColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 5, "Reversal Setup", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 5, reversalSetupText, text_color=reversalSetupColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 6, "Reversal Confirmed", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 6, reversalConfirmedText, text_color=reversalConfirmedColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 7, "Footprint Bias", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 7, footprintBiasText, text_color=biasColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 8, "Footprint Delta", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 8, footprintText, text_color=footprintColor, bgcolor=dashboardBg)
    table.cell(dash, 0, 9, "ATS Spike Streak", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 9, spikeStreakText, text_color=consecutiveSpikeUp > 0 ? bullColor : consecutiveSpikeDown > 0 ? bearColor : dashboardText, bgcolor=dashboardBg)
    table.cell(dash, 0, 10, "Signal", text_color=dashboardMuted, bgcolor=dashboardBg)
    table.cell(dash, 1, 10, signalText, text_color=signalColor, bgcolor=dashboardBg)

bool priorBullFootprintSignalOk = bar_index > 0 and bullFootprintSignalOk[1]
bool priorBearFootprintSignalOk = bar_index > 0 and bearFootprintSignalOk[1]
bool priorBullReversalContextActive = bar_index > 0 and bullReversalContextActive[1]
bool priorBearReversalContextActive = bar_index > 0 and bearReversalContextActive[1]
bool priorBullSetupArmed = bar_index > 0 and bullSetupArmed[1]
bool priorBearSetupArmed = bar_index > 0 and bearSetupArmed[1]
bool bullishArmedLoose = bullSetupArmed and not priorBullSetupArmed
bool bearishArmedLoose = bearSetupArmed and not priorBearSetupArmed
bool bullishFootprintSignalLoose = bullFootprintSignalOk and not priorBullFootprintSignalOk
bool bearishFootprintSignalLoose = bearFootprintSignalOk and not priorBearFootprintSignalOk
bool bullishReversalContextLoose = bullReversalContextActive and not priorBullReversalContextActive
bool bearishReversalContextLoose = bearReversalContextActive and not priorBearReversalContextActive
bool bullishLooseCompositeAlert = bullishArmedLoose or bullishFootprintSignalLoose or bullishReversalContextLoose
bool bearishLooseCompositeAlert = bearishArmedLoose or bearishFootprintSignalLoose or bearishReversalContextLoose

alertcondition(bullishAtsSpikeUpSignal, title="Bullish ATS Spike Up", message="{{ticker}} bullish ATS spike up on {{interval}}")
alertcondition(bearishAtsSpikeDownSignal, title="Bearish ATS Spike Down", message="{{ticker}} bearish ATS spike down on {{interval}}")
alertcondition(bullishAtsSpikeSequenceSignal, title="Bullish ATS Spike Sequence", message="{{ticker}} bullish ATS spike sequence reached on {{interval}}")
alertcondition(bearishAtsSpikeSequenceSignal, title="Bearish ATS Spike Sequence", message="{{ticker}} bearish ATS spike sequence reached on {{interval}}")
alertcondition(bullSetupSignal or bullishAtsSpikeSequenceSignal, title="Bullish Reversal Setup Or ATS Spike Sequence", message="{{ticker}} bullish reversal setup or bullish ATS spike sequence on {{interval}}")
alertcondition(bullSetupSignal, title="Bullish Reversal Setup", message="{{ticker}} bullish reversal setup armed on {{interval}}")
alertcondition(bearSetupSignal, title="Bearish Reversal Setup", message="{{ticker}} bearish reversal setup armed on {{interval}}")
alertcondition(bullishArmedLoose, title="Bullish Reversal Armed (Loose)", message="{{ticker}} bullish reversal armed event triggered on {{interval}}")
alertcondition(bearishArmedLoose, title="Bearish Reversal Armed (Loose)", message="{{ticker}} bearish reversal armed event triggered on {{interval}}")
alertcondition(bullSetupArmed, title="Bullish Reversal Armed Active", message="{{ticker}} bullish reversal setup remains armed on {{interval}}")
alertcondition(bearSetupArmed, title="Bearish Reversal Armed Active", message="{{ticker}} bearish reversal setup remains armed on {{interval}}")
alertcondition(bullishLooseCompositeAlert, title="Bullish Reversal Loose Composite", message="{{ticker}} bullish loose composite event triggered on {{interval}}")
alertcondition(bearishLooseCompositeAlert, title="Bearish Reversal Loose Composite", message="{{ticker}} bearish loose composite event triggered on {{interval}}")
alertcondition(bullishFootprintAbsorption, title="Bullish Footprint Absorption", message="{{ticker}} bullish footprint absorption on {{interval}}")
alertcondition(bearishFootprintAbsorption, title="Bearish Footprint Absorption", message="{{ticker}} bearish footprint absorption on {{interval}}")
alertcondition(bullishFootprintContinuation, title="Bullish Footprint Continuation", message="{{ticker}} bullish breakout footprint continuation on {{interval}}")
alertcondition(bearishFootprintContinuation, title="Bearish Footprint Continuation", message="{{ticker}} bearish breakout footprint continuation on {{interval}}")
alertcondition(bullishFootprintDeltaImprovement, title="Bullish Footprint Delta Improvement", message="{{ticker}} bullish footprint delta improved on {{interval}}")
alertcondition(bearishFootprintDeltaImprovement, title="Bearish Footprint Delta Improvement", message="{{ticker}} bearish footprint delta weakened on {{interval}}")
alertcondition(bullishFootprintSignalLoose, title="Bullish Footprint Signal (Loose)", message="{{ticker}} bullish footprint setup signal became active on {{interval}}")
alertcondition(bearishFootprintSignalLoose, title="Bearish Footprint Signal (Loose)", message="{{ticker}} bearish footprint setup signal became active on {{interval}}")
alertcondition(bullishReversalContextLoose, title="Bullish Reversal Context (Loose)", message="{{ticker}} bullish reversal context became active on {{interval}}")
alertcondition(bearishReversalContextLoose, title="Bearish Reversal Context (Loose)", message="{{ticker}} bearish reversal context became active on {{interval}}")
alertcondition(bullishFootprintBiasCondition, title="Bullish Footprint Bias Active", message="{{ticker}} footprint bias is bullish on {{interval}}")
alertcondition(bearishFootprintBiasCondition, title="Bearish Footprint Bias Active", message="{{ticker}} footprint bias is bearish on {{interval}}")
alertcondition(bullishFootprintBiasCondition or bearishFootprintBiasCondition, title="Footprint Bias Active", message="{{ticker}} footprint bias is directional on {{interval}}")
alertcondition(bullConfirmedSignal and positiveFootprintOk and bullImbalanceStackOk, title="Bullish Reversal Confirmed With Footprint", message="{{ticker}} bullish reversal confirmed with footprint support on {{interval}}")
alertcondition(bearConfirmedSignal and negativeFootprintOk and bearImbalanceStackOk, title="Bearish Reversal Confirmed With Footprint", message="{{ticker}} bearish reversal confirmed with footprint support on {{interval}}")
alertcondition(bullConfirmedSignal, title="Bullish Reversal Confirmed", message="{{ticker}} bullish reversal confirmed on {{interval}}")
alertcondition(bearConfirmedSignal, title="Bearish Reversal Confirmed", message="{{ticker}} bearish reversal confirmed on {{interval}}")
alertcondition(bullConfirmedSignal or bearConfirmedSignal, title="Reversal Confirmed", message="{{ticker}} reversal confirmed on {{interval}}")