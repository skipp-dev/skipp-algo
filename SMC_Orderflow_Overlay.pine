//@version=6

// ─────────────────────────────────────────────────────────────────
// SMC Orderflow Overlay — lightweight companion to SMC Core Engine
//
// Visualizes flow qualifier fields from the v5.1 enrichment layer:
//   • Relative volume / activity / size bars
//   • Delta proxy indicator
//   • ATS state + spike markers
//   • Flow direction confirmation (long ok / short ok)
//
// Reads mp.* fields from the generated micro-profiles library.
// Keep on a separate pane — independent of trade signals.
// ─────────────────────────────────────────────────────────────────

indicator("SMC Orderflow Overlay", "Flow.Ov", overlay = false, max_labels_count = 50)

import preuss_steffen/smc_micro_profiles_generated/1 as mp

// ── Inputs ──────────────────────────────────────────────────────

var g_fl = "Orderflow Overlay"
var bool show_rel_vol        = input.bool(true,  "Show relative volume bar",   group = g_fl)
var bool show_delta_proxy    = input.bool(true,  "Show delta proxy",           group = g_fl)
var bool show_ats_state      = input.bool(true,  "Show ATS state",             group = g_fl)
var bool show_flow_direction = input.bool(true,  "Show flow direction markers", group = g_fl)
var color col_bullish        = input.color(color.new(color.green, 30), "Bullish color",  group = g_fl)
var color col_bearish        = input.color(color.new(color.red, 30),   "Bearish color",  group = g_fl)
var color col_neutral        = input.color(color.new(color.gray, 50),  "Neutral color",  group = g_fl)

// ── Library fields ──────────────────────────────────────────────

float  fl_rel_vol         = mp.REL_VOL
float  fl_rel_activity    = mp.REL_ACTIVITY
float  fl_delta_proxy_pct = mp.DELTA_PROXY_PCT
bool   fl_flow_long_ok    = mp.FLOW_LONG_OK
bool   fl_flow_short_ok   = mp.FLOW_SHORT_OK
string fl_ats_state       = mp.ATS_STATE
bool   fl_ats_spike_up    = mp.ATS_SPIKE_UP
bool   fl_ats_spike_down  = mp.ATS_SPIKE_DOWN

// ── Relative volume plot ────────────────────────────────────────

color rv_color = fl_rel_vol >= 1.5 ? col_bullish : fl_rel_vol <= 0.5 ? col_bearish : col_neutral
plot(show_rel_vol ? fl_rel_vol : na, "RelVol", rv_color, 2, plot.style_columns)
hline(1.0, "RelVol Baseline", color.new(color.gray, 70), hline.style_dotted)

// ── Delta proxy ─────────────────────────────────────────────────

color dp_color = fl_delta_proxy_pct > 0 ? col_bullish : fl_delta_proxy_pct < 0 ? col_bearish : col_neutral
plot(show_delta_proxy ? fl_delta_proxy_pct : na, "Delta Proxy %", dp_color, 1, plot.style_histogram, display = display.pane)

// ── ATS state background ────────────────────────────────────────

color ats_bg = show_ats_state ?
     fl_ats_state == "ACCUMULATION" ? color.new(color.green, 90) :
     fl_ats_state == "DISTRIBUTION" ? color.new(color.red, 90)   :
     fl_ats_state == "TRANSITION"   ? color.new(color.yellow, 90) :
     na :
     na
bgcolor(ats_bg, title = "ATS State")

// ── ATS spike markers ──────────────────────────────────────────

plotshape(show_ats_state and fl_ats_spike_up,  "ATS Spike Up",   shape.triangleup,   location.bottom, col_bullish, size = size.tiny)
plotshape(show_ats_state and fl_ats_spike_down, "ATS Spike Down", shape.triangledown, location.top,    col_bearish, size = size.tiny)

// ── Flow direction markers ──────────────────────────────────────

plotchar(show_flow_direction and fl_flow_long_ok  ? 0 : na, "Flow Long OK",  "▲", location.bottom, col_bullish, size = size.tiny, display = display.all)
plotchar(show_flow_direction and fl_flow_short_ok ? 0 : na, "Flow Short OK", "▼", location.top,    col_bearish, size = size.tiny, display = display.all)

// ── Status line ─────────────────────────────────────────────────

string flow_summary = "RV:" + str.tostring(fl_rel_vol, "#.##") + " Δ:" + str.tostring(fl_delta_proxy_pct, "#.#") + "% ATS:" + fl_ats_state
plotchar(0, "Flow Summary", "•", location.absolute, size = size.tiny, display = display.status_line, char = flow_summary)
