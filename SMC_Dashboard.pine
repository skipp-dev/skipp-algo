indicator("SMC Dashboard", "SMC Dash", overlay = true, max_labels_count = 50)

src_zone_active = input.source(close, "BUS ZoneActive")
src_armed = input.source(close, "BUS Armed")
src_confirmed = input.source(close, "BUS Confirmed")
src_ready = input.source(close, "BUS Ready")
src_entry_best = input.source(close, "BUS EntryBest")
src_entry_strict = input.source(close, "BUS EntryStrict")
src_trigger = input.source(close, "BUS Trigger")
src_invalidation = input.source(close, "BUS Invalidation")
src_quality_score = input.source(close, "BUS QualityScore")
src_source_kind = input.source(close, "BUS SourceKind")
src_state_code = input.source(close, "BUS StateCode")
src_trend_pack = input.source(close, "BUS TrendPack")
src_meta_pack = input.source(close, "BUS MetaPack")
src_hard_gates_pack_a = input.source(close, "BUS HardGatesPackA")
src_hard_gates_pack_b = input.source(close, "BUS HardGatesPackB")
src_event_risk_row = input.source(close, "BUS EventRiskRow")
src_quality_pack_a = input.source(close, "BUS QualityPackA")
src_quality_pack_b = input.source(close, "BUS QualityPackB")
src_quality_bounds_pack = input.source(close, "BUS QualityBoundsPack")
src_module_pack_a = input.source(close, "BUS ModulePackA")
src_module_pack_b = input.source(close, "BUS ModulePackB")
src_module_pack_c = input.source(close, "BUS ModulePackC")
src_module_pack_d = input.source(close, "BUS ModulePackD")
src_engine_pack = input.source(close, "BUS EnginePack")
src_stop_level = input.source(close, "BUS StopLevel")
src_target_1 = input.source(close, "BUS Target1")
src_target_2 = input.source(close, "BUS Target2")
src_lean_pack_a = input.source(close, "BUS LeanPackA")
src_lean_pack_b = input.source(close, "BUS LeanPackB")

show_table = input.bool(true, "Show Dashboard")
show_risk_lines = input.bool(true, "Show Trigger/Invalidation")
show_state_bg = input.bool(false, "State Background")

state_on(float value) =>
    not na(value) and value > 0.5

pack_slot(float packed_value, int slot) =>
    int packed = int(math.round(nz(packed_value, 0.0)))
    int slot_value = 0
    if slot == 0
        slot_value := int(math.floor(packed / 1000000000))
    else if slot == 1
        slot_value := int(math.floor(packed / 1000000)) % 1000
    else if slot == 2
        slot_value := int(math.floor(packed / 1000)) % 1000
    else
        slot_value := packed % 1000
    slot_value

trend_slot(float packed_value, int slot) =>
    int packed = int(math.round(nz(packed_value, 0.0)))
    int slot_value = 0
    if slot == 0
        slot_value := int(math.floor(packed / 1000)) % 10
    else if slot == 1
        slot_value := int(math.floor(packed / 100)) % 10
    else if slot == 2
        slot_value := int(math.floor(packed / 10)) % 10
    else
        slot_value := packed % 10
    slot_value

meta_slot(float packed_value, int slot) =>
    int packed = int(math.round(nz(packed_value, 0.0)))
    int slot_value = 0
    if slot == 0
        slot_value := int(math.floor(packed / 1000)) % 10
    else if slot == 1
        slot_value := int(math.floor(packed / 100)) % 10
    else if slot == 2
        slot_value := int(math.floor(packed / 10)) % 10
    else
        slot_value := packed % 10
    slot_value

row_status(int row_code) =>
    int(math.floor(row_code / 100)) - 1

row_reason(int row_code) =>
    row_code % 100

status_bg(int state_value) =>
    color bg = color.new(color.gray, 92)
    if state_value >= 6
        bg := color.new(color.green, 70)
    else if state_value == 5
        bg := color.new(color.teal, 75)
    else if state_value == 4
        bg := color.new(color.green, 82)
    else if state_value == 3
        bg := color.new(color.aqua, 80)
    else if state_value == 2
        bg := color.new(color.orange, 82)
    else if state_value == 1
        bg := color.new(color.yellow, 84)
    else if state_value == -1
        bg := color.new(color.red, 82)
    bg

dashboard_row(table tbl, int row, string label_text, string value_text, color bg, color txt) =>
    table.cell(tbl, 0, row, label_text, bgcolor = bg, text_color = txt, text_halign = text.align_left)
    table.cell(tbl, 1, row, value_text, bgcolor = bg, text_color = txt, text_halign = text.align_left)

section_row(table tbl, int row, string title, color bg, color txt) =>
    dashboard_row(tbl, row, title, "", bg, txt)

primary_metric_bg(int state_value) =>
    color.new(status_bg(state_value), 0)

diagnostic_metric_bg(int state_value) =>
    color.new(status_bg(state_value), 8)

source_kind_text(int source_code) =>
    string label_text = "None"
    if source_code == 1
        label_text := "OB"
    else if source_code == 2
        label_text := "FVG"
    else if source_code == 3
        label_text := "Swing Low"
    else if source_code == 4
        label_text := "Internal Low"
    label_text

trend_text(int trend_code) =>
    string label_text = "Neutral"
    if trend_code == 2
        label_text := "Bullish"
    else if trend_code == 0
        label_text := "Bearish"
    label_text

freshness_text(int freshness_code) =>
    string label_text = "n/a"
    if freshness_code == 1
        label_text := "confirm fresh"
    else if freshness_code == 2
        label_text := "confirm stale"
    else if freshness_code == 3
        label_text := "armed fresh"
    else if freshness_code == 4
        label_text := "armed stale"
    label_text

source_state_text(int source_state_code) =>
    string label_text = "n/a"
    if source_state_code == 1
        label_text := "source alive"
    else if source_state_code == 2
        label_text := "source invalid"
    else if source_state_code == 3
        label_text := "source lost"
    label_text

zone_reason_text(int zone_code) =>
    string label_text = "No Long Zone"
    if zone_code == 1
        label_text := "Zone touched"
    else if zone_code == 2
        label_text := "In FVG Zone"
    else if zone_code == 3
        label_text := "In OB Zone"
    else if zone_code == 4
        label_text := "In OB + FVG Zone"
    label_text

reclaim_reason_text(int reclaim_code) =>
    string label_text = "No Reclaim"
    if reclaim_code == 1
        label_text := "Reclaim recent"
    else if reclaim_code == 2
        label_text := "Internal Low Reclaimed"
    else if reclaim_code == 3
        label_text := "Swing Low Reclaimed"
    else if reclaim_code == 4
        label_text := "FVG Reclaimed"
    else if reclaim_code == 5
        label_text := "OB Reclaimed"
    label_text

long_visual_text(int state_code) =>
    string label_text = "Neutral"
    if state_code == -1
        label_text := "Fail"
    else if state_code == 1
        label_text := "In Zone"
    else if state_code == 2
        label_text := "Armed"
    else if state_code == 3
        label_text := "Building"
    else if state_code == 4
        label_text := "Confirmed"
    else if state_code >= 5
        label_text := "Ready"
    label_text

exec_tier_text(int state_code) =>
    string label_text = "n/a"
    if state_code >= 7
        label_text := "Strict"
    else if state_code == 6
        label_text := "Best"
    else if state_code == 5
        label_text := "Ready"
    else if state_code == 4
        label_text := "Confirmed"
    else if state_code == 2 or state_code == 3
        label_text := "Armed"
    else if state_code == 1
        label_text := "Watchlist"
    label_text

setup_text(int state_code, int source_code) =>
    string source_text = source_kind_text(source_code)
    string label_text = "No Setup"
    if state_code == -1
        label_text := "Invalidated"
    else if state_code == 1
        label_text := "In Zone"
    else if state_code == 2
        label_text := "Armed | " + source_text
    else if state_code == 3
        label_text := "Building | " + source_text
    else if state_code == 4
        label_text := "Confirmed | " + source_text
    else if state_code == 5
        label_text := "Ready | " + source_text
    else if state_code == 6
        label_text := "Entry Best | " + source_text
    else if state_code >= 7
        label_text := "Entry Strict | " + source_text
    label_text

setup_age_text(int state_code, int freshness_code) =>
    if state_code >= 4
        freshness_text(freshness_code)
    else if state_code == 2 or state_code == 3
        freshness_text(freshness_code)
    else
        "n/a"

decode_session_text(int row_code) =>
    int reason_code = row_reason(row_code)
    string label_text = "OR blocked"
    if reason_code == 1
        label_text := row_status(row_code) == 5 ? "OK" : "n/a"
    else if reason_code == 2
        label_text := "off"
    else if reason_code == 3
        label_text := "Entry session blocked"
    label_text

decode_market_text(int row_code) =>
    int reason_code = row_reason(row_code)
    string label_text = "Breadth blocked"
    if reason_code == 1
        label_text := row_status(row_code) == 5 ? "OK" : "off"
    else if reason_code == 2
        label_text := "Missing symbol"
    else if reason_code == 3
        label_text := "Index blocked"
    else if reason_code == 4
        label_text := "Sector blocked"
    label_text

decode_vola_text(int row_code) =>
    int reason_code = row_reason(row_code)
    string label_text = "Blocked"
    if reason_code == 1
        label_text := row_status(row_code) == 0 ? "off" : "OK"
    else if reason_code == 2
        label_text := "Compression -> Expansion"
    else if reason_code == 3
        label_text := "Compression context"
    label_text

decode_micro_session_text(int row_code) =>
    int reason_code = row_reason(row_code)
    string label_text = "Weak after-hours"
    if reason_code == 1
        label_text := row_status(row_code) == 0 ? "off" : "OK"
    else if reason_code == 2
        label_text := "RTH only"
    else if reason_code == 3
        label_text := "Midday block"
    else if reason_code == 4
        label_text := "Weak premarket"
    label_text

decode_micro_fresh_text(int row_code, int freshness_code, int source_state_code) =>
    if row_reason(row_code) == 1 and row_status(row_code) == 0
        "off"
    else
        freshness_text(freshness_code) + " | " + source_state_text(source_state_code)

decode_volume_data_text(int row_code) =>
    int reason_code = row_reason(row_code)
    string label_text = "OK"
    if reason_code == 1
        label_text := "OK"
    else if reason_code == 2
        label_text := "Weak feed quality"
    else if reason_code == 3
        label_text := "Chart OK | LTF no-vol"
    else if reason_code == 4
        label_text := "Price-only LTF"
    else if reason_code == 5 or reason_code == 0
        label_text := "No current bar volume"
    label_text

