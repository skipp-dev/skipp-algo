int context_quality_row_code = pack_slot(src_quality_pack_b, 1)
int quality_clean_row_code = pack_slot(src_quality_pack_b, 2)
int quality_score_row_code = pack_slot(src_quality_pack_b, 3)
int sd_confluence_row_code = pack_slot(src_module_pack_a, 0)
int sd_osc_row_code = pack_slot(src_module_pack_a, 1)
int vol_regime_row_code = pack_slot(src_module_pack_a, 2)
int vol_squeeze_row_code = pack_slot(src_module_pack_a, 3)
int vol_expand_row_code = pack_slot(src_module_pack_b, 0)
int stretch_row_code = pack_slot(src_module_pack_b, 1)
int ddvi_row_code = pack_slot(src_module_pack_b, 2)
int ltf_bias_row_code = pack_slot(src_module_pack_b, 3)
int ltf_delta_row_code = pack_slot(src_module_pack_c, 0)
int objects_row_code = pack_slot(src_module_pack_c, 1)
int swing_row_code = pack_slot(src_module_pack_c, 2)
int micro_profile_row_code = pack_slot(src_module_pack_c, 3)
int long_zones_row_code = pack_slot(src_module_pack_d, 0)
int long_triggers_row_code = pack_slot(src_module_pack_d, 1)
int risk_plan_row_code = pack_slot(src_module_pack_d, 2)
int debug_flags_row_code = pack_slot(src_module_pack_d, 3)
int ready_gate_row_code = pack_slot(src_engine_pack, 0)
int strict_gate_row_code = pack_slot(src_engine_pack, 1)
int long_debug_row_code = pack_slot(src_engine_pack, 2)
int micro_modifier_mask = pack_slot(src_engine_pack, 3)
// v5.5 Lean Pack unpacking
int lean_sq_row_code = pack_slot(src_lean_pack_a, 0)
int lean_freshness_row_code = pack_slot(src_lean_pack_a, 1)
int lean_erl_row_code = pack_slot(src_lean_pack_a, 2)
int lean_struct_row_code = pack_slot(src_lean_pack_a, 3)
int lean_ob_row_code = pack_slot(src_lean_pack_b, 0)
int lean_fvg_row_code = pack_slot(src_lean_pack_b, 1)
int lean_session_row_code = pack_slot(src_lean_pack_b, 2)
int htf_bull_count = (trend_htf_1 == 2 ? 1 : 0) + (trend_htf_2 == 2 ? 1 : 0) + (trend_htf_3 == 2 ? 1 : 0)
int setup_state = state_code >= 6 ? 5 : state_code == 5 or state_code == 4 ? 4 : state_code == 3 ? 3 : state_code == 2 ? 2 : state_code == 1 ? 1 : state_code == -1 ? -1 : 0
int exec_state = state_code >= 6 ? 5 : state_code == 5 or state_code == 4 ? 4 : state_code == 2 or state_code == 3 ? 2 : state_code == 1 ? 1 : 0
int setup_age_state = state_code >= 4 ? freshness_code == 1 ? 5 : 2 : state_code == 2 or state_code == 3 ? freshness_code == 3 ? 4 : 2 : 0
int htf_state = htf_bull_count >= 2 ? 5 : htf_bull_count == 1 ? 3 : -1
int reclaim_state = reclaim_code >= 4 ? 5 : reclaim_code >= 2 ? 4 : reclaim_code == 1 ? 2 : 0
string source_label = source_kind_text(source_code)
string long_debug_text = row_status(long_debug_row_code) == 0 ? "off" : "state=" + long_visual_text(state_code) + " | src=" + source_label + " | fresh=" + freshness_text(freshness_code) + " | " + source_state_text(source_state_code)

plot(show_risk_lines ? src_trigger : na, "Core Trigger", color = color.new(color.aqua, 0), linewidth = 2, style = plot.style_linebr)
plot(show_risk_lines ? src_invalidation : na, "Core Invalidation", color = color.new(color.orange, 0), linewidth = 2, style = plot.style_linebr)
bgcolor(show_state_bg and state_code >= 5 ? color.new(color.green, 90) : na)

var table smc_dashboard = table.new(position.bottom_right, 2, 58, border_width = 0)

if show_table and barstate.islast
    color txt = chart.fg_color
    color header_bg = color.new(color.black, 100)
    dashboard_row(smc_dashboard, 0, "SMC Dashboard", "v5.5b Hero Surface", header_bg, txt)
    // ── PRIMARY: Lifecycle + Hero Surface ──
    section_row(smc_dashboard, 1, "[ Lifecycle ]", header_bg, txt)
    dashboard_row(smc_dashboard, 2, "Trend", trend_text(trend_now), status_bg(trend_now == 2 ? 5 : trend_now == 0 ? -1 : 0), txt)
    dashboard_row(smc_dashboard, 3, "HTF Trend", "HTF1:" + trend_text(trend_htf_1) + " | HTF2:" + trend_text(trend_htf_2) + " | HTF3:" + trend_text(trend_htf_3), status_bg(htf_state), txt)
    dashboard_row(smc_dashboard, 4, "Pullback Zone", zone_reason_text(zone_code), status_bg(row_status(long_zones_row_code)), txt)
    dashboard_row(smc_dashboard, 5, "Reclaim", reclaim_reason_text(reclaim_code), status_bg(reclaim_state), txt)
    dashboard_row(smc_dashboard, 6, "Long Setup", setup_text(state_code, source_code), status_bg(setup_state), txt)
    dashboard_row(smc_dashboard, 7, "Setup Age", setup_age_text(state_code, freshness_code), status_bg(setup_age_state), txt)
    dashboard_row(smc_dashboard, 8, "Long Visual", long_visual_text(state_code), status_bg(state_code), txt)
    dashboard_row(smc_dashboard, 9, "Exec Tier", exec_tier_text(state_code), status_bg(exec_state), txt)
    section_row(smc_dashboard, 10, "[ Hero Surface v5.5b ]", header_bg, txt)
    dashboard_row(smc_dashboard, 11, "Signal Quality", decode_lean_sq_text(lean_sq_row_code), status_bg(row_status(lean_sq_row_code)), txt)
    dashboard_row(smc_dashboard, 12, "Signal Fresh", decode_lean_freshness_text(lean_freshness_row_code), status_bg(row_status(lean_freshness_row_code)), txt)
    dashboard_row(smc_dashboard, 13, "Event Risk Light", decode_lean_erl_text(lean_erl_row_code), status_bg(row_status(lean_erl_row_code)), txt)
    dashboard_row(smc_dashboard, 14, "Structure Light", decode_lean_struct_text(lean_struct_row_code), status_bg(row_status(lean_struct_row_code)), txt)
    dashboard_row(smc_dashboard, 15, "OB Light", decode_lean_ob_text(lean_ob_row_code), status_bg(row_status(lean_ob_row_code)), txt)
    dashboard_row(smc_dashboard, 16, "FVG Light", decode_lean_fvg_text(lean_fvg_row_code), status_bg(row_status(lean_fvg_row_code)), txt)
    dashboard_row(smc_dashboard, 17, "Session Light", decode_lean_session_text(lean_session_row_code), status_bg(row_status(lean_session_row_code)), txt)
    // ── SECONDARY: Diagnostic sections below ──
    section_row(smc_dashboard, 18, "[ Hard Gates — Diagnostic ]", header_bg, txt)
    dashboard_row(smc_dashboard, 19, "Session", decode_session_text(session_row_code), status_bg(row_status(session_row_code)), txt)
    dashboard_row(smc_dashboard, 20, "Market Gate", decode_market_text(market_row_code), status_bg(row_status(market_row_code)), txt)
    dashboard_row(smc_dashboard, 21, "Vola Regime", decode_vola_text(vola_row_code), status_bg(row_status(vola_row_code)), txt)
    dashboard_row(smc_dashboard, 22, "Micro Session", decode_micro_session_text(micro_session_row_code), status_bg(row_status(micro_session_row_code)), txt)
    dashboard_row(smc_dashboard, 23, "Micro Fresh", decode_micro_fresh_text(micro_fresh_row_code, freshness_code, source_state_code), status_bg(row_status(micro_fresh_row_code)), txt)
    dashboard_row(smc_dashboard, 24, "Volume Data", decode_volume_data_text(volume_data_row_code), status_bg(row_status(volume_data_row_code)), txt)
    dashboard_row(smc_dashboard, 25, "Event Risk", decode_event_risk_text(event_risk_row_code), status_bg(row_status(event_risk_row_code)), txt)
    section_row(smc_dashboard, 26, "[ Quality — Diagnostic ]", header_bg, txt)
    dashboard_row(smc_dashboard, 27, "Primary | Quality Env", decode_quality_env_text(quality_env_row_code), primary_metric_bg(row_status(quality_env_row_code)), txt)
    dashboard_row(smc_dashboard, 28, "Diag | Quality Strict", decode_quality_strict_text(quality_strict_row_code), diagnostic_metric_bg(row_status(quality_strict_row_code)), txt)
    dashboard_row(smc_dashboard, 29, "Diag | Close Strength", decode_close_text(close_row_code), diagnostic_metric_bg(row_status(close_row_code)), txt)
    dashboard_row(smc_dashboard, 30, "Diag | EMA Support", decode_ema_text(ema_row_code), diagnostic_metric_bg(row_status(ema_row_code)), txt)
    dashboard_row(smc_dashboard, 31, "Diag | ADX", decode_adx_text(adx_row_code), diagnostic_metric_bg(row_status(adx_row_code)), txt)
    dashboard_row(smc_dashboard, 32, "Diag | Rel Volume", decode_relvol_text(relvol_row_code), diagnostic_metric_bg(row_status(relvol_row_code)), txt)
    dashboard_row(smc_dashboard, 33, "Diag | VWAP Filter", decode_vwap_text(vwap_row_code), diagnostic_metric_bg(row_status(vwap_row_code)), txt)
    dashboard_row(smc_dashboard, 34, "Diag | Context Quality", decode_context_quality_text(context_quality_row_code), diagnostic_metric_bg(row_status(context_quality_row_code)), txt)
    dashboard_row(smc_dashboard, 35, "Primary | Signal Quality", quality_bounds_text(src_quality_score, src_quality_bounds_pack), primary_metric_bg(row_status(quality_score_row_code)), txt)
    dashboard_row(smc_dashboard, 36, "Primary | Quality Clean", decode_quality_clean_text(quality_clean_row_code), primary_metric_bg(row_status(quality_clean_row_code)), txt)
    section_row(smc_dashboard, 37, "[ Modules — Diagnostic ]", header_bg, txt)
    dashboard_row(smc_dashboard, 38, "SD Confluence", decode_sd_confluence_text(sd_confluence_row_code), status_bg(row_status(sd_confluence_row_code)), txt)
    dashboard_row(smc_dashboard, 39, "SD Osc", decode_sd_osc_text(sd_osc_row_code), status_bg(row_status(sd_osc_row_code)), txt)
    dashboard_row(smc_dashboard, 40, "Vol Regime", decode_vol_regime_text(vol_regime_row_code), status_bg(row_status(vol_regime_row_code)), txt)
    dashboard_row(smc_dashboard, 41, "Vol Squeeze", decode_vol_squeeze_text(vol_squeeze_row_code), status_bg(row_status(vol_squeeze_row_code)), txt)
    dashboard_row(smc_dashboard, 42, "Vol Expand", decode_vol_expand_text(vol_expand_row_code), status_bg(row_status(vol_expand_row_code)), txt)
