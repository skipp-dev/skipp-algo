// ── Trade Management mirror inputs ────────────────────────────
// READ-ONLY mirror of SMC_Hold_Manager.pine state machine. Renders 2 extra
// rows (Trade-State + live Stop) at the bottom of the dashboard table when
// enabled. NO alerts here — Mobile/Dashboard surfaces are read-only by
// design. For audible alerts, link SMC_Hold_Manager on the same chart.
// MIRROR-OF: SMC_Hold_Manager.pine §state-machine (FLAT/ARMED/IN_TRADE)
tm_enable      = input.bool(false, "Enable Trade-Mgmt rows",            group = g_trade_mgmt, tooltip = "Adds 2 read-only rows (Trade-State + live Stop) showing the same FLAT/ARMED/IN-TRADE machine SMC_Hold_Manager runs. No alerts; for audible alerts add SMC_Hold_Manager.")
tm_tp1_r       = input.float(1.5,  "TP1 (R-multiple)",                  group = g_trade_mgmt, minval = 0.25, step = 0.25)
tm_tp2_r       = input.float(3.0,  "TP2 (R-multiple)",                  group = g_trade_mgmt, minval = 0.5,  step = 0.25)
tm_be_after_t1 = input.bool(true,  "Move stop to break-even after TP1", group = g_trade_mgmt)

surface_mode = input.string("Decision Brief", "View", options = ["Focus", "Hero", "Explain", "Decision Brief", "Audit View"], group = g_surface, tooltip = "Focus: 3-row traffic light — just the essentials.\nHero: 7-row decision-first surface (action, market, quality, trust, why now, risk, plan) reading the hero state contract from the generated library.\nExplain: checklist showing why the current zone state holds.\nDecision Brief: compact setup overview with context.\nAudit View: full expert table for review.")
show_table = input.bool(true, "Show Brief Panel", group = g_surface)
show_risk_lines = input.bool(true, "Show Trade Plan", group = g_surface)
show_state_bg = input.bool(false, "Highlight Live Setup", group = g_surface)
compact_dashboard = input.bool(false, "Compact Dashboard", group = g_surface, tooltip = "WP-OV5: Show only 5 key rows for mobile or small screens. Overrides Decision Brief when enabled.")
color_theme = input.string("Standard", "Color Theme", options = ["Standard", "Colorblind Safe"], group = g_surface, tooltip = "Match this to the Core Engine color theme. Colorblind Safe replaces red/green with orange/blue.")
hero_token_order = input.string("BIAS,TRUST,FAM,ZONE,BLOCKER", "Hero Token Order", group = g_surface, tooltip = "Plan 1.1 follow-up — comma-separated tokens that compose the Hero one-liner after the fixed 'SMC' prefix. Vocabulary: BIAS, TRUST, FAM (top-family hit-rate %), ZONE (rank), BLOCKER (warning), SHA (calibration SHA, requires Calibration SHA input below). Unknown tokens are ignored. Default 'BIAS,TRUST,FAM,ZONE,BLOCKER' matches the original hardcoded order. This input is the seam for the W22 preset/template marketplace (Plan §3.5) — users can already build their own Hero today.")
calibration_sha = input.string("", "Calibration SHA", group = g_surface, tooltip = "Plan §3.1.1 — paste the short git SHA of the calibration_report artifact you trust (e.g. 'a1b2c3d'). When set and the SHA token is present in Hero Token Order, the Hero one-liner appends 'sha:<7chars>' so a screenshot stays SHA-anchored. Empty by default → SHA segment is omitted (no surface change).")
calibration_breach_banner = input.bool(false, "Calibration Breach Banner", group = g_surface, tooltip = "Plan §3.1.2 — manual operator switch for the rolling-30-day smECE SLO breach. Flip on when docs/slo_calibration.md mitigation pipeline is triggered. Hero one-liner then prepends '⚠CAL-BREACH' to the BLOCKER token. Auto-flip from the daily artifact stream lands once Plan W14–W15 ships the public dashboard.")
fvg_context_health_text = input.string("", "FVG Context Health (paste from sidecar)", group = g_surface, tooltip = "Plan §D2 — paste the operator-summary line from the latest pine/generated/fvg_context_health.json sidecar (e.g. '⚠ FVG weak in ETH+HIGH (41% HR, 12 events); OK in RTH+NORMAL (72% HR, 34 events)'). Renders as a tooltip on the FVG Status row (line 32) and an extra hint row (32a). Empty by default → tooltip falls back to the legacy single-number summary (no surface change). Auto-flip from the daily artifact stream lands once the smc_micro_profiles_generated library exposes per-context FVG fields (separate library republish PR).")

