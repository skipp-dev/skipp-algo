    dashboard_row(smc_dashboard, 50, "Long Triggers", trigger_text(row_status(long_triggers_row_code) == 5, src_trigger, src_invalidation), status_bg(row_status(long_triggers_row_code)), txt)
    dashboard_row(smc_dashboard, 51, "Micro Profile", decode_micro_profile_text(micro_profile_row_code, micro_modifier_mask), status_bg(row_status(micro_profile_row_code)), txt)
    dashboard_row(smc_dashboard, 52, "Risk Plan", plan_text(row_status(risk_plan_row_code) == 5, src_trigger, src_stop_level, src_target_1, src_target_2), status_bg(row_status(risk_plan_row_code)), txt)
    section_row(smc_dashboard, 53, "[ Engine — Diagnostic ]", header_bg, txt)
    dashboard_row(smc_dashboard, 54, "Ready Gate", decode_ready_gate_text(ready_gate_row_code), status_bg(row_status(ready_gate_row_code)), txt)
    dashboard_row(smc_dashboard, 55, "Strict Gate", decode_strict_gate_text(strict_gate_row_code), status_bg(row_status(strict_gate_row_code)), txt)
    dashboard_row(smc_dashboard, 56, "Debug Flags", decode_debug_flags_text(debug_flags_row_code), status_bg(row_status(debug_flags_row_code)), txt)
