int close_row_code = pack_slot(src_quality_pack_a, 0)
int ema_row_code = pack_slot(src_quality_pack_a, 1)
int adx_row_code = pack_slot(src_quality_pack_a, 2)
int relvol_row_code = pack_slot(src_quality_pack_a, 3)
