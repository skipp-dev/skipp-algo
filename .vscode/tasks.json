{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "python: bootstrap repo .venv",
            "type": "shell",
            "command": "bash",
            "args": [
                "scripts/bootstrap_venv.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "SKIPP_VENV": "${workspaceFolder}/.venv"
                }
            },
            "windows": {
                "command": "pwsh",
                "args": [
                    "-NoLogo",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${workspaceFolder}\\scripts\\bootstrap_venv.ps1",
                    "-VenvPath",
                    ".venv"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "pytest: focused current file",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pytest",
                "-q",
                "--maxfail=1",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "pytest: debug current file",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pytest",
                "-vv",
                "-s",
                "--maxfail=1",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "pytest: local fast (8 workers)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pytest",
                "-q",
                "--maxfail=1",
                "-n",
                "8",
                "--dist=worksteal",
                "tests"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "pytest: CI parity (PR)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pytest",
                "-q",
                "--maxfail=1",
                "-n",
                "auto",
                "--dist=worksteal",
                "tests"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "pytest: push-like coverage",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "pytest",
                "-q",
                "--maxfail=1",
                "-n",
                "auto",
                "--dist=worksteal",
                "--cov",
                "--cov-report=term-missing:skip-covered",
                "tests"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}