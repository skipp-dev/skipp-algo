export resolve_bus_session_row(bool intraday_time_chart, bool use_trade_session_gate, bool use_opening_range_gate, bool session_structure_gate_ok, bool session_gate_ok) =>
    bp.resolve_bus_session_row(intraday_time_chart, use_trade_session_gate, use_opening_range_gate, session_structure_gate_ok, session_gate_ok)

export resolve_bus_market_row(bool use_index_gate, bool use_sector_gate, bool use_breadth_symbol_gate, bool market_symbols_missing, bool block_on_missing_market_symbol, bool market_regime_gate_ok, bool index_gate_effective_ok, bool sector_gate_effective_ok, bool market_valuation_caution) =>
    if not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate
        bp.pack_bus_row(0, 1)
    else if market_symbols_missing and block_on_missing_market_symbol
        bp.pack_bus_row(-1, 2)
    else if market_symbols_missing
        bp.pack_bus_row(2, 2)
    else if market_valuation_caution and market_regime_gate_ok
        bp.pack_bus_row(2, 6)
    else if market_regime_gate_ok
        bp.pack_bus_row(5, 1)
    else if not index_gate_effective_ok
        bp.pack_bus_row(-1, 3)
    else if not sector_gate_effective_ok
        bp.pack_bus_row(-1, 4)
    else
        bp.pack_bus_row(-1, 5)

export resolve_bus_vola_row(bool use_vola_compression_gate, bool vola_regime_gate_safe, bool vola_expansion_now, bool vola_compression_recent) =>
    bp.resolve_bus_vola_row(use_vola_compression_gate, vola_regime_gate_safe, vola_expansion_now, vola_compression_recent)

