export resolve_bus_micro_profile_code(bool use_microstructure_profiles, string micro_profile_text, string micro_modifier_text) =>
    int base_code = micro_profile_text == 'Stop-Hunt Sensitive' ? 2 : micro_profile_text == 'Clean Reclaim' ? 3 : micro_profile_text == 'RTH Only' ? 4 : micro_profile_text == 'Midday Dead' ? 5 : micro_profile_text == 'Fast Decay' ? 6 : 1
    int modifier_code = micro_modifier_text != '' ? 10 : 0
    use_microstructure_profiles ? base_code + modifier_code : 0

// ── v5.5 Lean BUS Resolvers ──

export resolve_bus_signal_quality_row(int sq_score, string sq_tier) =>
    int score_band = sq_score >= 80 ? 4 : sq_score >= 60 ? 3 : sq_score >= 40 ? 2 : 1
    if sq_tier == "high"
        pack_bus_row(5, score_band)
    else if sq_tier == "good"
        pack_bus_row(4, score_band)
    else if sq_tier == "ok"
        pack_bus_row(3, score_band)
    else
        pack_bus_row(2, score_band)

export resolve_bus_signal_freshness_row(string sq_freshness, string sq_bias) =>
    int fresh_code = sq_freshness == "fresh" ? 5 : sq_freshness == "aging" ? 3 : 1
    int bias_code = sq_bias == "bull" ? 1 : sq_bias == "bear" ? 2 : sq_bias == "mixed" ? 3 : 4
    pack_bus_row(fresh_code, bias_code)

export resolve_bus_event_risk_light_row(string erl_window, string erl_level, bool erl_market_blocked, bool erl_symbol_blocked) =>
    if erl_market_blocked
        pack_bus_row(-1, 1)
    else if erl_symbol_blocked
        pack_bus_row(-1, 6)
    else if erl_window == "ACTIVE"
        pack_bus_row(2, 2)
    else if erl_window == "PRE_EVENT" and (erl_level == "ELEVATED" or erl_level == "HIGH")
        pack_bus_row(2, 3)
    else if erl_window == "COOLDOWN"
        pack_bus_row(3, 4)
    else
        pack_bus_row(5, 5)

export resolve_bus_struct_light_row(int trend_strength, bool fresh, string last_event) =>
    int event_code = last_event == "BOS_BULL" ? 1 : last_event == "CHOCH_BULL" ? 2 : last_event == "BOS_BEAR" ? 3 : last_event == "CHOCH_BEAR" ? 4 : 5
    if trend_strength >= 60 and fresh
        pack_bus_row(5, event_code)
    else if trend_strength >= 30
        pack_bus_row(4, event_code)
    else
        pack_bus_row(2, event_code)

export resolve_bus_ob_light_row(string ob_side, bool ob_fresh, string ob_mitig) =>
    if ob_side == "BULL" and ob_fresh
        pack_bus_row(5, ob_mitig == "fresh" ? 1 : ob_mitig == "touched" ? 2 : 3)
    else if ob_side == "BULL"
        pack_bus_row(3, 2)
    else if ob_side == "BEAR"
        pack_bus_row(2, 4)
    else
        pack_bus_row(3, 5)

export resolve_bus_fvg_light_row(string fvg_side, bool fvg_fresh, bool fvg_invalidated) =>
    if fvg_invalidated
        pack_bus_row(2, 1)
    else if fvg_side == "BULL" and fvg_fresh
        pack_bus_row(5, 2)
    else if fvg_side == "BULL"
        pack_bus_row(4, 3)
    else if fvg_side == "BEAR"
        pack_bus_row(2, 4)
    else
        pack_bus_row(3, 5)

export resolve_bus_ensemble_transport_state(float ensemble_quality_score, string ensemble_quality_tier) =>
    if ensemble_quality_tier == "high"
        5
    else if ensemble_quality_tier == "good"
        4
    else if ensemble_quality_tier == "ok"
        3
    else if ensemble_quality_tier == "low" or ensemble_quality_score > 0
        2
    else
        0

export resolve_bus_library_vol_reason_code(string volatility_regime, string volatility_model_source) =>
    int regime_code = volatility_regime == "EXTREME" ? 4 : volatility_regime == "HIGH_VOL" ? 3 : volatility_regime == "NORMAL" ? 2 : volatility_regime == "LOW_VOL" ? 1 : 0
    int source_code = volatility_model_source == "arch_garch" ? 1 : volatility_model_source == "atr_fallback" ? 2 : 0
    regime_code * 10 + source_code

export resolve_bus_ensemble_vol_transport_row(float ensemble_quality_score, string ensemble_quality_tier, string volatility_regime, string volatility_model_source) =>
    pack_bus_row(resolve_bus_ensemble_transport_state(ensemble_quality_score, ensemble_quality_tier), resolve_bus_library_vol_reason_code(volatility_regime, volatility_model_source))

export resolve_bus_trend_pack(int structure_display_trend, int mtf_trend_1, int mtf_trend_2, int mtf_trend_3) =>
    pack_bus_trend_set(structure_display_trend, mtf_trend_1, mtf_trend_2, mtf_trend_3)

export resolve_bus_meta_pack(bool long_setup_armed, bool long_setup_confirmed, bool ready_is_fresh, bool confirm_is_fresh, bool long_source_tracked, bool long_source_alive, bool long_source_broken, bool reclaim_recent, bool bull_reclaim_internal_low_strict, bool bull_reclaim_swing_low_strict, bool bull_reclaim_fvg_strict, bool bull_reclaim_ob_strict, bool long_zone_active, bool in_bull_ob_zone, bool in_bull_fvg_zone) =>
    pack_bus_meta(resolve_bus_freshness_code(long_setup_armed, long_setup_confirmed, ready_is_fresh, confirm_is_fresh), resolve_bus_source_state_code(long_source_tracked, long_source_alive, long_source_broken), resolve_bus_reclaim_code(reclaim_recent, bull_reclaim_internal_low_strict, bull_reclaim_swing_low_strict, bull_reclaim_fvg_strict, bull_reclaim_ob_strict), resolve_bus_zone_code(long_zone_active, in_bull_ob_zone, in_bull_fvg_zone))

export resolve_bus_lean_pack_a(int signal_quality_score, string signal_quality_tier, string signal_freshness, string signal_bias_alignment, string event_window_state, string event_risk_level, bool market_event_blocked, bool symbol_event_blocked, int structure_trend_strength, bool structure_fresh, string structure_last_event) =>
    pack_bus_four(resolve_bus_signal_quality_row(signal_quality_score, signal_quality_tier), resolve_bus_signal_freshness_row(signal_freshness, signal_bias_alignment), resolve_bus_event_risk_light_row(event_window_state, event_risk_level, market_event_blocked, symbol_event_blocked), resolve_bus_struct_light_row(structure_trend_strength, structure_fresh, structure_last_event))

export resolve_bus_lean_pack_b(string ob_side, bool ob_fresh, string ob_mitigation_state, string fvg_side, bool fvg_fresh, bool fvg_invalidated, int session_context_score, bool in_killzone, float ensemble_quality_score, string ensemble_quality_tier, string volatility_regime, string volatility_model_source) =>
    pack_bus_four(resolve_bus_ob_light_row(ob_side, ob_fresh, ob_mitigation_state), resolve_bus_fvg_light_row(fvg_side, fvg_fresh, fvg_invalidated), pack_bus_row(session_context_score, in_killzone ? 1 : 2), resolve_bus_ensemble_vol_transport_row(ensemble_quality_score, ensemble_quality_tier, volatility_regime, volatility_model_source))

// ── Alert Detail Composites ──

export compose_long_invalidated_alert_detail(string long_last_invalid_source, string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'BLOCKED. ' + long_last_invalid_source + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_entry_strict_alert_detail(string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'ENTER LONG. Strict execution conditions passed' + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_entry_best_alert_detail(string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'ENTER LONG. Best execution conditions passed' + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_ready_alert_detail(string long_setup_source_display, string long_strict_alert_suffix, string long_environment_alert_suffix, string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'READY LONG. Confirmed setup from ' + long_setup_source_display + ' is ready for the trigger break' + long_strict_alert_suffix + long_environment_alert_suffix + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_confirmed_alert_detail(string long_setup_source_display, string long_strict_alert_suffix, string long_environment_alert_suffix, string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. Setup confirmed from ' + long_setup_source_display + '; wait for READY LONG' + long_strict_alert_suffix + long_environment_alert_suffix + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_clean_alert_detail(string long_environment_alert_suffix, string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. Confirmed setup with supportive context' + long_environment_alert_suffix + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_early_alert_detail(string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. Strict reclaim is in; confirmation is starting' + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_armed_plus_alert_detail(string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. Strict reclaim is in; setup armed' + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_armed_alert_detail(string long_setup_source_display, string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. ' + long_setup_source_display + ' armed after reclaim confirmation' + long_micro_alert_suffix + long_score_detail_suffix

export compose_long_watchlist_alert_detail(string long_micro_alert_suffix, string long_score_detail_suffix) =>
    'PREPARE LONG. Bullish trend plus active pullback zone' + long_micro_alert_suffix + long_score_detail_suffix
