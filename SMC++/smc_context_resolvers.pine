//@version=6
// @description Pure context resolver and BUS packing functions.
// No state, no drawing — all functions are parameter-in, value-out.
library("smc_context_resolvers", overlay = false)

import preuss_steffen/smc_utils/1 as u
import preuss_steffen/smc_bus_private/1 as bp

// ── Ticker Heat Parser ──

export f_parse_ticker_heat(string heat_map, string ticker) =>
    float heat = 0.0
    if heat_map != ''
        string search = ticker + ':'
        int pos = str.pos(heat_map, search)
        if pos >= 0
            int val_start = pos + str.length(search)
            int comma_pos = str.pos(str.substring(heat_map, val_start), ',')
            string val_str = comma_pos >= 0 ? str.substring(heat_map, val_start, val_start + comma_pos) : str.substring(heat_map, val_start)
            heat := str.tonumber(val_str)
    heat

// ── Core Resolvers ──

export resolve_core_provider_state(string provider_status, int provider_count, string stale_providers) =>
    string provider_text = 'Degraded'
    if stale_providers != ''
        provider_text := str.tostring(provider_count) + ' provider · ' + stale_providers + ' stale'
    else if provider_count > 0
        provider_text := str.tostring(provider_count) + '/' + str.tostring(provider_count) + ' ok'
    else
        string provider_status_norm = str.lower(provider_status)
        if provider_status_norm == 'ok'
            provider_text := 'OK'
        else if provider_status_norm == 'calendar_missing'
            provider_text := 'Calendar missing'
        else if provider_status_norm == 'news_missing'
            provider_text := 'News missing'
        else if provider_status_norm == 'no_data'
            provider_text := 'No data'
        else if provider_status_norm == ''
            provider_text := 'Unknown'
        else
            provider_text := provider_status
    provider_text

export resolve_core_bias_text(string signal_bias_alignment) =>
    string bias_text = 'Mixed'
    if signal_bias_alignment == 'bull'
        bias_text := 'Bullish'
    else if signal_bias_alignment == 'bear'
        bias_text := 'Bearish'
    bias_text

export compose_why_now_text(string product_state, string long_setup_source_display, string signal_freshness, string signal_warnings, string long_ready_blocker_text, string long_strict_blocker_text, float long_trigger) =>
    string why_now = 'No confirmed reclaim yet'
    string ready_text = str.lower(long_ready_blocker_text)
    string strict_text = str.lower(long_strict_blocker_text)
    if product_state == 'ENTER LONG'
        why_now := 'Trigger is live'
    else if product_state == 'READY LONG'
        why_now := 'Confirmed setup is ready'
        if not na(long_trigger)
            why_now += '; watch ' + u.format_level(long_trigger)
    else if product_state == 'PREPARE LONG'
        why_now := long_setup_source_display == 'None' ? 'Wait for reclaim confirmation' : long_setup_source_display + ' zone is active'
    else if product_state == 'BLOCKED'
        if long_ready_blocker_text != '' and ready_text != 'ready'
            why_now := long_ready_blocker_text
        else if long_strict_blocker_text != '' and strict_text != 'strict'
            why_now := long_strict_blocker_text
        else
            why_now := 'Setup invalidated; wait for reset'
    if product_state == 'READY LONG' or product_state == 'ENTER LONG'
        if signal_freshness == 'fresh'
            why_now += ' | fresh'
        else if signal_freshness == 'aging'
            why_now += ' | aging'
    if signal_warnings != ''
        why_now += ' | ' + signal_warnings
    why_now

export compose_main_risk_text(string product_state, string event_risk_state, string long_ready_blocker_text, string long_strict_blocker_text, string long_last_invalid_source, string signal_warnings, string provider_status, bool has_earnings_tomorrow) =>
    string main_risk = product_state == 'BLOCKED' ? 'Setup is blocked' : ((product_state == 'READY LONG' or product_state == 'ENTER LONG') ? 'No active blocker' : 'No trade plan yet')
    string ready_text = str.lower(long_ready_blocker_text)
    string strict_text = str.lower(long_strict_blocker_text)
    if event_risk_state == 'blocked'
        main_risk := 'Event risk is blocking'
    else if event_risk_state == 'caution'
        main_risk := 'Event risk is elevated'
    else if long_ready_blocker_text != '' and ready_text != 'ready'
        main_risk := long_ready_blocker_text
    else if long_strict_blocker_text != '' and strict_text != 'strict'
        main_risk := long_strict_blocker_text
    else if long_last_invalid_source != 'None'
        main_risk := 'Last invalidation came from ' + long_last_invalid_source
    else if signal_warnings != ''
        main_risk := signal_warnings
    else if provider_status != 'ok'
        main_risk := 'Data quality is degraded'
    else if has_earnings_tomorrow
        main_risk := 'Earnings tomorrow — size with care'
    main_risk

export compose_trade_threshold_text(string trust_tier, int signal_quality_score) =>
    string confidence_text = 'Caution'
    if trust_tier == 'High'
        confidence_text := 'High'
    else if trust_tier == 'Guarded'
        confidence_text := 'Usable'
    else if trust_tier == 'Degraded'
        confidence_text := 'Thin'
    if signal_quality_score < 50
        confidence_text += ' (low quality)'
    confidence_text

export resolve_core_hero_color(string product_state, color bull_hero, color bull_hero_ready, color bear_hero) =>
    color hero_color = color.new(color.gray, 70)
    if product_state == 'ENTER LONG'
        hero_color := bull_hero
    else if product_state == 'READY LONG'
        hero_color := bull_hero_ready
    else if product_state == 'PREPARE LONG'
        hero_color := color.new(color.orange, 60)
    else if product_state == 'BLOCKED'
        hero_color := bear_hero
    hero_color

export compose_core_hero_text(string product_state, string bias_text, string trade_threshold_text, string trust_tier, string trust_suffix, string provider_state, string why_now, string main_risk, string market_regime, bool regime_blocks, bool regime_dims, string asof_display, float vix_level, string market_event, string tone_text, bool yield_inverted, string sector_leading, bool breaking_news, int high_impact_count, int universe_status_code) =>
    string action_display = product_state
    if (product_state == 'WAIT' or product_state == 'BLOCKED') and (regime_blocks or regime_dims)
        action_display := product_state + ' (regime: ' + market_regime + ')'
    string bias_display = bias_text
    if (bias_text == 'Bullish' or bias_text == 'Bearish') and (regime_blocks or regime_dims)
        bias_display := bias_text + ' tone — ' + market_regime + ' regime overrides'
    string trust_display = trust_suffix != '' ? trust_tier + ' (' + trust_suffix + ')' : trust_tier
    string yield_text = yield_inverted ? ' · Yield INVERTED' : ''
    string sector_text = sector_leading != '' ? sector_leading : '—'
    string breaking_text = breaking_news ? ' · ⚡ BREAKING' : ''
    string news_depth_text = high_impact_count > 5 ? ' · ' + str.tostring(high_impact_count) + ' high-impact' : ''
    'Action: ' + action_display + '\nBias: ' + bias_display + '\nConfidence: ' + trade_threshold_text + '\nTrust: ' + trust_display + '\nVIX: ' + str.tostring(vix_level, '#.##') + '\nTone: ' + tone_text + breaking_text + news_depth_text + '\nMarket: ' + market_event + yield_text + '\nSector: ' + sector_text + '\nProvider: ' + provider_state + '\n' + u.universe_status_badge(universe_status_code) + '\n' + u.universe_status_banner(universe_status_code) + '\nWhy now: ' + why_now + '\nMain blocker: ' + main_risk + '\nData: ' + asof_display

export resolve_core_alert_action_name(string event_name) =>
    string action_name = 'WAIT'
    string event_name_upper = str.upper(event_name)
    if str.contains(event_name_upper, 'INVALID')
        action_name := 'BLOCKED'
    else if str.contains(event_name_upper, 'STRICT') or str.contains(event_name_upper, 'BEST')
        action_name := 'ENTER LONG'
    else if str.contains(event_name_upper, 'READY')
        action_name := 'READY LONG'
    else if str.contains(event_name_upper, 'CONFIRM') or str.contains(event_name_upper, 'ARM') or str.contains(event_name_upper, 'WATCH')
        action_name := 'PREPARE LONG'
    action_name

