{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skipp-algo.local/spec/smc_structure_artifact.schema.json",
  "title": "SmcStructureArtifact",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "required": ["schema_version", "generated_at", "source", "structure_coverage", "entries"]
    },
    {
      "required": ["schema_version", "generated_at", "symbol", "timeframe", "source", "coverage", "structure"]
    }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "number"
    },
    "producer": {
      "type": "object",
      "required": ["name", "primary_reference", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "primary_reference": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "symbol": { "type": "string", "minLength": 1 },
    "timeframe": { "type": "string", "enum": ["5m", "15m", "1H", "4H", "1D"] },
    "source": {
      "type": "object",
      "required": ["sheet", "event_logic"],
      "additionalProperties": false,
      "properties": {
        "workbook_path": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "canonical_upstream": { "type": "string", "minLength": 1 },
        "sheet": { "type": "string", "const": "daily_bars" },
        "timeframe": { "type": "string", "enum": ["5m", "15m", "1H", "4H", "1D"] },
        "event_logic": { "type": "string", "minLength": 1 },
        "structure_profile": { "type": "string", "minLength": 1 },
        "event_logic_version": { "type": "string", "minLength": 1 }
      }
    },
    "structure_coverage": {
      "type": "string",
      "enum": ["full", "partial", "none"]
    },
    "coverage_mode": {
      "type": "string",
      "enum": ["full", "partial", "none"]
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "event_evidence": {
      "type": "object",
      "required": ["last_event", "trend_state"],
      "additionalProperties": true,
      "properties": {
        "last_event": {
          "type": "string",
          "enum": ["bos_up", "bos_down", "choch_up", "choch_down", "range", "none"]
        },
        "trend_state": { "type": "integer", "enum": [-1, 0, 1] },
        "reference_close": { "type": "number" }
      }
    },
    "structure": {
      "$ref": "#/$defs/structure"
    },
    "auxiliary": {
      "$ref": "#/$defs/auxiliary"
    },
    "diagnostics": {
      "$ref": "#/$defs/diagnostics"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "timeframe", "asof_ts", "coverage", "structure", "event_evidence"],
        "additionalProperties": false,
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "timeframe": { "type": "string", "enum": ["5m", "15m", "1H", "4H", "1D"] },
          "asof_ts": { "type": "number" },
          "coverage": { "type": "string", "enum": ["full", "partial", "none"] },
          "coverage_detail": { "$ref": "#/$defs/coverage" },
          "event_evidence": { "$ref": "#/properties/event_evidence" },
          "structure": { "$ref": "#/$defs/structure" },
          "auxiliary": { "$ref": "#/$defs/auxiliary" },
          "diagnostics": { "$ref": "#/$defs/diagnostics" }
        }
      }
    }
  },
  "$defs": {
    "coverage": {
      "type": "object",
      "required": ["mode", "has_bos", "has_orderblocks", "has_fvg", "has_liquidity_sweeps"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["full", "partial", "none"] },
        "has_bos": { "type": "boolean" },
        "has_orderblocks": { "type": "boolean" },
        "has_fvg": { "type": "boolean" },
        "has_liquidity_sweeps": { "type": "boolean" }
      }
    },
    "structure": {
      "type": "object",
      "required": ["bos", "orderblocks", "fvg", "liquidity_sweeps"],
      "additionalProperties": false,
      "properties": {
        "bos": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "time", "price", "kind", "dir"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "time": { "type": "number" },
              "price": { "type": "number" },
              "kind": { "type": "string", "enum": ["BOS", "CHOCH"] },
              "dir": { "type": "string", "enum": ["UP", "DOWN"] },
              "source": { "type": "string", "minLength": 1 }
            }
          }
        },
        "orderblocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "low", "high", "dir", "valid"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "low": { "type": "number" },
              "high": { "type": "number" },
              "dir": { "type": "string", "enum": ["BULL", "BEAR"] },
              "valid": { "type": "boolean" },
              "anchor_ts": { "type": "number" },
              "source": { "type": "string", "minLength": 1 }
            }
          }
        },
        "fvg": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "low", "high", "dir", "valid"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "low": { "type": "number" },
              "high": { "type": "number" },
              "dir": { "type": "string", "enum": ["BULL", "BEAR"] },
              "valid": { "type": "boolean" },
              "anchor_ts": { "type": "number" },
              "source": { "type": "string", "minLength": 1 }
            }
          }
        },
        "liquidity_sweeps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "time", "price", "side"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "time": { "type": "number" },
              "price": { "type": "number" },
              "side": { "type": "string", "enum": ["BUY_SIDE", "SELL_SIDE"] },
              "source": { "type": "string", "minLength": 1 },
              "source_liquidity_id": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "auxiliary": {
      "type": "object",
      "required": ["liquidity_lines", "session_ranges", "session_pivots", "ipda_range", "htf_fvg_bias", "broken_fractal_signals"],
      "additionalProperties": false,
      "properties": {
        "liquidity_lines": { "type": "array" },
        "session_ranges": { "type": "array" },
        "session_pivots": { "type": "array" },
        "ipda_range": { "type": "object", "additionalProperties": true },
        "htf_fvg_bias": { "type": "object", "additionalProperties": true },
        "broken_fractal_signals": { "type": "array" }
      }
    },
    "diagnostics": {
      "type": "object",
      "required": ["structure_profile_used", "event_logic_version", "counts", "warnings", "notes"],
      "additionalProperties": true,
      "properties": {
        "structure_profile_used": { "type": "string", "minLength": 1 },
        "event_logic_version": { "type": "string", "minLength": 1 },
        "counts": {
          "type": "object",
          "required": ["bos", "orderblocks", "fvg", "liquidity_sweeps", "liquidity_lines", "session_ranges", "session_pivots", "broken_fractal_signals"],
          "additionalProperties": false,
          "properties": {
            "bos": { "type": "integer", "minimum": 0 },
            "orderblocks": { "type": "integer", "minimum": 0 },
            "fvg": { "type": "integer", "minimum": 0 },
            "liquidity_sweeps": { "type": "integer", "minimum": 0 },
            "liquidity_lines": { "type": "integer", "minimum": 0 },
            "session_ranges": { "type": "integer", "minimum": 0 },
            "session_pivots": { "type": "integer", "minimum": 0 },
            "broken_fractal_signals": { "type": "integer", "minimum": 0 }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
