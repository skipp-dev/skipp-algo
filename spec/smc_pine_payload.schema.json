{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skipp-algo.local/spec/smc_pine_payload.schema.json",
  "title": "SmcPinePayload",
  "type": "object",
  "required": [
    "symbol",
    "timeframe",
    "generated_at",
    "schema_version",
    "product_cut",
    "structure_coverage",
    "bos",
    "orderblocks",
    "fvg",
    "liquidity_sweeps"
  ],
  "additionalProperties": true,
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "timeframe": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "number" },
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "product_cut": {
      "type": "object",
      "required": ["manifestVersion", "source", "artifactPath", "mainlineSurfaceFiles", "litePrimaryFiles", "proPrimaryFiles", "companionOperatorOnlyFiles", "internalFiles", "legacyFiles", "surfaceRoles", "contracts", "preflightScopes", "deprecatedFieldPolicy"],
      "additionalProperties": true,
      "properties": {
        "manifestVersion": { "type": "integer", "minimum": 1 },
        "source": { "type": "string", "minLength": 1 },
        "artifactPath": { "type": "string", "minLength": 1 },
        "mainlineSurfaceFiles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "litePrimaryFiles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "proPrimaryFiles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "companionOperatorOnlyFiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "internalFiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "legacyFiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "surfaceRoles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file", "script_name", "surface_role", "contract_tier", "consumer_role", "validation_target", "notes"],
            "additionalProperties": true,
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "script_name": { "type": "string", "minLength": 1 },
              "surface_role": { "type": "string", "enum": ["lite_primary", "pro_primary", "companion_operator_only", "internal", "legacy"] },
              "contract_tier": { "type": "string", "enum": ["lite_and_pro", "pro", "execution", "internal", "legacy"] },
              "consumer_role": { "type": "string", "enum": ["producer", "dashboard_companion", "execution_wrapper", "overlay_companion", "context_companion", "setup_utility", "confluence_hub", "mobile_companion", "bridge", "legacy_monolith", "legacy_split", "exit_companion"] },
              "validation_target": { "type": "boolean" },
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "contracts": {
          "type": "object",
          "required": ["engine", "executable", "liteSurface", "lite", "proOnly", "dashboardBindings", "strategyBindings"],
          "additionalProperties": false,
          "properties": {
            "engine": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "executable": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "liteSurface": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "lite": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "proOnly": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "dashboardBindings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "strategyBindings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          }
        },
        "preflightScopes": {
          "type": "object",
          "required": ["smcCoreDashboard", "smcMainline", "smcDecisionFirst"],
          "additionalProperties": false,
          "properties": {
            "smcCoreDashboard": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["file", "scriptName", "checkInputs", "addToChart"],
                "additionalProperties": false,
                "properties": {
                  "file": { "type": "string", "minLength": 1 },
                  "scriptName": { "type": "string", "minLength": 1 },
                  "checkInputs": { "type": "boolean" },
                  "addToChart": { "type": "boolean" },
                  "minInputs": { "type": "integer", "minimum": 0 },
                  "savedScriptName": { "type": "string", "minLength": 1 },
                  "bindingContractKey": { "type": "string", "enum": ["dashboardBindings", "strategyBindings"] },
                  "bindingContractName": { "type": "string", "minLength": 1 },
                  "bindingConsumerRole": { "type": "string", "enum": ["dashboard_companion", "execution_wrapper"] },
                  "bindingContractLabels": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "bindingLabelGroups": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["label", "group", "groupTitle"],
                      "additionalProperties": false,
                      "properties": {
                        "label": { "type": "string", "minLength": 1 },
                        "group": { "type": "string", "minLength": 1 },
                        "groupTitle": { "type": "string", "minLength": 1 },
                        "tier": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            },
            "smcMainline": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["file", "scriptName", "checkInputs", "addToChart"],
                "additionalProperties": false,
                "properties": {
                  "file": { "type": "string", "minLength": 1 },
                  "scriptName": { "type": "string", "minLength": 1 },
                  "checkInputs": { "type": "boolean" },
                  "addToChart": { "type": "boolean" },
                  "minInputs": { "type": "integer", "minimum": 0 },
                  "savedScriptName": { "type": "string", "minLength": 1 },
                  "bindingContractKey": { "type": "string", "enum": ["dashboardBindings", "strategyBindings"] },
                  "bindingContractName": { "type": "string", "minLength": 1 },
                  "bindingConsumerRole": { "type": "string", "enum": ["dashboard_companion", "execution_wrapper"] },
                  "bindingContractLabels": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "bindingLabelGroups": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["label", "group", "groupTitle"],
                      "additionalProperties": false,
                      "properties": {
                        "label": { "type": "string", "minLength": 1 },
                        "group": { "type": "string", "minLength": 1 },
                        "groupTitle": { "type": "string", "minLength": 1 },
                        "tier": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            },
            "smcDecisionFirst": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["file", "scriptName", "checkInputs", "addToChart"],
                "additionalProperties": false,
                "properties": {
                  "file": { "type": "string", "minLength": 1 },
                  "scriptName": { "type": "string", "minLength": 1 },
                  "checkInputs": { "type": "boolean" },
                  "addToChart": { "type": "boolean" },
                  "minInputs": { "type": "integer", "minimum": 0 },
                  "savedScriptName": { "type": "string", "minLength": 1 },
                  "bindingContractKey": { "type": "string", "enum": ["dashboardBindings", "strategyBindings"] },
                  "bindingContractName": { "type": "string", "minLength": 1 },
                  "bindingConsumerRole": { "type": "string", "enum": ["dashboard_companion", "execution_wrapper"] },
                  "bindingContractLabels": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "bindingLabelGroups": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["label", "group", "groupTitle"],
                      "additionalProperties": false,
                      "properties": {
                        "label": { "type": "string", "minLength": 1 },
                        "group": { "type": "string", "minLength": 1 },
                        "groupTitle": { "type": "string", "minLength": 1 },
                        "tier": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "deprecatedFieldPolicy": {
          "type": "object",
          "required": ["mode", "preferredFieldVersion", "extensionAllowed", "deprecatedGroups"],
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "const": "compatibility_only" },
            "preferredFieldVersion": { "type": "string", "minLength": 1 },
            "extensionAllowed": { "type": "boolean", "const": false },
            "sunset_date": { "type": "string", "minLength": 1 },
            "sunset_action": { "type": "string", "minLength": 1 },
            "deprecatedGroups": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "source_plan": {
      "type": "object",
      "required": ["structure", "volume", "technical", "news"],
      "additionalProperties": false,
      "properties": {
        "structure": { "type": "string", "minLength": 1 },
        "volume": { "type": "string", "minLength": 1 },
        "technical": { "type": "string", "minLength": 1 },
        "news": { "type": "string", "minLength": 1 },
        "structure_resolution_mode": { "type": "string" }
      }
    },
    "structure_status": {
      "type": "object",
      "required": ["selected_structure_source", "selected_structure_mode", "selected_category_coverage", "selected_missing_categories"],
      "additionalProperties": true,
      "properties": {
        "selected_structure_source": { "type": "string", "minLength": 1 },
        "selected_structure_mode": { "type": "string", "enum": ["full", "partial", "none"] },
        "selected_category_coverage": {
          "type": "object",
          "required": ["bos", "choch", "orderblocks", "fvg", "liquidity_sweeps"],
          "additionalProperties": false,
          "properties": {
            "bos": { "type": "boolean" },
            "choch": { "type": "boolean" },
            "orderblocks": { "type": "boolean" },
            "fvg": { "type": "boolean" },
            "liquidity_sweeps": { "type": "boolean" }
          }
        },
        "selected_missing_categories": {
          "type": "array",
          "items": { "type": "string", "enum": ["bos", "choch", "orderblocks", "fvg", "liquidity_sweeps"] }
        }
      }
    },
    "structure_coverage": {
      "type": "object",
      "required": ["available_categories", "missing_categories", "has_bos", "has_orderblocks", "has_fvg", "has_liquidity_sweeps"],
      "additionalProperties": false,
      "properties": {
        "available_categories": {
          "type": "array",
          "items": { "type": "string", "enum": ["bos", "choch", "orderblocks", "fvg", "liquidity_sweeps"] }
        },
        "missing_categories": {
          "type": "array",
          "items": { "type": "string", "enum": ["bos", "choch", "orderblocks", "fvg", "liquidity_sweeps"] }
        },
        "has_bos": { "type": "boolean" },
        "has_orderblocks": { "type": "boolean" },
        "has_fvg": { "type": "boolean" },
        "has_liquidity_sweeps": { "type": "boolean" }
      }
    },
    "trust_summary": {
      "type": "object",
      "required": ["trust_state", "provider_state", "main_blocker", "measurement_status", "measurement_events", "measurement_family_count", "measurement_quality_tier", "measurement_quality_score", "measurement_warning_count", "provider_health_issue_count", "structure_state", "structure_missing_categories", "missing_domains", "stale_domains", "quality_recommendation", "quality_guardrail", "quality_recommendation_reason"],
      "additionalProperties": false,
      "properties": {
        "trust_state": { "type": "string", "enum": ["high", "guarded", "degraded", "insufficient"] },
        "provider_state": { "type": "string", "enum": ["ok", "degraded", "unavailable"] },
        "main_blocker": { "type": "string" },
        "measurement_status": { "type": "string" },
        "measurement_events": { "type": "integer", "minimum": 0 },
        "measurement_family_count": { "type": "integer", "minimum": 0 },
        "measurement_quality_tier": { "type": "string", "enum": ["high", "good", "ok", "low", "unknown"] },
        "measurement_quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "measurement_warning_count": { "type": "integer", "minimum": 0 },
        "provider_health_issue_count": { "type": "integer", "minimum": 0 },
        "structure_state": { "type": "string", "enum": ["full", "partial", "none", "unknown"] },
        "structure_missing_categories": { "type": "array", "items": { "type": "string", "enum": ["bos", "choch", "orderblocks", "fvg", "liquidity_sweeps"] } },
        "missing_domains": { "type": "array", "items": { "type": "string", "enum": ["volume", "technical", "news"] } },
        "stale_domains": { "type": "array", "items": { "type": "string", "enum": ["volume", "technical", "news"] } },
        "quality_recommendation": { "type": "string", "enum": ["trusted", "observable", "limited", "insufficient"] },
        "quality_guardrail": { "type": "string" },
        "quality_recommendation_reason": { "type": "string" }
      }
    },
    "bos": { "type": "array" },
    "orderblocks": { "type": "array" },
    "fvg": { "type": "array" },
    "liquidity_sweeps": { "type": "array" }
  }
}
