{
  "name": "skipp-algo-automation",
  "private": true,
  "type": "module",
  "scripts": {
    "smc:verify-micro-publish": "python3 scripts/verify_smc_micro_publish_contract.py",
    "tv:publish-micro-library": "tsx scripts/tv_publish_micro_library.ts",
    "tv:storage-state": "tsx scripts/create_tradingview_storage_state.ts",
    "tv:profile-login": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/create_tradingview_storage_state.ts --persistent-profile-dir automation/tradingview/auth/chromium-profile",
    "tv:preflight": "tsx scripts/tv_preflight.ts",
    "tv:smoke-readonly": "tsx scripts/tv_preflight.ts --execution-mode readonly",
    "tv:test": "tsx --test automation/tradingview/tests/**/*.test.ts",
    "tsc:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "playwright": "^1.55.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}