{
  "name": "skipp-algo-automation",
  "private": true,
  "type": "module",
  "scripts": {
    "smc:verify-micro-publish": "python3 scripts/verify_smc_micro_publish_contract.py",
    "smc:ci-health-gates": "python3 scripts/run_smc_ci_health_checks.py --output -",
    "smc:pre-release-refresh": "python3 scripts/run_smc_pre_release_artifact_refresh.py --output -",
    "smc:release-gates": "python3 scripts/run_smc_release_gates.py --output -",
    "smc:collect-gate-evidence": "python3 scripts/collect_smc_gate_evidence.py --output -",
    "smc:live-news-snapshot": "python3 scripts/export_smc_live_news_snapshot.py",
    "tv:publish-lifecycle-library": "tsx scripts/tv_publish_lifecycle_library.ts",
    "tv:publish-lifecycle-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_lifecycle_library.ts",
    "tv:publish-observability-library": "tsx scripts/tv_publish_observability_library.ts",
    "tv:publish-observability-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_observability_library.ts",
    "tv:publish-core-types-library": "tsx scripts/tv_publish_core_types_library.ts",
    "tv:publish-core-types-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_core_types_library.ts",
    "tv:publish-draw-library": "tsx scripts/tv_publish_draw_library.ts",
    "tv:publish-draw-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_draw_library.ts",
    "tv:publish-utils-library": "tsx scripts/tv_publish_utils_library.ts",
    "tv:publish-utils-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_utils_library.ts",
    "tv:publish-profile-engine-library": "tsx scripts/tv_publish_profile_engine_library.ts",
    "tv:publish-profile-engine-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_profile_engine_library.ts",
    "tv:publish-context-resolvers-library": "tsx scripts/tv_publish_context_resolvers_library.ts",
    "tv:publish-context-resolvers-library:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_publish_context_resolvers_library.ts",
    "tv:publish-micro-library": "tsx scripts/tv_publish_micro_library.ts",
    "tv:publish-overlay-library": "tsx scripts/tv_publish_overlay_library.ts",
    "tv:storage-state": "tsx scripts/create_tradingview_storage_state.ts",
    "tv:auth-security": "python3 scripts/check_tradingview_storage_state_security.py",
    "tv:profile-login": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/create_tradingview_storage_state.ts --persistent-profile-dir automation/tradingview/auth/chromium-profile",
    "tv:preflight": "tsx scripts/tv_preflight.ts",
    "tv:preflight:profile": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_preflight.ts",
    "tv:preflight:core-dashboard": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_preflight.ts --config automation/tradingview/preflight-core-dashboard.json",
    "tv:preflight:smc-mainline": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_preflight.ts --config automation/tradingview/preflight-smc-mainline.json",
    "tv:preflight:decision-first": "TV_PERSISTENT_PROFILE_DIR=automation/tradingview/auth/chromium-profile tsx scripts/tv_preflight.ts --config automation/tradingview/preflight-decision-first.json",
    "tv:smoke-readonly": "tsx scripts/tv_preflight.ts --execution-mode readonly",
    "tv:test": "tsx --test automation/tradingview/tests/**/*.test.ts",
    "tv:verify": "bash scripts/tv_verify_publish_chain.sh",
    "tv:verify:report-only": "bash scripts/tv_verify_publish_chain.sh --report-only",
    "tv:evidence-summary": "python3 scripts/tv_publish_evidence_summary.py",
    "node:bootstrap-worktree": "bash scripts/bootstrap_node_worktree.sh",
    "tsc:check": "tsc --noEmit"
  },
  "dependencies": {
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "playwright": "^1.55.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  }
}
