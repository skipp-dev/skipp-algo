bool internal_bull_choch_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? internal_bull_choch_alert : barstate.isconfirmed and internal_bull_choch_alert
bool internal_bear_bos_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? internal_bear_bos_alert : barstate.isconfirmed and internal_bear_bos_alert
bool internal_bear_choch_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? internal_bear_choch_alert : barstate.isconfirmed and internal_bear_choch_alert

bool internal_structure_break_detected = internal_bull_bos_alert or internal_bull_choch_alert or internal_bear_bos_alert or internal_bear_choch_alert
internal_display_trend = not na(ta.barssince(internal_structure_break_detected)) ? internal_trend : 0

var color bull_internal_css = color.new(bull_css, 78)
var color bear_internal_css = color.new(bear_css, 78)

