//@version=6

indicator("Smart Money Concepts (Highly Advanced)", "SMC++", overlay = true, max_bars_back = 500, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

import preuss_steffen/smc_core_types/1 as ct
import preuss_steffen/smc_utils/1 as u
import preuss_steffen/smc_draw/1 as d

// Safe refactor notes:
// - Core BOS/CHoCH, Order Block and FVG logic is intentionally unchanged.
// - Improvements are limited to readability, defensive guards around draw/delete paths,
//   clearer configuration naming and more descriptive alerts.
// - The Order Block lifecycle remains: tracking -> extension -> awaiting confirmation -> confirmed/broken.
// - Shared enums (ct.SmcLibMovingAverage, ct.LevelBreakMode, ct.SignalMode) live in smc_core_types (ct).
// - Generic helpers (in_range, format_level, edge, ...) live in smc_utils (u).
// - Draw wrappers (SmcLabel, SmcLine, SmcBox, factories, methods) live in smc_draw (d).

// --------------------------------------------------
// Embedded Library Subset (remaining local helpers)
// --------------------------------------------------

// ATR helper
smc_lib_atr(simple int length) =>
    float atr_value = ta.atr(length)
    float tr_cum = ta.cum(ta.tr(true))
    if bar_index < length
        atr_value := tr_cum / (bar_index + 1)
    atr_value

// Moving-average selector helpers used by DDVI

smc_lib_ehma(float source, simple int length) =>
    int half_length = math.max(1, int(math.round(length / 2.0)))
    int sqrt_length = math.max(1, int(math.round(math.sqrt(length))))
    ta.ema(2 * ta.ema(source, half_length) - ta.ema(source, length), sqrt_length)

smc_lib_thma(float source, simple int length) =>
    int len_sixth = math.max(1, int(math.round(length / 6.0)))
    int len_quarter = math.max(1, int(math.round(length / 4.0)))
    int len_half = math.max(1, int(math.round(length / 2.0)))
    ta.wma(ta.wma(source, len_sixth) * 3 - ta.wma(source, len_quarter) - ta.wma(source, len_half), len_half)

smc_lib_get_ma(simple ct.SmcLibMovingAverage select_ma = ct.SmcLibMovingAverage.SMA, float source, simple int length) =>
    switch select_ma
        ct.SmcLibMovingAverage.EMA => ta.ema(source, length)
        ct.SmcLibMovingAverage.RMA => ta.rma(source, length)
        ct.SmcLibMovingAverage.WMA => ta.wma(source, length)
        ct.SmcLibMovingAverage.VWMA => ta.vwma(source, length)
        ct.SmcLibMovingAverage.HMA => ta.hma(source, length)
        ct.SmcLibMovingAverage.EHMA => smc_lib_ehma(source, length)
        ct.SmcLibMovingAverage.THMA => smc_lib_thma(source, length)
        => ta.sma(source, length)

smc_lib_bb(float source, simple int length, float mult, simple ct.SmcLibMovingAverage select_ma) =>
    float base = smc_lib_get_ma(select_ma, source, length)
    float dev = mult * ta.stdev(source, length)
    [base, base + dev, base - dev]

// DMI helper used by DDVI
smc_lib_dmi(simple int di_length = 17, simple int adx_smoothing = 14) =>
    ta.dmi(di_length, adx_smoothing)

// Divergence helper used by DDVI
smc_lib_detect_divergence(float osc, simple int pivot_confirmation_bars_left = 5, simple int pivot_confirmation_bars_right = 3, simple int pivot_min_x_distance = 5, simple int pivot_max_x_distance = 50, series float ref_low = low, series float ref_high = high, simple int pivot_min_y_distance_len = 14, simple float pivot_min_y_distance_dev_mult = 0.1, simple float pivot_min_y_distance_atr_mult = 0.1) =>
    bool osc_pivot_l = not na(ta.pivotlow(osc, pivot_confirmation_bars_left, pivot_confirmation_bars_right))
    bool osc_pivot_h = not na(ta.pivothigh(osc, pivot_confirmation_bars_left, pivot_confirmation_bars_right))
    float pivot_osc_value = osc[pivot_confirmation_bars_right]
    float osc_dev_value = nz(ta.dev(pivot_osc_value, pivot_min_y_distance_len), 0.0) * pivot_min_y_distance_dev_mult
    float price_atr_value = smc_lib_atr(pivot_min_y_distance_len) * pivot_min_y_distance_atr_mult
    var int osc_prev_l_idx = na
    var float osc_prev_l_value = na
    var float price_prev_l = na
    var int osc_prev_h_idx = na
    var float osc_prev_h_value = na
    var float price_prev_h = na

    if barstate.isconfirmed and (osc_pivot_h or osc_pivot_l)
        float prev_pivot_value = osc_pivot_h ? osc_prev_h_value : osc_prev_l_value
        float prev_pivot_price = osc_pivot_h ? price_prev_h : price_prev_l
        float new_pivot_value = osc[pivot_confirmation_bars_right]
        float new_pivot_price = osc_pivot_h ? ref_high[pivot_confirmation_bars_right] : ref_low[pivot_confirmation_bars_right]
        int new_pivot_distance = osc_pivot_h ? bar_index - osc_prev_h_idx : bar_index - osc_prev_l_idx
        bool has_prev_pivot = osc_pivot_h ? not na(osc_prev_h_idx) and not na(prev_pivot_value) and not na(prev_pivot_price) : not na(osc_prev_l_idx) and not na(prev_pivot_value) and not na(prev_pivot_price)

        if osc_pivot_h
            osc_prev_h_idx := bar_index
            osc_prev_h_value := new_pivot_value
            price_prev_h := new_pivot_price
        if osc_pivot_l
            osc_prev_l_idx := bar_index
            osc_prev_l_value := new_pivot_value
            price_prev_l := new_pivot_price

        int mode = has_prev_pivot ? new_pivot_value < prev_pivot_value - osc_dev_value ? -1 : new_pivot_value > prev_pivot_value + osc_dev_value ? 1 : 0 : 0
        int mode_p = has_prev_pivot ? new_pivot_price < prev_pivot_price - price_atr_value ? -1 : new_pivot_price > prev_pivot_price + price_atr_value ? 1 : 0 : 0
        bool x_distance_in_range = has_prev_pivot and new_pivot_distance >= pivot_min_x_distance and new_pivot_distance <= pivot_max_x_distance

        bool strong_bull = osc_pivot_l and x_distance_in_range and mode == 1 and mode_p == -1
        bool medium_bull = osc_pivot_l and x_distance_in_range and mode == 1 and mode_p == 0
        bool weak_bull = osc_pivot_l and x_distance_in_range and mode == 0 and mode_p == -1
        bool hidden_bull = osc_pivot_l and x_distance_in_range and mode == -1 and mode_p == 1
        bool strong_bear = osc_pivot_h and x_distance_in_range and mode == -1 and mode_p == 1
        bool medium_bear = osc_pivot_h and x_distance_in_range and mode == -1 and mode_p == 0
        bool weak_bear = osc_pivot_h and x_distance_in_range and mode == 0 and mode_p == 1
        bool hidden_bear = osc_pivot_h and x_distance_in_range and mode == 1 and mode_p == -1
        [strong_bull, strong_bear, medium_bull, medium_bear, weak_bull, weak_bear, hidden_bull, hidden_bear, osc_pivot_h, osc_pivot_l]
    else
        [false, false, false, false, false, false, false, false, osc_pivot_h, osc_pivot_l]

// Embedded profile engine subset replacing the former lib_profile dependency.
type Bucket
    varip int idx
    varip float value
    varip float top
    varip float btm
    varip float center
    varip float fraction
    d.SmcLine plot_bucket_line = na

method update(Bucket this, float top, float bottom, float value, float fraction) =>
    rounded_top = math.round_to_mintick(top)
    rounded_bottom = math.round_to_mintick(bottom)
    rounded_fraction = math.round(fraction, 2)
    this.top := rounded_top
    this.btm := rounded_bottom
    this.center := math.avg(rounded_top, rounded_bottom)
    this.value := value
    this.fraction := rounded_fraction
    this

method update(Bucket this, float value, float fraction) =>
    this.value := value
    this.fraction := math.round(fraction, 2)
    this

type ProfileConfig
    bool show_poc = true
    bool show_profile = false
    bool show_va = false
    bool show_background = false
    bool show_labels = false
    bool show_price_levels = false
    bool extend = false

    string poc_label_text = 'POC'
    d.LineArgs args_poc_line = na
    d.LineArgs args_vah_line = na
    d.LineArgs args_val_line = na
    d.LabelArgs args_poc_label = na
    d.LineArgs args_profile_line = na
    d.BoxArgs args_profile_bg = na
    bool initialized = false

method init(ProfileConfig this) =>
    if na(this) ? false : not this.initialized
        if na(this.args_poc_line)
            this.args_poc_line := d.LineArgs.new(color.orange, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_vah_line)
            this.args_vah_line := d.LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_val_line)
            this.args_val_line := d.LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_poc_label)
            this.args_poc_label := d.LabelArgs.new(color.orange, #00000000, xloc = xloc.bar_index, style = label.style_label_left)
        if na(this.args_profile_line)
            this.args_profile_line := d.LineArgs.new(color.rgb(120, 123, 134, 40), line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_profile_bg)
            this.args_profile_bg := d.BoxArgs.new(#00000000, bg_color = color.rgb(120, 123, 134, 92), xloc = xloc.bar_index)
        this.initialized := true
    this

type Profile
    int id
    int resolution
    float vah_threshold_pc
    float val_threshold_pc
    varip float[] data_opens
    varip float[] data_highs
    varip float[] data_lows
    varip float[] data_closes
    varip float[] data_values
    varip float h = na
    varip float l = na
    varip float total = 0
    varip float total_up = 0
    varip float total_down = 0
    Bucket[] buckets
    varip int poc_bucket_index = na
    varip int vah_bucket_index = na
    varip int val_bucket_index = na
    varip float poc = na
    varip float vah = na
    varip float val = na
    d.SmcLine plot_poc = na
    d.SmcLine plot_vah = na
    d.SmcLine plot_val = na
    d.SmcLabel plot_poc_label = na
    d.SmcBox plot_profile_bg = na
    bool hidden = false

method apply_style(Profile this, ProfileConfig args) =>
    if not na(this) and not na(args)
        if not na(this.plot_poc)
            this.plot_poc.apply_style(args.args_poc_line)
        if not na(this.plot_vah)
            this.plot_vah.apply_style(args.args_vah_line)
        if not na(this.plot_val)
            this.plot_val.apply_style(args.args_val_line)
        if not na(this.plot_poc_label)
            this.plot_poc_label.apply_style(args.args_poc_label)
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.apply_style(args.args_profile_bg, d.BoxTextArgs.new())
    this

method delete(Profile this) =>
    if not na(this)
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.delete()
                    bucket.plot_bucket_line := na
        if not na(this.plot_poc)
            this.plot_poc.delete()
            this.plot_poc := na
        if not na(this.plot_vah)
            this.plot_vah.delete()
            this.plot_vah := na
        if not na(this.plot_val)
            this.plot_val.delete()
            this.plot_val := na
        if not na(this.plot_poc_label)
            this.plot_poc_label.delete()
            this.plot_poc_label := na
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.delete()
            this.plot_profile_bg := na
        this.hidden := false
    this

method hide(Profile this) =>
    if na(this) ? false : not this.hidden
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.hide()
        if not na(this.plot_poc)
            this.plot_poc.hide()
        if not na(this.plot_vah)
            this.plot_vah.hide()
        if not na(this.plot_val)
            this.plot_val.hide()
        if not na(this.plot_poc_label)
            this.plot_poc_label.hide()
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.hide()
        this.hidden := true
    this

method init(Profile this, bool update_buckets = false) =>
    if not na(this)
        create_buckets = na(this.buckets)
        if create_buckets or update_buckets
            float bucket_size = this.resolution > 0 ? (this.h - this.l) / this.resolution : 0
            if create_buckets
                this.buckets := array.new<Bucket>(this.resolution)
            for i = 0 to this.resolution - 1
                float bucket_bottom = this.l + i * bucket_size
                float bucket_top = bucket_bottom + bucket_size
                if create_buckets
                    this.buckets.set(i, Bucket.new(i, 0, bucket_top, bucket_bottom, math.avg(bucket_top, bucket_bottom), 0))
                else
                    this.buckets.get(i).update(bucket_top, bucket_bottom, 0, 0)
    this

method calculate(Profile this, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    int range_count = array.size(this.data_values)
    if not na(this.buckets)
        this.poc_bucket_index := na
        this.val_bucket_index := na
        this.vah_bucket_index := na
        this.poc := na
        this.val := na
        this.vah := na
        this.total_up := 0
        this.total_down := 0
        float poc_volume = 0
        float sum_volume_up = 0
        float sum_volume_down = 0
        int range_count_opens = na(this.data_opens) ? 0 : array.size(this.data_opens)
        int range_count_closes = na(this.data_closes) ? 0 : array.size(this.data_closes)

        if range_count <= 0 or this.total <= 0
            for i = 0 to this.resolution - 1
                this.buckets.get(i).update(0, 0)
        else
            for i = 0 to this.resolution - 1
                Bucket bucket = this.buckets.get(i)
                float bucket_value = 0
                for j = 0 to range_count - 1
                    float range_value = array.get(this.data_values, j)
                    float range_high = array.get(this.data_highs, j)
                    float range_low = array.get(this.data_lows, j)
                    float range_size = range_high - range_low
                    float overlap = math.max(0, math.min(range_high, bucket.top) - math.max(range_low, bucket.btm))
                    if (i == 0 or 0 < use_open_close_data_for_ranges_shorter_than_bars) and j < range_count_opens and j < range_count_closes
                        float range_open = array.get(this.data_opens, j)
                        float range_close = array.get(this.data_closes, j)
                        if i == 0
                            if range_open < range_close
                                sum_volume_up += range_value
                            else
                                sum_volume_down += range_value
                        if j < use_open_close_data_for_ranges_shorter_than_bars
                            overlap += math.max(0, math.min(math.max(range_open, range_close), bucket.top) - math.max(math.min(range_open, range_close), bucket.btm)) / 2
                            range_size += math.abs(range_open - range_close) / 2
                    float range_value_fraction = range_size > 0 ? overlap / range_size : (overlap > 0 ? 1 : 0)
                    bucket_value += range_value_fraction * range_value
                bucket.update(bucket_value, bucket_value / this.total)
                if bucket_value > 0 and (na(this.poc_bucket_index) or bucket_value >= poc_volume)
                    poc_volume := bucket_value
                    this.poc_bucket_index := i
                    this.poc := bucket.center
            if not na(this.poc_bucket_index)
                int left_va = this.poc_bucket_index
                int right_va = this.poc_bucket_index
                float va_sum = this.buckets.get(this.poc_bucket_index).value
                float va_target = this.total * math.max(this.vah_threshold_pc - this.val_threshold_pc, 0) / 100.0

                while va_sum < va_target and (left_va > 0 or right_va < this.resolution - 1)
                    float next_left = left_va > 0 ? this.buckets.get(left_va - 1).value : -1
                    float next_right = right_va < this.resolution - 1 ? this.buckets.get(right_va + 1).value : -1

                    if next_left > next_right
                        left_va -= 1
                        va_sum += next_left
                    else
                        right_va += 1
                        va_sum += next_right

                this.val_bucket_index := left_va
                this.vah_bucket_index := right_va
                this.val := this.buckets.get(left_va).center
                this.vah := this.buckets.get(right_va).center
            this.total_up := sum_volume_up
            this.total_down := sum_volume_down
    this

create_profile(float[] opens, float[] highs, float[] lows, float[] closes, float[] values, int resolution = 25, float vah_pc = 80, float val_pc = 20, int idx = bar_index, bool init_calculated = true, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    profile = Profile.new(idx, resolution, vah_pc, val_pc, opens, highs, lows, closes, values, h = highs.max(), l = lows.min(), total = values.sum())
    profile.init(update_buckets = true)
    if init_calculated
        profile.calculate(use_open_close_data_for_ranges_shorter_than_bars)
    profile

method update(Profile this, float[] opens = na, float[] highs = na, float[] lows = na, float[] closes = na, float[] values = na) =>
    if not na(this)
        recalculation_required = false
        layout_required = false
        if not na(opens)
            this.data_opens := opens
            recalculation_required := true
        if not na(highs)
            this.data_highs := highs
            high_max = highs.max()
            layout_required := this.h != high_max
            this.h := high_max
            recalculation_required := true
        if not na(lows)
            this.data_lows := lows
            low_min = lows.min()
            layout_required := layout_required or this.l != low_min
            this.l := low_min
            recalculation_required := true
        if not na(closes)
            this.data_closes := closes
            recalculation_required := true
        if not na(values)
            this.data_values := values
            this.total := values.sum()
            recalculation_required := true
        if layout_required
            this.init(update_buckets = true)
        if recalculation_required or na(this.poc)
            this.calculate()
    this

method draw(Profile this, ProfileConfig config, int left = na, int right = na, bool extend_only = true, simple bool force_overlay = false, string poc_text_override = na) =>
    if na(this) ? false : na(this.buckets) ? false : this.buckets.size() > 0
        config.init()
        this.init()
        if config.show_background
            if na(this.plot_profile_bg)
                this.plot_profile_bg := d.create_box(left, this.h, right, this.l, config.args_profile_bg.xloc)
            else
                this.plot_profile_bg.left_top.update(left, this.h, config.args_profile_bg.xloc)
                this.plot_profile_bg.right_bottom.update(right, this.l, config.args_profile_bg.xloc)
            this.plot_profile_bg.draw(config.args_profile_bg, na, extend_only, force_overlay)
        if config.show_poc and not na(this.poc)
            if na(this.plot_poc)
                this.plot_poc := d.create_line(left, this.poc, right, this.poc, config.args_poc_line.xloc)
            else
                this.plot_poc.start.update(left, this.poc, config.args_poc_line.xloc)
                this.plot_poc.end.update(right, this.poc, config.args_poc_line.xloc)
            this.plot_poc.draw(config.args_poc_line, extend_only, force_overlay)
            if config.show_labels
                tooltip = str.format('{0} ({1})', na(poc_text_override) ? config.poc_label_text : poc_text_override, this.poc)
                txt = config.show_price_levels ? tooltip : na(poc_text_override) ? config.poc_label_text : poc_text_override
                if na(this.plot_poc_label)
                    this.plot_poc_label := d.create_label(d.create_point(right, this.poc, config.args_poc_label.xloc), txt, tooltip)
                else
                    this.plot_poc_label.point.update(right, this.poc, config.args_poc_label.xloc)
                    this.plot_poc_label.txt := txt
                    this.plot_poc_label.tooltip := tooltip
                this.plot_poc_label.draw(config.args_poc_label, force_overlay)
        if config.show_va and not na(this.vah) and not na(this.val)
            if na(this.plot_vah)
                this.plot_vah := d.create_line(left, this.vah, right, this.vah, config.args_vah_line.xloc)
            else
                this.plot_vah.start.update(left, this.vah, config.args_vah_line.xloc)
                this.plot_vah.end.update(right, this.vah, config.args_vah_line.xloc)
            this.plot_vah.draw(config.args_vah_line, extend_only, force_overlay)
            if na(this.plot_val)
                this.plot_val := d.create_line(left, this.val, right, this.val, config.args_val_line.xloc)
            else
                this.plot_val.start.update(left, this.val, config.args_val_line.xloc)
                this.plot_val.end.update(right, this.val, config.args_val_line.xloc)
            this.plot_val.draw(config.args_val_line, extend_only, force_overlay)
        this.hidden := false
    this

/////////////////////////////////////////////////////////////////////////////////
//#region    EMBEDDED SMC SUBSET
/////////////////////////////////////////////////////////////////////////////////

//-----------------------------------------------------------------------------
//Core structures and helpers
//-----------------------------------------------------------------------------

type OrderBlock
    int id
    int dir
    chart.point left_top
    chart.point right_bottom
    float break_price
    ct.LevelBreakMode break_mode = ct.LevelBreakMode.CLOSE
    
    float[] ltf_open
    float[] ltf_high
    float[] ltf_low
    float[] ltf_close
    float[] ltf_volume

    d.SmcBox plot
    Profile profile

    float quality_score                          = 0
    bool trailing                                = false
    bool extending                               = false
    bool awaiting_confirmation                   = false
    bool touched_break_price_before_confirmation = false
    bool soft_confirmed                          = false
    bool has_fvg_out                             = false
    bool has_big_candle                          = false
    bool hidden                                  = false
    bool broken                                  = false
    int  broken_time                             = na
    int  broken_index                            = na

type OrderBlockConfig
    bool show = true
    int show_last = 5
    bool show_id = false
    bool show_profile = true
    bool show_text = true
    bool show_fvg_out = true
    bool show_quality_score = false
    bool extend_until_broken = true

    d.BoxArgs args
    string txt = 'OB'
    d.BoxTextArgs txt_args
    bool use_profile = false
    ProfileConfig profile_config = na

method delete(OrderBlock this) =>
    if not na(this)
        if not na(this.plot)
            this.plot.delete()
            this.plot := na
        if not na(this.profile)
            this.profile.delete()
            this.profile := na
        this.hidden := false
    this

method delete(OrderBlock[] blocks) =>
    if not na(blocks)
        for block in blocks
            block.delete()
    blocks

create_ob(int id, int mode, int start_t, int start_i, float top, int end_t, int end_i, float bottom, float break_price = na, simple ct.LevelBreakMode break_mode = ct.LevelBreakMode.CLOSE) =>
    OrderBlock block = OrderBlock.new(id, mode,
     chart.point.new(start_t, start_i, top),
     chart.point.new(end_t, end_i, bottom),
     not na(break_price) ? break_price : mode == 1 ? top : bottom,
     break_mode,
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0)
     )

    float block_height = math.max(top - bottom, syminfo.mintick)
    float normalized_height = math.min(block_height / math.max(syminfo.mintick * 20, syminfo.mintick), 1.0)
    block.quality_score := math.max(0.0, math.min(1.0, 0.20 + normalized_height * 0.20))

    block

ob_quality_score(OrderBlock block) =>
    if na(block)
        0.0
    else
        float block_height = math.max(block.left_top.price - block.right_bottom.price, syminfo.mintick)
        float size_component = math.min(block_height / math.max(syminfo.mintick * 20, syminfo.mintick), 1.0)
        float score = 0.15
        score += size_component * 0.20
        score += block.has_fvg_out ? 0.20 : 0.0
        score += block.has_big_candle ? 0.15 : 0.0
        score += block.soft_confirmed ? 0.15 : 0.0
        score += not block.broken ? 0.10 : 0.0
        score += not na(block.profile) and block.profile.total > 0 ? 0.05 : 0.0
        math.max(0.0, math.min(1.0, score))

method align_to_profile(OrderBlock block, bool align_edge = false, bool align_break_price = false) =>
    if not na(block.profile) and block.profile.total > 0
        if align_edge and not na(block.profile.vah)
            block.left_top.price     := block.profile.vah
            block.right_bottom.price := block.profile.val
        if align_break_price and not na(block.profile.poc)
            block.break_price        := block.profile.poc
    block

method _create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if na(block.profile)
        block.profile := create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, block.left_top.index, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    else
        block.profile.update(opens, tops, bottoms, closes, values)
    block

method create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if barstate.isconfirmed and not na(block)
        block._create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    block

method create_profile(OrderBlock block, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    block.create_profile(block.ltf_open, block.ltf_high, block.ltf_low, block.ltf_close, block.ltf_volume, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)

resolve_confirmed_ob_break_price(bool align_edge_to_value_area, bool align_break_price_to_poc, float original_top, float original_bottom, float confirmed_top, float confirmed_bottom, float current_break_price) =>
    float resolved_break_price = current_break_price
    if not align_break_price_to_poc
        resolved_break_price := align_edge_to_value_area ? math.avg(confirmed_top, confirmed_bottom) : math.avg(original_top, original_bottom)
    resolved_break_price

method overlaps_range(OrderBlock this, float range_top = 0, float range_btm = 0) =>
    na(this) ? false : u.range_overlap(this.left_top.price, this.right_bottom.price, range_top, range_btm)

method any_overlaps(OrderBlock[] this, float range_top, float range_btm) =>
    found = false
    if not na(this)
        for i = this.size() - 1 to 0
            if this.get(i).overlaps_range(range_top, range_btm)
                found := true
                break
    found

method contains_id(OrderBlock[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for block in this
            if block.id == id
                found := true
                break
    found

method get_by_id(OrderBlock[] this, int id) =>
    OrderBlock found = na
    if not na(this) and not na(id)
        for block in this
            if block.id == id
                found := block
                break
    found

current_bar_right_time() =>
    barstate.isrealtime ? math.min(time_close, timenow) : time_close

effective_live_event_time(int event_time, int fallback_time) =>
    base_time = nz(event_time, fallback_time)
    barstate.isrealtime ? math.min(base_time, current_bar_right_time()) : base_time

method rendered_right_time(OrderBlock this, bool extend_until_broken = true) =>
    if na(this)
        na
    else
        int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
        extend_until_broken ? (this.broken ? effective_live_event_time(this.broken_time, base_right_time) : current_bar_right_time()) : base_right_time

method overlaps_window(OrderBlock this, int left_time, int right_time, bool extend_until_broken = true) =>
    if na(this)
        false
    else
        effective_right_time = this.rendered_right_time(extend_until_broken)
        effective_right_time >= left_time and this.left_top.time <= right_time

update_broken(int mode, OrderBlock[] tracking_blocks, OrderBlock[] broken_blocks, OrderBlock[] broken_blocks_new, simple ct.LevelBreakMode broken_by = ct.LevelBreakMode.HIGHLOW, int keep_broken_max = 5, OrderBlock[] discarded_buffer = na) =>
    bool broken_by_close = broken_by == ct.LevelBreakMode.CLOSE
    OrderBlock[] moved_blocks = array.new<OrderBlock>(0)
    
    broken_blocks_new.clear()
    
    tracking_size = tracking_blocks.size()
    if tracking_size > 0
        break_src = broken_by_close ? close : mode == 1 ? low : high
        
        for i = tracking_size - 1 to 0
            block = tracking_blocks.get(i)

            if broken_by != ct.LevelBreakMode.CLOSE or barstate.isconfirmed
                if mode == 1 ? block.break_price > break_src : block.break_price < break_src
                    block.broken       := true                    
                    block.broken_time  := time_close
                    block.broken_index := bar_index + 1
                    moved_blocks.unshift(block)
                    tracking_blocks.remove(i)

        for block in moved_blocks
            broken_blocks.push(block)
            broken_blocks_new.push(block)

        if keep_broken_max >= 0
            while broken_blocks.size() > keep_broken_max
                if not na(discarded_buffer)
                    discarded_buffer.push(broken_blocks.shift())
                else
                    broken_blocks.shift()

    true

method reset_tracking(OrderBlock this) =>
    this.ltf_high.clear()
    this.ltf_low.clear()
    this.ltf_open.clear()
    this.ltf_close.clear()
    this.ltf_volume.clear()

    this.trailing := true
    this.extending := false
    this.awaiting_confirmation := false
    this.touched_break_price_before_confirmation := false
    this.soft_confirmed := false
    this.has_fvg_out := false
    this.broken := false
    this.broken_time := na
    this.broken_index := na

    this.left_top := chart.point.now(high)
    this.right_bottom := chart.point.now(low)
    this.break_price := hl2
  
method remove_insignificant(OrderBlock[] blocks, float min_size, float max_size, OrderBlock[] removed_buffer = na, int protected_id = na) =>
    if blocks.size() > 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            size = block.left_top.price - block.right_bottom.price
            bool is_protected = not na(protected_id) and block.id == protected_id
            if not is_protected and (size < min_size or max_size < size)
                log.info("clearing out old OB to free memory (top: {0} | bottom: {1}) with size ({2}) outside range (min: {3} | max: {4})", block.left_top.price, block.right_bottom.price, size, min_size, max_size)

                if not na(removed_buffer)
                    removed_buffer.push(block)

                block.delete()
                blocks.remove(i)
                
    blocks

track_obs(
 int swing_len,
 float swing_high_confirmed,
 float swing_low_confirmed,
 bool bull_bos_alert,
 bool bull_choch_alert,
 bool bear_bos_alert,
 bool bear_choch_alert,
 float min_block_size,
 float max_block_size,
 bool enabled = true,
 simple bool include_consecutive_bars = true,
 bool capture_profile = false,
 bool update_profile_current_bar = true,
 bool align_edge_to_value_area = false,
 bool align_break_price_to_poc = false,
 simple bool use_soft_confirm = true,
 float soft_confirm_offset = 0,
 simple bool use_soft_confirm_big_candle = true,
 simple bool use_retracements_with_FVG_out = true,
 simple ct.LevelBreakMode broken_by = ct.LevelBreakMode.HIGHLOW,
 simple int keep_broken_max = 5,
 simple int gc_cycle = na,
 int protected_bull_id = na,
 int protected_bear_id = na
 ) =>
    // Order block lifecycle:
    // 1. trailing: candidate block is tracked while price builds it
    // 2. extending: block grows as same-direction candles continue
    // 3. awaiting_confirmation: extension stopped, block waits for confirmation
    // 4. confirmed: block is copied into the tracked blocks buffer
    // 5. broken: later mitigation/break moves it into the broken history buffer

    var OrderBlock[] tracking_blocks_bull   = array.new<OrderBlock>(0)
    var OrderBlock[] tracking_blocks_bear   = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bull     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bear     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bull = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bear = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bull  = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bear  = array.new<OrderBlock>(0)

    float atr = smc_lib_atr(200)
    float fvg_min_size = atr * 0.2
    float impulse_candle_size = atr * 3
        
    var int next_id = 0
    var OrderBlock bull_ob = create_ob(0,  1, time, bar_index, high, time, bar_index, low, hl2, broken_by)
    var OrderBlock bear_ob = create_ob(0, -1, time, bar_index, high, time, bar_index, low, hl2, broken_by)

    if barstate.isfirst
        bull_ob.reset_tracking()
        bear_ob.reset_tracking()

    var float ob_size_min_bull = min_block_size
    var float ob_size_min_bear = min_block_size
    var float ob_size_max_bull = max_block_size
    var float ob_size_max_bear = max_block_size

    bool is_green = open < close
    bool is_red = close < open
    bool is_fvg_up = low - high[2] > fvg_min_size
    bool is_fvg_down = low[2] - high > fvg_min_size
    float candle_top = math.max(open, close)
    float candle_btm = math.min(open, close)
    float candle_body = math.abs(open - close)
    bool is_impulse_candle = candle_body >= impulse_candle_size
    bool is_indecision = u.in_range(high, low, high[1], low[1]) and candle_body[1] > candle_body or u.in_range(candle_top, candle_btm, candle_top[1], candle_btm[1]) or open == close
    OrderBlock bull_ob_confirmed = na
    OrderBlock bear_ob_confirmed = na
    var bool reset_bull_next_bar = false
    var bool reset_bear_next_bar = false

    bool profile_features_active = capture_profile or align_edge_to_value_area or align_break_price_to_poc

    if enabled
        update_broken( 1, tracking_blocks_bull, broken_blocks_bull, broken_blocks_new_bull, broken_by, keep_broken_max, discarded_blocks_bull)
        update_broken(-1, tracking_blocks_bear, broken_blocks_bear, broken_blocks_new_bear, broken_by, keep_broken_max, discarded_blocks_bear)

        if gc_cycle > 0 and bar_index % gc_cycle == 0
            tracking_blocks_bull.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bull, protected_bull_id)
            tracking_blocks_bear.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bear, protected_bear_id)

        if reset_bull_next_bar
            reset_bull_next_bar := false
            bull_ob.reset_tracking()
        if reset_bear_next_bar
            reset_bear_next_bar := false
            bear_ob.reset_tracking()

        if bull_ob.trailing 
            if profile_features_active and update_profile_current_bar
                bull_ob.ltf_open.push(open)
                bull_ob.ltf_high.push(high)
                bull_ob.ltf_low.push(low)
                bull_ob.ltf_close.push(close)
                bull_ob.ltf_volume.push(volume)

            _check_start_t = bull_ob.left_top.time
            _check_start_i = bull_ob.left_top.index
            _check_end_t = bull_ob.right_bottom.time
            _check_end_i = bull_ob.right_bottom.index
            _check_top = bull_ob.left_top.price
            _check_btm = bull_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bull_ob.extending

            if bull_ob.right_bottom.price > low
                if barstate.isconfirmed and _check_start_i < bar_index - 1 and use_retracements_with_FVG_out and is_fvg_down
                    if not _check_ext[2] and not tracking_blocks_bear.any_overlaps(_check_top[2], _check_btm[2]) and not bear_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bear_ob_confirmed := create_ob(next_id, -1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bear_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bear_ob_confirmed.ltf_open := bull_ob.ltf_open.copy()
                            bear_ob_confirmed.ltf_high := bull_ob.ltf_high.copy()
                            bear_ob_confirmed.ltf_low := bull_ob.ltf_low.copy()
                            bear_ob_confirmed.ltf_close := bull_ob.ltf_close.copy()
                            bear_ob_confirmed.ltf_volume := bull_ob.ltf_volume.copy()

                            if align_edge_to_value_area or align_break_price_to_poc
                                bear_ob_confirmed.create_profile()
                                bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                            bear_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, _check_top[2], _check_btm[2], bear_ob_confirmed.left_top.price, bear_ob_confirmed.right_bottom.price, bear_ob_confirmed.break_price)

                        bear_ob_confirmed.right_bottom.index := bar_index
                        bear_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bear.push(bear_ob_confirmed)

                if is_green
                    bull_ob.reset_tracking()
                else 
                    reset_bull_next_bar := true

                if barstate.isconfirmed
                    bull_ob.profile := na

            else if bull_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bull_ob.extending := true

            if bull_ob.extending and is_green and bull_ob.left_top.price < high
                bull_ob.left_top.price := high
                bull_ob.right_bottom := chart.point.now(bull_ob.right_bottom.price)
                bull_ob.touched_break_price_before_confirmation := false
                bull_ob.soft_confirmed := false

                if is_impulse_candle
                    bull_ob.has_big_candle := true

        if bear_ob.trailing
            if profile_features_active and update_profile_current_bar
                bear_ob.ltf_open.push(open)
                bear_ob.ltf_high.push(high)
                bear_ob.ltf_low.push(low)
                bear_ob.ltf_close.push(close)
                bear_ob.ltf_volume.push(volume)

            _check_start_t = bear_ob.left_top.time
            _check_start_i = bear_ob.left_top.index
            _check_end_t = bear_ob.right_bottom.time
            _check_end_i = bear_ob.right_bottom.index
            _check_top = bear_ob.left_top.price
            _check_btm = bear_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bear_ob.extending

            if bear_ob.left_top.price < high
                if barstate.isconfirmed and use_retracements_with_FVG_out and is_fvg_up
                    if not _check_ext[2] and not tracking_blocks_bull.any_overlaps(_check_top[2], _check_btm[2]) and not bull_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bull_ob_confirmed := create_ob(next_id, 1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bull_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bull_ob_confirmed.ltf_open := bear_ob.ltf_open.copy()
                            bull_ob_confirmed.ltf_high := bear_ob.ltf_high.copy()
                            bull_ob_confirmed.ltf_low := bear_ob.ltf_low.copy()
                            bull_ob_confirmed.ltf_close := bear_ob.ltf_close.copy()
                            bull_ob_confirmed.ltf_volume := bear_ob.ltf_volume.copy()

                            if align_edge_to_value_area or align_break_price_to_poc
                                bull_ob_confirmed.create_profile()
                                bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                            bull_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, _check_top[2], _check_btm[2], bull_ob_confirmed.left_top.price, bull_ob_confirmed.right_bottom.price, bull_ob_confirmed.break_price)

                        bull_ob_confirmed.right_bottom.index := bar_index
                        bull_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bull.push(bull_ob_confirmed)

                if is_red
                    bear_ob.reset_tracking()
                else 
                    reset_bear_next_bar := true

                if barstate.isconfirmed
                    bear_ob.profile := na

            else if bear_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bear_ob.extending := true

            if bear_ob.extending and is_red
                bear_ob.right_bottom := chart.point.now(math.min(bear_ob.right_bottom.price, low))
                bear_ob.touched_break_price_before_confirmation := false
                bear_ob.soft_confirmed := false

                if is_impulse_candle
                    bear_ob.has_big_candle := true

        if barstate.isconfirmed
            if bull_ob.trailing and bull_ob.extending and bull_ob.left_top.index < bar_index and is_red and not is_indecision and u.in_range(close, bull_ob.left_top.price, bull_ob.right_bottom.price)
                bull_ob.left_top.price := math.max(open, bull_ob.left_top.price)
                bull_ob.right_bottom := chart.point.new(time_close[1], bar_index[1], bull_ob.right_bottom.price)
                bull_ob.extending := false
                bull_ob.awaiting_confirmation := true

                ob_length = bull_ob.right_bottom.index - bull_ob.left_top.index + 1
                ob_size_min_bull := math.round_to_mintick(min_block_size)
                ob_size_max_bull := math.round_to_mintick(max_block_size * ob_length)

                if update_profile_current_bar and (align_edge_to_value_area or align_break_price_to_poc)
                    bull_ob.create_profile()
                    bull_ob.align_to_profile(align_break_price = true)

                if not bear_ob.awaiting_confirmation and not bear_ob.extending
                    bear_ob.reset_tracking()

            if bear_ob.trailing and bear_ob.extending and bear_ob.left_top.index < bar_index and is_green and not is_indecision and u.in_range(close, bear_ob.left_top.price, bear_ob.right_bottom.price)
                bear_ob.left_top.price := math.max(open, bear_ob.left_top.price)
                bear_ob.right_bottom := chart.point.new(time_close[1], bar_index[1], bear_ob.right_bottom.price)
                bear_ob.extending := false
                bear_ob.awaiting_confirmation := true

                ob_length = bear_ob.right_bottom.index - bear_ob.left_top.index + 1
                ob_size_min_bear := min_block_size
                ob_size_max_bear := max_block_size * ob_length

                if update_profile_current_bar and (align_edge_to_value_area or align_break_price_to_poc)
                    bear_ob.create_profile()
                    bear_ob.align_to_profile(align_break_price = true)

                if not bull_ob.awaiting_confirmation and not bull_ob.extending
                    bull_ob.reset_tracking()

        if bull_ob.trailing and bull_ob.awaiting_confirmation
            if barstate.isconfirmed and not bull_ob.soft_confirmed
                if not bull_ob.touched_break_price_before_confirmation
                    if bull_ob.break_price > low and bull_ob.right_bottom.index < bar_index
                        bull_ob.touched_break_price_before_confirmation := true

                if bull_ob.touched_break_price_before_confirmation and bull_ob.left_top.price + soft_confirm_offset < close
                    bull_ob.soft_confirmed := true
                else if use_soft_confirm_big_candle and is_impulse_candle and is_green and close - bull_ob.left_top.price >= impulse_candle_size / 2
                    bull_ob.soft_confirmed := true

            bull_price_exited = bull_ob.left_top.price + soft_confirm_offset < close
            bull_confirm_trigger = (bull_ob.soft_confirmed and use_soft_confirm) or not na(swing_low_confirmed) or bull_bos_alert or bull_choch_alert or bar_index - bull_ob.right_bottom.index >= swing_len
            bull_should_confirm = bull_price_exited and barstate.isconfirmed and bull_confirm_trigger

            if bull_should_confirm
                if align_edge_to_value_area and not na(bull_ob.profile) ? u.in_range(math.round_to_mintick(bull_ob.profile.vah - bull_ob.profile.val), ob_size_max_bull, ob_size_min_bull) : u.in_range(math.round_to_mintick(bull_ob.left_top.price - bull_ob.right_bottom.price), ob_size_max_bull, ob_size_min_bull)
                    bull_ob.trailing := false
                    next_id += 1
                    bull_ob.id := next_id
                    bull_ob_confirmed := bull_ob.copy()
                    bull_ob_confirmed.id := bull_ob.id
                    bull_ob_confirmed.left_top := bull_ob.left_top.copy()
                    bull_ob_confirmed.right_bottom := bull_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        bull_ob_confirmed.create_profile()
                        bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    bull_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, bull_ob.left_top.price, bull_ob.right_bottom.price, bull_ob_confirmed.left_top.price, bull_ob_confirmed.right_bottom.price, bull_ob_confirmed.break_price)
                    bull_ob.profile := na

                    if is_fvg_up and high[2] < bull_ob_confirmed.left_top.price and bull_ob_confirmed.left_top.price < low
                        bull_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bull.push(bull_ob_confirmed)

                    if barstate.isconfirmed
                        bull_ob.reset_tracking()
                else
                    bull_ob.reset_tracking()

        if bear_ob.trailing and bear_ob.awaiting_confirmation
            if barstate.isconfirmed and not bear_ob.soft_confirmed
                if not bear_ob.touched_break_price_before_confirmation
                    if bear_ob.break_price < high and bear_ob.right_bottom.index < bar_index
                        bear_ob.touched_break_price_before_confirmation := true

                if bear_ob.touched_break_price_before_confirmation and bear_ob.right_bottom.price - soft_confirm_offset > close
                    bear_ob.soft_confirmed := true
                else if use_soft_confirm_big_candle and is_impulse_candle and is_red and bear_ob.right_bottom.price - close >= impulse_candle_size / 2
                    bear_ob.soft_confirmed := true

            bear_price_exited = bear_ob.right_bottom.price - soft_confirm_offset > close
            bear_confirm_trigger = (bear_ob.soft_confirmed and use_soft_confirm) or not na(swing_high_confirmed) or bear_bos_alert or bear_choch_alert or bar_index - bear_ob.right_bottom.index >= swing_len
            bear_should_confirm = bear_price_exited and barstate.isconfirmed and bear_confirm_trigger

            if bear_should_confirm
                if align_edge_to_value_area and not na(bear_ob.profile) ? u.in_range(math.round_to_mintick(bear_ob.profile.vah - bear_ob.profile.val), ob_size_max_bear, ob_size_min_bear) : u.in_range(math.round_to_mintick(bear_ob.left_top.price - bear_ob.right_bottom.price), ob_size_max_bear, ob_size_min_bear)
                    bear_ob.trailing := false
                    next_id += 1
                    bear_ob.id := next_id
                    bear_ob_confirmed := bear_ob.copy()
                    bear_ob_confirmed.id := bear_ob.id
                    bear_ob_confirmed.left_top := bear_ob.left_top.copy()
                    bear_ob_confirmed.right_bottom := bear_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        bear_ob_confirmed.create_profile()
                        bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    bear_ob_confirmed.break_price := resolve_confirmed_ob_break_price(align_edge_to_value_area, align_break_price_to_poc, bear_ob.left_top.price, bear_ob.right_bottom.price, bear_ob_confirmed.left_top.price, bear_ob_confirmed.right_bottom.price, bear_ob_confirmed.break_price)
                    bear_ob.profile := na

                    if is_fvg_down and low[2] < bear_ob_confirmed.right_bottom.price and bear_ob_confirmed.right_bottom.price < high
                        bear_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bear.push(bear_ob_confirmed)

                    if barstate.isconfirmed
                        bear_ob.reset_tracking()
                else
                    bear_ob.reset_tracking()

    [tracking_blocks_bull, tracking_blocks_bear, bull_ob_confirmed, bear_ob_confirmed, broken_blocks_bull, broken_blocks_bear, broken_blocks_new_bull, broken_blocks_new_bear, discarded_blocks_bull, discarded_blocks_bear]

method draw(OrderBlock this, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    visible_match = na(visible_left) or na(visible_right) or this.overlaps_window(visible_left, visible_right, config.extend_until_broken)

    if not visible_match
        if not na(this.plot) and not this.hidden
            this.plot.hide()
            if not na(this.profile)
                this.profile.hide()
            this.hidden := true
        this
    else

        if barstate.islast and not na(this) and config.show
            txt_fvg = config.show_fvg_out and this.has_fvg_out ? '+FVG' : ''
            float ob_quality = config.show_quality_score ? ob_quality_score(this) : 0.0
            txt_quality = config.show_quality_score and ob_quality > 0 ? str.format(' (Q {0,number,percent})', ob_quality) : ''
            txt_id = config.show_id ? ' #' + str.tostring(this.id) : ''
            txt = config.show_text ? config.show_profile and config.profile_config.show_poc and config.profile_config.show_labels ? str.format('{0}{1}{2}', config.txt, txt_fvg, txt_id) : str.format('{0}{1}{2}{3}', config.txt, txt_fvg, txt_quality, txt_id) : ''

            xloc_bartime = config.args.xloc == xloc.bar_time
            int broken_right_time = effective_live_event_time(this.broken_time, math.max(this.left_top.time, this.right_bottom.time))

            int left = not na(left_override) ? left_override : xloc_bartime ? this.left_top.time : this.left_top.index
            int right = not na(right_override) ? right_override : config.extend_until_broken ? this.broken ? xloc_bartime ? broken_right_time : this.broken_index - 1 : xloc_bartime ? current_bar_right_time() : bar_index : xloc_bartime ? this.right_bottom.time : this.right_bottom.index

            chart.point plot_left_top = d.create_point(left, this.left_top.price, config.args.xloc)
            chart.point plot_right_bottom = d.create_point(right, this.right_bottom.price, config.args.xloc)

            if config.show
                if na(this.plot)
                    this.plot := d.SmcBox.new(plot_left_top, plot_right_bottom, txt)
                else
                    this.plot.left_top := plot_left_top
                    this.plot.right_bottom := plot_right_bottom

                this.plot.draw(config.args, config.txt_args, extend_only, force_overlay)
                if this.broken or this.has_fvg_out
                    this.plot.plot.set_text(txt)

                if config.show_profile and not na(this.profile)
                    poc_txt = config.show_quality_score and config.profile_config.show_poc and config.profile_config.show_labels ? config.profile_config.poc_label_text + txt_fvg + txt_quality : na
                    this.profile.draw(config.profile_config, left, right, extend_only, force_overlay, poc_txt)

                if this.broken and broken_right_time <= current_bar_right_time()
                    this.plot.apply_style(config.args, config.txt_args)
                    if not na(this.profile) and config.show_profile
                        this.profile.apply_style(config.profile_config)

            this.hidden := false

    this

method hide(OrderBlock this) =>
    if not na(this) and not this.hidden
        if not na(this.plot)
            this.plot.hide()
        if not na(this.profile)
            this.profile.hide()
        this.hidden := true
    this

method draw(OrderBlock[] blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    if na(blocks) ? false : config.show and blocks.size() > 0
        count = 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            visible_match = na(visible_left) or na(visible_right) or block.overlaps_window(visible_left, visible_right, config.extend_until_broken)
            if visible_match and count < config.show_last
                block.draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
                count += 1
            else
                if not na(block.plot) and not block.hidden
                    block.hide()
    blocks

method draw(map<int, OrderBlock> blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    blocks.values().draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
    blocks

// Market structure helpers

detect_swings(simple int length = 10) =>
    var os = 0
    float hh = na
    float ll = na
    int idx = na

    h_swing = high[length]
    l_swing = low[length]
    upper = ta.highest(high, length)
    lower = ta.lowest(low, length)

    os := h_swing > upper ? 0 : l_swing < lower ? 1 : os[1]
    hh := os == 0 and os[1] != 0 ? h_swing : na
    ll := os == 1 and os[1] != 1 ? l_swing : na
    idx := not na(hh) or not na(ll) ? bar_index - length : na

    [idx, hh, ll]

detect_pivot(simple int mode, int trend, int hhll_x, float hhll, float super_hhll = na, bool filter_insignificant_internal_breaks = false) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var sy = 0.
    var x = 0, var y = 0.
    var trail_x = 0, var trail_y = mode_high ? high : mode_low ? low : na
    var lvl_cross = true
    bool choch_alert = false
    bool bos_alert = false

    if not na(super_hhll)
        sy := super_hhll

    if not na(hhll)
        lvl_cross := true
        y := hhll
        x := hhll_x
        trail_y := hhll
        trail_x := hhll_x

    trail_y := mode_high ? math.max(high, trail_y) : math.min(low, trail_y)
    trail_x := (mode_high and trail_y == high) or (mode_low and trail_y == low) ? bar_index : trail_x

    var trend_concordant = true
    atr = ta.atr(3)

    structure_detected = switch mode
        1 => ta.crossover(close, y)
        -1 => ta.crossunder(close, y)
        => false

    if structure_detected and lvl_cross and y != sy
        lvl_cross := false

        if filter_insignificant_internal_breaks
            body = math.abs(open - close)
            distance_to_level = math.abs(open - y)
            big_candle = body > 2 * distance_to_level or body > atr

            top_wick = high - math.max(close, open)
            btm_wick = math.min(close, open) - low
            impulse_wick = switch mode
                1 => top_wick > btm_wick
                -1 => top_wick < btm_wick
                => false

            trend_concordant := big_candle or impulse_wick

        if trend_concordant
            _trend = (trend != 1 and trend != -1 ? 1 : trend)
            choch_alert := mode == _trend * -1
            bos_alert := mode == _trend

    [x, y, trail_x, trail_y, bos_alert, choch_alert]

detect_structure(simple int swing_len = 50, float super_hh = na, float super_ll = na, bool filter_insignificant_internal_breaks = true) =>
    var trend = 1

    [hhll_x, hh, ll] = detect_swings(swing_len)
    [top_x, top_y, trail_up_x, trail_up, bull_bos_alert, bull_choch_alert] = detect_pivot(1, trend, hhll_x, hh, super_hh, filter_insignificant_internal_breaks)
    [btm_x, btm_y, trail_dn_x, trail_dn, bear_bos_alert, bear_choch_alert] = detect_pivot(-1, trend, hhll_x, ll, super_ll, filter_insignificant_internal_breaks)

    trend := bull_choch_alert ? 1 : bear_choch_alert ? -1 : trend

    [trend, bull_bos_alert, bull_choch_alert, top_x, top_y, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm_y, trail_dn_x, trail_dn, ll, hhll_x]

plot_pivot_points(int mode, int x, float y, bool enabled, d.LabelArgs args, bool keep_history) =>
    var float prev_high_pivot = na
    var float prev_low_pivot = na
    if enabled and not na(x)
        txt_swing_point = mode == 1 ? (na(prev_high_pivot) or y > prev_high_pivot ? 'HH' : 'LH') : mode == -1 ? (na(prev_low_pivot) or y < prev_low_pivot ? 'LL' : 'HL') : na
        label_swing_point = label.new(x, y, txt_swing_point, color = args.bg_color, textcolor = args.text_color, style = args.style, size = args.size)
        if mode == 1
            prev_high_pivot := y
        else if mode == -1
            prev_low_pivot := y
        if not keep_history
            label.delete(label_swing_point[1])

plot_swing_levels(int mode, int trail_x, float trail_y, int trend, bool enabled, d.LabelArgs label_args, d.LineArgs line_args, int override_right_index = na, string text_prefix = '') =>
    var label label_latest_swing = label.new(na, na, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)
    var line line_latest_swing = line.new(na, na, na, na, color = line_args.line_color, style = line_args.style)

    if enabled
        if trail_x != line_latest_swing.get_x1() or na(line_latest_swing.get_x1())
            line_latest_swing.set_xy1(trail_x, trail_y)
        else
            line_latest_swing.set_y1(trail_y)

        if barstate.islast
            hl_swing_txt = mode == 1 ? (trend < 0 ? 'Strong High' : 'Weak High') : mode == -1 ? (trend > 0 ? 'Strong Low' : 'Weak Low') : na
            right = not na(override_right_index) ? override_right_index : bar_index + 20
            line_latest_swing.set_xy2(right, trail_y)
            label_latest_swing.set_xy(right, trail_y)
            label_latest_swing.set_text(text_prefix + hl_swing_txt)

plot_structure(int x, float y, bool is_bos = false, bool is_choch = false, d.LabelArgs label_args, d.LineArgs line_args, bool keep_history, string text_prefix = '', string bos_text = 'BOS', string choch_text = 'CHoCH') =>
    if is_bos or is_choch
        txt = text_prefix + (is_choch ? choch_text : bos_text)
        structure_line = line.new(x, y, bar_index, y, color = line_args.line_color, style = line_args.style)
        structure_lbl = label.new(int(math.avg(x, bar_index)), y, txt, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)

        if not keep_history
            line.delete(structure_line[1])
            label.delete(structure_lbl[1])

detect_equal_level(int mode, int len, float eq_threshold, bool enabled = true) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var int x1 = 0, var float y1 = 0.
    var int x2 = 0, var float y2 = 0.

    eq_alert = false
    ph = ta.pivothigh(len, len)
    pl = ta.pivotlow(len, len)

    if enabled
        eq_lvl = mode_high ? ph : pl
        if not na(eq_lvl)
            x1 := x2, y1 := y2
            x2 := bar_index - len, y2 := eq_lvl

            max = math.max(eq_lvl, y1)
            min = math.min(eq_lvl, y1)

            if mode_high and (max < min + eq_threshold) or mode_low and (min > max - eq_threshold)
                eq_alert := true

    [eq_alert, eq_alert ? x1 : na, eq_alert ? y1 : na, eq_alert ? x2 : na, eq_alert ? y2 : na]

detect_equal_levels(int len, float threshold, bool enabled = true) =>
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2] = detect_equal_level(1, len, threshold, enabled)
    [eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_level(-1, len, threshold, enabled)
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2]

plot_equal_level(bool show_eq, int x1, float y1, int x2, float y2, string label_txt, d.LabelArgs label_args, d.LineArgs line_args, bool keep_history = true, bool force_overlay = false) =>
    if show_eq and not na(x1) and not na(x2) and not na(y1) and not na(y2)
        line eq_line = na
        label eq_lbl = na

        if force_overlay
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width, force_overlay = true)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, xloc = label_args.xloc, yloc = label_args.yloc, color = label_args.bg_color, style = label_args.style, textcolor = label_args.text_color, size = label_args.size, textalign = label_args.text_align, text_font_family = label_args.text_font_family, force_overlay = true)
        else
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, xloc = label_args.xloc, yloc = label_args.yloc, color = label_args.bg_color, style = label_args.style, textcolor = label_args.text_color, size = label_args.size, textalign = label_args.text_align, text_font_family = label_args.text_font_family)

        if not keep_history
            line.delete(eq_line[1])
            label.delete(eq_lbl[1])

type FVGConfig
    bool show_box = true
    bool show_target = true
    bool show_target_label = true
    int show_last = 5
    bool show_text = true
    bool show_quality_score = false
    bool show_profile = false
    d.BoxArgs box_args = na
    d.BoxTextArgs box_text_args = na
    d.LineArgs line_args = na
    d.LabelArgs label_args = na
    string txt = na
    int extend_bars = 1
    bool extend_until_filled = false

type FVG
    int id
    int dir
    ct.LevelBreakMode fill_mode
    chart.point left_top
    chart.point right_bottom
    float fvg_fill_target_ratio
    float fill_target_level
    float fill_current_ratio
    float fill_current_level
    float total_volume
    float quality_score = na
    bool filled = false
    int fill_time = na
    int fill_index = na
    d.SmcBox plot_box = na
    d.SmcLine plot_fill_target_level = na
    d.SmcLabel plot_fill_target_label = na
    bool hidden = false

method rendered_right_time(FVG this, bool extend_until_filled = true) =>
    int rendered_right_time_value = na
    if not na(this)
        int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
        int effective_fill_time = effective_live_event_time(this.fill_time, base_right_time)
        rendered_right_time_value := extend_until_filled ? (this.filled ? effective_fill_time : current_bar_right_time()) : (this.filled ? math.min(effective_fill_time, base_right_time) : base_right_time)
    rendered_right_time_value

method overlaps_window(FVG this, int left_time, int right_time, bool extend_until_filled = true) =>
    if na(this)
        false
    else
        effective_right_time = this.rendered_right_time(extend_until_filled)
        effective_right_time >= left_time and this.left_top.time <= right_time

method contains_id(FVG[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for fvg in this
            if fvg.id == id
                found := true
                break
    found

method get_by_id(FVG[] this, int id) =>
    FVG found = na
    if not na(this) and not na(id)
        for fvg in this
            if fvg.id == id
                found := fvg
                break
    found

zone_candidate_preferred(bool candidate_touch_anchor, int candidate_recency, float candidate_quality, float candidate_overlap, int candidate_id, bool best_touch_anchor, int best_recency, float best_quality, float best_overlap, int best_id) =>
    bool prefer_candidate = candidate_touch_anchor and not best_touch_anchor
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor
        prefer_candidate := na(best_recency) or candidate_recency > best_recency
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency
        prefer_candidate := na(best_quality) or candidate_quality > best_quality
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency and candidate_quality == best_quality
        prefer_candidate := na(best_overlap) or candidate_overlap > best_overlap
    if not prefer_candidate and candidate_touch_anchor == best_touch_anchor and candidate_recency == best_recency and candidate_quality == best_quality and candidate_overlap == best_overlap
        prefer_candidate := na(best_id) or candidate_id > best_id
    prefer_candidate

prefer_primary_zone(bool primary_touch_anchor, int primary_recency, float primary_quality, float primary_overlap, int primary_id, bool secondary_touch_anchor, int secondary_recency, float secondary_quality, float secondary_overlap, int secondary_id) =>
    zone_candidate_preferred(primary_touch_anchor, primary_recency, primary_quality, primary_overlap, primary_id, secondary_touch_anchor, secondary_recency, secondary_quality, secondary_overlap, secondary_id)

select_locked_source_touch_count(bool source_upgrade_now, bool prefer_ob_upgrade_now, int ob_candidate_id, int active_ob_touch_id, int active_ob_touch_count, int touched_ob_touch_count, int fvg_candidate_id, int active_fvg_touch_id, int active_fvg_touch_count, int touched_fvg_touch_count, int locked_source_touch_count) =>
    source_upgrade_now ? prefer_ob_upgrade_now ? (ob_candidate_id == active_ob_touch_id ? active_ob_touch_count : math.max(touched_ob_touch_count, 1)) : (fvg_candidate_id == active_fvg_touch_id ? active_fvg_touch_count : math.max(touched_fvg_touch_count, 1)) : locked_source_touch_count

select_long_arm_backing_zone_touch_count(string arm_backing_zone_kind, int arm_backing_zone_id, int active_ob_touch_id, int active_ob_touch_count, int touched_bull_ob_id, int touched_bull_ob_touch_count, int active_fvg_touch_id, int active_fvg_touch_count, int touched_bull_fvg_id, int touched_bull_fvg_touch_count) =>
    arm_backing_zone_kind == 'OB' and arm_backing_zone_id == active_ob_touch_id ? active_ob_touch_count : arm_backing_zone_kind == 'OB' and arm_backing_zone_id == touched_bull_ob_id ? touched_bull_ob_touch_count : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == active_fvg_touch_id ? active_fvg_touch_count : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == touched_bull_fvg_id ? touched_bull_fvg_touch_count : 0

resolve_long_invalidation_reason(bool long_source_broken, bool long_source_lost, bool long_setup_expired, bool long_confirm_expired, string long_validation_source, string long_entry_origin_source, string long_setup_source_display) =>
    long_source_broken ? long_validation_source + ' source invalidated' : long_source_lost ? long_validation_source + ' backing zone lost' : long_setup_expired ? long_entry_origin_source + ' setup expired' : long_confirm_expired ? long_entry_origin_source + ' confirm expired' : long_setup_source_display

compose_long_setup_source_display(string long_entry_origin_source, string long_validation_source) =>
    long_entry_origin_source == 'None' ? long_validation_source : long_validation_source == 'None' or long_entry_origin_source == long_validation_source ? long_entry_origin_source : long_entry_origin_source + ' -> ' + long_validation_source

describe_long_freshness(bool long_setup_armed, bool long_setup_confirmed, bool ready_is_fresh, bool confirm_is_fresh) =>
    not long_setup_armed and not long_setup_confirmed ? 'n/a' : long_setup_confirmed ? ready_is_fresh ? 'confirm fresh' : 'confirm stale' : confirm_is_fresh ? 'armed fresh' : 'armed stale'

describe_long_source_state(bool long_source_tracked, bool long_source_alive, bool long_source_broken) =>
    not long_source_tracked ? 'n/a' : long_source_alive ? 'source alive' : long_source_broken ? 'source invalid' : 'source lost'

select_effective_long_touch_count(bool long_setup_armed, bool long_setup_confirmed, int long_setup_backing_zone_touch_count, bool bull_reclaim_ob_strict, bool in_bull_ob_zone, bool in_bull_fvg_zone, int active_ob_touch_count, bool bull_reclaim_fvg_strict, int active_fvg_touch_count, int active_zone_touch_count) =>
    long_setup_armed or long_setup_confirmed ? long_setup_backing_zone_touch_count : bull_reclaim_ob_strict or (in_bull_ob_zone and not in_bull_fvg_zone) ? active_ob_touch_count : bull_reclaim_fvg_strict or (in_bull_fvg_zone and not in_bull_ob_zone) ? active_fvg_touch_count : active_zone_touch_count

describe_long_zone_quality(bool long_zone_active, bool long_setup_armed, bool long_setup_confirmed, int effective_long_active_touch_count) =>
    not long_zone_active and not long_setup_armed and not long_setup_confirmed ? 'n/a' : effective_long_active_touch_count <= 1 ? 'fresh touch' : effective_long_active_touch_count == 2 ? '2nd touch' : 'crowded'

compose_long_setup_text(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidated_now, bool invalidated_prior_setup, string long_setup_source_display) =>
compose_long_setup_text(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidated_now, bool invalidated_prior_setup, bool long_invalidated_this_bar, string long_setup_source_display) =>
    string setup_text = 'No Setup'
    if long_zone_active
        setup_text := 'In Zone'
    if long_setup_armed
        setup_text := 'Armed | ' + long_setup_source_display
    if long_building_state
        setup_text := 'Building | ' + long_setup_source_display
    if long_setup_confirmed
        setup_text := 'Confirmed | ' + long_setup_source_display
    if long_ready_state
        setup_text := 'Ready | ' + long_setup_source_display
    if long_entry_best_state
        setup_text := 'Entry Best | ' + long_setup_source_display
    if long_entry_strict_state
        setup_text := 'Entry Strict | ' + long_setup_source_display
    if (invalidated_prior_setup or long_invalidated_now or long_invalidated_this_bar) and not long_setup_armed and not long_setup_confirmed
        setup_text := 'Invalidated'
    setup_text

resolve_long_visual_state(bool long_zone_active, bool long_setup_armed, bool long_building_state, bool long_setup_confirmed, bool long_ready_state, bool long_entry_best_state, bool long_entry_strict_state, bool long_invalidate_signal, bool invalidated_prior_setup, bool long_invalidated_now, bool long_invalidated_this_bar) =>
    int visual_state = 0
    if long_zone_active
        visual_state := 1
    if long_setup_armed
        visual_state := 2
    if long_building_state
        visual_state := 3
    if long_setup_confirmed
        visual_state := 4
    if long_ready_state
        visual_state := 5
    if long_entry_best_state
        visual_state := 6
    if long_entry_strict_state
        visual_state := 7
    if (long_setup_armed or long_setup_confirmed or long_invalidate_signal or invalidated_prior_setup or long_invalidated_this_bar) and (long_invalidated_now or long_invalidated_this_bar)
        visual_state := -1
    visual_state


resolve_long_visual_text(int long_visual_state) =>
    long_visual_state == -1 ? 'Fail' :
     long_visual_state == 0 ? 'Neutral' :
     long_visual_state == 1 ? 'In Zone' :
     long_visual_state == 2 ? 'Armed' :
     long_visual_state == 3 ? 'Building' :
     long_visual_state == 4 ? 'Confirmed' :
     'Ready'

resolve_long_bg_color(int long_visual_state, color long_color_building) =>
    color bg_color = na
    if long_visual_state == -1
        bg_color := color.new(color.red, 90)
    else if long_visual_state == 1
        bg_color := color.new(color.aqua, 92)
    else if long_visual_state == 2
        bg_color := color.new(color.orange, 88)
    else if long_visual_state == 3
        bg_color := color.new(long_color_building, 84)
    else if long_visual_state == 4
        bg_color := color.new(color.lime, 88)
    else if long_visual_state == 5
        bg_color := color.new(color.green, 82)
    else if long_visual_state == 6
        bg_color := color.new(color.green, 74)
    else if long_visual_state >= 7
        bg_color := color.new(color.green, 66)
    bg_color

resolve_long_bar_color(int long_visual_state, color long_color_building) =>
    color bar_color = na
    if long_visual_state == -1
        bar_color := color.new(color.red, 0)
    else if long_visual_state == 1
        bar_color := color.new(color.aqua, 45)
    else if long_visual_state == 2
        bar_color := color.new(color.orange, 25)
    else if long_visual_state == 3
        bar_color := color.new(long_color_building, 5)
    else if long_visual_state == 4
        bar_color := color.new(color.lime, 0)
    else if long_visual_state == 5
        bar_color := color.new(color.green, 0)
    else if long_visual_state == 6
        bar_color := color.new(color.green, 0)
    else if long_visual_state >= 7
        bar_color := color.new(color.teal, 0)
    bar_color

