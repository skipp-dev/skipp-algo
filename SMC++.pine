    dashboard_row(tbl, 32, 'Vol Squeeze', _db_vol_squeeze_text, status_bg(_db_vol_squeeze_state), _db_text)
    dashboard_row(tbl, 33, 'Vol Expand', _db_vol_expand_text, status_bg(_db_vol_expand_state), _db_text)
    dashboard_row(tbl, 34, 'Stretch', _db_stretch_text, status_bg(_db_stretch_state), _db_text)
    dashboard_row(tbl, 35, 'DDVI', _db_ddvi_text, status_bg(_db_ddvi_state), _db_text)
    dashboard_row(tbl, 36, 'LTF Bias', _db_ltf_bias_text, status_bg(_db_ltf_bias_state), _db_text)
    dashboard_row(tbl, 37, 'LTF Delta', _db_ltf_delta_text, status_bg(_db_ltf_delta_state), _db_text)
    dashboard_row(tbl, 38, 'Objects', _db_objects_text, status_bg(_db_objects_state), _db_text)
    dashboard_row(tbl, 39, 'Swing H/L', _db_swing_text, status_bg(_db_swing_state), _db_text)
    dashboard_row(tbl, 40, 'Long Zones', _db_long_zones_text, status_bg(_db_long_zones_state), _db_text)
    dashboard_row(tbl, 41, 'Long Triggers', _db_long_triggers_text, status_bg(_db_long_triggers_state), _db_text)
    dashboard_row(tbl, 42, 'Micro Profile', _db_micro_profile_text, status_bg(_db_micro_profile_state), _db_text)
    dashboard_row(tbl, 43, 'Risk Plan', _db_risk_plan_text, status_bg(_db_risk_plan_state), _db_text)

var table _smc_dashboard = table.new(position.bottom_right, 2, 44, border_width = 0)

if show_dashboard and barstate.islast
    render_smc_dashboard_documented(_smc_dashboard)
else if barstate.islast
    table.clear(_smc_dashboard, 0, 0, 1, 43)

