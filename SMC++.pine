    plot_pivot_points(1, top_x, top, show_swing_points and not na(hh), d.LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_down), keep_history = keep_visual_history)
    plot_pivot_points(-1, btm_x, btm, show_swing_points and not na(ll), d.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_up), keep_history = keep_visual_history)

// UX-Fix:
