float bull_ob_live_event_level = any_live_bull_ob_break ? resolve_ob_alert_level(bull_live_broken_ob) : bull_ob_break_for_alert
FVG bull_live_filled_gap = any_live_bull_fvg_fill ? array.get(filled_fvgs_new_bull, array.size(filled_fvgs_new_bull) - 1) : na
float bull_fvg_live_event_level = any_live_bull_fvg_fill ? resolve_fvg_alert_level(bull_live_filled_gap) : bull_fvg_fill_for_alert
int best_live_bull_ob_idx = na
int best_live_bull_fvg_idx = na

if not any_live_bull_ob_break and array.size(ob_blocks_bull) > 0
    for i = array.size(ob_blocks_bull) - 1 to bull_ob_scan_start
        bull_ob_live_candidate = array.get(ob_blocks_bull, i)
        float bull_ob_live_candidate_level = resolve_ob_alert_level(bull_ob_live_candidate)
        float bull_ob_live_candidate_boundary = resolve_ob_bottom_boundary(bull_ob_live_candidate)
        float best_live_bull_ob_boundary = na
        if not na(best_live_bull_ob_idx)
            OrderBlock best_live_bull_ob = array.get(ob_blocks_bull, best_live_bull_ob_idx)
            best_live_bull_ob_boundary := resolve_ob_bottom_boundary(best_live_bull_ob)
        if low <= bull_ob_live_candidate_level and (na(best_live_bull_ob_idx) or bull_ob_live_candidate_boundary < best_live_bull_ob_boundary)
            best_live_bull_ob_idx := i
if not na(best_live_bull_ob_idx)
    any_live_bull_ob_break := true
    OrderBlock bull_live_ob = array.get(ob_blocks_bull, best_live_bull_ob_idx)
    bull_ob_live_event_level := resolve_ob_alert_level(bull_live_ob)


if not any_live_bull_fvg_fill and array.size(fvgs_bull) > 0
    for i = array.size(fvgs_bull) - 1 to bull_fvg_scan_start
        bull_fvg_live_candidate = array.get(fvgs_bull, i)
        float bull_fvg_live_candidate_level = resolve_fvg_alert_level(bull_fvg_live_candidate)
        float bull_fvg_live_candidate_boundary = resolve_fvg_bottom_boundary(bull_fvg_live_candidate)
        float best_live_bull_fvg_boundary = na
        if not na(best_live_bull_fvg_idx)
            FVG best_live_bull_fvg = array.get(fvgs_bull, best_live_bull_fvg_idx)
            best_live_bull_fvg_boundary := resolve_fvg_bottom_boundary(best_live_bull_fvg)
        if low <= bull_fvg_live_candidate_level and (na(best_live_bull_fvg_idx) or bull_fvg_live_candidate_boundary < best_live_bull_fvg_boundary)
            best_live_bull_fvg_idx := i
if not na(best_live_bull_fvg_idx)
    any_live_bull_fvg_fill := true
    FVG bull_live_fvg = array.get(fvgs_bull, best_live_bull_fvg_idx)
    bull_fvg_live_event_level := resolve_fvg_alert_level(bull_live_fvg)


float long_reclaim_ob_break_src = live_exec ? high : close
float long_reclaim_fvg_break_src = live_exec ? high : close
float long_reclaim_internal_break_src = live_exec ? high : close
float long_reclaim_swing_break_src = live_exec ? high : close
float long_reclaim_internal_level = nz(internal_trail_dn[1], internal_trail_dn)
float long_reclaim_swing_level = nz(trail_dn[1], trail_dn)
bool long_reclaim_bar_ok = live_exec ? true : barstate.isconfirmed
float touched_bull_ob_top_prev = nz(touched_bull_ob_top[1], touched_bull_ob_top)
float touched_bull_fvg_top_prev = nz(touched_bull_fvg_top[1], touched_bull_fvg_top)
bool new_touched_ob_source = not na(touched_bull_ob_id) and (na(touched_bull_ob_id[1]) or touched_bull_ob_id != touched_bull_ob_id[1])
bool new_touched_fvg_source = not na(touched_bull_fvg_id) and (na(touched_bull_fvg_id[1]) or touched_bull_fvg_id != touched_bull_fvg_id[1])
bool bull_reclaim_ob_cross = touched_bull_ob_still_active and not na(touched_bull_ob_top) and long_reclaim_ob_break_src > touched_bull_ob_top and (new_touched_ob_source ? low <= touched_bull_ob_top : nz(long_reclaim_ob_break_src[1], long_reclaim_ob_break_src) <= touched_bull_ob_top_prev)
bool bull_reclaim_fvg_cross = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and long_reclaim_fvg_break_src > touched_bull_fvg_top and (new_touched_fvg_source ? low <= touched_bull_fvg_top : nz(long_reclaim_fvg_break_src[1], long_reclaim_fvg_break_src) <= touched_bull_fvg_top_prev)
bool bull_reclaim_ob_wick_reclaim = touched_bull_ob_still_active and not na(touched_bull_ob_top) and low <= touched_bull_ob_top and open <= touched_bull_ob_top and long_reclaim_ob_break_src > touched_bull_ob_top
bool bull_reclaim_fvg_wick_reclaim = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and low <= touched_bull_fvg_top and open <= touched_bull_fvg_top and long_reclaim_fvg_break_src > touched_bull_fvg_top

bool bull_reclaim_ob = long_reclaim_bar_ok and touched_bull_ob_recent and not na(touched_bull_ob_top) and (bull_reclaim_ob_cross or bull_reclaim_ob_wick_reclaim)
bool bull_reclaim_fvg = long_reclaim_bar_ok and touched_bull_fvg_recent and not na(touched_bull_fvg_top) and (bull_reclaim_fvg_cross or bull_reclaim_fvg_wick_reclaim)
bool bull_reclaim_internal_low = long_reclaim_bar_ok and not na(long_reclaim_internal_level) and low < long_reclaim_internal_level and long_reclaim_internal_break_src > long_reclaim_internal_level
bool bull_reclaim_swing_low = long_reclaim_bar_ok and not na(long_reclaim_swing_level) and low < long_reclaim_swing_level and long_reclaim_swing_break_src > long_reclaim_swing_level
float bull_ob_zone_height = not na(touched_bull_ob_top) and not na(touched_bull_ob_bottom) ? math.max(touched_bull_ob_top - touched_bull_ob_bottom, syminfo.mintick) : na
float bull_fvg_zone_height = not na(touched_bull_fvg_top) and not na(touched_bull_fvg_bottom) ? math.max(touched_bull_fvg_top - touched_bull_fvg_bottom, syminfo.mintick) : na
float bull_ob_required_sweep_level = not na(bull_ob_zone_height) ? touched_bull_ob_top - bull_ob_zone_height * effective_ob_reclaim_min_penetration : na
float bull_fvg_required_sweep_level = not na(bull_fvg_zone_height) ? touched_bull_fvg_top - bull_fvg_zone_height * effective_fvg_reclaim_min_penetration : na
bool bull_ob_real_sweep = touched_bull_ob_still_active and not na(bull_ob_required_sweep_level) and low <= bull_ob_required_sweep_level
bool bull_fvg_real_sweep = touched_bull_fvg_still_active and not na(bull_fvg_required_sweep_level) and low <= bull_fvg_required_sweep_level
bool bull_reclaim_ob_strict = bull_reclaim_ob and (not use_strict_sequence or ob_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim or bull_ob_real_sweep)
bool bull_reclaim_fvg_strict = bull_reclaim_fvg and (not use_strict_sequence or fvg_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim or bull_fvg_real_sweep)
bool bull_reclaim_internal_low_strict = bull_reclaim_internal_low and (not use_strict_sequence or generic_zone_touch_sequence_ok)
bool bull_reclaim_swing_low_strict = bull_reclaim_swing_low and (not use_strict_sequence or generic_zone_touch_sequence_ok)
bool bull_reclaim_any = bull_reclaim_ob_strict or bull_reclaim_fvg_strict or bull_reclaim_internal_low_strict or bull_reclaim_swing_low_strict
bool bull_reclaim_any_for_arm = bull_reclaim_ob_strict or bull_reclaim_fvg_strict or ((bull_reclaim_internal_low_strict or bull_reclaim_swing_low_strict) and long_zone_active)

int zone_since_bars = ta.barssince(zone_touch_event)
int reclaim_since_bars = ta.barssince(bull_reclaim_any)
int internal_choch_since_bars = ta.barssince(internal_bull_choch_sig)
int internal_bos_since_bars = ta.barssince(internal_bull_bos_sig)
int main_bos_since_bars = ta.barssince(bull_bos_sig)

bool zone_recent = not na(zone_since_bars) and zone_since_bars <= long_signal_window
bool reclaim_recent = not na(reclaim_since_bars) and reclaim_since_bars <= long_signal_window
bool internal_choch_recent = not na(internal_choch_since_bars) and internal_choch_since_bars <= long_signal_window
bool internal_bos_recent = not na(internal_bos_since_bars) and internal_bos_since_bars <= long_signal_window
bool main_bos_recent = not na(main_bos_since_bars) and main_bos_since_bars <= long_signal_window

bool bearish_abort_signal = bear_bos_sig or bear_choch_sig or internal_bear_bos_sig or internal_bear_choch_sig
int bearish_abort_since_bars = ta.barssince(bearish_abort_signal)
bool bearish_abort_recent = not na(bearish_abort_since_bars) and bearish_abort_since_bars <= long_signal_window
bool long_confirm_bearish_guard_ok = not use_strict_confirm_guard or (not bearish_abort_signal and not bearish_abort_recent)

string long_zone_text = 'No Long Zone'
if zone_recent
    long_zone_text := 'Zone touched'
if in_bull_fvg_zone
    long_zone_text := 'In FVG Zone'
if in_bull_ob_zone
    long_zone_text := 'In OB Zone'
if in_bull_ob_zone and in_bull_fvg_zone
    long_zone_text := 'In OB + FVG Zone'

string reclaim_text = 'No Reclaim'
if reclaim_recent
    reclaim_text := 'Reclaim recent'
if bull_reclaim_internal_low_strict
    reclaim_text := 'Internal Low Reclaimed'
if bull_reclaim_swing_low_strict
    reclaim_text := 'Swing Low Reclaimed'
if bull_reclaim_fvg_strict
    reclaim_text := 'FVG Reclaimed'
if bull_reclaim_ob_strict
    reclaim_text := 'OB Reclaimed'

float long_invalidation_buffer = ob_threshold_atr * effective_long_invalidation_atr_mult
float prior_long_trigger_level = nz(ta.highest(high, long_confirm_lookback)[1], high)

// --------------------------------------------------
// Long dip state machine
// 1) stored state
// 2) invalidation rules
// 3) arm setup
// 4) confirm setup
// 5) ready state + visual state
// --------------------------------------------------

bool long_arm_signal = false
bool long_confirm_signal = false
bool long_invalidate_signal = false
string long_setup_text = 'No Setup'
int long_visual_state = 0
string long_visual_text = 'Neutral'
color long_bg_color = na
color long_bar_color = na
string arm_source_text = 'None'
string long_validation_source = 'None'
string long_setup_source_display = 'None'
float arm_invalidation_candidate = low
float arm_trigger_candidate = math.max(high, prior_long_trigger_level)
bool long_confirm_break = false
bool internal_choch_since_arm = false
bool internal_bos_since_arm = false
bool long_confirm_structure_ok = false
bool long_internal_structure_ok = false
bool long_building_state = false
bool long_plan_active = false
float long_stop_level = na
float long_risk_r = na
float long_target_1 = na
float long_target_2 = na
bool long_source_tracked = false
bool long_source_alive = true
bool long_source_lost = false
string arm_backing_zone_kind = 'None'
int arm_backing_zone_id = na

if bull_reclaim_ob_strict
    arm_source_text := 'OB'
    arm_invalidation_candidate := touched_bull_ob_bottom
    arm_backing_zone_kind := 'OB'
    arm_backing_zone_id := touched_bull_ob_id
else if bull_reclaim_fvg_strict
    arm_source_text := 'FVG'
    arm_invalidation_candidate := touched_bull_fvg_bottom
    arm_backing_zone_kind := 'FVG'
    arm_backing_zone_id := touched_bull_fvg_id
else if bull_reclaim_swing_low_strict
    arm_source_text := 'Swing Low'
    arm_invalidation_candidate := long_reclaim_swing_level
else if bull_reclaim_internal_low_strict
    arm_source_text := 'Internal Low'
    arm_invalidation_candidate := long_reclaim_internal_level
if arm_source_text == 'Swing Low' or arm_source_text == 'Internal Low'
    if in_bull_ob_zone and in_bull_fvg_zone
        bool ob_more_recent = na(last_fvg_zone_touch_bar_index) or (not na(last_ob_zone_touch_bar_index) and last_ob_zone_touch_bar_index >= last_fvg_zone_touch_bar_index)
        arm_backing_zone_kind := ob_more_recent ? 'OB' : 'FVG'
        arm_backing_zone_id := ob_more_recent ? active_bull_ob_id : active_bull_fvg_id
    else if in_bull_ob_zone
        arm_backing_zone_kind := 'OB'
        arm_backing_zone_id := active_bull_ob_id
    else if in_bull_fvg_zone
        arm_backing_zone_kind := 'FVG'
        arm_backing_zone_id := active_bull_fvg_id
    else if touched_bull_ob_recent and not na(touched_bull_ob_id)
        arm_backing_zone_kind := 'OB'
        arm_backing_zone_id := touched_bull_ob_id
    else if touched_bull_fvg_recent and not na(touched_bull_fvg_id)
        arm_backing_zone_kind := 'FVG'
        arm_backing_zone_id := touched_bull_fvg_id

// 2) Invalidation
if barstate.isnew
    long_invalidated_this_bar := false

bool close_safe_mode = live_exec or barstate.isconfirmed
int long_setup_age = long_setup_armed and not na(long_setup_arm_bar_index) ? bar_index - long_setup_arm_bar_index : 0
int long_confirm_age = long_setup_confirmed and not na(long_confirm_bar_index) ? bar_index - long_confirm_bar_index : 0
bool confirm_is_fresh = long_setup_armed and not na(long_setup_arm_bar_index) and long_setup_age <= max_bars_arm_to_confirm
bool ready_is_fresh = long_setup_confirmed and not na(long_confirm_bar_index) and long_confirm_age <= max_bars_confirm_to_ready
bool micro_setup_fresh_enough = not use_microstructure_profiles or not micro_is_fast_decay or not long_setup_armed or long_setup_confirmed or long_setup_age <= effective_fast_decay_setup_age_max
bool micro_confirm_fresh_enough = not use_microstructure_profiles or not micro_is_fast_decay or not long_setup_confirmed or long_confirm_age <= effective_fast_decay_confirm_age_max
bool micro_freshness_gate_ok = micro_setup_fresh_enough and micro_confirm_fresh_enough
// Snapshot des aktuell gelockten Sources VOR einer moeglichen Source-Upgrade-Entscheidung.
// Dadurch gewinnt eine echte Invalidierung des alten Sources immer gegen ein gleichzeitiges Upgrade.
string prev_locked_source_kind = long_locked_source_kind
int prev_locked_source_id = long_locked_source_id
bool prev_locked_source_tracked = not na(prev_locked_source_id)

OrderBlock prev_locked_bull_ob = prev_locked_source_kind == 'OB' ? get_by_id(ob_blocks_bull, prev_locked_source_id) : na
FVG prev_locked_bull_fvg = prev_locked_source_kind == 'FVG' ? get_by_id(fvgs_bull, prev_locked_source_id) : na

float long_locked_source_quality = prev_locked_source_kind == 'OB' ? ob_quality_score(prev_locked_bull_ob) : prev_locked_source_kind == 'FVG' ? fvg_quality_score(prev_locked_bull_fvg, fvg_size_threshold) : 0.0

bool prev_locked_source_alive = prev_locked_source_kind == 'OB' ? not na(prev_locked_bull_ob) : prev_locked_source_kind == 'FVG' ? not na(prev_locked_bull_fvg) : false

bool prev_locked_source_broken = prev_locked_source_kind == 'OB' ? contains_id(ob_broken_bull, prev_locked_source_id) or contains_id(ob_broken_new_bull, prev_locked_source_id) : prev_locked_source_kind == 'FVG' ? contains_id(filled_fvgs_bull, prev_locked_source_id) or contains_id(filled_fvgs_new_bull, prev_locked_source_id) : false

bool prev_locked_source_lost = (long_setup_armed or long_setup_confirmed) and prev_locked_source_tracked and not prev_locked_source_alive and not prev_locked_source_broken

bool prev_locked_source_invalid_now = prev_locked_source_tracked and (prev_locked_source_broken or prev_locked_source_lost)

// Upgrade nur erlauben, wenn der bisher gelockte Source in diesem Bar NICHT bereits invalid ist.
bool ob_source_upgrade_ok = allow_armed_source_upgrade and long_setup_armed and not long_setup_confirmed and not prev_locked_source_invalid_now and bull_reclaim_ob_strict and not na(touched_bull_ob_block) and (prev_locked_source_kind != 'OB' or prev_locked_source_id != touched_bull_ob_id) and touched_bull_ob_quality >= long_locked_source_quality + min_source_upgrade_quality_gain
bool fvg_source_upgrade_ok = allow_armed_source_upgrade and long_setup_armed and not long_setup_confirmed and not prev_locked_source_invalid_now and bull_reclaim_fvg_strict and not na(touched_bull_fvg_block) and (prev_locked_source_kind != 'FVG' or prev_locked_source_id != touched_bull_fvg_id) and touched_bull_fvg_quality >= long_locked_source_quality + min_source_upgrade_quality_gain

bool long_source_upgrade_now = ob_source_upgrade_ok or fvg_source_upgrade_ok
bool prefer_ob_upgrade = long_source_upgrade_now and ob_source_upgrade_ok and (not fvg_source_upgrade_ok or touched_bull_ob_quality >= touched_bull_fvg_quality)

string long_locked_source_kind_final = long_source_upgrade_now ? prefer_ob_upgrade ? 'OB' : 'FVG' : prev_locked_source_kind
int long_locked_source_id_final = long_source_upgrade_now ? prefer_ob_upgrade ? touched_bull_ob_id : touched_bull_fvg_id : prev_locked_source_id
string long_setup_backing_zone_kind_final = long_source_upgrade_now ? prefer_ob_upgrade ? 'OB' : 'FVG' : long_setup_backing_zone_kind
int long_setup_backing_zone_id_final = long_source_upgrade_now ? prefer_ob_upgrade ? touched_bull_ob_id : touched_bull_fvg_id : long_setup_backing_zone_id
int long_locked_source_touch_count_effective = select_locked_source_touch_count(long_source_upgrade_now, prefer_ob_upgrade, touched_bull_ob_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_touch_count, touched_bull_fvg_id, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_touch_count, long_locked_source_touch_count)
int long_locked_source_last_touch_bar_index_effective = long_source_upgrade_now and not na(long_locked_source_id_final) ? bar_index : long_locked_source_last_touch_bar_index
bool long_locked_source_alive_now = long_locked_source_kind_final == 'OB' ? contains_id(ob_blocks_bull, long_locked_source_id_final) : long_locked_source_kind_final == 'FVG' ? contains_id(fvgs_bull, long_locked_source_id_final) : false
float long_locked_source_top_now = long_locked_source_kind_final == 'OB' and long_locked_source_id_final == active_bull_ob_id ? active_bull_ob_top : long_locked_source_kind_final == 'OB' and long_locked_source_id_final == touched_bull_ob_id ? touched_bull_ob_top : long_locked_source_kind_final == 'FVG' and long_locked_source_id_final == active_bull_fvg_id ? active_bull_fvg_top : long_locked_source_kind_final == 'FVG' and long_locked_source_id_final == touched_bull_fvg_id ? touched_bull_fvg_top : long_locked_source_alive_now and not long_source_upgrade_now and long_locked_source_kind_final == prev_locked_source_kind and long_locked_source_id_final == prev_locked_source_id ? long_locked_source_top : na
float long_locked_source_bottom_now = long_locked_source_kind_final == 'OB' and long_locked_source_id_final == active_bull_ob_id ? active_bull_ob_bottom : long_locked_source_kind_final == 'OB' and long_locked_source_id_final == touched_bull_ob_id ? touched_bull_ob_bottom : long_locked_source_kind_final == 'FVG' and long_locked_source_id_final == active_bull_fvg_id ? active_bull_fvg_bottom : long_locked_source_kind_final == 'FVG' and long_locked_source_id_final == touched_bull_fvg_id ? touched_bull_fvg_bottom : long_locked_source_alive_now and not long_source_upgrade_now and long_locked_source_kind_final == prev_locked_source_kind and long_locked_source_id_final == prev_locked_source_id ? long_locked_source_bottom : na
bool long_locked_source_in_zone = long_locked_source_alive_now and not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now) and math.min(high, long_locked_source_top_now) - math.max(low, long_locked_source_bottom_now) >= 0
bool long_locked_source_touch_now = long_locked_source_in_zone and (not long_locked_source_in_zone[1] or long_locked_source_id_final != long_locked_source_id_final[1] or long_locked_source_kind_final != long_locked_source_kind_final[1])
if state_update_bar_ok and (long_setup_armed or long_setup_confirmed) and long_locked_source_touch_now and long_locked_source_last_touch_bar_index_effective != bar_index and not na(long_locked_source_id_final)
    long_locked_source_touch_count_effective += 1
    long_locked_source_last_touch_bar_index_effective := bar_index
bool long_locked_source_touch_recent = (long_setup_armed or long_setup_confirmed) and not na(long_locked_source_last_touch_bar_index_effective) and bar_index - long_locked_source_last_touch_bar_index_effective <= long_signal_window
float long_locked_source_zone_height = not na(long_locked_source_top_now) and not na(long_locked_source_bottom_now) ? math.max(long_locked_source_top_now - long_locked_source_bottom_now, syminfo.mintick) : na
float long_locked_ob_required_sweep_level = long_locked_source_kind_final == 'OB' and not na(long_locked_source_zone_height) ? long_locked_source_top_now - long_locked_source_zone_height * effective_ob_reclaim_min_penetration : na
float long_locked_fvg_required_sweep_level = long_locked_source_kind_final == 'FVG' and not na(long_locked_source_zone_height) ? long_locked_source_top_now - long_locked_source_zone_height * effective_fvg_reclaim_min_penetration : na
bool long_locked_ob_real_sweep = long_locked_source_kind_final == 'OB' and long_locked_source_alive_now and not na(long_locked_ob_required_sweep_level) and low <= long_locked_ob_required_sweep_level
bool long_locked_fvg_real_sweep = long_locked_source_kind_final == 'FVG' and long_locked_source_alive_now and not na(long_locked_fvg_required_sweep_level) and low <= long_locked_fvg_required_sweep_level
if long_source_upgrade_now
    long_setup_backing_zone_kind := long_setup_backing_zone_kind_final
    long_setup_backing_zone_id := long_setup_backing_zone_id_final
    long_setup_backing_zone_touch_count := long_locked_source_touch_count_effective
    long_locked_source_kind := long_locked_source_kind_final
    long_locked_source_id := long_locked_source_id_final
if state_update_bar_ok or long_source_upgrade_now
    long_locked_source_touch_count := long_locked_source_touch_count_effective
    long_locked_source_last_touch_bar_index := long_locked_source_last_touch_bar_index_effective
if long_locked_source_alive_now
    long_locked_source_top := long_locked_source_top_now
    long_locked_source_bottom := long_locked_source_bottom_now
long_source_tracked := not na(long_locked_source_id)
long_source_alive := not long_source_tracked ? true : long_locked_source_alive_now
bool long_source_broken = long_locked_source_kind_final == 'OB' ? contains_id(ob_broken_bull, long_locked_source_id_final) or contains_id(ob_broken_new_bull, long_locked_source_id_final) : long_locked_source_kind_final == 'FVG' ? contains_id(filled_fvgs_bull, long_locked_source_id_final) or contains_id(filled_fvgs_new_bull, long_locked_source_id_final) : false
long_source_lost := (long_setup_armed or long_setup_confirmed) and long_source_tracked and not long_source_alive and not long_source_broken
bool long_setup_expired = long_setup_armed and not long_setup_confirmed and long_setup_age > long_setup_expiry_bars
bool long_confirm_expired = long_setup_confirmed and long_confirm_age > long_confirm_expiry_bars
float long_invalidation_break_src = live_exec and effective_use_live_invalidation_break ? low : close
bool long_broken_down = not na(long_invalidation_level) and long_invalidation_break_src < long_invalidation_level - long_invalidation_buffer
bool long_invalidated_now = long_source_broken or long_source_lost or (close_safe_mode and (long_broken_down or long_setup_expired or long_confirm_expired))
bool invalidated_prior_setup = false
string long_validation_source_now = long_locked_source_kind_final == 'OB' ? 'OB' : long_locked_source_kind_final == 'FVG' ? 'FVG' : 'None'
string long_setup_source_display_now = compose_long_setup_source_display(long_entry_origin_source, long_validation_source_now)

if long_invalidated_now
    long_last_invalid_source := resolve_long_invalidation_reason(long_source_broken, long_source_lost, long_setup_expired, long_confirm_expired, long_validation_source_now, long_entry_origin_source, long_setup_source_display_now)
    long_last_invalid_level := long_invalidation_level
    long_invalidate_signal := long_setup_armed or long_setup_confirmed
    invalidated_prior_setup := long_invalidate_signal
    long_invalidated_this_bar := long_invalidate_signal
    long_setup_armed := false
    long_setup_confirmed := false
    long_setup_arm_bar_index := na
    long_confirm_bar_index := na
    long_setup_trigger := na
    long_invalidation_level := na
    long_entry_origin_source := 'None'
    long_setup_backing_zone_kind := 'None'
    long_setup_backing_zone_id := na
    long_setup_backing_zone_touch_count := 0
    long_locked_source_kind := 'None'
    long_locked_source_id := na
    long_locked_source_top := na
    long_locked_source_bottom := na
    long_locked_source_touch_count := 0
    long_locked_source_last_touch_bar_index := na

// 3) Arm setup
bool armed_prequality_ok = not tighten_armed_stage or (bullish_trend_safe and micro_session_gate_ok and zone_touch_quality_ok and bull_close_strong and ema_support_ok)
if bull_reclaim_any_for_arm and (use_strict_sequence ? zone_touch_event_recent : zone_recent) and not long_setup_armed and not long_invalidated_this_bar and micro_session_gate_ok and sd_armed_gate_ok and armed_prequality_ok
    long_arm_signal := true
    long_setup_armed := true
    long_setup_confirmed := false
    long_setup_arm_bar_index := bar_index
    long_confirm_bar_index := na
    long_setup_trigger := arm_trigger_candidate
    long_invalidation_level := arm_invalidation_candidate
    long_entry_origin_source := arm_source_text
    long_setup_backing_zone_kind := arm_backing_zone_kind
    long_setup_backing_zone_id := arm_backing_zone_id
    long_setup_backing_zone_touch_count := select_long_arm_backing_zone_touch_count(arm_backing_zone_kind, arm_backing_zone_id, active_ob_touch_id, active_ob_touch_count, touched_bull_ob_id, touched_bull_ob_touch_count, active_fvg_touch_id, active_fvg_touch_count, touched_bull_fvg_id, touched_bull_fvg_touch_count)
    long_locked_source_kind := arm_backing_zone_kind
    long_locked_source_id := arm_backing_zone_kind == 'OB' ? arm_backing_zone_id : arm_backing_zone_kind == 'FVG' ? arm_backing_zone_id : na
    long_locked_source_top := arm_backing_zone_kind == 'OB' and arm_backing_zone_id == active_bull_ob_id ? active_bull_ob_top : arm_backing_zone_kind == 'OB' and arm_backing_zone_id == touched_bull_ob_id ? touched_bull_ob_top : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == active_bull_fvg_id ? active_bull_fvg_top : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == touched_bull_fvg_id ? touched_bull_fvg_top : na
    long_locked_source_bottom := arm_backing_zone_kind == 'OB' and arm_backing_zone_id == active_bull_ob_id ? active_bull_ob_bottom : arm_backing_zone_kind == 'OB' and arm_backing_zone_id == touched_bull_ob_id ? touched_bull_ob_bottom : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == active_bull_fvg_id ? active_bull_fvg_bottom : arm_backing_zone_kind == 'FVG' and arm_backing_zone_id == touched_bull_fvg_id ? touched_bull_fvg_bottom : na
    long_locked_source_touch_count := long_setup_backing_zone_touch_count
    long_locked_source_last_touch_bar_index := not na(long_locked_source_id) ? bar_index : na
    long_setup_serial += 1

// 4) Confirm setup
float long_confirm_break_src = live_exec and effective_use_live_confirm_break ? high : close
long_confirm_break := long_setup_armed and not long_setup_confirmed and not na(long_setup_arm_bar_index) and bar_index > long_setup_arm_bar_index and long_confirm_break_src > long_setup_trigger
internal_choch_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_choch_since_bars) and internal_choch_since_bars <= bar_index - long_setup_arm_bar_index
internal_bos_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_bos_since_bars) and internal_bos_since_bars <= bar_index - long_setup_arm_bar_index
long_internal_structure_ok := long_internal_structure_mode == 'Internal CHoCH only' ? (internal_bull_choch_sig or internal_choch_since_arm) : (internal_bull_choch_sig or internal_bull_bos_sig or internal_choch_since_arm or internal_bos_since_arm)
long_confirm_structure_ok := not require_internal_break_for_confirm
if not long_confirm_structure_ok
    long_confirm_structure_ok := long_internal_structure_ok

// 5) Ready state + visuals
long_plan_active := (long_setup_armed or long_setup_confirmed) and not na(long_setup_trigger) and not na(long_invalidation_level)
float long_planned_stop_level = long_plan_active ? long_invalidation_level - ob_threshold_atr * stop_buffer_atr_mult : na
if long_setup_armed or long_setup_confirmed
    long_setup_backing_zone_touch_count := long_locked_source_touch_count
float overhead_scan_reference = long_plan_active and not na(long_setup_trigger) ? long_setup_trigger : close
float nearest_bear_ob_blocker_level = na
if array.size(ob_blocks_bear) > 0
    for i = array.size(ob_blocks_bear) - 1 to bear_ob_scan_start
        bear_ob_blocker = array.get(ob_blocks_bear, i)
        float bear_ob_blocker_level = resolve_ob_alert_level(bear_ob_blocker)
        if not na(bear_ob_blocker_level) and bear_ob_blocker_level >= overhead_scan_reference and (na(nearest_bear_ob_blocker_level) or bear_ob_blocker_level < nearest_bear_ob_blocker_level)
            nearest_bear_ob_blocker_level := bear_ob_blocker_level
float nearest_bear_fvg_blocker_level = na
if array.size(fvgs_bear) > 0
    for i = array.size(fvgs_bear) - 1 to bear_fvg_scan_start
        bear_fvg_blocker = array.get(fvgs_bear, i)
        float bear_fvg_blocker_level = resolve_fvg_alert_level(bear_fvg_blocker)
        if not na(bear_fvg_blocker_level) and bear_fvg_blocker_level >= overhead_scan_reference and (na(nearest_bear_fvg_blocker_level) or bear_fvg_blocker_level < nearest_bear_fvg_blocker_level)
            nearest_bear_fvg_blocker_level := bear_fvg_blocker_level
float nearest_overhead_level = na
if not na(nearest_bear_ob_blocker_level) and not na(nearest_bear_fvg_blocker_level)
    nearest_overhead_level := math.min(nearest_bear_ob_blocker_level, nearest_bear_fvg_blocker_level)
else
    nearest_overhead_level := not na(nearest_bear_ob_blocker_level) ? nearest_bear_ob_blocker_level : nearest_bear_fvg_blocker_level
float planned_risk = long_plan_active and not na(long_planned_stop_level) ? math.max(long_setup_trigger - long_planned_stop_level, syminfo.mintick) : na
float headroom_to_overhead = not na(nearest_overhead_level) and long_plan_active ? nearest_overhead_level - long_setup_trigger : na
bool overhead_zone_ok = not use_overhead_zone_filter or na(headroom_to_overhead) or na(planned_risk) or headroom_to_overhead >= planned_risk * min_headroom_r
bool htf_alignment_ok = (mtf_trend_1 > 0 ? 1 : 0) + (mtf_trend_2 > 0 ? 1 : 0) + (mtf_trend_3 > 0 ? 1 : 0) >= 2
bool strict_entry_ltf_ok = not use_ltf_for_strict_entry or (strict_ltf_available and ltf_volume_delta >= 0) or (allow_strict_entry_without_ltf and (strict_ltf_unavailable or strict_ltf_unverifiable))
bool relvol_score_unavailable = use_rel_volume and not relvol_data_ok and allow_relvol_without_volume_data
int context_quality_vwap_weight = use_vwap_filter ? 1 : 0
int context_quality_score = 0
context_quality_score += bullish_trend_safe ? score_weight_structure : 0
context_quality_score += htf_alignment_ok ? score_weight_htf : 0
context_quality_score += ema_support_ok ? score_weight_ema : 0
context_quality_score += adx_strong ? score_weight_adx : 0
context_quality_score += bull_close_strong ? score_weight_close : 0
context_quality_score += relvol_score_ok ? score_weight_relvol : 0
context_quality_score += vwap_filter_ok ? context_quality_vwap_weight : 0
int context_quality_max_score = score_weight_structure + score_weight_htf + score_weight_ema + score_weight_adx + score_weight_close + score_weight_relvol + context_quality_vwap_weight
int effective_context_quality_max_score = context_quality_max_score - (relvol_score_unavailable ? score_weight_relvol : 0)
int effective_min_context_quality_score = math.min(min_context_quality_score, effective_context_quality_max_score)
bool context_quality_gate_ok = not use_context_quality_score or context_quality_score >= effective_min_context_quality_score
bool environment_hard_gate_ok = market_regime_gate_ok and vola_regime_gate_safe
bool quality_gate_ok = context_quality_gate_ok
bool microstructure_entry_gate_ok = micro_session_gate_ok and micro_freshness_gate_ok
bool trade_hard_gate_ok = session_structure_gate_ok and micro_session_gate_ok and micro_freshness_gate_ok and overhead_zone_ok
string long_environment_focus_display = not market_regime_gate_ok ? 'Market Block' : not vola_regime_gate_safe ? 'Vola Block' : 'Env OK'
string freshness_text = describe_long_freshness(long_setup_armed, long_setup_confirmed, ready_is_fresh, confirm_is_fresh)
string source_state_text = describe_long_source_state(long_source_tracked, long_source_alive, long_source_broken)
long_validation_source := long_locked_source_kind == 'OB' ? 'OB' : long_locked_source_kind == 'FVG' ? 'FVG' : 'None'
long_setup_source_display := compose_long_setup_source_display(long_entry_origin_source, long_validation_source)
int effective_long_active_touch_count = select_effective_long_touch_count(long_setup_armed, long_setup_confirmed, long_setup_backing_zone_touch_count, bull_reclaim_ob_strict, in_bull_ob_zone, in_bull_fvg_zone, active_ob_touch_count, bull_reclaim_fvg_strict, active_fvg_touch_count, active_zone_touch_count)
bool effective_zone_touch_quality_ok = not block_third_touch or effective_long_active_touch_count <= max_zone_touches_for_entry
bool setup_hard_gate_ok = effective_zone_touch_quality_ok
string zone_quality_text = describe_long_zone_quality(long_zone_active, long_setup_armed, long_setup_confirmed, effective_long_active_touch_count)
string overhead_text = not use_overhead_zone_filter ? 'off' : na(headroom_to_overhead) or na(planned_risk) ? 'clear' : str.tostring(headroom_to_overhead / planned_risk, '#.##') + 'R'
string long_score_detail_suffix = ' | ctx=' + str.tostring(context_quality_score) + '/' + str.tostring(effective_min_context_quality_score)
string long_strict_alert_suffix = (use_strict_sequence or use_strict_sweep_for_zone_reclaim or use_strict_confirm_guard) ? ' | strict=on' : ''
string long_environment_alert_suffix = ' | env=' + long_environment_focus_display + ' | overhead=' + overhead_text
string long_micro_alert_suffix = use_microstructure_profiles ? ' | micro=' + micro_profile_text + ' | freshness=' + freshness_text + ' | source=' + source_state_text + ' | zone=' + zone_quality_text : ''
bool confirm_hard_gate_ok = micro_session_gate_ok and micro_freshness_gate_ok
bool confirm_upgrade_gate_ok = accel_confirm_gate_ok and sd_confirmed_gate_ok
bool confirm_lifecycle_ok = close_safe_mode and long_confirm_break and long_confirm_structure_ok and confirm_is_fresh and long_confirm_bearish_guard_ok
bool confirm_filters_ok = confirm_hard_gate_ok and confirm_upgrade_gate_ok
if confirm_lifecycle_ok and confirm_filters_ok
    long_setup_confirmed := true
    long_confirm_bar_index := bar_index
    long_confirm_signal := true

bool long_setup_in_progress = long_setup_armed and not long_setup_confirmed
long_building_state := long_setup_armed and long_internal_structure_ok and not long_setup_confirmed
bool ready_bar_gap_ok = not na(long_confirm_bar_index) and bar_index > long_confirm_bar_index
bool lifecycle_ready_ok = close_safe_mode and long_setup_confirmed and ready_bar_gap_ok and not long_confirm_expired and ready_is_fresh and long_confirm_bearish_guard_ok and (not require_main_break_for_ready or bull_bos_sig or main_bos_recent)
bool long_ready_state = lifecycle_ready_ok and setup_hard_gate_ok and trade_hard_gate_ok and environment_hard_gate_ok and quality_gate_ok and accel_ready_gate_ok and sd_ready_gate_ok and vol_ready_context_ok and stretch_ready_context_ok and ddvi_ready_ok_safe
bool long_entry_best_state = long_ready_state and accel_entry_best_gate_ok and sd_entry_best_gate_ok and vol_entry_best_context_ok_safe and stretch_entry_best_context_ok and ddvi_entry_best_ok_safe
bool long_entry_strict_state = long_ready_state and strict_entry_ltf_ok and htf_alignment_ok and accel_strict_entry_gate_ok and sd_entry_strict_gate_ok and vol_entry_strict_context_ok_safe and stretch_entry_strict_context_ok and ddvi_entry_strict_ok_safe
// Clean is a diagnostic alert/dashboard tier, not lifecycle progression.
bool long_quality_clean_tier = close_safe_mode and bullish_trend_safe and zone_recent and reclaim_recent and long_setup_confirmed and setup_hard_gate_ok and trade_hard_gate_ok and environment_hard_gate_ok and quality_gate_ok and bull_close_strong and ema_support_ok and adx_strong and relvol_ok and vwap_filter_ok
if long_plan_active
    long_stop_level := long_planned_stop_level
    long_risk_r := math.max(long_setup_trigger - long_stop_level, syminfo.mintick)
    long_target_1 := long_setup_trigger + long_risk_r * target1_r
    long_target_2 := long_setup_trigger + long_risk_r * target2_r

float long_mean_target = na
if long_plan_active and show_mean_target_overlay and not na(stretch_mean)
    long_mean_target := stretch_mean > long_setup_trigger ? stretch_mean : na

varip int long_ready_state_rt_prev = 0
varip bool long_ready_fired_this_bar = false
if barstate.isnew
    long_ready_state_rt_prev := long_ready_state[1] ? 1 : 0
    long_ready_fired_this_bar := false
bool long_ready_signal = long_ready_state and long_ready_state_rt_prev == 0 and not long_ready_fired_this_bar
if long_ready_signal
    long_ready_fired_this_bar := true
long_ready_state_rt_prev := long_ready_state ? 1 : 0

long_setup_text := compose_long_setup_text(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidated_now, invalidated_prior_setup, long_invalidated_this_bar, long_setup_source_display)

long_visual_state := resolve_long_visual_state(long_zone_active, long_setup_armed, long_building_state, long_setup_confirmed, long_ready_state, long_entry_best_state, long_entry_strict_state, long_invalidate_signal, invalidated_prior_setup, long_invalidated_now, long_invalidated_this_bar)


// Lifecycle axis stays pure. Quality is shown in separate dashboard rows.
long_visual_text := resolve_long_visual_text(long_visual_state)
long_bg_color := resolve_long_bg_color(long_visual_state, long_color_building)
long_bar_color := resolve_long_bar_color(long_visual_state, long_color_building)

if live_exec
    if not live_bull_ob_break and any_live_bull_ob_break
        live_bull_ob_break := true
    if not live_bull_fvg_fill and any_live_bull_fvg_fill
        live_bull_fvg_fill := true

var int last_reclaim_marker_bar = na
var int last_long_state_marker_bar = na
var int last_long_ready_marker_bar = na
var label[] reclaim_marker_history = array.new<label>(0)
var label[] long_state_marker_history = array.new<label>(0)
var label[] long_ready_marker_history = array.new<label>(0)
if barstate.islast
    u.trim_label_history(reclaim_marker_history, show_reclaim_markers ? long_marker_history_limit : 0)
    u.trim_label_history(long_state_marker_history, show_long_confirmation_markers ? long_marker_history_limit : 0)
    u.trim_label_history(long_ready_marker_history, show_long_confirmation_markers ? long_marker_history_limit : 0)
bool can_draw_reclaim_marker = na(last_reclaim_marker_bar) or effective_reclaim_marker_gap <= 0 or bar_index - last_reclaim_marker_bar >= effective_reclaim_marker_gap
bool can_draw_long_state_marker = na(last_long_state_marker_bar) or effective_confirm_marker_gap <= 0 or bar_index - last_long_state_marker_bar >= effective_confirm_marker_gap
bool can_draw_long_ready_marker = na(last_long_ready_marker_bar) or effective_ready_marker_gap <= 0 or bar_index - last_long_ready_marker_bar >= effective_ready_marker_gap

if show_reclaim_markers and bull_reclaim_ob_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_ob_label = label.new(bar_index, low, TXT_RECLAIM_OB, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    u.push_capped_label(reclaim_marker_history, reclaim_ob_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_fvg_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_fvg_label = label.new(bar_index, low, TXT_RECLAIM_FVG, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    u.push_capped_label(reclaim_marker_history, reclaim_fvg_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_swing_low_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_swing_label = label.new(bar_index, low, TXT_RECLAIM_SWING, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    u.push_capped_label(reclaim_marker_history, reclaim_swing_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_internal_low_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_internal_label = label.new(bar_index, low, TXT_RECLAIM_INTERNAL, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.tiny)
    u.push_capped_label(reclaim_marker_history, reclaim_internal_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

plotshape(show_strict_debug_markers and zone_touch_event, title = 'Zone Touch Event', style = shape.circle, location = location.belowbar, color = color.aqua, size = size.tiny, text = 'ZT')
plotshape(show_strict_debug_markers and bull_ob_real_sweep, title = 'OB Sweep OK', style = shape.circle, location = location.belowbar, color = color.orange, size = size.tiny, text = 'OBS')
plotshape(show_strict_debug_markers and bull_fvg_real_sweep, title = 'FVG Sweep OK', style = shape.circle, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'FVS')
plotshape(show_strict_debug_markers and bull_reclaim_ob_strict, title = 'OB Reclaim Strict', style = shape.triangleup, location = location.belowbar, color = color.orange, size = size.tiny, text = 'ROB')
plotshape(show_strict_debug_markers and bull_reclaim_fvg_strict, title = 'FVG Reclaim Strict', style = shape.triangleup, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'RFV')
plotshape(show_strict_debug_markers and long_confirm_break and not long_confirm_bearish_guard_ok, title = 'Confirm Blocked By Bearish Abort', style = shape.xcross, location = location.abovebar, color = color.red, size = size.tiny, text = 'XCONF')
plotshape(show_accel_debug and accel_below_zero_rising_safe, title = 'Accel Below Zero Rising', style = shape.circle, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'ACC↑')
plotshape(show_accel_debug and accel_cross_up_safe, title = 'Accel Cross Up', style = shape.circle, location = location.belowbar, color = color.aqua, size = size.tiny, text = 'XUP')
plotshape(show_accel_debug and accel_above_zero, title = 'Accel Above Zero', style = shape.circle, location = location.abovebar, color = color.lime, size = size.tiny, text = 'ACC+')
plotshape(show_sd_debug and sd_bullish_divergence_event, title = 'Bullish SD Divergence', style = shape.circle, location = location.belowbar, color = color.aqua, size = size.tiny, text = 'DIV')
plotshape(show_sd_debug and sd_higher_lows_event, title = 'SD Higher Lows', style = shape.circle, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'HL')
plotshape(show_sd_debug and sd_support_both_recent, title = 'SD Strong Confluence', style = shape.circle, location = location.belowbar, color = color.lime, size = size.tiny, text = 'DIV+HL')
plotshape(show_vol_regime_debug and vol_squeeze_on, title = 'Vol Squeeze On', style = shape.circle, location = location.belowbar, color = color.orange, size = size.tiny, text = 'SQZ')
plotshape(show_vol_regime_debug and vol_squeeze_released, title = 'Vol Squeeze Release', style = shape.circle, location = location.belowbar, color = color.aqua, size = size.tiny, text = 'REL')
plotshape(show_vol_regime_debug and vol_regime_trend_ok, title = 'Vol Bull Stack', style = shape.circle, location = location.abovebar, color = color.lime, size = size.tiny, text = 'STACK')
plotshape(show_vol_regime_debug and vol_momentum_expanding_long and vol_stack_spread_rising, title = 'Vol Expansion Bias', style = shape.circle, location = location.abovebar, color = color.yellow, size = size.tiny, text = 'EXP')
plotshape(show_microstructure_debug and micro_session_gate_ok and zone_recent, title = 'Micro Session OK', style = shape.circle, location = location.belowbar, color = color.blue, size = size.tiny, text = 'uOK')
plotshape(show_microstructure_debug and not micro_session_gate_ok and zone_recent, title = 'Micro Session Blocked', style = shape.xcross, location = location.abovebar, color = color.red, size = size.tiny, text = 'uBLK')
plotshape(show_microstructure_debug and micro_is_stop_hunt and bull_reclaim_any, title = 'Stop-hunt profile active', style = shape.circle, location = location.belowbar, color = color.orange, size = size.tiny, text = 'uSH')
plotshape(show_microstructure_debug and not micro_freshness_gate_ok and (long_setup_armed or long_setup_confirmed), title = 'Micro Freshness Blocked', style = shape.xcross, location = location.abovebar, color = color.red, size = size.tiny, text = 'uSTALE')

if show_long_confirmation_markers and internal_bull_choch_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    int_reversal_label = label.new(bar_index, high, TXT_INT_REVERSAL, color = #00000000, textcolor = long_color_reversal, style = label.style_label_down, size = size.tiny)
    u.push_capped_label(long_state_marker_history, int_reversal_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and internal_bull_bos_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    int_break_label = label.new(bar_index, high, TXT_INT_BREAK, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.tiny)
    u.push_capped_label(long_state_marker_history, int_break_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and bull_bos_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    trend_confirm_label = label.new(bar_index, high, TXT_TREND_CONFIRM, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    u.push_capped_label(long_state_marker_history, trend_confirm_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_arm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    long_armed_label = label.new(bar_index, low, TXT_LONG_ARMED, color = #00000000, textcolor = long_color_zone, style = label.style_label_up, size = size.small)
    u.push_capped_label(long_state_marker_history, long_armed_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_confirm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    long_confirmed_label = label.new(bar_index, high, TXT_LONG_CONFIRMED, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.small)
    u.push_capped_label(long_state_marker_history, long_confirmed_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_ready_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    long_ready_label = label.new(bar_index, high, TXT_LONG_READY, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    u.push_capped_label(long_ready_marker_history, long_ready_label, long_marker_history_limit)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_long_confirmation_markers and long_invalidate_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    long_invalidated_label = label.new(bar_index, high, TXT_LONG_INVALIDATED, color = #00000000, textcolor = long_color_invalid, style = label.style_label_down, size = size.tiny)
    u.push_capped_label(long_ready_marker_history, long_invalidated_label, long_marker_history_limit)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_htf_fvg and barstate.islast
    draw(htf_fvg_buffer_bull, htf_fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)

    if htf_fvg_keep_filled and htf_fvg_keep_filled_max > 0
        draw(htf_fvg_buffer_bull_filled, htf_fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        delete(htf_fvg_buffer_bull_filled)

    if barstate.isconfirmed
        delete(htf_fvg_buffer_bull_discarded)
        array.clear(htf_fvg_buffer_bull_discarded)

var g_eq = 'Equal Highs / Lows'
var show_eq = input.bool(false, 'Equal High / Low', group = g_eq, tooltip = SHOW_EQHL)
var eq_len = input.int(3, 'Bars Confirmation', minval = 1, group = g_eq, tooltip = EQHL_BARS)
var eq_threshold_in = input.float(0.1, 'Threshold', minval = 0, maxval = 0.5, step = 0.1, group = g_eq, tooltip = EQHL_THRESHOLD)

eq_atr = smc_lib_atr(ATR_LEN_MAIN)
eq_threshold = eq_threshold_in * eq_atr
[eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_levels(eq_len, eq_threshold, enabled = show_eq)

d.LabelArgs eqh_label_args = d.LabelArgs.new(bear_css, #00000000, style = label.style_label_down, size = size.tiny)
d.LineArgs eqh_line_args = d.LineArgs.new(bear_css, line.style_dotted)
d.LabelArgs eql_label_args = d.LabelArgs.new(bull_css, #00000000, style = label.style_label_up, size = size.tiny)
d.LineArgs eql_line_args = d.LineArgs.new(bull_css, line.style_dotted)

plot_equal_level(show_eq and eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, 'EQH', eqh_label_args, eqh_line_args, keep_history = keep_visual_history, force_overlay = false)
plot_equal_level(show_eq and eql_alert, eql_x1, eql_y1, eql_x2, eql_y2, 'EQL', eql_label_args, eql_line_args, keep_history = keep_visual_history, force_overlay = false)

bgcolor(show_long_background ? long_bg_color : na, title = 'Long-only Background')
barcolor(color_long_bars ? long_bar_color : na)
plot(show_risk_levels and long_plan_active ? long_setup_trigger : na, 'Long Trigger', color = color.new(color.aqua, 0), linewidth = 2, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_invalidation_level : na, 'Long Invalidation', color = color.new(color.orange, 0), linewidth = 1, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_stop_level : na, 'Long Stop', color = color.new(color.red, 0), linewidth = 2, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_target_1 : na, 'Long Target 1', color = color.new(color.lime, 0), linewidth = 1, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_target_2 : na, 'Long Target 2', color = color.new(color.green, 0), linewidth = 1, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active and show_mean_target_overlay ? long_mean_target : na, 'Long Mean Target', color = color.new(color.blue, 0), linewidth = 2, style = plot.style_linebr)
plot(show_stretch_overlay ? stretch_mean : na, 'Stretch Mean', color = color.new(color.blue, 45), linewidth = 1, style = plot.style_linebr)
plot(show_stretch_overlay ? stretch_lower_threshold : na, 'Lower Extreme Threshold', color = color.new(color.aqua, 0), linewidth = 1, style = plot.style_linebr)
bgcolor(show_lower_extreme_bg and in_lower_extreme ? color.new(color.aqua, 90) : na, title = 'Lower Extreme Background')

// --------------------------------------------------
// Long-dip alert presets
// --------------------------------------------------
alert_long_watchlist = bullish_trend_safe and long_zone_active_safe and vol_watchlist_context_ok_safe and stretch_watchlist_context_ok_safe and ddvi_watchlist_ok_safe
alert_long_armed = bullish_trend_safe and zone_recent and reclaim_recent and long_setup_in_progress
alert_long_early = bullish_trend_safe and long_setup_in_progress and zone_recent and reclaim_recent and long_internal_structure_ok and bull_close_strong and ema_support_ok and accel_early_gate_ok and sd_early_gate_ok
alert_long_clean = long_quality_clean_tier
alert_long_entry_best = long_entry_best_state
float long_watchlist_alert_level = na
if not na(active_bull_ob_id) and (na(active_bull_fvg_id) or prefer_active_ob_zone)
    long_watchlist_alert_level := active_bull_ob_bottom
else if not na(active_bull_fvg_id)
    long_watchlist_alert_level := active_bull_fvg_bottom
else
    long_watchlist_alert_level := not na(last_bull_ob_bottom) ? last_bull_ob_bottom : not na(last_bull_fvg_bottom) ? last_bull_fvg_bottom : low
float long_early_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_clean_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_entry_best_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_entry_strict_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
alert_long_entry_strict = long_entry_strict_state
alert_long_fail = long_invalidate_signal
var int long_watchlist_serial = 0
varip int long_watchlist_rt_prev_active = 0
varip bool long_watchlist_fired_this_bar = false
if barstate.isnew
    long_watchlist_rt_prev_active := alert_long_watchlist[1] ? 1 : 0
    long_watchlist_fired_this_bar := false
bool long_watchlist_started = alert_long_watchlist and long_watchlist_rt_prev_active == 0 and not long_watchlist_fired_this_bar
if long_watchlist_started
    long_watchlist_serial += 1
    long_watchlist_fired_this_bar := true
long_watchlist_rt_prev_active := alert_long_watchlist ? 1 : 0
var int last_long_armed_alert_serial = na
var int last_long_early_alert_serial = na
var int last_long_clean_alert_serial = na
var int last_long_entry_best_alert_serial = na
var int last_long_entry_strict_alert_serial = na
bool alert_long_watchlist_event = long_watchlist_started and long_watchlist_serial > 0
bool alert_long_early_event = alert_long_early and long_setup_serial > 0 and last_long_early_alert_serial != long_setup_serial
last_long_early_alert_serial := alert_long_early_event ? long_setup_serial : last_long_early_alert_serial
bool suppress_armed_plus_event = alert_long_early or long_arm_signal
bool alert_long_armed_event = alert_long_armed and not suppress_armed_plus_event and long_setup_serial > 0 and last_long_armed_alert_serial != long_setup_serial
last_long_armed_alert_serial := alert_long_armed_event ? long_setup_serial : last_long_armed_alert_serial
bool alert_long_clean_event = alert_long_clean and long_setup_serial > 0 and last_long_clean_alert_serial != long_setup_serial
last_long_clean_alert_serial := alert_long_clean_event ? long_setup_serial : last_long_clean_alert_serial
bool alert_long_entry_best_event = alert_long_entry_best and long_setup_serial > 0 and last_long_entry_best_alert_serial != long_setup_serial
last_long_entry_best_alert_serial := alert_long_entry_best_event ? long_setup_serial : last_long_entry_best_alert_serial
bool alert_long_entry_strict_event = alert_long_entry_strict and long_setup_serial > 0 and last_long_entry_strict_alert_serial != long_setup_serial
last_long_entry_strict_alert_serial := alert_long_entry_strict_event ? long_setup_serial : last_long_entry_strict_alert_serial
bool bull_ob_broken_event = array.size(ob_broken_new_bull) > 0

varip bool long_arm_signal_latched = false
varip bool long_confirm_signal_latched = false
varip bool long_ready_signal_latched = false
varip bool long_invalidate_signal_latched = false
varip bool alert_long_watchlist_event_latched = false
varip bool alert_long_armed_event_latched = false
varip bool alert_long_early_event_latched = false
varip bool alert_long_clean_event_latched = false
varip bool alert_long_entry_best_event_latched = false
varip bool alert_long_entry_strict_event_latched = false
varip bool bull_ob_broken_event_latched = false
varip bool bull_fvg_filled_event_latched = false
varip bool live_bull_ob_break_latched = false
varip bool live_bull_fvg_fill_latched = false
varip bool long_dynamic_alert_sent = false

if barstate.isnew
    long_arm_signal_latched := false
    long_confirm_signal_latched := false
    long_ready_signal_latched := false
    long_invalidate_signal_latched := false
    alert_long_watchlist_event_latched := false
    alert_long_armed_event_latched := false
    alert_long_early_event_latched := false
    alert_long_clean_event_latched := false
    alert_long_entry_best_event_latched := false
    alert_long_entry_strict_event_latched := false
    bull_ob_broken_event_latched := false
    bull_fvg_filled_event_latched := false
    live_bull_ob_break_latched := false
    live_bull_fvg_fill_latched := false
    long_dynamic_alert_sent := false

long_arm_signal_latched := update_latched_flag(long_arm_signal_latched, long_arm_signal, live_exec, barstate.isconfirmed)
long_confirm_signal_latched := update_latched_flag(long_confirm_signal_latched, long_confirm_signal, live_exec, barstate.isconfirmed)
long_ready_signal_latched := update_latched_flag(long_ready_signal_latched, long_ready_signal, live_exec, barstate.isconfirmed)
long_invalidate_signal_latched := update_latched_flag(long_invalidate_signal_latched, long_invalidate_signal, live_exec, barstate.isconfirmed)
alert_long_watchlist_event_latched := update_latched_flag(alert_long_watchlist_event_latched, alert_long_watchlist_event, live_exec, barstate.isconfirmed)
alert_long_armed_event_latched := update_latched_flag(alert_long_armed_event_latched, alert_long_armed_event, live_exec, barstate.isconfirmed)
alert_long_early_event_latched := update_latched_flag(alert_long_early_event_latched, alert_long_early_event, live_exec, barstate.isconfirmed)
alert_long_clean_event_latched := update_latched_flag(alert_long_clean_event_latched, alert_long_clean_event, live_exec, barstate.isconfirmed)
alert_long_entry_best_event_latched := update_latched_flag(alert_long_entry_best_event_latched, alert_long_entry_best_event, live_exec, barstate.isconfirmed)
alert_long_entry_strict_event_latched := update_latched_flag(alert_long_entry_strict_event_latched, alert_long_entry_strict_event, live_exec, barstate.isconfirmed)
if bull_ob_broken_event
    bull_ob_broken_event_latched := true
if bullish_fvg_filled_alert
    bull_fvg_filled_event_latched := true
if live_bull_ob_break
    live_bull_ob_break_latched := true
if live_bull_fvg_fill
    live_bull_fvg_fill_latched := true

if long_invalidate_signal_latched
    long_arm_signal_latched := false
    long_confirm_signal_latched := false
    long_ready_signal_latched := false
    alert_long_watchlist_event_latched := false
    alert_long_armed_event_latched := false
    alert_long_early_event_latched := false
    alert_long_clean_event_latched := false
    alert_long_entry_best_event_latched := false
    alert_long_entry_strict_event_latched := false

bool long_arm_close_safe = barstate.isconfirmed and long_setup_armed and not long_setup_armed[1]
bool long_confirm_close_safe = barstate.isconfirmed and long_setup_confirmed and not long_setup_confirmed[1]
bool long_ready_close_safe = barstate.isconfirmed and long_ready_state and not long_ready_state[1]
bool long_invalidated_close_safe = barstate.isconfirmed and not long_setup_armed and not long_setup_confirmed and (long_setup_armed[1] or long_setup_confirmed[1])
bool long_arm_alert_event = long_arm_signal_latched
bool long_confirm_alert_event = long_confirm_signal_latched
bool long_ready_alert_event = long_ready_signal_latched
bool long_invalidate_alert_event = long_invalidate_signal_latched
bool live_bull_ob_break_alert_event = live_bull_ob_break_latched
bool live_bull_fvg_fill_alert_event = live_bull_fvg_fill_latched

// Alerts use clearer wording but keep the same underlying trigger logic.
alertcondition(long_arm_alert_event, 'Long Armed', 'SMC++: Long setup armed. Reclaim and zone confirmation are in place.')
alertcondition(long_confirm_alert_event, 'Long Confirmed', 'SMC++: Long setup confirmed. Confirmation lifecycle and filters passed.')
alertcondition(long_ready_alert_event, 'Long Ready', 'SMC++: Long setup ready. Lifecycle, gates, context, and upgrades passed.')
alertcondition(long_invalidate_alert_event, 'Long Invalidated', 'SMC++: Long setup invalidated.')

alertcondition(long_arm_close_safe, 'Long Armed (Close Safe)', 'SMC++: Long setup armed at candle close. Reclaim and zone confirmation held.')
alertcondition(long_confirm_close_safe, 'Long Confirmed (Close Safe)', 'SMC++: Long setup confirmed at candle close. Confirmation lifecycle and filters held.')
alertcondition(long_ready_close_safe, 'Long Ready (Close Safe)', 'SMC++: Long setup ready at candle close. Lifecycle, gates, context, and upgrades held.')
alertcondition(long_invalidated_close_safe, 'Long Invalidated (Close Safe)', 'SMC++: Long setup invalidated at candle close.')

alertcondition(alert_long_watchlist_event_latched, 'Long Dip Watchlist', 'SMC++: Watchlist state active. Bullish trend with an active pullback zone.')
alertcondition(alert_long_armed_event_latched, 'Long Dip Armed+', 'SMC++: Armed+ state active. Strict reclaim qualified and setup is armed.')
alertcondition(alert_long_early_event_latched, 'Long Dip Early', 'SMC++: Early long state active. Strict reclaim is in and internal confirmation is starting.')
alertcondition(alert_long_clean_event_latched, 'Long Dip Clean', 'SMC++: Clean long state active. Confirmed setup with supportive gate context.')
alertcondition(alert_long_entry_best_event_latched, 'Long Dip Entry Best', 'SMC++: Entry Best state active. Ready is live and best-upgrade filters passed.')
alertcondition(alert_long_entry_strict_event_latched, 'Long Dip Entry Strict', 'SMC++: Entry Strict state active. Ready is live and strict-upgrade filters passed.')

alertcondition(bull_bos_sig, 'Bullish BOS Detected', 'SMC++: Bullish break of structure detected.')
alertcondition(bull_choch_sig, 'Bullish CHoCH Detected', 'SMC++: Bullish change of character detected.')

alertcondition(bull_ob_broken_event_latched, 'Bullish Order Block Broken', 'SMC++: A bullish order block was broken.')

alertcondition(eqh_alert, 'Equal Highs Detected', 'SMC++: Equal highs detected.')
alertcondition(eql_alert, 'Equal Lows Detected', 'SMC++: Equal lows detected.')

alertcondition(bullish_fvg_alert, 'Bullish FVG Formed', 'SMC++: Bullish fair value gap formed.')
alertcondition(bull_fvg_filled_event_latched, 'Bullish FVG Filled', 'SMC++: Bullish fair value gap fill target reached.')

alertcondition(live_bull_ob_break_alert_event, 'Bullish OB Live Break', 'SMC++: Intrabar bullish order block break detected.')
alertcondition(live_bull_fvg_fill_alert_event, 'Bullish FVG Live Fill', 'SMC++: Intrabar bullish fair value gap fill detected.')

alertcondition(bullish_trend_started, 'Bullish Trend Started', 'SMC++: Structure trend turned bullish.')
alertcondition(directional_trend_started, 'Trend Direction Changed', 'SMC++: Structure trend changed direction.')

varip string dynamic_alert_seen_keys = ''

if barstate.isnew
    dynamic_alert_seen_keys := ''

string bull_bos_alert_key = '|bull_bos|'
string bull_bos_alert_name = 'Bullish BOS'
string bull_bos_alert_detail = 'Structure break confirmed'
string bull_choch_alert_key = '|bull_choch|'
string bull_choch_alert_name = 'Bullish CHoCH'
string bull_choch_alert_detail = 'Character shift confirmed'
string bull_ob_alert_key = '|new_bull_ob|'
string bull_ob_alert_name = 'Bullish Order Block'
string bull_ob_alert_detail = 'New order block confirmed'
string bull_fvg_alert_key = '|new_bull_fvg|'
string bull_fvg_alert_name = 'Bullish FVG'
string bull_fvg_alert_detail = 'New fair value gap formed'
string bull_fvg_filled_alert_key = '|bull_fvg_filled|'
string bull_fvg_filled_alert_name = 'Bullish FVG Filled'
string bull_fvg_filled_alert_detail = 'Gap fill target reached'
string bull_live_ob_alert_key = '|live_bull_ob_break|'
string bull_live_ob_alert_name = 'Bullish OB Live Break'
string bull_live_ob_alert_detail = 'Intrabar bullish order block break detected'
string bull_live_fvg_alert_key = '|live_bull_fvg_fill|'
string bull_live_fvg_alert_name = 'Bullish FVG Live Fill'
string bull_live_fvg_alert_detail = 'Intrabar bullish fair value gap fill detected'
float new_fvg_bull_alert_level = resolve_fvg_alert_level(new_fvg_bull)
float new_ob_bull_alert_level = resolve_ob_alert_level(new_ob_bull)

dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and bull_bos_sig, bull_bos_alert_key, bull_bos_alert_name, bull_bos_alert_detail, top, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and bull_choch_sig, bull_choch_alert_key, bull_choch_alert_name, bull_choch_alert_detail, top, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and not na(new_ob_bull), bull_ob_alert_key, bull_ob_alert_name, bull_ob_alert_detail, new_ob_bull_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and bullish_fvg_alert, bull_fvg_alert_key, bull_fvg_alert_name, bull_fvg_alert_detail, new_fvg_bull_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and bullish_fvg_filled_alert, bull_fvg_filled_alert_key, bull_fvg_filled_alert_name, bull_fvg_filled_alert_detail, bull_filled_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_ob_break, bull_live_ob_alert_key, bull_live_ob_alert_name, bull_live_ob_alert_detail, bull_ob_live_event_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_fvg_fill, bull_live_fvg_alert_key, bull_live_fvg_alert_name, bull_live_fvg_alert_detail, bull_fvg_live_event_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and use_sd_confluence and sd_bullish_divergence_event, '|sd_bull_div|', 'Bullish SD Divergence', 'Price lower low vs oscillator higher low', low, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and use_sd_confluence and sd_higher_lows_event, '|sd_higher_lows|', 'SD Higher Lows', 'Oscillator printed consecutive higher lows', close, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
string long_invalidated_alert_key = '|long_invalidated|'
string long_invalidated_alert_name = 'Long Invalidated'
string long_entry_strict_alert_key = '|long_entry_strict|'
string long_entry_strict_alert_name = 'Long Dip Entry Strict'
string long_entry_best_alert_key = '|long_entry_best|'
string long_entry_best_alert_name = 'Long Dip Entry Best'
string long_ready_alert_key = '|long_ready|'
string long_ready_alert_name = 'Long Ready'
string long_confirmed_alert_key = '|long_confirmed|'
string long_confirmed_alert_name = 'Long Confirmed'
string long_clean_alert_key = '|long_clean|'
string long_clean_alert_name = 'Long Dip Clean'
string long_early_alert_key = '|long_early|'
string long_early_alert_name = 'Long Dip Early'
string long_armed_plus_alert_key = '|long_armed_plus|'
string long_armed_plus_alert_name = 'Long Dip Armed+'
string long_armed_alert_key = '|long_armed|'
string long_armed_alert_name = 'Long Armed'
string long_watchlist_alert_key = '|long_watchlist|'
string long_watchlist_alert_name = 'Long Dip Watchlist'
if dynamic_long_alert_mode == 'Priority'
    if enable_dynamic_alerts and long_invalidate_signal
        priority_seen_keys_invalidated = emit_dynamic_alert_if_allowed(
             dynamic_alert_seen_keys,
             true,
             long_invalidated_alert_key,
             long_invalidated_alert_name,
             compose_long_invalidated_alert_detail(long_last_invalid_source, long_micro_alert_suffix, long_score_detail_suffix),
             long_last_invalid_level,
             -1,
             ltf_bull_share,
             ltf_volume_delta,
             ltf_price_only,
             signal_mode_text)

        bool invalidated_sent_now = priority_seen_keys_invalidated != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_invalidated
        long_dynamic_alert_sent := long_dynamic_alert_sent or invalidated_sent_now

    else if enable_dynamic_alerts and alert_long_entry_strict_event
        priority_seen_keys_strict = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_entry_strict_alert_key, long_entry_strict_alert_name, compose_long_entry_strict_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_strict_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_strict != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_strict
    else if enable_dynamic_alerts and alert_long_entry_best_event
        priority_seen_keys_best = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_entry_best_alert_key, long_entry_best_alert_name, compose_long_entry_best_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_best_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_best != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_best
    else if enable_dynamic_alerts and long_ready_signal
        priority_seen_keys_ready = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_ready_alert_key, long_ready_alert_name, compose_long_ready_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_ready != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_ready
    else if enable_dynamic_alerts and long_confirm_signal
        priority_seen_keys_confirmed = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_confirmed_alert_key, long_confirmed_alert_name, compose_long_confirmed_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_confirmed != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_confirmed
    else if enable_dynamic_alerts and alert_long_clean_event
        priority_seen_keys_clean = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_clean_alert_key, long_clean_alert_name, compose_long_clean_alert_detail(long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_clean_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_clean != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_clean
    else if enable_dynamic_alerts and alert_long_early_event
        priority_seen_keys_early = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_early_alert_key, long_early_alert_name, compose_long_early_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_early_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_early != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_early
    else if enable_dynamic_alerts and alert_long_armed_event
        priority_seen_keys_armed_plus = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_armed_plus_alert_key, long_armed_plus_alert_name, compose_long_armed_plus_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_armed_plus != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_armed_plus
    else if enable_dynamic_alerts and long_arm_signal
        priority_seen_keys_armed = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_armed_alert_key, long_armed_alert_name, compose_long_armed_alert_detail(long_setup_source_display, long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_armed != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_armed
    else if enable_dynamic_alerts and alert_long_watchlist_event
        priority_seen_keys_watchlist = emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, not long_dynamic_alert_sent, long_watchlist_alert_key, long_watchlist_alert_name, compose_long_watchlist_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_watchlist_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
        long_dynamic_alert_sent := priority_seen_keys_watchlist != dynamic_alert_seen_keys
        dynamic_alert_seen_keys := priority_seen_keys_watchlist
else
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and long_invalidate_signal, long_invalidated_alert_key, long_invalidated_alert_name, compose_long_invalidated_alert_detail(long_last_invalid_source, long_micro_alert_suffix, long_score_detail_suffix), long_last_invalid_level, -1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_entry_strict_event, long_entry_strict_alert_key, long_entry_strict_alert_name, compose_long_entry_strict_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_strict_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_entry_best_event, long_entry_best_alert_key, long_entry_best_alert_name, compose_long_entry_best_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_entry_best_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and long_ready_signal, long_ready_alert_key, long_ready_alert_name, compose_long_ready_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_clean_event, long_clean_alert_key, long_clean_alert_name, compose_long_clean_alert_detail(long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_clean_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and long_confirm_signal, long_confirmed_alert_key, long_confirmed_alert_name, compose_long_confirmed_alert_detail(long_setup_source_display, long_strict_alert_suffix, long_environment_alert_suffix, long_micro_alert_suffix, long_score_detail_suffix), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_early_event, long_early_alert_key, long_early_alert_name, compose_long_early_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_early_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_armed_event, long_armed_plus_alert_key, long_armed_plus_alert_name, compose_long_armed_plus_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and long_arm_signal, long_armed_alert_key, long_armed_alert_name, compose_long_armed_alert_detail(long_setup_source_display, long_micro_alert_suffix, long_score_detail_suffix), long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)
    dynamic_alert_seen_keys := emit_dynamic_alert_if_allowed(dynamic_alert_seen_keys, enable_dynamic_alerts and alert_long_watchlist_event, long_watchlist_alert_key, long_watchlist_alert_name, compose_long_watchlist_alert_detail(long_micro_alert_suffix, long_score_detail_suffix), long_watchlist_alert_level, 1, ltf_bull_share, ltf_volume_delta, ltf_price_only, signal_mode_text)

// --------------------------------------------------
// Documented Dashboard
// --------------------------------------------------
dashboard_header(table tbl, int row, string title, color bg, color txt) =>
    table.cell(tbl, 0, row, title, text_color = txt, bgcolor = bg, text_size = size.tiny)
    table.cell(tbl, 1, row, '', text_color = txt, bgcolor = bg, text_size = size.tiny)

dashboard_row(table tbl, int row, string name, string value, color bg, color txt) =>
    table.cell(tbl, 0, row, name, text_color = txt, bgcolor = bg, text_size = size.tiny)
    table.cell(tbl, 1, row, value, text_color = txt, bgcolor = bg, text_size = size.tiny)

db_trend_text(int dir) =>
    dir > 0 ? 'Bullish' : dir < 0 ? 'Bearish' : 'Neutral'

db_trend_state(int dir) =>
    dir > 0 ? 5 : dir < 0 ? -1 : 0

db_exec_tier_text() =>
    long_entry_strict_state ? 'Strict' :
     long_entry_best_state ? 'Best' :
     long_ready_state ? 'Ready' :
     long_setup_confirmed ? 'Confirmed' :
     long_setup_armed ? 'Armed' :
     long_zone_active ? 'Watchlist' : 'n/a'

db_setup_age_text() =>
    long_setup_confirmed and not na(long_confirm_bar_index) ? 'confirmed ' + str.tostring(long_confirm_age) :
     long_setup_armed and not na(long_setup_arm_bar_index) ? 'armed ' + str.tostring(long_setup_age) :
     'n/a'

render_smc_dashboard_documented(table tbl) =>
    color _db_text = chart.fg_color
    color _db_header_bg = color.new(color.black, 100)

    int _mtf_bull_count = (mtf_trend_1 > 0 ? 1 : 0) + (mtf_trend_2 > 0 ? 1 : 0) + (mtf_trend_3 > 0 ? 1 : 0)
    string _db_htf_text = mtf_trend_tf1 + ':' + db_trend_text(mtf_trend_1) + ' | ' + mtf_trend_tf2 + ':' + db_trend_text(mtf_trend_2) + ' | ' + mtf_trend_tf3 + ':' + db_trend_text(mtf_trend_3)
    int _db_htf_state = _mtf_bull_count >= 2 ? 5 : _mtf_bull_count == 1 ? 3 : -1

    int _db_setup_state = long_entry_strict_state ? 5 : long_entry_best_state ? 5 : long_ready_state ? 4 : long_setup_confirmed ? 4 : long_building_state ? 3 : long_setup_armed ? 2 : long_zone_active ? 1 : 0
    string _db_exec_tier_text = db_exec_tier_text()
    int _db_exec_tier_state = long_entry_strict_state ? 5 : long_entry_best_state ? 5 : long_ready_state ? 4 : long_setup_confirmed ? 4 : long_setup_armed ? 2 : long_zone_active ? 1 : 0

    string _db_setup_age = db_setup_age_text()
    int _db_setup_age_state = long_setup_confirmed ? (ready_is_fresh ? 5 : 2) : long_setup_armed ? (confirm_is_fresh ? 4 : 2) : 0

    int _db_pullback_state = in_bull_ob_zone and in_bull_fvg_zone ? 5 : in_bull_ob_zone or in_bull_fvg_zone ? 4 : 0
    int _db_reclaim_state = bull_reclaim_ob_strict or bull_reclaim_fvg_strict ? 5 : bull_reclaim_swing_low_strict or bull_reclaim_internal_low_strict ? 4 : reclaim_recent ? 2 : 0

    string _db_session_text = not intraday_time_chart ? 'n/a' :
         not use_trade_session_gate and not use_opening_range_gate ? 'off' :
         session_structure_gate_ok ? 'OK' :
         not session_gate_ok ? 'Entry session blocked' :
         'OR blocked'
    int _db_session_state = not intraday_time_chart ? 0 : not use_trade_session_gate and not use_opening_range_gate ? 0 : session_structure_gate_ok ? 5 : -1

    string _db_market_text = not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate ? 'off' :
         market_symbols_missing and block_on_missing_market_symbol ? 'Missing symbol' :
         market_regime_gate_ok ? 'OK' :
         not index_gate_effective_ok ? 'Index blocked' :
         not sector_gate_effective_ok ? 'Sector blocked' :
         'Breadth blocked'
    int _db_market_state = not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate ? 0 : market_symbols_missing and not block_on_missing_market_symbol ? 2 : market_regime_gate_ok ? 5 : -1

    string _db_vola_gate_text = not use_vola_compression_gate ? 'off' :
         vola_regime_gate_safe ? (vola_expansion_now ? 'Compression -> Expansion' : vola_compression_recent ? 'Compression context' : 'OK') :
         'Blocked'
    int _db_vola_gate_state = not use_vola_compression_gate ? 0 : vola_regime_gate_safe ? (vola_expansion_now ? 5 : 3) : -1

    string _db_micro_session_text = not use_microstructure_profiles or not intraday_time_chart ? 'off' :
         micro_session_gate_ok ? 'OK' :
         not micro_rth_gate_ok ? 'RTH only' :
         not micro_midday_gate_ok ? 'Midday block' :
         not micro_premarket_gate_ok ? 'Weak premarket' :
         'Weak after-hours'
    int _db_micro_session_state = not use_microstructure_profiles or not intraday_time_chart ? 0 : micro_session_gate_ok ? 5 : -1

    string _db_micro_fresh_text = not use_microstructure_profiles ? 'off' : freshness_text + ' | ' + source_state_text
    int _db_micro_fresh_state = not use_microstructure_profiles ? 0 : micro_freshness_gate_ok ? 5 : -1

    string _db_volume_data_text = not volume_current_bar_ok ? 'No current bar volume' :
         not volume_feed_quality_ok ? 'Weak feed quality' :
         ltf_sampling_active and ltf_price_ok and not ltf_volume_ok ? 'Chart OK | LTF no-vol' :
         ltf_price_only ? 'Price-only LTF' :
         'OK'
    int _db_volume_data_state = not volume_current_bar_ok ? -1 : not volume_feed_quality_ok ? 2 : ltf_sampling_active and ltf_price_ok and not ltf_volume_ok ? 2 : 5

    string _db_quality_env_text = environment_hard_gate_ok ? 'Passed' :
         not market_regime_gate_ok ? 'Market Gate Blocked' :
         not vola_regime_gate_safe ? 'Vola Gate Blocked' :
         'Mixed'
    int _db_quality_env_state = environment_hard_gate_ok ? 5 : not market_regime_gate_ok or not vola_regime_gate_safe ? -1 : 2

    bool _db_strict_quality_ok = strict_entry_ltf_ok and htf_alignment_ok and accel_strict_entry_gate_ok and sd_entry_strict_gate_ok and vol_entry_strict_context_ok_safe and stretch_entry_strict_context_ok and ddvi_entry_strict_ok_safe
    string _db_quality_strict_text = long_entry_strict_state ? 'Passed' :
         _db_strict_quality_ok ? 'Eligible' :
         not strict_entry_ltf_ok ? 'LTF Blocked' :
         not htf_alignment_ok ? 'HTF Blocked' :
         not accel_strict_entry_gate_ok ? 'Accel Blocked' :
         not sd_entry_strict_gate_ok ? 'SD Blocked' :
         not vol_entry_strict_context_ok_safe ? 'Vol Blocked' :
         not stretch_entry_strict_context_ok ? 'Stretch Blocked' :
         'DDVI Blocked'
    int _db_quality_strict_state = long_entry_strict_state ? 5 : _db_strict_quality_ok ? 4 : -1

    string _db_adx_text = not use_adx ? 'off' : not adx_data_ok ? 'n/a' : str.tostring(adx_value, '#.##') + ' | ' + adx_state_text
    int _db_adx_state = not use_adx or not adx_data_ok ? 0 : plus_di < minus_di ? -1 : adx_strong ? 5 : adx_value >= adx_trend_min ? 3 : 2

    string _db_relvol_text = relvol_text
    int _db_relvol_state = not use_rel_volume ? 0 : not relvol_data_ok ? (allow_relvol_without_volume_data ? 2 : -1) : relvol_ok ? 5 : -1

    string _db_vwap_text = vwap_state_text
    int _db_vwap_state = not use_vwap_filter ? 0 : not intraday_time_chart ? 0 : not vwap_session_active ? 0 : vwap_filter_ok ? 5 : -1

    string _db_context_quality_text = not use_context_quality_score ? 'off' : context_quality_gate_ok ? 'Supportive' : 'Weak'
    int _db_context_quality_state = not use_context_quality_score ? 0 : context_quality_gate_ok ? 5 : 2

    string _db_quality_score_text = str.tostring(context_quality_score) + '/' + str.tostring(effective_context_quality_max_score) + ' | min ' + str.tostring(effective_min_context_quality_score)
    int _db_quality_score_state = context_quality_gate_ok ? 5 : 2

    string _db_quality_clean_text = long_quality_clean_tier ? 'Clean' : 'No'
    int _db_quality_clean_state = long_quality_clean_tier ? 5 : 0

    string _db_sd_confluence_text = not use_sd_confluence ? 'off' :
         sd_support_both_recent ? 'Bull div + HL' :
         sd_bullish_divergence_recent ? 'Bull div' :
         sd_higher_lows_recent ? 'Higher lows' :
         'none'
    int _db_sd_confluence_state = not use_sd_confluence ? 0 : sd_support_both_recent ? 5 : sd_support_any_recent ? 4 : 0

    string _db_sd_osc_text = not use_sd_confluence ? 'off' :
         na(sd_value) ? 'n/a' :
         str.tostring(sd_value, '#.##') + ' | ' + (sd_rising ? 'rising' : sd_falling ? 'falling' : 'flat')
    int _db_sd_osc_state = not use_sd_confluence or na(sd_value) ? 0 : sd_above_zero and sd_rising ? 5 : sd_rising ? 3 : sd_below_zero and sd_falling ? -1 : 0

    string _db_vol_regime_text = not use_volatility_regime ? 'off' : vol_regime_trend_ok ? 'Bull stack' : 'Weak stack'
    int _db_vol_regime_state = not use_volatility_regime ? 0 : vol_regime_trend_ok ? 5 : -1

    string _db_vol_squeeze_text = not use_volatility_regime ? 'off' :
         vol_squeeze_on ? 'Squeeze on' :
         vol_squeeze_release_recent ? 'Released' :
         vol_squeeze_recent ? 'Recent squeeze' :
         'No squeeze'
    int _db_vol_squeeze_state = not use_volatility_regime ? 0 : vol_squeeze_on ? 5 : vol_squeeze_release_recent ? 4 : vol_squeeze_recent ? 3 : 0

    string _db_vol_expand_text = not use_volatility_regime ? 'off' :
         vol_momentum_expanding_long and vol_stack_spread_rising ? 'Expansion' :
         vol_momentum_expanding_long or vol_stack_spread_rising ? 'Building' :
         'No Expansion'
    int _db_vol_expand_state = not use_volatility_regime ? 0 : vol_momentum_expanding_long and vol_stack_spread_rising ? 5 : vol_momentum_expanding_long or vol_stack_spread_rising ? 3 : 0

    string _db_stretch_text = not use_stretch_context ? 'off' :
         na(distance_to_mean_z) ? 'n/a' :
         str.tostring(distance_to_mean_z, '#.##') + 'z | ' + (in_lower_extreme ? 'lower extreme' : lower_extreme_recent ? 'recent extreme' : anti_chase_ok_entry_best ? 'anti-chase ok' : 'chasing')
    int _db_stretch_state = not use_stretch_context or na(distance_to_mean_z) ? 0 : (in_lower_extreme or lower_extreme_recent) and anti_chase_ok_entry_best ? 5 : anti_chase_ok_ready ? 3 : -1

    string _db_ddvi_text = not use_ddvi_context ? 'off' :
         ddvi_bias_ok and ddvi_bull_divergence_any ? 'Bull bias + div' :
         ddvi_bias_ok ? 'Bull bias' :
         ddvi_bull_divergence_any ? 'Bull div' :
         ddvi_lower_extreme_context ? 'Lower extreme' :
         'Weak'
    int _db_ddvi_state = not use_ddvi_context ? 0 : ddvi_bias_ok and ddvi_bull_divergence_any ? 5 : ddvi_bias_ok or ddvi_bull_divergence_any ? 4 : ddvi_lower_extreme_context ? 3 : 0

    string _db_ltf_bias_text = not show_dashboard_ltf ? 'off' :
         not ltf_sampling_active ? 'n/a' :
         not ltf_price_ok ? 'n/a' :
         str.tostring(ltf_bull_share * 100.0, '#') + '%' + (ltf_price_only ? ' price-only' : '')
    int _db_ltf_bias_state = not show_dashboard_ltf or not ltf_sampling_active or not ltf_price_ok ? 0 : ltf_bull_share >= ltf_bias_hint ? 5 : ltf_bull_share >= 0.50 ? 3 : -1

    string _db_ltf_delta_text = not show_dashboard_ltf ? 'off' :
         not ltf_sampling_active ? 'n/a' :
         ltf_price_only ? 'no-vol' :
         na(ltf_volume_delta) ? 'n/a' :
         str.format('{0,number,percent}', ltf_volume_delta)
    int _db_ltf_delta_state = not show_dashboard_ltf or not ltf_sampling_active ? 0 : ltf_price_only ? 2 : na(ltf_volume_delta) ? 0 : ltf_volume_delta >= 0 ? 5 : -1

    string _db_objects_text = 'OB ' + str.tostring(array.size(ob_blocks_bull)) + ' | FVG ' + str.tostring(array.size(fvgs_bull))
    int _db_objects_state = array.size(ob_blocks_bull) > 0 and array.size(fvgs_bull) > 0 ? 5 : array.size(ob_blocks_bull) > 0 or array.size(fvgs_bull) > 0 ? 3 : 0

    string _db_swing_text = 'S ' + (not na(trail_up) ? u.format_level(trail_up) : 'n/a') + ' / ' + (not na(trail_dn) ? u.format_level(trail_dn) : 'n/a') + ' | I ' + (not na(internal_trail_up) ? u.format_level(internal_trail_up) : 'n/a') + ' / ' + (not na(internal_trail_dn) ? u.format_level(internal_trail_dn) : 'n/a')
    int _db_swing_state = bullish_trend_safe ? 5 : bearish_trend_safe ? -1 : 0

    string _db_long_zones_text = 'No Long Zones'
    if in_bull_ob_zone
        _db_long_zones_text := 'OB ' + u.format_level(active_bull_ob_top) + ' / ' + u.format_level(active_bull_ob_bottom)
    if in_bull_fvg_zone
        _db_long_zones_text := 'FVG ' + u.format_level(active_bull_fvg_top) + ' / ' + u.format_level(active_bull_fvg_bottom)
    if in_bull_ob_zone and in_bull_fvg_zone
        _db_long_zones_text := 'OB ' + u.format_level(active_bull_ob_top) + ' / ' + u.format_level(active_bull_ob_bottom) + ' | FVG ' + u.format_level(active_bull_fvg_top) + ' / ' + u.format_level(active_bull_fvg_bottom)
    int _db_long_zones_state = long_zone_active ? 5 : 0

    string _db_long_triggers_text = long_plan_active ? 'Trig ' + u.format_level(long_setup_trigger) + ' | Inv ' + u.format_level(long_invalidation_level) : 'n/a'
    int _db_long_triggers_state = long_plan_active ? 5 : 0

    string _db_micro_profile_text = not use_microstructure_profiles ? 'off' :
         str.length(micro_modifier_text) > 0 ? micro_profile_text + ' | mod: ' + micro_modifier_text :
         micro_profile_text
    int _db_micro_profile_state = not use_microstructure_profiles ? 0 : str.length(micro_modifier_text) > 0 or micro_profile_text != 'Default' ? 5 : 3

    string _db_risk_plan_text = long_plan_active ? 'Entry ' + u.format_level(long_setup_trigger) + ' | Stop ' + u.format_level(long_stop_level) + ' | T1 ' + u.format_level(long_target_1) + ' | T2 ' + u.format_level(long_target_2) : 'n/a'
    int _db_risk_plan_state = long_plan_active ? 5 : 0

    dashboard_header(tbl, 0, 'SMC++ | ' + signal_mode_text, _db_header_bg, _db_text)

    dashboard_header(tbl, 1, '[ Lifecycle ]', _db_header_bg, _db_text)
    dashboard_row(tbl, 2, 'Trend', db_trend_text(structure_display_trend), status_bg(db_trend_state(structure_display_trend)), _db_text)
    dashboard_row(tbl, 3, 'HTF Trend', _db_htf_text, status_bg(_db_htf_state), _db_text)
