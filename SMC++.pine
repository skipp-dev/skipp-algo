bool show_internal_bull_choch = show_internals and (show_bull == 'All' or show_bull == 'CHoCH')
bool show_internal_bear_bos = show_internals and (show_bear == 'All' or show_bear == 'BOS')
bool show_internal_bear_choch = show_internals and (show_bear == 'All' or show_bear == 'CHoCH')

