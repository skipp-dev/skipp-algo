status_bg(int state) =>
    state <= -1 ? color.new(color.red, 75) :
     state == 0 ? color.new(color.gray, 80) :
     state == 1 ? color.new(color.aqua, 80) :
     state == 2 ? color.new(color.orange, 72) :
     state == 3 ? color.new(color.yellow, 68) :
     state == 4 ? color.new(color.lime, 72) :
     color.new(color.green, 60)


get_structure_display_trend_only(simple int structure_len) =>
    [trend, bull_bos_alert, bull_choch_alert, _, _, _, _, _, bear_bos_alert, bear_choch_alert, _, _, _, _, _, _] = detect_structure(structure_len, filter_insignificant_internal_breaks = true)
    bool structure_break_detected = bull_bos_alert or bull_choch_alert or bear_bos_alert or bear_choch_alert
    not na(ta.barssince(structure_break_detected)) ? trend : 0

get_confirmed_structure_trend(string trend_tf, simple int structure_len) =>
    request.security(syminfo.tickerid, trend_tf, get_structure_display_trend_only(structure_len)[1], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

build_dynamic_alert_message(bool enabled, bool condition, string event_name, string detail, float level, int direction, float ltf_bull_share, float ltf_volume_delta, bool ltf_price_only_context, string mode_text) =>
    if enabled and condition
        direction_text = direction > 0 ? 'bullish' : direction < 0 ? 'bearish' : 'neutral'
        share_text = na(ltf_bull_share) ? 'n/a' : ltf_price_only_context ? str.format('{0,number,percent} (price-only)', ltf_bull_share) : str.format('{0,number,percent}', ltf_bull_share)
        delta_text = ltf_price_only_context ? 'no-vol' : na(ltf_volume_delta) ? 'n/a' : str.format('{0,number,percent}', ltf_volume_delta)
        str.format('SMC++ | {0} | {1} | {2} | dir={3} | level={4} | tf={5} | mode={6} | ltf_bull_share={7} | ltf_volume_delta={8}', syminfo.ticker, event_name, detail, direction_text, u.format_level(level), timeframe.period, mode_text, share_text, delta_text)
    else
        ''

emit_dynamic_alert_if_allowed(string seen_keys, bool event_active, string seen_key, string event_name, string detail, float level, int direction, float ltf_bull_share, float ltf_volume_delta, bool ltf_price_only_context, string mode_text) =>
    next_seen_keys = seen_keys
    if event_active and not str.contains(seen_keys, seen_key)
        next_seen_keys := seen_keys + seen_key
        alert(build_dynamic_alert_message(true, true, event_name, detail, level, direction, ltf_bull_share, ltf_volume_delta, ltf_price_only_context, mode_text), alert.freq_all)
    next_seen_keys

