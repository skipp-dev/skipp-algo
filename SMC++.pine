var g_fvg = 'Fair Value Gaps'
var show_fvg = input.bool(true, 'Show Fair Value Gaps', group = g_fvg, inline = 'show', tooltip = SHOW_FVG)
var fvg_showlast = input.int(DEFAULT_FVG_SHOW_LAST, 'Show last', minval = 1, group = g_fvg, inline = 'show2')
var fvg_extend_until_filled = input.bool(true, 'Extend until filled', group = g_fvg, inline = 'ext')
var fvg_keep_filled = input.bool(true, 'Keep filled', group = g_fvg, inline = 'keep filled')
var fvg_keep_filled_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 1, group = g_fvg, inline = 'keep filled')
var bull_fvg_css = input.color(color.new(#00ff68, 90), '', group = g_fvg, inline = 'show')
var bull_fvg_line_css = input.color(color.new(#00ff68, 25), '', group = g_fvg, inline = 'show')
var bull_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bull_fvg_line_css_filled = color.new(bull_fvg_css_filled, 50)
var filter_insignificant_fvgs = input.bool(true, 'Filter: min size', group = g_fvg, inline = 'fvg_min', tooltip = FILTER_FVG)
var min_fvg_size_atr_len = input.int(ATR_LEN_MAIN, 'ATR Length', minval = 1, group = g_fvg, inline = 'fvg_min')
var min_fvg_size_atr_mult = input.float(DEFAULT_FVG_MIN_SIZE_MULT, 'x', minval = 0, step = 0.1, group = g_fvg, inline = 'fvg_min')
float fvg_size_threshold = filter_insignificant_fvgs ? smc_lib_atr(min_fvg_size_atr_len) * min_fvg_size_atr_mult : 0
var float fvg_fill_target_pct = input.float(DEFAULT_FVG_FILL_TARGET_PCT, 'Filled at %', minval = 0, maxval = 100, step = 5, group = g_fvg)
float fvg_fill_target_ratio = math.max(0.0, math.min(1.0, fvg_fill_target_pct / 100.0))
var use_fvg_engine = input.bool(true, 'Use FVG engine', group = g_fvg, display = display.none, tooltip = 'Keeps FVG-based long-dip logic and alerts running even if chart rendering is hidden.')

bool enable_fvg_engine = use_fvg_engine
int _fvg_backing_zone_id = long_setup_backing_zone_kind == 'FVG' ? long_setup_backing_zone_id : na
[bullish_fvg_alert, bearish_fvg_alert, fvgs_bull, fvgs_bear, new_fvg_bull, _new_fvg_bear, filled_fvgs_bull, _filled_fvgs_bear, filled_fvgs_new_bull, _filled_fvgs_new_bear, fvg_discarded_bull, fvg_discarded_bear] = fvgs_objects(active_break_mode, fvg_fill_target_ratio, fvg_size_threshold, enable_fvg_engine, fvg_keep_filled_max, object_gc_cycle, _fvg_backing_zone_id)

var fvg_config_bull = FVGConfig.new(show_box = show_fvg, show_target = show_fvg, show_target_label = true, show_last = fvg_showlast, txt = 'FVG ⬈', show_quality_score = true, extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css, 0, line.style_solid, bull_fvg_css, xloc.bar_index), box_text_args = d.BoxTextArgs.new(bull_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css, line.style_solid, 1, xloc.bar_index), label_args = d.LabelArgs.new(bull_fvg_line_css, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var show_fvg_filled = show_fvg and fvg_keep_filled and fvg_keep_filled_max > 0
var fvg_config_bull_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_quality_score = false, extend_until_filled = fvg_extend_until_filled, box_args = d.BoxArgs.new(bull_fvg_line_css_filled, 0, line.style_solid, bull_fvg_css_filled, xloc.bar_index), box_text_args = d.BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = d.LineArgs.new(bull_fvg_line_css_filled, line.style_solid, 1, xloc.bar_index), label_args = d.LabelArgs.new(#00000000, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))

bool bullish_fvg_filled_alert = array.size(filled_fvgs_new_bull) > 0
FVG bull_filled_alert_gap = bullish_fvg_filled_alert ? array.get(filled_fvgs_new_bull, array.size(filled_fvgs_new_bull) - 1) : na
float bull_filled_alert_level = resolve_fvg_alert_level(bull_filled_alert_gap)

if barstate.islast
    draw(fvgs_bull, fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_fvg_filled
        draw(filled_fvgs_bull, fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        delete(filled_fvgs_bull)

    if barstate.isconfirmed
        delete(fvg_discarded_bull)
        array.clear(fvg_discarded_bull)
        delete(fvg_discarded_bear)
        array.clear(fvg_discarded_bear)

fvgs_objects_htf(FVG new_bull, FVG new_bear, bool htf_is_confirmed, float size_threshold, simple ct.LevelBreakMode fill_mode = ct.LevelBreakMode.CLOSE, simple float fill_target_ratio = 0.5, simple int filled_max_keep = 5, simple int gc_cycle = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] htf_buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] htf_buffer_bear_discarded = array.new<FVG>(0)

    if barstate.isfirst and not u.in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    bool htf_update_ok = fill_mode == ct.LevelBreakMode.HIGHLOW or signal_mode == ct.SignalMode.AGGRESSIVE_LIVE or barstate.isconfirmed
    if htf_update_ok
        buffer_bull.update()
        buffer_bear.update()
        buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, htf_buffer_bull_discarded)
        buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, htf_buffer_bear_discarded)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, htf_buffer_bull_discarded)
        buffer_bear.remove_insignificant(size_threshold, htf_buffer_bear_discarded)

    bool htf_insert_ok = fill_mode == ct.LevelBreakMode.CLOSE ? htf_is_confirmed : true

    if htf_insert_ok and not na(new_bull)
        buffer_bull.push(new_bull)
    if htf_insert_ok and not na(new_bear)
        buffer_bear.push(new_bear)

    [buffer_bull, buffer_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, htf_buffer_bull_discarded, htf_buffer_bear_discarded]

var g_htf_fvg = 'Fair Value Gaps (Higher Timeframe)'
var show_htf_fvg = input.bool(true, 'Show Fair Value Gaps (HTF)', group = g_htf_fvg, inline = 'show', tooltip = SHOW_FVG + '\n' + FVG_TF)
var fvg_htf = input.timeframe('1D', '', group = g_htf_fvg, inline = 'show')
