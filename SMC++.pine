var bool show_sd_debug = input.bool(false, 'Show SD debug markers', group = g_sd)

var g_volreg = 'Volatility / Expansion Regime'
var bool use_volatility_regime = input.bool(true, 'Use volatility regime filter', group = g_volreg, tooltip = 'Preset guide:\nStacked rollout = Ready squeeze off, Entry Best release off, Entry Strict release off.\nBalanced = turn Ready squeeze on once regime quality is stable.\nTight = require squeeze or release context deeper into the stack if you want fewer but cleaner entries.')
var string vol_ma_mode = input.string('EMA', 'Stack MA mode', options = ['EMA', 'QEMA-like'], group = g_volreg)
var int vol_ma_len_1 = input.int(8, 'MA 1', minval = 2, group = g_volreg, inline = 'ma1')
var int vol_ma_len_2 = input.int(21, 'MA 2', minval = 3, group = g_volreg, inline = 'ma1')
var int vol_ma_len_3 = input.int(34, 'MA 3', minval = 5, group = g_volreg, inline = 'ma2')
var int vol_ma_len_4 = input.int(55, 'MA 4', minval = 8, group = g_volreg, inline = 'ma2')
var bool vol_require_all_stack_slopes = input.bool(true, 'Require all stack slopes rising', group = g_volreg)
var int vol_bb_len = input.int(20, 'BB length', minval = 5, group = g_volreg, inline = 'sq1')
var float vol_bb_mult = input.float(2.0, 'BB mult', minval = 0.5, step = 0.1, group = g_volreg, inline = 'sq1')
var int vol_kc_len = input.int(20, 'KC length', minval = 5, group = g_volreg, inline = 'sq2')
var float vol_kc_mult = input.float(1.5, 'KC mult', minval = 0.5, step = 0.1, group = g_volreg, inline = 'sq2')
var int vol_squeeze_recent_bars = input.int(12, 'Squeeze recent bars', minval = 1, maxval = 100, group = g_volreg, inline = 'sq3')
var int vol_release_recent_bars = input.int(8, 'Release recent bars', minval = 1, maxval = 100, group = g_volreg, inline = 'sq3')
var int vol_momentum_len = input.int(10, 'Momentum length', minval = 1, group = g_volreg, inline = 'mom1')
var int vol_momentum_smooth = input.int(3, 'Smooth', minval = 1, group = g_volreg, inline = 'mom1')
var bool vol_require_squeeze_for_watchlist = input.bool(false, 'Watchlist prefers squeeze context', group = g_volreg)
var bool vol_require_squeeze_for_ready = input.bool(false, 'Ready requires squeeze context', group = g_volreg, tooltip = 'Stacked rollout recommendation: off. Ready already needs regime trend, momentum expansion, and spread expansion, so squeeze context is better reserved for tighter entry tiers.')
var bool vol_require_release_for_entry_best = input.bool(false, 'Entry Best requires squeeze release', group = g_volreg)
var bool vol_require_release_for_entry_strict = input.bool(false, 'Entry Strict requires squeeze release', group = g_volreg, tooltip = 'Stacked rollout recommendation: off. Strict already requires regime trend, rising slopes, expansion, acceleration, stretch, and DDVI/SD confluence, so mandatory squeeze release can make it unnecessarily rare.')
var bool show_vol_regime_debug = input.bool(false, 'Show volatility regime debug markers', group = g_volreg)

var g_stretch = 'Stretch / Mean Reversion Context'
var bool use_stretch_context = input.bool(true, 'Use stretch context', group = g_stretch, tooltip = 'Preset guide:\nStacked rollout = Watchlist lower-extreme off, Ready lower-extreme off, Best off, Strict on, anti-chase active.\nBalanced = turn Ready lower-extreme on if you want more genuine deep-pullback bias.\nTight = keep Strict at 0.00 or below and keep Best tied to lower-extreme context.')
var int stretch_len = input.int(100, 'Mean / StdDev length', minval = 20, group = g_stretch, inline = 'dist1', tooltip = 'Recommended start: 100. Shorter reacts faster, longer is smoother and more stable.')
var float lower_extreme_z = input.float(1.5, 'Lower extreme z', minval = 0.5, step = 0.1, group = g_stretch, inline = 'dist1', tooltip = 'Recommended start: 1.5. Higher values require deeper downside stretch before context turns favorable.')
var int lower_extreme_recent_bars = input.int(12, 'Lower extreme recent bars', minval = 1, maxval = 100, group = g_stretch, inline = 'dist2', tooltip = 'Recommended start: 12. This keeps stretch context alive briefly after the actual lower-extreme touch.')
var float anti_chase_max_z_ready = input.float(0.50, 'Ready max z', step = 0.1, group = g_stretch, inline = 'ac1', tooltip = 'Cautious rollout: 0.50. Higher values allow later rebounds to still qualify as Ready.')
var float anti_chase_max_z_best = input.float(0.25, 'Best max z', step = 0.1, group = g_stretch, inline = 'ac1', tooltip = 'Cautious rollout: 0.25. Keeps Entry Best closer to the original dip rather than a late mean chase.')
var float anti_chase_max_z_strict = input.float(0.00, 'Strict max z', step = 0.1, group = g_stretch, inline = 'ac1', tooltip = 'Cautious rollout: 0.00. Strict then only allows entries at or below the mean, not above it.')
var bool stretch_require_lower_extreme_for_watchlist = input.bool(false, 'Watchlist prefers lower extreme', group = g_stretch, tooltip = 'Recommended off for rollout. Watchlist stays broader while stronger stretch filters are reserved for higher-conviction states.')
var bool stretch_require_lower_extreme_for_ready = input.bool(false, 'Ready requires lower extreme context', group = g_stretch, tooltip = 'Stacked rollout recommendation: off. Keep anti-chase active for Ready, but reserve mandatory lower-extreme context for Entry Best and Entry Strict.')
var bool stretch_require_lower_extreme_for_entry_best = input.bool(false, 'Entry Best requires lower extreme context', group = g_stretch, tooltip = 'Stacked rollout recommendation: off. Anti-chase stays active, but Best no longer needs a fresh lower-extreme context on top of acceleration, DDVI, and regime filters.')
var bool stretch_require_lower_extreme_for_entry_strict = input.bool(true, 'Entry Strict requires lower extreme context', group = g_stretch, tooltip = 'Recommended on. Strict should stay fully tied to real lower-extreme mean-reversion setups.')
var bool show_stretch_overlay = input.bool(true, 'Show stretch overlays', group = g_stretch)
var bool show_mean_target_overlay = input.bool(true, 'Show mean target overlay', group = g_stretch)
var bool show_lower_extreme_bg = input.bool(false, 'Highlight lower extreme background', group = g_stretch)

var string g_ddvi_ctx = 'DDVI Context'
var bool use_ddvi_context = input.bool(true, 'Use DDVI context', group = g_ddvi_ctx, tooltip = 'Preset guide:\nStacked rollout = close-safe on, hidden bull on, strong bull on, lower-extreme context modestly persistent.\nBalanced = strong bull off if DDVI should mostly reward continuation-quality hidden divergence.\nTight = keep strong bull on and shorten the lower-extreme context window if DDVI should gate only the cleanest reversals.')
var int ddvi_di_length = input.int(14, 'DDVI DI Length', minval = 1, group = g_ddvi_ctx, inline = 'd1')
var int ddvi_advx_smooth = input.int(14, 'ADVX Smooth', minval = 1, group = g_ddvi_ctx, inline = 'd1')
var ct.SmcLibMovingAverage ddvi_ma_select = input.enum(ct.SmcLibMovingAverage.SMA, 'DDVI MA', group = g_ddvi_ctx, inline = 'd2')
var int ddvi_ma_len = input.int(5, 'Length', minval = 1, group = g_ddvi_ctx, inline = 'd2')
var ct.SmcLibMovingAverage ddvi_bb_ma_select = input.enum(ct.SmcLibMovingAverage.SMA, 'DDVI BB MA', group = g_ddvi_ctx, inline = 'bb')
var int ddvi_bb_len = input.int(100, 'BB Length', minval = 5, group = g_ddvi_ctx, inline = 'bb')
var float ddvi_bb_mult = input.float(1.5, 'BB Stdev', minval = 0.1, step = 0.1, group = g_ddvi_ctx, inline = 'bb')
var int ddvi_lower_extreme_lookback = input.int(12, 'Lower extreme context bars', minval = 1, maxval = 50, group = g_ddvi_ctx, tooltip = 'Stacked rollout recommendation: 12. This keeps DDVI context alive long enough for Watchlist and Ready without forcing DDVI to remain at the absolute lower extreme.')
var bool use_ddvi_hidden_bull = input.bool(true, 'Use hidden bull divergence', group = g_ddvi_ctx, inline = 'div', tooltip = 'Recommended on. Hidden bull divergence is the most natural DDVI continuation signal for long-dip entries.')
var bool use_ddvi_strong_bull = input.bool(true, 'Use strong bull divergence', group = g_ddvi_ctx, inline = 'div', tooltip = 'Stacked rollout recommendation: on. Strong bull divergence can upgrade DDVI into Entry Best without forcing Strict to rely on a second divergence engine on top of SD.')
var int ddvi_pivot_left = input.int(5, 'Pivot Left', minval = 1, group = g_ddvi_ctx, inline = 'p1')
var int ddvi_pivot_right = input.int(3, 'Right', minval = 1, group = g_ddvi_ctx, inline = 'p1')
var int ddvi_div_min_range = input.int(5, 'Div Min', minval = 1, group = g_ddvi_ctx, inline = 'p2')
var int ddvi_div_max_range = input.int(60, 'Max', minval = 2, group = g_ddvi_ctx, inline = 'p2')
var int ddvi_eq_zone_len = input.int(14, 'Equal zone length', minval = 1, group = g_ddvi_ctx, inline = 'p3')
var float ddvi_eq_zone_atr_mult = input.float(0.2, 'Price ATR x', minval = 0.0, step = 0.1, group = g_ddvi_ctx, inline = 'p3')
var float ddvi_eq_zone_dev_mult = input.float(0.2, 'DDVI Dev x', minval = 0.0, step = 0.01, group = g_ddvi_ctx, inline = 'p3')
var bool ddvi_close_safe_only = input.bool(true, 'DDVI events close-safe only', group = g_ddvi_ctx, tooltip = 'Recommended on. Keeps DDVI event gating aligned with the rest of the close-safe SMC++ flow.')

var g_struct = 'Market Structure'
var bool show_Structure = input.bool(false, 'Show Market Structure', group = g_struct, tooltip = SHOW_SWING)
var string show_bull = input.string('All', 'Bullish Structure', options = ['All', 'BOS', 'CHoCH'], group = g_struct, inline = 'bull')
var color bull_css = input.color(#089981, '', group = g_struct, inline = 'bull')
var color bear_css = input.color(#f23645, '', group = g_struct, inline = 'bear')
var bool show_swing_points = input.bool(false, 'Show Swing Points (HH/LH/HL/LL)', group = g_struct, inline = 'swings', tooltip = SHOW_SWING_POINTS)
var int swing_length = input.int(DEFAULT_SWING_LENGTH, 'Swing Size', minval = 10, group = g_struct, inline = 'swings')
var bool show_internals = input.bool(false, 'Show Internal Structure', group = g_struct, inline = 'internals')
var int internal_length = input.int(DEFAULT_INTERNAL_LENGTH, 'Internal Size', minval = 3, group = g_struct, inline = 'internals')
var bool show_latest_swings_levels = input.bool(true, 'Show Strong/Weak High/Low', group = g_struct, tooltip = SHOW_SWHL_POINTS)

var bool show_bull_bos = show_Structure and (show_bull == 'All' or show_bull == 'BOS')
var bool show_bull_choch = show_Structure and (show_bull == 'All' or show_bull == 'CHoCH')

var g_ob = 'Order Blocks'
var show_ob = input.bool(true, 'Show Order Blocks', group = g_ob, inline = 'OB', tooltip = SWING_OB)
var bull_ob_css = input.color(color.new(#3668f2, 80), '', group = g_ob, inline = 'OB')
var bull_ob_css_line = input.color(color.new(#3668f2, 15), '', group = g_ob, inline = 'OB')
var ob_showlast = input.int(DEFAULT_OB_SHOW_LAST, 'Show last', minval = 1, group = g_ob, inline = 'OB')
var ob_filter_min_mult = input.float(DEFAULT_OB_FILTER_MIN_MULT, 'Size Filter (ATR x) Min', minval = 0, step = 0.1, group = g_ob, inline = 'OB Filter')
var ob_filter_max_mult = input.float(DEFAULT_OB_FILTER_MAX_MULT, 'Max', minval = 1, step = 0.1, group = g_ob, inline = 'OB Filter', tooltip = FILTER_OB)
var show_ob_id = false
var ob_extend_until_broken = input.bool(true, 'Extend until broken', group = g_ob)
var ob_keep_broken = input.bool(true, 'Keep broken', group = g_ob, inline = 'keep broken')
var ob_keep_broken_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 0, group = g_ob, inline = 'keep broken')
var bull_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken')
var bull_ob_line_css_broken = color.new(bull_ob_css_broken, 50)
var use_ob_profile = input.bool(true, 'Use profiles', group = g_ob, display = display.none, tooltip = 'Narrows the box to the value area and can align the break price to the profile POC.')
var use_ob_soft_confirm = input.bool(true, 'Use soft confirm', inline = 'soft confirm', group = g_ob, display = display.none, tooltip = 'A block may confirm early if price interacts with the break area and then exits in trend direction.')
var soft_confirm_offset_atr_len = ATR_LEN_MAIN
var soft_confirm_offset_atr_mult = 1.0
var use_retracements_with_FVG_out = input.bool(true, 'Use retracements with FVG-out as trend-supporting OB', group = g_ob, display = display.none, tooltip = 'Allows certain failed extensions with FVG confirmation to become valid continuation order blocks.')
var use_ob_engine = input.bool(true, 'Use OB engine', group = g_ob, display = display.none, tooltip = 'Keeps OB-based long-dip logic and alerts running even if chart rendering is hidden.')

active_break_mode = signal_mode == ct.SignalMode.CONFIRMED_ONLY ? ct.LevelBreakMode.CLOSE : ct.LevelBreakMode.HIGHLOW
signal_mode_text = signal_mode == ct.SignalMode.CONFIRMED_ONLY ? 'confirmed' : 'live rt-only'
visible_left_time = render_visible_only ? chart.left_visible_bar_time : na
visible_right_time = render_visible_only ? chart.right_visible_bar_time : na

float soft_confirm_offset = smc_lib_atr(soft_confirm_offset_atr_len) * soft_confirm_offset_atr_mult
ob_threshold_atr = smc_lib_atr(ATR_LEN_MAIN)
ob_threshold_min = ob_threshold_atr * ob_filter_min_mult
ob_threshold_max = ob_threshold_atr * ob_filter_max_mult

float nonzero_volume_cum = ta.cum((not na(volume) and volume > 0) ? 1.0 : 0.0)
float nonzero_volume_bars = nonzero_volume_cum - nz(nonzero_volume_cum[volume_quality_lookback], 0.0)
float summed_volume_cum = ta.cum(nz(volume, 0))
float summed_volume = summed_volume_cum - nz(summed_volume_cum[volume_quality_lookback], 0.0)
bool volume_current_bar_ok = not na(volume) and volume > 0
bool volume_feed_quality_ok = summed_volume > 0 and nonzero_volume_bars >= min_nonzero_volume_bars
bool volume_data_ok = volume_current_bar_ok and volume_feed_quality_ok
bool use_ob_profile_effective = use_ob_profile and volume_feed_quality_ok
bool collect_ob_profile_current_bar = use_ob_profile_effective and volume_current_bar_ok

var label volume_quality_warning = na
if barstate.islast
    if not volume_current_bar_ok or not volume_feed_quality_ok
        string profile_warning_text = not use_ob_profile ? 'OB profiles are already off' : not volume_feed_quality_ok ? 'OB profiles are paused from weak feed' : not volume_current_bar_ok ? 'OB profiles keep last valid shape' : 'OB profiles are on'
        string relvol_warning_text = not use_rel_volume ? 'RelVol is off' : volume_current_bar_ok ? allow_relvol_without_volume_data ? 'RelVol can fall back' : 'RelVol can stay blocked' : allow_relvol_without_volume_data ? 'RelVol falls back on this bar' : 'RelVol is blocked on this bar'
        string strict_warning_text = use_ltf_for_strict_entry ? 'Strict and LTF delta stay limited' : 'Strict LTF is off'
        string volume_warning_text = str.format('Volume data quality is limited\n{0}; {1}; {2}', profile_warning_text, relvol_warning_text, strict_warning_text)
        if na(volume_quality_warning)
            volume_quality_warning := label.new(bar_index, close, volume_warning_text, color = color.orange, textcolor = color.white, style = label.style_label_left, size = size.small)
        else
            label.set_xy(volume_quality_warning, bar_index, close)
            label.set_text(volume_quality_warning, volume_warning_text)
    else if not na(volume_quality_warning)
        label.delete(volume_quality_warning)
        volume_quality_warning := na

var ProfileConfig profile_config_bull = ProfileConfig.new(poc_label_text = 'OB - POC ⬈', extend = ob_extend_until_broken, show_labels = true, args_poc_line = d.LineArgs.new(bull_ob_css_line, line.style_dashed, xloc = xloc.bar_index), args_poc_label = d.LabelArgs.new(bull_ob_css_line, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal))
var OrderBlockConfig ob_config_bull = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = d.BoxArgs.new(bg_color = bull_ob_css, border_color = #00000000, xloc = xloc.bar_index), txt_args = d.BoxTextArgs.new(color.green, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull)
var ProfileConfig profile_config_bull_broken = ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = d.LineArgs.new(bull_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_index), args_poc_label = d.LabelArgs.new(#00000000))
var OrderBlockConfig ob_config_bull_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = d.BoxArgs.new(bg_color = bull_ob_css_broken, border_color = #00000000, xloc = xloc.bar_index), txt_args = d.BoxTextArgs.new(bull_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull_broken)
ob_config_bull.show_profile := use_ob_profile_effective
ob_config_bull_broken.show_profile := use_ob_profile_effective

int chart_tf_sec = nz(timeframe.in_seconds(), 0)
bool intraday_time_chart = chart_tf_sec > 0 and chart_tf_sec < 86400
string current_symbol_key = syminfo.ticker
string current_symbol_key_qualified = syminfo.tickerid
bool micro_is_clean_reclaim = use_microstructure_profiles and u.csv_has_symbol_token(clean_reclaim_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_stop_hunt = use_microstructure_profiles and u.csv_has_symbol_token(stop_hunt_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_midday_dead = use_microstructure_profiles and u.csv_has_symbol_token(midday_dead_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_rth_only = use_microstructure_profiles and u.csv_has_symbol_token(rth_only_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_weak_premarket = use_microstructure_profiles and u.csv_has_symbol_token(weak_premarket_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_weak_afterhours = use_microstructure_profiles and u.csv_has_symbol_token(weak_afterhours_tickers, current_symbol_key, current_symbol_key_qualified)
bool micro_is_fast_decay = use_microstructure_profiles and u.csv_has_symbol_token(fast_decay_tickers, current_symbol_key, current_symbol_key_qualified)
string micro_profile_text = 'Default'
if micro_is_stop_hunt
    micro_profile_text := 'Stop-Hunt Sensitive'
else if micro_is_clean_reclaim
    micro_profile_text := 'Clean Reclaim'
else if micro_is_rth_only
    micro_profile_text := 'RTH Only'
else if micro_is_midday_dead
    micro_profile_text := 'Midday Dead'
else if micro_is_fast_decay
    micro_profile_text := 'Fast Decay'
string micro_modifier_text = ''
if micro_is_stop_hunt and micro_profile_text != 'Stop-Hunt Sensitive'
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Stop-Hunt' : 'Stop-Hunt'
if micro_is_clean_reclaim and micro_profile_text != 'Clean Reclaim'
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Clean Reclaim' : 'Clean Reclaim'
if micro_is_fast_decay and micro_profile_text != 'Fast Decay'
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Fast Decay' : 'Fast Decay'
if micro_is_rth_only and micro_profile_text != 'RTH Only'
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', RTH Only' : 'RTH Only'
if micro_is_midday_dead and micro_profile_text != 'Midday Dead'
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Midday Dead' : 'Midday Dead'
if micro_is_weak_premarket
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Weak Premarket' : 'Weak Premarket'
if micro_is_weak_afterhours
    micro_modifier_text += str.length(micro_modifier_text) > 0 ? ', Weak Afterhours' : 'Weak Afterhours'
auto_selected_ltf = u.auto_ltf_timeframe(chart_tf_sec)
effective_ltf_timeframe = ltf_auto_select ? auto_selected_ltf : ltf_timeframe
int effective_ltf_tf_sec = nz(timeframe.in_seconds(effective_ltf_timeframe), 0)
ltf_timeframe_valid = chart_tf_sec > 0 and str.length(effective_ltf_timeframe) > 0 and effective_ltf_tf_sec > 0 and effective_ltf_tf_sec < chart_tf_sec
ltf_ratio = effective_ltf_tf_sec > 0 ? int(math.floor(chart_tf_sec / effective_ltf_tf_sec)) : na
bool ltf_needed_for_logic = (show_dashboard and show_dashboard_ltf) or use_ltf_for_strict_entry
bool ltf_needed_for_messages = enable_dynamic_alerts and use_ltf_for_dynamic_alerts
bool ltf_needed = ltf_needed_for_logic or ltf_needed_for_messages
bool ltf_ratio_ok = not na(ltf_ratio) and ltf_ratio > 0 and ltf_ratio <= max_ltf_ratio
bool ltf_sample_count_ok = not na(ltf_ratio) and ltf_ratio <= max_ltf_samples_per_bar
ltf_sampling_active = enable_ltf_sampling and ltf_timeframe_valid and ltf_needed and ltf_ratio_ok and ltf_sample_count_ok
if barstate.isfirst and enable_ltf_sampling and ltf_timeframe_valid and (not ltf_ratio_ok or not ltf_sample_count_ok)
    log.warning(str.format('LTF sampling disabled: ratio chart/ltf = {0} exceeds configured limits. Chart TF={1}s, LTF={2}s, max_ratio={3}, max_samples={4}', ltf_ratio, chart_tf_sec, effective_ltf_tf_sec, max_ltf_ratio, max_ltf_samples_per_bar))
int marker_gap_reference_seconds = marker_gap_reference_minutes * 60
int effective_reclaim_marker_gap = u.scaled_marker_gap(reclaim_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_confirm_marker_gap = u.scaled_marker_gap(confirm_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_ready_marker_gap = u.scaled_marker_gap(ready_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)

[ltf_opens_raw, ltf_closes_raw, ltf_volumes_raw] = if ltf_sampling_active
    request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, [open, close, volume], calc_bars_count = 1)
else
    [array.new<float>(0), array.new<float>(0), array.new<float>(0)]
int ltf_open_count = ltf_opens_raw.size()
int ltf_close_count = ltf_closes_raw.size()
int ltf_volume_count = ltf_volumes_raw.size()
bool ltf_price_ok = ltf_sampling_active and ltf_open_count > 0 and ltf_open_count == ltf_close_count
bool ltf_volume_ok = ltf_price_ok and ltf_volume_count > 0 and ltf_volume_count == ltf_open_count
bool ltf_price_only = ltf_price_ok and not ltf_volume_ok
float[] ltf_opens = ltf_price_ok ? ltf_opens_raw : array.new<float>(0)
float[] ltf_closes = ltf_price_ok ? ltf_closes_raw : array.new<float>(0)
float[] ltf_volumes = ltf_volume_ok ? ltf_volumes_raw : array.new<float>(0)
[ltf_sample_count_raw, ltf_bull_share_raw, ltf_volume_delta_raw] = u.ltf_stats(ltf_opens, ltf_closes, ltf_volumes)
ltf_sample_count = ltf_price_ok ? ltf_sample_count_raw : 0
ltf_bull_share = ltf_price_ok ? ltf_bull_share_raw : na
ltf_volume_delta = ltf_volume_ok ? ltf_volume_delta_raw : na
bool strict_ltf_available = ltf_sampling_active and ltf_volume_ok
bool strict_ltf_unavailable = use_ltf_for_strict_entry and not strict_ltf_available
bool strict_ltf_unverifiable = use_ltf_for_strict_entry and not barstate.isrealtime and not strict_ltf_available
var label strict_ltf_warning = na
if barstate.islast
    if strict_ltf_unavailable and not allow_strict_entry_without_ltf
        string strict_ltf_reason_text = not enable_ltf_sampling ? 'LTF sampling is turned off' : not ltf_timeframe_valid ? 'LTF timeframe is unavailable on this chart' : not ltf_ratio_ok or not ltf_sample_count_ok ? 'LTF sampling is guarded by ratio/sample limits' : not ltf_price_ok ? 'LTF intrabars are unavailable on this bar/history window' : not ltf_volume_ok ? 'LTF volume is unavailable on this bar' : 'LTF sampling is unavailable'
        string strict_ltf_warning_text = str.format('Strict entry is blocked\n{0}\nAdjust chart/LTF settings or enable the strict-entry fallback', strict_ltf_reason_text)
        if na(strict_ltf_warning)
            strict_ltf_warning := label.new(bar_index, high, strict_ltf_warning_text, color = color.new(color.red, 0), textcolor = color.white, style = label.style_label_upper_left, size = size.small)
        else
            label.set_xy(strict_ltf_warning, bar_index, high)
            label.set_text(strict_ltf_warning, strict_ltf_warning_text)
    else if not na(strict_ltf_warning)
        label.delete(strict_ltf_warning)
        strict_ltf_warning := na

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
float session_vwap = intraday_time_chart ? ta.vwap(hlc3) : na
bool vwap_session_active = intraday_time_chart and not na(time(timeframe.period, vwap_session))
bool trade_entry_session_active = intraday_time_chart and not na(time(timeframe.period, trade_entry_session))
bool micro_midday_block_active = intraday_time_chart and not na(time(timeframe.period, micro_midday_block_session))
bool micro_premarket_active = intraday_time_chart and not na(time(timeframe.period, micro_premarket_session))
bool micro_afterhours_active = intraday_time_chart and not na(time(timeframe.period, micro_afterhours_session))
bool session_gate_ok = not use_trade_session_gate ? true : not intraday_time_chart ? true : not block_entries_outside_session ? true : trade_entry_session_active
int opening_range_bars = chart_tf_sec > 0 ? math.max(1, int(math.ceil(opening_range_minutes * 60.0 / chart_tf_sec))) : 1
var float opening_range_high = na
var float opening_range_low = na
var int regular_session_open_bar = na
bool regular_session_just_opened = vwap_session_active and not vwap_session_active[1]
if regular_session_just_opened
    regular_session_open_bar := bar_index
    opening_range_high := high
    opening_range_low := low
else if vwap_session_active and not na(regular_session_open_bar)
    int bars_since_regular_open = bar_index - regular_session_open_bar
    if bars_since_regular_open < opening_range_bars
        opening_range_high := na(opening_range_high) ? high : math.max(opening_range_high, high)
        opening_range_low := na(opening_range_low) ? low : math.min(opening_range_low, low)
bool opening_range_ready = vwap_session_active and not na(regular_session_open_bar) and bar_index - regular_session_open_bar >= opening_range_bars and not na(opening_range_high) and not na(opening_range_low)
float opening_range_mid = opening_range_ready ? math.avg(opening_range_high, opening_range_low) : na
bool opening_range_gate_ok = not use_opening_range_gate ? true : not intraday_time_chart ? true : not vwap_session_active ? true : not opening_range_ready ? false : opening_range_bias_mode == 'Above OR High' ? close > opening_range_high : close > opening_range_mid
bool session_structure_gate_ok = session_gate_ok and opening_range_gate_ok
bool micro_rth_gate_ok = not micro_is_rth_only or not intraday_time_chart or vwap_session_active
bool micro_midday_gate_ok = not micro_is_midday_dead or not intraday_time_chart or not micro_midday_block_active
bool micro_premarket_gate_ok = not micro_is_weak_premarket or not intraday_time_chart or not micro_premarket_active
bool micro_afterhours_gate_ok = not micro_is_weak_afterhours or not intraday_time_chart or not micro_afterhours_active
bool micro_session_gate_ok = not use_microstructure_profiles or not intraday_time_chart or (micro_rth_gate_ok and micro_midday_gate_ok and micro_premarket_gate_ok and micro_afterhours_gate_ok)
bool vwap_filter_ok = not use_vwap_filter ? true : not intraday_time_chart ? true : not vwap_session_active ? true : not na(session_vwap) and close >= session_vwap

plot(show_session_vwap and intraday_time_chart ? session_vwap : na, 'Session VWAP', color = color.new(color.blue, 0), linewidth = 2)

plot(show_ema_support ? ema_fast : na, 'EMA Fast', color = color.new(color.lime, 0), linewidth = 2)
plot(show_ema_support ? ema_slow : na, 'EMA Slow', color = color.new(color.teal, 0), linewidth = 2)

[plus_di, minus_di, adx_value] = ta.dmi(adx_len, adx_len)
bool adx_data_ok = not na(adx_value) and not na(plus_di) and not na(minus_di)
float rel_volume_ma_raw = ta.sma(volume, relvol_len)
bool relvol_data_ok = volume_current_bar_ok and not na(rel_volume_ma_raw) and rel_volume_ma_raw > 0
float rel_volume_ma = relvol_data_ok ? rel_volume_ma_raw : na
float rel_volume = not relvol_data_ok ? float(na) : volume / rel_volume_ma

bar_range = math.max(high - low, syminfo.mintick)
bull_close_in_range = (close - low) / bar_range
float atr_now = smc_lib_atr(ATR_LEN_MAIN)
float atr_baseline = ta.sma(atr_now, vola_baseline_len)
float range_baseline = ta.sma(bar_range, vola_baseline_len)
bool vola_compression_now = not na(atr_baseline) and not na(range_baseline) and atr_baseline > 0 and range_baseline > 0 and atr_now <= atr_baseline * compression_ratio_max and bar_range <= range_baseline * compression_ratio_max
int compression_since_bars = ta.barssince(vola_compression_now)
bool vola_compression_recent = not na(compression_since_bars) and compression_since_bars <= compression_recent_bars

bool bull_close_strong = not use_strong_close_filter ? true : bull_close_in_range >= min_close_in_range_pct
string close_state_text = not use_strong_close_filter ? 'off' : bull_close_strong ? 'Strong Close' : 'Weak Close'
bool vola_expansion_now = not na(range_baseline) and range_baseline > 0 and bar_range >= range_baseline * expansion_range_mult and bull_close_strong
bool vola_regime_gate_ok = not use_vola_compression_gate ? true : vola_compression_recent and (not require_expansion_on_confirm_or_ready or vola_expansion_now)

bool ema_support_ok = not show_ema_support ? true : close >= ema_fast and ema_fast >= ema_slow and ema_fast > ema_fast[1]
string ema_state_text = not show_ema_support ? 'off' : ema_support_ok ? 'OK' : 'No'
string vwap_state_text = not use_vwap_filter ? 'off' : not intraday_time_chart ? 'n/a' : not vwap_session_active ? 'off session' : na(session_vwap) ? 'n/a' : close >= session_vwap ? 'Above VWAP' : 'Below VWAP'

bool adx_strong = not use_adx ? true : adx_data_ok and adx_value >= adx_strong_min and plus_di >= minus_di
string adx_state_text = not use_adx ? 'off' : not adx_data_ok ? 'n/a' : plus_di < minus_di ? 'Bearish pressure' : adx_value < adx_trend_min ? 'Sideways' : adx_value < adx_strong_min ? 'Trend building' : 'Trend'

float accel_fast_raw = u.lr_slope_pct(close, accel_len_fast)
float accel_mid1_raw = u.lr_slope_pct(close, accel_len_mid1)
float accel_mid2_raw = u.lr_slope_pct(close, accel_len_mid2)
float accel_slow_raw = u.lr_slope_pct(close, accel_len_slow)
float accel_raw = u.weighted_avg4(accel_fast_raw, accel_mid1_raw, accel_mid2_raw, accel_slow_raw, 1.5, 1.25, 1.0, 0.75)
float accel_value = ta.ema(accel_raw, accel_smooth_len)
bool accel_above_zero = not na(accel_value) and accel_value > accel_cross_threshold
bool accel_below_zero = not na(accel_value) and accel_value < accel_cross_threshold
bool accel_rising = not na(accel_value) and accel_value > accel_value[1]
bool accel_below_zero_rising = not na(accel_value) and accel_value < accel_cross_threshold and accel_value > accel_value[1]
bool accel_cross_up = ta.crossover(accel_value, accel_cross_threshold)
int accel_cross_since_bars = ta.barssince(accel_cross_up)
bool accel_cross_up_recent = not na(accel_cross_since_bars) and accel_cross_since_bars <= accel_recent_cross_bars
float accel_value_safe = accel_value
bool accel_below_zero_rising_safe = accel_below_zero_rising
bool accel_cross_up_safe = accel_cross_up
bool accel_cross_up_recent_safe = accel_cross_up_recent
if accel_close_safe_only and not barstate.isconfirmed
    accel_value_safe := nz(accel_value[1], accel_value)
    accel_below_zero_rising_safe := false
    accel_cross_up_safe := false
    accel_cross_up_recent_safe := false
    if bar_index > 0
        accel_below_zero_rising_safe := accel_below_zero_rising[1]
        accel_cross_up_safe := accel_cross_up[1]
        accel_cross_up_recent_safe := accel_cross_up_recent[1]
bool accel_pullback_exhaustion_long = use_accel_module and accel_below_zero_rising_safe
bool accel_zero_cross_up = accel_cross_up_safe
bool accel_reaccel_confirm_long = use_accel_module and accel_cross_up_safe
bool accel_recent_cross_long = accel_cross_up_recent_safe
bool accel_mode_early_only = accel_integration_mode == 'Early only'
bool accel_mode_strict_entries_only = accel_integration_mode == 'Strict entries only'
bool accel_early_context_ok = not use_accel_module or not accel_use_for_early or accel_below_zero_rising_safe or accel_cross_up_recent_safe
bool accel_ready_context_ok = not use_accel_module or not accel_use_for_ready or accel_below_zero_rising_safe or accel_cross_up_recent_safe
bool accel_entry_best_context_ok = not use_accel_module or not accel_use_for_entry_best or accel_below_zero_rising_safe or accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_entry_strict_context_ok = not use_accel_module or not accel_use_for_entry_strict or accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_early_gate_ok = accel_early_context_ok
bool accel_confirm_gate_ok = not use_accel_module or accel_mode_early_only or accel_mode_strict_entries_only or accel_cross_up_safe or accel_cross_up_recent_safe
bool accel_ready_gate_ok = not use_accel_module or accel_mode_strict_entries_only or (require_accel_above_zero_for_ready ? ((not na(accel_value_safe) and accel_value_safe > accel_cross_threshold) or accel_cross_up_recent_safe) : accel_ready_context_ok)
bool accel_entry_best_gate_ok = accel_entry_best_context_ok
bool accel_strict_entry_gate_ok = accel_entry_strict_context_ok

float sd_raw = u.sd_lr2_pct(close, sd_lr_len)
float sd_value = ta.ema(sd_raw, sd_smooth_len)
bool sd_above_zero = not na(sd_value) and sd_value > 0
bool sd_below_zero = not na(sd_value) and sd_value < 0
bool sd_rising = not na(sd_value) and sd_value > sd_value[1]
bool sd_falling = not na(sd_value) and sd_value < sd_value[1]

var float last_price_pivot_low = na
var float last_sd_at_price_pivot_low = na
var int last_price_pivot_low_bar = na
bool sd_bullish_divergence_event = false
float price_pivot_low = ta.pivotlow(low, sd_pivot_len, sd_pivot_len)
if not na(price_pivot_low)
    float new_price_pivot_low = price_pivot_low
    float new_sd_at_price_pivot_low = sd_value[sd_pivot_len]
    int new_price_pivot_low_bar = bar_index - sd_pivot_len
    sd_bullish_divergence_event :=
         not na(last_price_pivot_low) and
         not na(last_sd_at_price_pivot_low) and
         new_price_pivot_low < last_price_pivot_low and
         new_sd_at_price_pivot_low > last_sd_at_price_pivot_low
    last_price_pivot_low := new_price_pivot_low
    last_sd_at_price_pivot_low := new_sd_at_price_pivot_low
    last_price_pivot_low_bar := new_price_pivot_low_bar

int sd_bull_div_since_bars = ta.barssince(sd_bullish_divergence_event)
bool sd_bullish_divergence_recent = not na(sd_bull_div_since_bars) and sd_bull_div_since_bars <= sd_recent_window

var float last_sd_pivot_low = na
var int sd_higher_low_streak = 0
bool sd_higher_lows_event = false
float sd_pivot_low = ta.pivotlow(sd_value, sd_pivot_len, sd_pivot_len)
if not na(sd_pivot_low)
    float new_sd_pivot_low = sd_pivot_low
    if not na(last_sd_pivot_low) and new_sd_pivot_low > last_sd_pivot_low
        sd_higher_low_streak += 1
    else
        sd_higher_low_streak := 0
    last_sd_pivot_low := new_sd_pivot_low
    sd_higher_lows_event := sd_higher_low_streak >= sd_higher_low_steps_required

int sd_higher_lows_since_bars = ta.barssince(sd_higher_lows_event)
bool sd_higher_lows_recent = not na(sd_higher_lows_since_bars) and sd_higher_lows_since_bars <= sd_recent_window

bool sd_support_any_recent = sd_bullish_divergence_recent or sd_higher_lows_recent
bool sd_support_both_recent = sd_bullish_divergence_recent and sd_higher_lows_recent
bool sd_ready_context_ok = sd_support_any_recent and (not sd_require_osc_rising_for_ready or sd_rising)
bool sd_armed_gate_ok = not use_sd_confluence or not sd_require_for_armed or sd_support_any_recent
bool sd_early_gate_ok = not use_sd_confluence or not sd_require_for_early or sd_support_any_recent
bool sd_confirmed_gate_ok = not use_sd_confluence or not sd_require_for_confirmed or sd_support_any_recent
bool sd_ready_gate_ok = not use_sd_confluence or not sd_require_for_ready or sd_ready_context_ok
bool sd_entry_best_context_ok = (not sd_require_for_ready or sd_ready_context_ok) and sd_support_any_recent
bool sd_entry_best_gate_ok = not use_sd_confluence or not sd_require_for_entry_best or sd_entry_best_context_ok
bool sd_entry_strict_context_ok = (not sd_require_for_ready or sd_ready_context_ok) and (sd_require_both_for_entry_strict ? sd_support_both_recent : sd_support_any_recent)
bool sd_entry_strict_gate_ok = not use_sd_confluence or sd_entry_strict_context_ok

float effective_ob_reclaim_min_penetration = ob_reclaim_min_penetration
float effective_fvg_reclaim_min_penetration = fvg_reclaim_min_penetration
float effective_relvol_good = relvol_good
float effective_long_invalidation_atr_mult = long_invalidation_atr_mult
bool effective_use_live_confirm_break = use_live_confirm_break
bool effective_use_live_invalidation_break = use_live_invalidation_break
int effective_fast_decay_setup_age_max = long_setup_expiry_bars
int effective_fast_decay_confirm_age_max = long_confirm_expiry_bars
if use_microstructure_profiles and micro_is_stop_hunt
    effective_ob_reclaim_min_penetration := math.max(effective_ob_reclaim_min_penetration, micro_stop_hunt_ob_sweep_depth)
    effective_fvg_reclaim_min_penetration := math.max(effective_fvg_reclaim_min_penetration, micro_stop_hunt_fvg_sweep_depth)
    effective_relvol_good := math.max(effective_relvol_good, micro_stop_hunt_relvol_min)
    effective_long_invalidation_atr_mult := math.max(effective_long_invalidation_atr_mult, micro_stop_hunt_invalidation_atr)
    if micro_stop_hunt_force_close_confirm
        effective_use_live_confirm_break := false
    if micro_stop_hunt_disable_live_invalid
        effective_use_live_invalidation_break := false
if use_microstructure_profiles and micro_is_fast_decay
    effective_fast_decay_setup_age_max := math.min(effective_fast_decay_setup_age_max, micro_fast_decay_setup_age_max)
    effective_fast_decay_confirm_age_max := math.min(effective_fast_decay_confirm_age_max, micro_fast_decay_confirm_age_max)

bool relvol_ok = not use_rel_volume ? true : not relvol_data_ok ? allow_relvol_without_volume_data : not na(rel_volume) and rel_volume >= effective_relvol_good
bool relvol_score_ok = not use_rel_volume ? true : relvol_data_ok and not na(rel_volume) and rel_volume >= effective_relvol_good
string relvol_value_text = na(rel_volume) ? 'n/a' : str.tostring(rel_volume, '#.##') + 'x'
string relvol_text = not use_rel_volume ? 'off' : not relvol_data_ok ? allow_relvol_without_volume_data ? 'fallback' : 'blocked' : relvol_value_text

float vol_ma_1_qema = u.qema_like(close, vol_ma_len_1)
float vol_ma_2_qema = u.qema_like(close, vol_ma_len_2)
float vol_ma_3_qema = u.qema_like(close, vol_ma_len_3)
float vol_ma_4_qema = u.qema_like(close, vol_ma_len_4)
float vol_ma_1_ema = ta.ema(close, vol_ma_len_1)
float vol_ma_2_ema = ta.ema(close, vol_ma_len_2)
float vol_ma_3_ema = ta.ema(close, vol_ma_len_3)
float vol_ma_4_ema = ta.ema(close, vol_ma_len_4)
float vol_ma_1 = vol_ma_mode == 'QEMA-like' ? vol_ma_1_qema : vol_ma_1_ema
float vol_ma_2 = vol_ma_mode == 'QEMA-like' ? vol_ma_2_qema : vol_ma_2_ema
float vol_ma_3 = vol_ma_mode == 'QEMA-like' ? vol_ma_3_qema : vol_ma_3_ema
float vol_ma_4 = vol_ma_mode == 'QEMA-like' ? vol_ma_4_qema : vol_ma_4_ema

bool vol_bull_stack_order = vol_ma_1 > vol_ma_2 and vol_ma_2 > vol_ma_3 and vol_ma_3 > vol_ma_4
bool vol_bull_stack_slopes = vol_ma_1 > vol_ma_1[1] and vol_ma_2 > vol_ma_2[1] and vol_ma_3 > vol_ma_3[1] and vol_ma_4 > vol_ma_4[1]

float vol_gap_12 = math.max(vol_ma_1 - vol_ma_2, 0.0)
float vol_gap_23 = math.max(vol_ma_2 - vol_ma_3, 0.0)
float vol_gap_34 = math.max(vol_ma_3 - vol_ma_4, 0.0)
float vol_stack_spread_pct = 100.0 * (vol_gap_12 + vol_gap_23 + vol_gap_34) / math.max(math.abs(close), syminfo.mintick)
bool vol_stack_spread_rising = not na(vol_stack_spread_pct) and vol_stack_spread_pct > vol_stack_spread_pct[1]

float vol_momentum_raw = ta.roc(close, vol_momentum_len)
float vol_momentum = ta.ema(vol_momentum_raw, vol_momentum_smooth)
bool vol_momentum_expanding_long = not na(vol_momentum) and vol_momentum > 0 and vol_momentum > vol_momentum[1]

float vol_bb_basis = ta.sma(close, vol_bb_len)
float vol_bb_dev = ta.stdev(close, vol_bb_len) * vol_bb_mult
float vol_bb_upper = vol_bb_basis + vol_bb_dev
float vol_bb_lower = vol_bb_basis - vol_bb_dev

float vol_kc_basis = ta.ema(close, vol_kc_len)
float vol_kc_range = ta.atr(vol_kc_len) * vol_kc_mult
float vol_kc_upper = vol_kc_basis + vol_kc_range
float vol_kc_lower = vol_kc_basis - vol_kc_range

bool vol_squeeze_on = vol_bb_upper < vol_kc_upper and vol_bb_lower > vol_kc_lower
bool vol_squeeze_released = not vol_squeeze_on and vol_squeeze_on[1]

int vol_squeeze_since_bars = ta.barssince(vol_squeeze_on)
bool vol_squeeze_recent = not na(vol_squeeze_since_bars) and vol_squeeze_since_bars <= vol_squeeze_recent_bars

int vol_release_since_bars = ta.barssince(vol_squeeze_released)
bool vol_squeeze_release_recent = not na(vol_release_since_bars) and vol_release_since_bars <= vol_release_recent_bars

bool vol_regime_trend_ok = vol_bull_stack_order and (not vol_require_all_stack_slopes or vol_bull_stack_slopes)

bool vol_watchlist_context_ok = not use_volatility_regime or (vol_regime_trend_ok and (not vol_require_squeeze_for_watchlist or vol_squeeze_on or vol_squeeze_recent or vol_squeeze_release_recent))

bool vol_ready_context_ok = not use_volatility_regime or (vol_regime_trend_ok and vol_momentum_expanding_long and vol_stack_spread_rising and (not vol_require_squeeze_for_ready or vol_squeeze_on or vol_squeeze_recent or vol_squeeze_release_recent))

bool vol_entry_best_context_ok = not use_volatility_regime or (vol_ready_context_ok and (not vol_require_release_for_entry_best or vol_squeeze_release_recent))

bool vol_entry_strict_context_ok = not use_volatility_regime or (vol_entry_best_context_ok and vol_bull_stack_slopes and (not vol_require_release_for_entry_strict or vol_squeeze_release_recent))

bool vol_watchlist_context_ok_safe = vol_watchlist_context_ok
bool vol_entry_best_context_ok_safe = vol_entry_best_context_ok
bool vol_entry_strict_context_ok_safe = vol_entry_strict_context_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    vol_watchlist_context_ok_safe := vol_watchlist_context_ok[1]
    vol_entry_best_context_ok_safe := vol_entry_best_context_ok[1]
    vol_entry_strict_context_ok_safe := vol_entry_strict_context_ok[1]

float stretch_mean = ta.sma(close, stretch_len)
float stretch_std = ta.stdev(close, stretch_len)
float stretch_lower_threshold = not na(stretch_mean) and not na(stretch_std) ? stretch_mean - lower_extreme_z * stretch_std : na
bool in_lower_extreme = not na(stretch_lower_threshold) and low <= stretch_lower_threshold
int lower_extreme_since_bars = ta.barssince(in_lower_extreme)
bool lower_extreme_recent = not na(lower_extreme_since_bars) and lower_extreme_since_bars <= lower_extreme_recent_bars
float distance_to_mean_z = not na(stretch_mean) and not na(stretch_std) and stretch_std > 0 ? (close - stretch_mean) / stretch_std : na
bool anti_chase_ok_ready = not use_stretch_context or na(distance_to_mean_z) or distance_to_mean_z <= anti_chase_max_z_ready
bool anti_chase_ok_entry_best = not use_stretch_context or na(distance_to_mean_z) or distance_to_mean_z <= anti_chase_max_z_best
bool anti_chase_ok_entry_strict = not use_stretch_context or na(distance_to_mean_z) or distance_to_mean_z <= anti_chase_max_z_strict
bool stretch_watchlist_context_ok = not use_stretch_context or (not stretch_require_lower_extreme_for_watchlist or in_lower_extreme or lower_extreme_recent)
bool stretch_ready_context_ok = not use_stretch_context or ((not stretch_require_lower_extreme_for_ready or in_lower_extreme or lower_extreme_recent) and anti_chase_ok_ready)
bool stretch_entry_best_context_ok = not use_stretch_context or (stretch_ready_context_ok and (not stretch_require_lower_extreme_for_entry_best or in_lower_extreme or lower_extreme_recent) and anti_chase_ok_entry_best)
bool stretch_entry_strict_context_ok = not use_stretch_context or (stretch_entry_best_context_ok and (not stretch_require_lower_extreme_for_entry_strict or in_lower_extreme or lower_extreme_recent) and anti_chase_ok_entry_strict)

float ddvi_plus = na
float ddvi_minus = na
float ddvi_advx = na
float ddvi = na
float ddvi_bb_basis = na
float ddvi_bb_upper = na
float ddvi_bb_lower = na
bool ddvi_strong_bull = false
bool ddvi_hidden_bull = false
bool ddvi_event_bar_ok = ddvi_close_safe_only ? barstate.isconfirmed : (signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? true : barstate.isconfirmed)
[ddvi_plus_raw, ddvi_minus_raw, ddvi_advx_raw] = smc_lib_dmi(ddvi_di_length, ddvi_advx_smooth)
float ddvi_raw = ddvi_plus_raw - ddvi_minus_raw
float ddvi_ma_raw = smc_lib_get_ma(ddvi_ma_select, ddvi_raw, ddvi_ma_len)
[ddvi_bb_basis_raw, ddvi_bb_upper_raw, ddvi_bb_lower_raw] = smc_lib_bb(ddvi_ma_raw, ddvi_bb_len, ddvi_bb_mult, ddvi_bb_ma_select)
[ddvi_strong_bull_raw, _, _, _, _, _, ddvi_hidden_bull_raw, _, _, _] = smc_lib_detect_divergence(ddvi_ma_raw, ddvi_pivot_left, ddvi_pivot_right, ddvi_div_min_range, ddvi_div_max_range, low, high, ddvi_eq_zone_len, ddvi_eq_zone_dev_mult, ddvi_eq_zone_atr_mult)
ddvi_plus := ddvi_plus_raw
ddvi_minus := ddvi_minus_raw
ddvi_advx := ddvi_advx_raw
ddvi := ddvi_ma_raw
ddvi_bb_basis := ddvi_bb_basis_raw
ddvi_bb_upper := ddvi_bb_upper_raw
ddvi_bb_lower := ddvi_bb_lower_raw
ddvi_strong_bull := ddvi_strong_bull_raw
ddvi_hidden_bull := ddvi_hidden_bull_raw

bool ddvi_bias_cross_up_raw = ta.crossover(ddvi_ma_raw, 0)
bool ddvi_recover_from_lower_extreme_raw = ta.crossover(ddvi_ma_raw, ddvi_bb_lower_raw)
bool ddvi_bias_bull = use_ddvi_context and not na(ddvi) and ddvi > 0
bool ddvi_bias_rising = use_ddvi_context and not na(ddvi) and not na(ddvi[1]) and ddvi > ddvi[1]
bool ddvi_bias_cross_up = use_ddvi_context and ddvi_event_bar_ok and not na(ddvi) and ddvi_bias_cross_up_raw
bool ddvi_bias_ok = ddvi_bias_bull and ddvi_bias_rising
bool ddvi_bias_transition_ok = ddvi_bias_cross_up or (ddvi_bias_bull and ddvi_bias_rising)
bool ddvi_lower_extreme_now = use_ddvi_context and not na(ddvi) and not na(ddvi_bb_lower) and ddvi <= ddvi_bb_lower
int ddvi_lower_extreme_since = ta.barssince(ddvi_lower_extreme_now)
bool ddvi_lower_extreme_recent = use_ddvi_context and not na(ddvi_lower_extreme_since) and ddvi_lower_extreme_since <= ddvi_lower_extreme_lookback
bool ddvi_recover_from_lower_extreme = use_ddvi_context and ddvi_event_bar_ok and not na(ddvi) and not na(ddvi_bb_lower) and ddvi_recover_from_lower_extreme_raw
bool ddvi_lower_extreme_context = ddvi_lower_extreme_now or ddvi_lower_extreme_recent or ddvi_recover_from_lower_extreme
bool hidden_bull_divergence = use_ddvi_context and use_ddvi_hidden_bull and ddvi_hidden_bull
bool strong_bull_divergence = use_ddvi_context and use_ddvi_strong_bull and ddvi_strong_bull
bool ddvi_bull_divergence_any = hidden_bull_divergence or strong_bull_divergence
bool ddvi_watchlist_ok = not use_ddvi_context ? true : (ddvi_lower_extreme_context or ddvi_bias_rising)
bool ddvi_ready_ok = not use_ddvi_context ? true : (ddvi_recover_from_lower_extreme or (ddvi_bias_rising and not ddvi_lower_extreme_now))
bool ddvi_entry_best_ok = not use_ddvi_context ? true : (ddvi_ready_ok and (ddvi_bias_transition_ok or hidden_bull_divergence or strong_bull_divergence))
bool ddvi_entry_strict_ok = not use_ddvi_context ? true : (ddvi_entry_best_ok and ddvi_bias_ok and not ddvi_lower_extreme_now)
if ddvi_close_safe_only and not barstate.isconfirmed
    ddvi_watchlist_ok := bar_index > 0 ? ddvi_watchlist_ok[1] : ddvi_watchlist_ok
    ddvi_ready_ok := bar_index > 0 ? ddvi_ready_ok[1] : ddvi_ready_ok
    ddvi_entry_best_ok := bar_index > 0 ? ddvi_entry_best_ok[1] : ddvi_entry_best_ok
    ddvi_entry_strict_ok := bar_index > 0 ? ddvi_entry_strict_ok[1] : ddvi_entry_strict_ok
bool ddvi_watchlist_ok_safe = ddvi_watchlist_ok
bool ddvi_ready_ok_safe = ddvi_ready_ok
bool ddvi_entry_best_ok_safe = ddvi_entry_best_ok
bool ddvi_entry_strict_ok_safe = ddvi_entry_strict_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    ddvi_watchlist_ok_safe := bar_index > 0 ? ddvi_watchlist_ok[1] : ddvi_watchlist_ok
    ddvi_ready_ok_safe := bar_index > 0 ? ddvi_ready_ok[1] : ddvi_ready_ok
    ddvi_entry_best_ok_safe := bar_index > 0 ? ddvi_entry_best_ok[1] : ddvi_entry_best_ok
    ddvi_entry_strict_ok_safe := bar_index > 0 ? ddvi_entry_strict_ok[1] : ddvi_entry_strict_ok

mtf_trend_1 = get_confirmed_structure_trend(mtf_trend_tf1, swing_length)
mtf_trend_2 = get_confirmed_structure_trend(mtf_trend_tf2, swing_length)
mtf_trend_3 = get_confirmed_structure_trend(mtf_trend_tf3, swing_length)
[index_missing_calc, index_gate_ok_calc] = u.external_trend_gate(index_gate_symbol, market_gate_fast_len, market_gate_slow_len)
[sector_missing_calc, sector_gate_ok_calc] = u.external_trend_gate(sector_gate_symbol, market_gate_fast_len, market_gate_slow_len)
[breadth_missing_calc, breadth_gate_ok_calc] = u.external_breadth_gate(breadth_gate_symbol, breadth_gate_mode, breadth_gate_len)
bool index_missing = use_index_gate and index_missing_calc
bool index_gate_ok_raw = not use_index_gate or index_gate_ok_calc
bool sector_missing = use_sector_gate and sector_missing_calc
bool sector_gate_ok_raw = not use_sector_gate or sector_gate_ok_calc
bool breadth_missing = use_breadth_symbol_gate and breadth_missing_calc
bool breadth_gate_ok_raw = not use_breadth_symbol_gate or breadth_gate_ok_calc
bool market_symbols_missing = (use_index_gate and index_missing) or (use_sector_gate and sector_missing) or (use_breadth_symbol_gate and breadth_missing)
bool index_gate_effective_ok = not use_index_gate or (index_missing ? not block_on_missing_market_symbol : index_gate_ok_raw)
bool sector_gate_effective_ok = not use_sector_gate or (sector_missing ? not block_on_missing_market_symbol : sector_gate_ok_raw)
bool breadth_gate_effective_ok = not use_breadth_symbol_gate or (breadth_missing ? not block_on_missing_market_symbol : breadth_gate_ok_raw)
bool market_regime_gate_ok_raw = index_gate_effective_ok and sector_gate_effective_ok and breadth_gate_effective_ok

[trend, bull_bos_alert, bull_choch_alert, top_x, top, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm, trail_dn_x, trail_dn, ll, hhll_x] = detect_structure(swing_length, filter_insignificant_internal_breaks = true)
// Separate display-only trend state: avoid exposing the engine's bullish bootstrap bias before a real structure break occurs.
bool bullish_structure_break = bull_bos_alert or bull_choch_alert
bool bearish_structure_break = bear_bos_alert or bear_choch_alert
bool structure_break_detected = bullish_structure_break or bearish_structure_break
structure_display_trend = not na(ta.barssince(structure_break_detected)) ? trend : 0
bool bullish_trend_condition = structure_display_trend == 1
bool bearish_trend_condition = structure_display_trend == -1
bool live_exec = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE and barstate.isrealtime
bool state_update_bar_ok = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? true : barstate.isconfirmed
bool bull_bos_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? bull_bos_alert : barstate.isconfirmed and bull_bos_alert
bool bull_choch_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? bull_choch_alert : barstate.isconfirmed and bull_choch_alert
bool bear_bos_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? bear_bos_alert : barstate.isconfirmed and bear_bos_alert
bool bear_choch_sig = signal_mode == ct.SignalMode.AGGRESSIVE_LIVE ? bear_choch_alert : barstate.isconfirmed and bear_choch_alert
bool bullish_trend_safe = bullish_trend_condition
bool bearish_trend_safe = bearish_trend_condition
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    bullish_trend_safe := bullish_trend_condition[1]
    bearish_trend_safe := bearish_trend_condition[1]
bool market_regime_gate_ok = market_regime_gate_ok_raw
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    market_regime_gate_ok := bar_index > 0 ? market_regime_gate_ok_raw[1] : market_regime_gate_ok_raw
bool vola_regime_gate_safe = vola_regime_gate_ok
if signal_mode != ct.SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    vola_regime_gate_safe := bar_index > 0 ? vola_regime_gate_ok[1] : vola_regime_gate_ok
bool bullish_trend_started = bullish_trend_safe and not bullish_trend_safe[1]
bool bearish_trend_started = bearish_trend_safe and not bearish_trend_safe[1]
bool directional_trend_started = bullish_trend_started or bearish_trend_started

[internal_trend, internal_bull_bos_alert, internal_bull_choch_alert, internal_top_x, internal_top, internal_trail_up_x, internal_trail_up, internal_hh, internal_bear_bos_alert, internal_bear_choch_alert, internal_btm_x, internal_btm, internal_trail_dn_x, internal_trail_dn, internal_ll, internal_hhll_x] = detect_structure(internal_length, top, btm, filter_insignificant_internal_breaks = true)
