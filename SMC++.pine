var bool show_bull_choch = show_Structure and (show_bull == 'All' or show_bull == 'CHoCH')
var bool show_bear_bos = show_Structure and (show_bear == 'All' or show_bear == 'BOS')
var bool show_bear_choch = show_Structure and (show_bear == 'All' or show_bear == 'CHoCH')

var g_ob = 'Order Blocks'
var show_ob = input.bool(true, 'Show Order Blocks', group = g_ob, inline = 'OB', tooltip = SWING_OB)
var bull_ob_css = input.color(color.new(#3668f2, 80), '', group = g_ob, inline = 'OB')
var bear_ob_css = input.color(color.new(#f925eb, 80), '', group = g_ob, inline = 'OB')
var bull_ob_css_line = input.color(color.new(#3668f2, 15), '', group = g_ob, inline = 'OB')
var bear_ob_css_line = input.color(color.new(#f925eb, 15), '', group = g_ob, inline = 'OB')
var ob_showlast = input.int(DEFAULT_OB_SHOW_LAST, 'Show last', minval = 1, group = g_ob, inline = 'OB')
var ob_filter_min_mult = input.float(DEFAULT_OB_FILTER_MIN_MULT, 'Size Filter (ATR x) Min', minval = 0, step = 0.1, group = g_ob, inline = 'OB Filter')
var ob_filter_max_mult = input.float(DEFAULT_OB_FILTER_MAX_MULT, 'Max', minval = 1, step = 0.1, group = g_ob, inline = 'OB Filter', tooltip = FILTER_OB)
var show_ob_id = false
var ob_extend_until_broken = input.bool(true, 'Extend until broken', group = g_ob)
var ob_keep_broken = input.bool(true, 'Keep broken', group = g_ob, inline = 'keep broken')
var ob_keep_broken_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 0, group = g_ob, inline = 'keep broken')
var bull_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken')
var bear_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken')
var bull_ob_line_css_broken = color.new(bull_ob_css_broken, 50)
var bear_ob_line_css_broken = color.new(bear_ob_css_broken, 50)
var use_ob_profile = input.bool(true, 'Use profiles', group = g_ob, display = display.none, tooltip = 'Narrows the box to the value area and can align the break price to the profile POC.')
var use_ob_soft_confirm = input.bool(true, 'Use soft confirm', inline = 'soft confirm', group = g_ob, display = display.none, tooltip = 'A block may confirm early if price interacts with the break area and then exits in trend direction.')
var soft_confirm_offset_atr_len = ATR_LEN_MAIN
var soft_confirm_offset_atr_mult = 1.0
var use_retracements_with_FVG_out = input.bool(true, 'Use retracements with FVG-out as trend-supporting OB', group = g_ob, display = display.none, tooltip = 'Allows certain failed extensions with FVG confirmation to become valid continuation order blocks.')
var use_ob_engine = input.bool(true, 'Use OB engine', group = g_ob, display = display.none, tooltip = 'Keeps OB-based long-dip logic and alerts running even if chart rendering is hidden.')

active_break_mode = signal_mode == SignalMode.CONFIRMED_ONLY ? LevelBreakMode.CLOSE : LevelBreakMode.HIGHLOW
signal_mode_text = signal_mode == SignalMode.CONFIRMED_ONLY ? 'confirmed' : 'live'
visible_left_time = render_visible_only ? chart.left_visible_bar_time : na
visible_right_time = render_visible_only ? chart.right_visible_bar_time : na

float soft_confirm_offset = nd_atr(soft_confirm_offset_atr_len) * soft_confirm_offset_atr_mult
ob_threshold_atr = nd_atr(ATR_LEN_MAIN)
ob_threshold_min = ob_threshold_atr * ob_filter_min_mult
ob_threshold_max = ob_threshold_atr * ob_filter_max_mult

float nonzero_volume_cum = ta.cum((not na(volume) and volume > 0) ? 1.0 : 0.0)
float nonzero_volume_bars = nonzero_volume_cum - nz(nonzero_volume_cum[volume_quality_lookback], 0.0)
float summed_volume_cum = ta.cum(nz(volume, 0))
float summed_volume = summed_volume_cum - nz(summed_volume_cum[volume_quality_lookback], 0.0)
bool volume_data_ok = not na(volume) and summed_volume > 0 and nonzero_volume_bars >= min_nonzero_volume_bars
bool use_ob_profile_effective = use_ob_profile and volume_data_ok

var label volume_quality_warning = na
if barstate.islast
    if not volume_data_ok
        string volume_warning_text = allow_relvol_without_volume_data ? 'Volume data quality is limited\nRelVol fallback is active; profiles and LTF delta may be weak' : 'Volume data quality is limited\nRelVol, strict entry and ready filters may stay blocked'
        if na(volume_quality_warning)
            volume_quality_warning := label.new(bar_index, close, volume_warning_text, color = color.orange, textcolor = color.white, style = label.style_label_left, size = size.small)
        else
            label.set_xy(volume_quality_warning, bar_index, close)
            label.set_text(volume_quality_warning, volume_warning_text)
    else if not na(volume_quality_warning)
        label.delete(volume_quality_warning)
        volume_quality_warning := na

var ProfileConfig profile_config_bull = ProfileConfig.new(poc_label_text = 'OB - POC ⬈', extend = ob_extend_until_broken, show_labels = true, args_poc_line = LineArgs.new(bull_ob_css_line, line.style_dashed, xloc = xloc.bar_index), args_poc_label = LabelArgs.new(bull_ob_css_line, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal))
var ProfileConfig profile_config_bear = ProfileConfig.new(poc_label_text = 'OB - POC ⬊', extend = ob_extend_until_broken, show_labels = true, args_poc_line = LineArgs.new(bear_ob_css_line, line.style_dashed, xloc = xloc.bar_index), args_poc_label = LabelArgs.new(bear_ob_css_line, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal))
var OrderBlockConfig ob_config_bull = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = BoxArgs.new(bg_color = bull_ob_css, border_color = #00000000, xloc = xloc.bar_index), txt_args = BoxTextArgs.new(color.green, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull)
var OrderBlockConfig ob_config_bear = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = BoxArgs.new(bg_color = bear_ob_css, border_color = #00000000, xloc = xloc.bar_index), txt_args = BoxTextArgs.new(color.red, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bear)
var ProfileConfig profile_config_bull_broken = ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = LineArgs.new(bull_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_index), args_poc_label = LabelArgs.new(#00000000))
var ProfileConfig profile_config_bear_broken = ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = LineArgs.new(bear_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_index), args_poc_label = LabelArgs.new(#00000000))
var OrderBlockConfig ob_config_bull_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = BoxArgs.new(bg_color = bull_ob_css_broken, border_color = #00000000, xloc = xloc.bar_index), txt_args = BoxTextArgs.new(bull_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull_broken)
var OrderBlockConfig ob_config_bear_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = BoxArgs.new(bg_color = bear_ob_css_broken, border_color = #00000000, xloc = xloc.bar_index), txt_args = BoxTextArgs.new(bear_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bear_broken)
ob_config_bull.show_profile := use_ob_profile_effective
ob_config_bear.show_profile := use_ob_profile_effective
ob_config_bull_broken.show_profile := use_ob_profile_effective
ob_config_bear_broken.show_profile := use_ob_profile_effective

int chart_tf_sec = nz(timeframe.in_seconds(), 0)
bool intraday_time_chart = chart_tf_sec > 0 and chart_tf_sec < 86400
auto_selected_ltf = auto_ltf_timeframe(chart_tf_sec)
effective_ltf_timeframe = ltf_auto_select ? auto_selected_ltf : ltf_timeframe
int effective_ltf_tf_sec = nz(timeframe.in_seconds(effective_ltf_timeframe), 0)
ltf_timeframe_valid = chart_tf_sec > 0 and str.length(effective_ltf_timeframe) > 0 and effective_ltf_tf_sec > 0 and effective_ltf_tf_sec < chart_tf_sec
ltf_ratio = effective_ltf_tf_sec > 0 ? int(math.floor(chart_tf_sec / effective_ltf_tf_sec)) : na
bool ltf_needed_for_logic = (show_dashboard and show_dashboard_ltf) or use_ltf_for_strict_entry
bool ltf_needed_for_messages = enable_dynamic_alerts and use_ltf_for_dynamic_alerts
bool ltf_needed = ltf_needed_for_logic or ltf_needed_for_messages
bool ltf_ratio_ok = not na(ltf_ratio) and ltf_ratio > 0 and ltf_ratio <= max_ltf_ratio
bool ltf_sample_count_ok = not na(ltf_ratio) and ltf_ratio <= max_ltf_samples_per_bar
ltf_sampling_active = enable_ltf_sampling and ltf_timeframe_valid and ltf_needed and ltf_ratio_ok and ltf_sample_count_ok
if barstate.isfirst and enable_ltf_sampling and ltf_timeframe_valid and (not ltf_ratio_ok or not ltf_sample_count_ok)
    log.warning(str.format('LTF sampling disabled: ratio chart/ltf = {0} exceeds configured limits. Chart TF={1}s, LTF={2}s, max_ratio={3}, max_samples={4}', ltf_ratio, chart_tf_sec, effective_ltf_tf_sec, max_ltf_ratio, max_ltf_samples_per_bar))
int marker_gap_reference_seconds = marker_gap_reference_minutes * 60
int effective_reclaim_marker_gap = scaled_marker_gap(reclaim_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_confirm_marker_gap = scaled_marker_gap(confirm_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_ready_marker_gap = scaled_marker_gap(ready_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)

[ltf_opens_raw, ltf_closes_raw, ltf_volumes_raw] = if ltf_sampling_active
    request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, [open, close, volume], calc_bars_count = 1)
else
    [array.new<float>(0), array.new<float>(0), array.new<float>(0)]
int ltf_open_count = ltf_opens_raw.size()
int ltf_close_count = ltf_closes_raw.size()
int ltf_volume_count = ltf_volumes_raw.size()
bool ltf_price_ok = ltf_sampling_active and ltf_open_count > 0 and ltf_open_count == ltf_close_count
bool ltf_volume_ok = ltf_price_ok and volume_data_ok and ltf_volume_count == ltf_open_count
float[] ltf_opens = ltf_price_ok ? ltf_opens_raw : array.new<float>(0)
float[] ltf_closes = ltf_price_ok ? ltf_closes_raw : array.new<float>(0)
float[] ltf_volumes = ltf_volume_ok ? ltf_volumes_raw : array.new<float>(0)
[ltf_sample_count_raw, ltf_bull_share_raw, ltf_volume_delta_raw] = ltf_stats(ltf_opens, ltf_closes, ltf_volumes)
ltf_sample_count = ltf_price_ok ? ltf_sample_count_raw : 0
ltf_bull_share = ltf_price_ok ? ltf_bull_share_raw : na
ltf_volume_delta = ltf_volume_ok ? ltf_volume_delta_raw : na
bool strict_ltf_available = ltf_sampling_active and ltf_volume_ok
bool strict_ltf_unavailable = use_ltf_for_strict_entry and not strict_ltf_available
var label strict_ltf_warning = na
if barstate.islast
    if strict_ltf_unavailable and not allow_strict_entry_without_ltf
        string strict_ltf_warning_text = 'Strict entry is blocked by unavailable LTF sampling\nAdjust chart/LTF settings or enable the strict-entry fallback'
        if na(strict_ltf_warning)
            strict_ltf_warning := label.new(bar_index, high, strict_ltf_warning_text, color = color.new(color.red, 0), textcolor = color.white, style = label.style_label_upper_left, size = size.small)
        else
            label.set_xy(strict_ltf_warning, bar_index, high)
            label.set_text(strict_ltf_warning, strict_ltf_warning_text)
    else if not na(strict_ltf_warning)
        label.delete(strict_ltf_warning)
        strict_ltf_warning := na

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
float session_vwap = intraday_time_chart ? ta.vwap(hlc3) : na
bool vwap_session_active = intraday_time_chart and not na(time(timeframe.period, vwap_session))
bool trade_entry_session_active = intraday_time_chart and not na(time(timeframe.period, trade_entry_session))
bool session_gate_ok = not use_trade_session_gate ? true : not intraday_time_chart ? true : not block_entries_outside_session ? true : trade_entry_session_active
int opening_range_bars = chart_tf_sec > 0 ? math.max(1, int(math.ceil(opening_range_minutes * 60.0 / chart_tf_sec))) : 1
var float opening_range_high = na
var float opening_range_low = na
var int regular_session_open_bar = na
bool regular_session_just_opened = vwap_session_active and not vwap_session_active[1]
if regular_session_just_opened
    regular_session_open_bar := bar_index
    opening_range_high := high
    opening_range_low := low
else if vwap_session_active and not na(regular_session_open_bar)
    int bars_since_regular_open = bar_index - regular_session_open_bar
    if bars_since_regular_open < opening_range_bars
        opening_range_high := na(opening_range_high) ? high : math.max(opening_range_high, high)
        opening_range_low := na(opening_range_low) ? low : math.min(opening_range_low, low)
bool opening_range_ready = vwap_session_active and not na(regular_session_open_bar) and bar_index - regular_session_open_bar >= opening_range_bars and not na(opening_range_high) and not na(opening_range_low)
float opening_range_mid = opening_range_ready ? math.avg(opening_range_high, opening_range_low) : na
bool opening_range_gate_ok = not use_opening_range_gate ? true : not intraday_time_chart ? true : not vwap_session_active ? true : not opening_range_ready ? false : opening_range_bias_mode == 'Above OR High' ? close > opening_range_high : close > opening_range_mid
bool session_structure_gate_ok = session_gate_ok and opening_range_gate_ok
bool vwap_filter_ok = not use_vwap_filter ? true : not intraday_time_chart ? true : not vwap_session_active ? true : not na(session_vwap) and close >= session_vwap

plot(show_session_vwap and intraday_time_chart ? session_vwap : na, 'Session VWAP', color = color.new(color.blue, 0), linewidth = 2)

plot(show_ema_support ? ema_fast : na, 'EMA Fast', color = color.new(color.lime, 0), linewidth = 2)
plot(show_ema_support ? ema_slow : na, 'EMA Slow', color = color.new(color.teal, 0), linewidth = 2)

[plus_di, minus_di, adx_value] = ta.dmi(adx_len, adx_len)
bool adx_data_ok = not na(adx_value) and not na(plus_di) and not na(minus_di)
float rel_volume_ma_raw = ta.sma(volume, relvol_len)
float rel_volume_ma = volume_data_ok ? rel_volume_ma_raw : na
float rel_volume = not volume_data_ok or na(rel_volume_ma) or rel_volume_ma <= 0 ? float(na) : volume / rel_volume_ma

bar_range = math.max(high - low, syminfo.mintick)
bull_close_in_range = (close - low) / bar_range
float atr_now = nd_atr(ATR_LEN_MAIN)
float atr_baseline = ta.sma(atr_now, vola_baseline_len)
float range_baseline = ta.sma(bar_range, vola_baseline_len)
bool vola_compression_now = not na(atr_baseline) and not na(range_baseline) and atr_baseline > 0 and range_baseline > 0 and atr_now <= atr_baseline * compression_ratio_max and bar_range <= range_baseline * compression_ratio_max
int compression_since_bars = ta.barssince(vola_compression_now)
bool vola_compression_recent = not na(compression_since_bars) and compression_since_bars <= compression_recent_bars

bool bull_close_strong = not use_strong_close_filter ? true : bull_close_in_range >= min_close_in_range_pct
string close_state_text = not use_strong_close_filter ? 'off' : bull_close_strong ? 'Strong Close' : 'Weak Close'
bool vola_expansion_now = not na(range_baseline) and range_baseline > 0 and bar_range >= range_baseline * expansion_range_mult and bull_close_strong
bool vola_regime_gate_ok = not use_vola_compression_gate ? true : vola_compression_recent and (not require_expansion_on_confirm_or_ready or vola_expansion_now)

bool ema_support_ok = not show_ema_support ? true : close >= ema_fast and ema_fast >= ema_slow and ema_fast > ema_fast[1]
string ema_state_text = not show_ema_support ? 'off' : ema_support_ok ? 'OK' : 'No'
string vwap_state_text = not use_vwap_filter ? 'off' : not intraday_time_chart ? 'n/a' : not vwap_session_active ? 'off session' : na(session_vwap) ? 'n/a' : close >= session_vwap ? 'Above VWAP' : 'Below VWAP'

bool adx_strong = not use_adx ? true : adx_data_ok and adx_value >= adx_strong_min and plus_di >= minus_di
string adx_state_text = not use_adx ? 'off' : not adx_data_ok ? 'n/a' : plus_di < minus_di ? 'Bearish pressure' : adx_value < adx_trend_min ? 'Sideways' : adx_value < adx_strong_min ? 'Trend building' : 'Trend'

bool relvol_ok = not use_rel_volume ? true : not volume_data_ok ? allow_relvol_without_volume_data : not na(rel_volume) and rel_volume >= relvol_good
string relvol_value_text = na(rel_volume) ? 'n/a' : str.tostring(rel_volume, '#.##') + 'x'
string relvol_text = not use_rel_volume ? 'off' : not volume_data_ok ? allow_relvol_without_volume_data ? 'fallback' : 'blocked' : relvol_value_text

mtf_trend_1 = get_confirmed_structure_trend(mtf_trend_tf1, swing_length)
mtf_trend_2 = get_confirmed_structure_trend(mtf_trend_tf2, swing_length)
mtf_trend_3 = get_confirmed_structure_trend(mtf_trend_tf3, swing_length)
[index_missing_calc, index_gate_ok_calc] = external_trend_gate(index_gate_symbol, market_gate_fast_len, market_gate_slow_len)
[sector_missing_calc, sector_gate_ok_calc] = external_trend_gate(sector_gate_symbol, market_gate_fast_len, market_gate_slow_len)
[breadth_missing_calc, breadth_gate_ok_calc] = external_breadth_gate(breadth_gate_symbol)
bool index_missing = use_index_gate and index_missing_calc
bool index_gate_ok_raw = not use_index_gate or index_gate_ok_calc
bool sector_missing = use_sector_gate and sector_missing_calc
bool sector_gate_ok_raw = not use_sector_gate or sector_gate_ok_calc
bool breadth_missing = use_breadth_symbol_gate and breadth_missing_calc
bool breadth_gate_ok_raw = not use_breadth_symbol_gate or breadth_gate_ok_calc
bool market_symbols_missing = (use_index_gate and index_missing) or (use_sector_gate and sector_missing) or (use_breadth_symbol_gate and breadth_missing)
bool index_gate_effective_ok = not use_index_gate or (index_missing ? not block_on_missing_market_symbol : index_gate_ok_raw)
bool sector_gate_effective_ok = not use_sector_gate or (sector_missing ? not block_on_missing_market_symbol : sector_gate_ok_raw)
bool breadth_gate_effective_ok = not use_breadth_symbol_gate or (breadth_missing ? not block_on_missing_market_symbol : breadth_gate_ok_raw)
bool market_regime_gate_ok_raw = index_gate_effective_ok and sector_gate_effective_ok and breadth_gate_effective_ok

[trend, bull_bos_alert, bull_choch_alert, top_x, top, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm, trail_dn_x, trail_dn, ll, hhll_x] = detect_structure(swing_length, filter_insignificant_internal_breaks = true)
// Separate display-only trend state: avoid exposing the engine's bullish bootstrap bias before a real structure break occurs.
bool bullish_structure_break = bull_bos_alert or bull_choch_alert
bool bearish_structure_break = bear_bos_alert or bear_choch_alert
bool structure_break_detected = bullish_structure_break or bearish_structure_break
structure_display_trend = not na(ta.barssince(structure_break_detected)) ? trend : 0
bool bullish_trend_condition = structure_display_trend == 1
bool bearish_trend_condition = structure_display_trend == -1
bool live_exec = signal_mode == SignalMode.AGGRESSIVE_LIVE and barstate.isrealtime
bool bull_bos_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? bull_bos_alert : barstate.isconfirmed and bull_bos_alert
bool bull_choch_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? bull_choch_alert : barstate.isconfirmed and bull_choch_alert
bool bear_bos_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? bear_bos_alert : barstate.isconfirmed and bear_bos_alert
bool bear_choch_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? bear_choch_alert : barstate.isconfirmed and bear_choch_alert
bool bullish_trend_safe = bullish_trend_condition
bool bearish_trend_safe = bearish_trend_condition
if signal_mode != SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    bullish_trend_safe := bullish_trend_condition[1]
    bearish_trend_safe := bearish_trend_condition[1]
bool market_regime_gate_ok = market_regime_gate_ok_raw
if signal_mode != SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    market_regime_gate_ok := bar_index > 0 ? market_regime_gate_ok_raw[1] : market_regime_gate_ok_raw
bool vola_regime_gate_safe = vola_regime_gate_ok
if signal_mode != SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    vola_regime_gate_safe := bar_index > 0 ? vola_regime_gate_ok[1] : vola_regime_gate_ok
bool bullish_trend_started = bullish_trend_safe and not bullish_trend_safe[1]
bool bearish_trend_started = bearish_trend_safe and not bearish_trend_safe[1]
bool directional_trend_started = bullish_trend_started or bearish_trend_started

[internal_trend, internal_bull_bos_alert, internal_bull_choch_alert, internal_top_x, internal_top, internal_trail_up_x, internal_trail_up, internal_hh, internal_bear_bos_alert, internal_bear_choch_alert, internal_btm_x, internal_btm, internal_trail_dn_x, internal_trail_dn, internal_ll, internal_hhll_x] = detect_structure(internal_length, top, btm, filter_insignificant_internal_breaks = true)
bool internal_bull_bos_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? internal_bull_bos_alert : barstate.isconfirmed and internal_bull_bos_alert
bool internal_bull_choch_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? internal_bull_choch_alert : barstate.isconfirmed and internal_bull_choch_alert
bool internal_bear_bos_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? internal_bear_bos_alert : barstate.isconfirmed and internal_bear_bos_alert
bool internal_bear_choch_sig = signal_mode == SignalMode.AGGRESSIVE_LIVE ? internal_bear_choch_alert : barstate.isconfirmed and internal_bear_choch_alert

bool internal_structure_break_detected = internal_bull_bos_alert or internal_bull_choch_alert or internal_bear_bos_alert or internal_bear_choch_alert
internal_display_trend = not na(ta.barssince(internal_structure_break_detected)) ? internal_trend : 0

var LabelArgs pivot_label_args_bull = LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_up)
var LabelArgs pivot_label_args_bear = LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_down)
var LabelArgs swing_level_label_args_bull = LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_left)
var LabelArgs swing_level_label_args_bear = LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_left)
var LabelArgs structure_label_args_bull = LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_down)
var LabelArgs structure_label_args_bear = LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_down)
var LineArgs structure_line_args_bull = LineArgs.new(bull_css, line.style_solid, 2)
var LineArgs structure_line_args_bear = LineArgs.new(bear_css, line.style_solid, 2)
var LineArgs swing_level_line_args_bull = LineArgs.new(bull_css, line.style_solid, 2)
var LineArgs swing_level_line_args_bear = LineArgs.new(bear_css, line.style_solid, 2)

var color bull_internal_css = color.new(bull_css, 78)
var color bear_internal_css = color.new(bear_css, 78)

var LabelArgs swing_level_label_args_internal_bull = LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_left)
var LabelArgs swing_level_label_args_internal_bear = LabelArgs.new(bear_internal_css, #00000000, size = size.tiny, style = label.style_label_left)

var LabelArgs structure_label_args_internal_bull = LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_down)
var LabelArgs structure_label_args_internal_bear = LabelArgs.new(bear_internal_css, #00000000, size = size.tiny, style = label.style_label_down)

var LineArgs structure_line_args_internal_bull = LineArgs.new(bull_internal_css, line.style_dashed)
var LineArgs structure_line_args_internal_bear = LineArgs.new(bear_internal_css, line.style_dashed)

var LineArgs swing_level_line_args_internal_bull = LineArgs.new(bull_internal_css, line.style_dashed)
var LineArgs swing_level_line_args_internal_bear = LineArgs.new(bear_internal_css, line.style_dashed)

var color long_color_zone = color.aqua
var color long_color_reclaim = color.orange
var color long_color_reversal = color.yellow
var color long_color_building = color.rgb(212, 170, 34)
var color long_color_confirmed = color.lime
var color long_color_ready = color.green
var color long_color_invalid = color.red
var color long_dashboard_building_text = color.rgb(105, 74, 0)

bool show_internal_bull_bos = show_internals and (show_bull == 'All' or show_bull == 'BOS')
bool show_internal_bull_choch = show_internals and (show_bull == 'All' or show_bull == 'CHoCH')
bool show_internal_bear_bos = show_internals and (show_bear == 'All' or show_bear == 'BOS')
bool show_internal_bear_choch = show_internals and (show_bear == 'All' or show_bear == 'CHoCH')

// Pivot labels (HH/LH/HL/LL)
if show_swing_points
    plot_pivot_points(1, top_x, top, show_swing_points and not na(hh), pivot_label_args_bear, keep_history = keep_visual_history)
    plot_pivot_points(-1, btm_x, btm, show_swing_points and not na(ll), pivot_label_args_bull, keep_history = keep_visual_history)

// UX-Fix:
// If the user enables swing points they usually also expect the active swing levels.
bool show_chart_swing_levels = show_latest_swings_levels or show_swing_points

if show_chart_swing_levels
    plot_swing_levels(1, trail_up_x, trail_up, structure_display_trend, true, swing_level_label_args_bear, swing_level_line_args_bear, override_right_index = bar_index + 20)
    plot_swing_levels(-1, trail_dn_x, trail_dn, structure_display_trend, true, swing_level_label_args_bull, swing_level_line_args_bull, override_right_index = bar_index + 20)

if show_bull_bos or show_bull_choch
    plot_structure(top_x, top, show_bull_bos and bull_bos_sig, show_bull_choch and bull_choch_sig, structure_label_args_bull, structure_line_args_bull, keep_history = keep_visual_history)

if show_bear_bos or show_bear_choch
    plot_structure(btm_x, btm, show_bear_bos and bear_bos_sig, show_bear_choch and bear_choch_sig, structure_label_args_bear, structure_line_args_bear, keep_history = keep_visual_history)

// Internal structure: lighter dashed rendering
if show_internals
    plot_swing_levels(1, internal_trail_up_x, internal_trail_up, internal_display_trend, true, swing_level_label_args_internal_bear, swing_level_line_args_internal_bear, override_right_index = bar_index + 10, text_prefix = 'INT ')
    plot_swing_levels(-1, internal_trail_dn_x, internal_trail_dn, internal_display_trend, true, swing_level_label_args_internal_bull, swing_level_line_args_internal_bull, override_right_index = bar_index + 10, text_prefix = 'INT ')

if show_internal_bull_bos or show_internal_bull_choch
    plot_structure(internal_top_x, internal_top, show_internal_bull_bos and internal_bull_bos_sig, show_internal_bull_choch and internal_bull_choch_sig, structure_label_args_internal_bull, structure_line_args_internal_bull, keep_history = keep_visual_history, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

if show_internal_bear_bos or show_internal_bear_choch
    plot_structure(internal_btm_x, internal_btm, show_internal_bear_bos and internal_bear_bos_sig, show_internal_bear_choch and internal_bear_choch_sig, structure_label_args_internal_bear, structure_line_args_internal_bear, keep_history = keep_visual_history, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

bool enable_ob_engine = use_ob_engine
[ob_blocks_bull, ob_blocks_bear, new_ob_bull, new_ob_bear, ob_broken_bull, ob_broken_bear, ob_broken_new_bull, ob_broken_new_bear, ob_discarded_bull, ob_discarded_bear] = track_obs(swing_length, hh, ll, bull_bos_alert, bull_choch_alert, bear_bos_alert, bear_choch_alert, ob_threshold_min, ob_threshold_max, enabled = enable_ob_engine, capture_profile = use_ob_profile_effective, align_edge_to_value_area = use_ob_profile_effective, align_break_price_to_poc = use_ob_profile_effective, use_soft_confirm = use_ob_soft_confirm, soft_confirm_offset = soft_confirm_offset, keep_broken_max = ob_keep_broken_max, broken_by = active_break_mode, gc_cycle = object_gc_cycle)

varip bool live_bull_ob_break = false
varip bool live_bear_ob_break = false
varip bool live_bull_fvg_fill = false
varip bool live_bear_fvg_fill = false
var int reclaim_marker_drawn_bar_index = na
var int long_state_marker_drawn_bar_index = na
var int long_ready_marker_drawn_bar_index = na

if barstate.isnew
    live_bull_ob_break := false
    live_bear_ob_break := false
    live_bull_fvg_fill := false
    live_bear_fvg_fill := false
    reclaim_marker_drawn_bar_index := na
    long_state_marker_drawn_bar_index := na
    long_ready_marker_drawn_bar_index := na

if barstate.islast
    ob_blocks_bull.draw(ob_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    ob_blocks_bear.draw(ob_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_ob and ob_keep_broken and ob_keep_broken_max > 0
        ob_broken_bull.draw(ob_config_bull_broken, visible_left = visible_left_time, visible_right = visible_right_time)
        ob_broken_bear.draw(ob_config_bear_broken, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        ob_broken_bull.delete()
        ob_broken_bear.delete()

    if barstate.isconfirmed
        ob_discarded_bull.delete()
        ob_discarded_bull.clear()
        ob_discarded_bear.delete()
        ob_discarded_bear.clear()

var g_fvg = 'Fair Value Gaps'
var show_fvg = input.bool(true, 'Show Fair Value Gaps', group = g_fvg, inline = 'show', tooltip = SHOW_FVG)
var fvg_showlast = input.int(DEFAULT_FVG_SHOW_LAST, 'Show last', minval = 1, group = g_fvg, inline = 'show2')
var fvg_extend_until_filled = input.bool(true, 'Extend until filled', group = g_fvg, inline = 'ext')
var fvg_keep_filled = input.bool(true, 'Keep filled', group = g_fvg, inline = 'keep filled')
var fvg_keep_filled_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 1, group = g_fvg, inline = 'keep filled')
var bull_fvg_css = input.color(color.new(#00ff68, 90), '', group = g_fvg, inline = 'show')
var bear_fvg_css = input.color(color.new(#ff0008, 90), '', group = g_fvg, inline = 'show')
var bull_fvg_line_css = input.color(color.new(#00ff68, 25), '', group = g_fvg, inline = 'show')
var bear_fvg_line_css = input.color(color.new(#ff0008, 25), '', group = g_fvg, inline = 'show')
var bull_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bear_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bull_fvg_line_css_filled = color.new(bull_fvg_css_filled, 50)
var bear_fvg_line_css_filled = color.new(bear_fvg_css_filled, 50)
var filter_insignificant_fvgs = input.bool(true, 'Filter: min size', group = g_fvg, inline = 'fvg_min', tooltip = FILTER_FVG)
var min_fvg_size_atr_len = input.int(ATR_LEN_MAIN, 'ATR Length', minval = 1, group = g_fvg, inline = 'fvg_min')
var min_fvg_size_atr_mult = input.float(DEFAULT_FVG_MIN_SIZE_MULT, 'x', minval = 0, step = 0.1, group = g_fvg, inline = 'fvg_min')
float fvg_size_threshold = filter_insignificant_fvgs ? nd_atr(min_fvg_size_atr_len) * min_fvg_size_atr_mult : 0
var float fvg_fill_target_pct = input.float(DEFAULT_FVG_FILL_TARGET_PCT, 'Filled at %', minval = 0, maxval = 100, step = 5, group = g_fvg)
float fvg_fill_target_ratio = math.max(0.0, math.min(1.0, fvg_fill_target_pct / 100.0))
var use_fvg_engine = input.bool(true, 'Use FVG engine', group = g_fvg, display = display.none, tooltip = 'Keeps FVG-based long-dip logic and alerts running even if chart rendering is hidden.')

bool enable_fvg_engine = use_fvg_engine
