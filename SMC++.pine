indicator("Smart Money Concepts (Advanced)", "SMC++", overlay = true, max_bars_back = 500, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// Safe refactor notes:
// - Core BOS/CHoCH, Order Block and FVG logic is intentionally unchanged.
// - Improvements are limited to readability, defensive guards around draw/delete paths,
//   clearer configuration naming and more descriptive alerts.
// - The Order Block lifecycle remains: tracking -> extension -> awaiting confirmation -> confirmed/broken.

// Local replacements for the small lib_math/lib_no_delay subset used by SMC++.
in_range(float value, float max, float min = 0.0) => min <= value and value <= max
in_range(int value, int max, int min = 0) => min <= value and value <= max
in_range(float max1, float min1, float max2, float min2) => min2 <= min1 and min1 <= max2 and min2 <= max1 and max1 <= max2
in_range(int max1, int min1, int max2, int min2) => min2 <= min1 and min1 <= max2 and min2 <= max1 and max1 <= max2
range_overlap(float max1, float min1, float max2, float min2) => min1 < max2 and max1 > min2
range_overlap(int max1, int min1, int max2, int min2) => min1 < max2 and max1 > min2

nd_atr(simple int length) =>
    float atr_value = ta.atr(length)
    var float sum = 0.0
    if bar_index < length
        sum += ta.tr(true)
        atr_value := sum / (bar_index + 1)
    atr_value

type LabelArgs
    varip color text_color = color.gray
    varip color bg_color = #00000000
    string text_font_family = font.family_default
    string xloc = xloc.bar_index
    string yloc = yloc.price
    string style = label.style_label_down
    string size = size.normal
    string text_align = text.align_center

type Label
    varip chart.point point
    varip string txt = ''
    varip string tooltip = na
    bool hidden = false
    label plot = na

type LineArgs
    varip color line_color = color.gray
    string style = line.style_solid
    int width = 1
    string xloc = xloc.bar_index
    string extend = extend.none

type Line
    varip chart.point start
    varip chart.point end
    bool hidden = false
    line plot = na

type LineFill
    Line a
    Line b
    varip color fill_color = #dededede
    Line flip_support = na
    linefill plot = na

type BoxArgs
    varip color border_color = color.gray
    int border_width = 1
    string border_style = line.style_solid
    varip color bg_color = #dededede
    string xloc = xloc.bar_index
    string extend = extend.none

type BoxTextArgs
    varip color text_color = color.gray
    string text_size = size.normal
    string text_halign = text.align_center
    string text_valign = text.align_center
    string text_wrap = text.wrap_none
    string text_font_family = font.family_default

type Box
    varip chart.point left_top
    varip chart.point right_bottom
    varip string txt = ''
    bool hidden = false
    box plot = na

method or_default(LineArgs args) =>
    var default = LineArgs.new()
    na(args) ? default : args

method or_default(LabelArgs args) =>
    var default = LabelArgs.new()
    na(args) ? default : args

method or_default(BoxArgs args) =>
    var default = BoxArgs.new()
    na(args) ? default : args

method or_default(BoxTextArgs args) =>
    var default = BoxTextArgs.new()
    na(args) ? default : args

create_point(int x, float price, string point_xloc) =>
    point_xloc == xloc.bar_time ? chart.point.from_time(x, price) : chart.point.from_index(x, price)

create_label(int x, float y, string point_xloc, string txt = na, string tooltip = na) =>
    point = point_xloc == xloc.bar_time ? chart.point.from_time(x, y) : chart.point.from_index(x, y)
    Label.new(point, txt, tooltip)

create_label(chart.point this, string txt = na, string tooltip = na) =>
    na(this) ? na : Label.new(this, txt, tooltip)

create_line(int x1, float y1, int x2, float y2, string point_xloc) =>
    start = point_xloc == xloc.bar_time ? chart.point.from_time(x1, y1) : chart.point.from_index(x1, y1)
    end = point_xloc == xloc.bar_time ? chart.point.from_time(x2, y2) : chart.point.from_index(x2, y2)
    Line.new(start, end)

create_box(int left, float top, int right, float bottom, string point_xloc, string txt = na) =>
    left_top = point_xloc == xloc.bar_time ? chart.point.from_time(left, top) : chart.point.from_index(left, top)
    right_bottom = point_xloc == xloc.bar_time ? chart.point.from_time(right, bottom) : chart.point.from_index(right, bottom)
    Box.new(left_top, right_bottom, txt)

create_fill(Line this, Line other, color fill_color = #dededede, bool flip = false) =>
    flip ? LineFill.new(this, other, fill_color, Line.new(other.end, other.start)) : LineFill.new(this, other, fill_color)

method update(chart.point this, int bar_time, int bar_idx, float price) =>
    if not na(this)
        this.time := bar_time
        this.index := bar_idx
        this.price := price
        true
    else
        false

method update(chart.point this, int x, float price, string point_xloc) =>
    point_xloc == xloc.bar_time ? this.update(x, na, price) : this.update(na, x, price)

method update(chart.point this, chart.point other) =>
    na(other) ? this.update(na, na, na) : this.update(other.time, other.index, other.price)

method update(Label this, int bar_time, int bar_idx, float price, string txt = '', string tooltip = '') =>
    this.point.update(bar_time, bar_idx, price)
    if txt != ''
        this.txt := txt
    if tooltip != ''
        this.tooltip := tooltip
    this

method update(Label this, chart.point point, string txt = '', string tooltip = '') =>
    na(point) ? this.update(na, na, na, txt, tooltip) : this.update(point.time, point.index, point.price, txt, tooltip)

method update(Line this, chart.point start, chart.point end) =>
    this.start.update(start)
    this.end.update(end)
    this

method update(Box this, chart.point left_top, chart.point right_bottom) =>
    this.left_top.update(left_top)
    this.right_bottom.update(right_bottom)
    this

method delete(Line this) =>
    if not na(this) and not na(this.plot)
        this.plot.delete()
        this.plot := na
    this

method delete(Label this) =>
    if not na(this) and not na(this.plot)
        this.plot.delete()
        this.plot := na
    this

method delete(Box this) =>
    if not na(this) and not na(this.plot)
        this.plot.delete()
        this.plot := na
    this

method delete(LineFill this) =>
    if not na(this) and not na(this.plot)
        this.plot.delete()
        this.plot := na
    if not na(this) and not na(this.flip_support)
        this.flip_support.delete()
        this.flip_support := na
    this

method delete(Line[] this) =>
    if not na(this)
        for item in this
            item.delete()
    this

method delete(Label[] this) =>
    if not na(this)
        for item in this
            item.delete()
    this

method delete(Box[] this) =>
    if not na(this)
        for item in this
            item.delete()
    this

method draw(Label this, LabelArgs args = na, simple bool force_overlay = false) =>
    if not na(this)
        config = args.or_default()
        if na(this.plot)
            if force_overlay
                this.plot := label.new(this.point, this.txt, config.xloc, config.yloc, config.bg_color, config.style, config.text_color, config.size, config.text_align, this.tooltip, config.text_font_family, force_overlay = true)
            else
                this.plot := label.new(this.point, this.txt, config.xloc, config.yloc, config.bg_color, config.style, config.text_color, config.size, config.text_align, this.tooltip, config.text_font_family, force_overlay = false)
        else
            this.plot.set_point(this.point)
            if this.plot.get_text() != this.txt
                this.plot.set_text(this.txt)
        this.hidden := false
    this

method draw(Line this, LineArgs args = na, bool extend_only = true, simple bool force_overlay = false) =>
    if not na(this)
        config = args.or_default()
        if na(this.plot)
            if force_overlay
                this.plot := line.new(this.start, this.end, config.xloc, config.extend, config.line_color, config.style, config.width, force_overlay = true)
            else
                this.plot := line.new(this.start, this.end, config.xloc, config.extend, config.line_color, config.style, config.width, force_overlay = false)
        else
            if extend_only
                this.plot.set_y1(this.start.price)
            else
                this.plot.set_first_point(this.start)
            this.plot.set_second_point(this.end)
        this.hidden := false
    this

method draw(Box this, BoxArgs args = na, BoxTextArgs text_args = na, bool extend_only = true, simple bool force_overlay = false) =>
    config = args.or_default()
    config_txt = text_args.or_default()
    if na(this.plot)
        if force_overlay
            this.plot := box.new(this.left_top, this.right_bottom, config.border_color, config.border_width, config.border_style, config.extend, config.xloc, config.bg_color, this.txt, config_txt.text_size, config_txt.text_color, config_txt.text_halign, config_txt.text_valign, config_txt.text_wrap, config_txt.text_font_family, force_overlay = true)
        else
            this.plot := box.new(this.left_top, this.right_bottom, config.border_color, config.border_width, config.border_style, config.extend, config.xloc, config.bg_color, this.txt, config_txt.text_size, config_txt.text_color, config_txt.text_halign, config_txt.text_valign, config_txt.text_wrap, config_txt.text_font_family, force_overlay = false)
    else
        if extend_only
            this.plot.set_top(this.left_top.price)
        else
            this.plot.set_top_left_point(this.left_top)
        this.plot.set_bottom_right_point(this.right_bottom)
    this.hidden := false
    this

method draw(LineFill this, LineArgs flip_support_args = na, simple bool force_overlay = false) =>
    if na(this) ? false : not na(this.a) and not na(this.b)
        flipped = not na(this.flip_support)
        line_b = flipped ? this.flip_support : this.b
        if na(this.plot)
            if flipped and not na(this.b.plot)
                this.flip_support.draw(flip_support_args, extend_only = false, force_overlay = force_overlay)
            this.plot := linefill.new(this.a.plot, line_b.plot, this.fill_color)
        else if flipped
            this.flip_support.update(this.b.end, this.b.start).draw(flip_support_args, extend_only = false, force_overlay = force_overlay)
    this

method hide(Label this) =>
    if not na(this) and not this.hidden and not na(this.plot)
        this.plot.set_y(na)
        this.plot.set_text(na)
        this.hidden := true
    this

method hide(Line this) =>
    if not na(this) and not this.hidden and not na(this.plot)
        this.plot.set_y2(na)
        this.hidden := true
    this

method hide(Box this) =>
    if not na(this) and not this.hidden and not na(this.plot)
        this.plot.set_bottom(na)
        this.hidden := true
    this

method apply_style(line this, LineArgs args) =>
    if not na(this) and not na(args)
        this.set_color(args.line_color)
        this.set_style(args.style)

method apply_style(label this, LabelArgs args) =>
    if not na(this) and not na(args)
        this.set_textcolor(args.text_color)
        this.set_color(args.bg_color)
        this.set_style(args.style)

method apply_style(box this, BoxArgs args, BoxTextArgs text_args) =>
    if not na(this)
        if not na(args)
            this.set_border_color(args.border_color)
            this.set_border_style(args.border_style)
            this.set_bgcolor(args.bg_color)
        if not na(text_args)
            this.set_text_color(text_args.text_color)

method apply_style(Label this, LabelArgs args) =>
    if not na(this) and not na(this.plot)
        this.plot.apply_style(args)
    this

method apply_style(Line this, LineArgs args) =>
    if not na(this) and not na(this.plot)
        this.plot.apply_style(args)
    this

method apply_style(Box this, BoxArgs args, BoxTextArgs text_args) =>
    if not na(this) and not na(this.plot)
        this.plot.apply_style(args, text_args)
    this

// Reduced local profile engine extracted from the used lib_profile subset.
type Bucket
    varip int idx
    varip float value
    varip float top
    varip float btm
    varip float center
    varip float fraction
    Line plot_bucket_line = na

method update(Bucket this, float top, float bottom, float value, float fraction) =>
    rounded_top = math.round_to_mintick(top)
    rounded_bottom = math.round_to_mintick(bottom)
    rounded_fraction = math.round(fraction, 2)
    this.top := rounded_top
    this.btm := rounded_bottom
    this.center := math.avg(rounded_top, rounded_bottom)
    this.value := value
    this.fraction := rounded_fraction
    this

method update(Bucket this, float value, float fraction) =>
    this.value := value
    this.fraction := math.round(fraction, 2)
    this

type ProfileConfig
    bool show_poc = true
    bool show_profile = false
    bool show_va = false
    bool show_va_fill = false
    bool show_background = false
    bool show_labels = false
    bool show_price_levels = false
    bool extend = false

    string poc_label_text = 'POC'
    string vah_label_text = 'VAH'
    string val_label_text = 'VAL'
    LineArgs args_poc_line = na
    LineArgs args_vah_line = na
    LineArgs args_val_line = na
    LabelArgs args_poc_label = na
    LabelArgs args_vah_label = na
    LabelArgs args_val_label = na
    LineArgs args_profile_line = na
    BoxArgs args_profile_bg = na
    color va_fill_color = color.yellow
    bool initialized = false

method init(ProfileConfig this) =>
    if na(this) ? false : not this.initialized
        if na(this.args_poc_line)
            this.args_poc_line := LineArgs.new(color.orange, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_vah_line)
            this.args_vah_line := LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_val_line)
            this.args_val_line := LineArgs.new(color.yellow, line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_poc_label)
            this.args_poc_label := LabelArgs.new(color.orange, #00000000, xloc = xloc.bar_index, style = label.style_label_left)
        if na(this.args_vah_label)
            this.args_vah_label := LabelArgs.new(color.yellow, #00000000, xloc = xloc.bar_index, style = label.style_label_left)
        if na(this.args_val_label)
            this.args_val_label := LabelArgs.new(color.yellow, #00000000, xloc = xloc.bar_index, style = label.style_label_left)
        if na(this.args_profile_line)
            this.args_profile_line := LineArgs.new(color.rgb(120, 123, 134, 40), line.style_dotted, 1, xloc = xloc.bar_index)
        if na(this.args_profile_bg)
            this.args_profile_bg := BoxArgs.new(#00000000, bg_color = color.rgb(120, 123, 134, 92), xloc = xloc.bar_index)
        this.initialized := true
    this

type Profile
    int id
    int resolution
    float vah_threshold_pc
    float val_threshold_pc
    varip float[] data_opens
    varip float[] data_highs
    varip float[] data_lows
    varip float[] data_closes
    varip float[] data_values
    varip float h = na
    varip float l = na
    varip float total = 0
    varip float total_up = 0
    varip float total_down = 0
    Bucket[] buckets
    varip int poc_bucket_index = na
    varip int vah_bucket_index = na
    varip int val_bucket_index = na
    varip float poc = na
    varip float vah = na
    varip float val = na
    Line plot_poc = na
    Line plot_vah = na
    Line plot_val = na
    Label plot_poc_label = na
    Label plot_vah_label = na
    Label plot_val_label = na
    LineFill plot_va_fill = na
    Box plot_profile_bg = na
    bool hidden = false

method apply_style(Profile this, ProfileConfig args) =>
    if not na(this) and not na(args)
        if not na(this.plot_poc)
            this.plot_poc.apply_style(args.args_poc_line)
        if not na(this.plot_vah)
            this.plot_vah.apply_style(args.args_vah_line)
        if not na(this.plot_val)
            this.plot_val.apply_style(args.args_val_line)
        if not na(this.plot_poc_label)
            this.plot_poc_label.apply_style(args.args_poc_label)
        if not na(this.plot_vah_label)
            this.plot_vah_label.apply_style(args.args_vah_label)
        if not na(this.plot_val_label)
            this.plot_val_label.apply_style(args.args_val_label)
        if not na(this.plot_va_fill)
            this.plot_va_fill.plot.set_color(args.va_fill_color)
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.apply_style(args.args_profile_bg, BoxTextArgs.new())
    this

method delete(Profile this) =>
    if not na(this)
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.delete()
                    bucket.plot_bucket_line := na
        if not na(this.plot_poc)
            this.plot_poc.delete()
            this.plot_poc := na
        if not na(this.plot_vah)
            this.plot_vah.delete()
            this.plot_vah := na
        if not na(this.plot_val)
            this.plot_val.delete()
            this.plot_val := na
        if not na(this.plot_poc_label)
            this.plot_poc_label.delete()
            this.plot_poc_label := na
        if not na(this.plot_vah_label)
            this.plot_vah_label.delete()
            this.plot_vah_label := na
        if not na(this.plot_val_label)
            this.plot_val_label.delete()
            this.plot_val_label := na
        if not na(this.plot_va_fill)
            this.plot_va_fill.delete()
            this.plot_va_fill := na
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.delete()
            this.plot_profile_bg := na
    this

method hide(Profile this) =>
    if na(this) ? false : not this.hidden
        if not na(this.buckets)
            for bucket in this.buckets
                if not na(bucket.plot_bucket_line)
                    bucket.plot_bucket_line.hide()
        if not na(this.plot_poc)
            this.plot_poc.hide()
        if not na(this.plot_vah)
            this.plot_vah.hide()
        if not na(this.plot_val)
            this.plot_val.hide()
        if not na(this.plot_poc_label)
            this.plot_poc_label.hide()
        if not na(this.plot_vah_label)
            this.plot_vah_label.hide()
        if not na(this.plot_val_label)
            this.plot_val_label.hide()
        if not na(this.plot_profile_bg)
            this.plot_profile_bg.hide()
        this.hidden := true
    this

method init(Profile this, bool update_buckets = false) =>
    if not na(this)
        create_buckets = na(this.buckets)
        if create_buckets or update_buckets
            float bucket_size = this.resolution > 0 ? (this.h - this.l) / this.resolution : 0
            if create_buckets
                this.buckets := array.new<Bucket>(this.resolution)
            for i = 0 to this.resolution - 1
                float bucket_bottom = this.l + i * bucket_size
                float bucket_top = bucket_bottom + bucket_size
                if create_buckets
                    this.buckets.set(i, Bucket.new(i, 0, bucket_top, bucket_bottom, math.avg(bucket_top, bucket_bottom), 0))
                else
                    this.buckets.get(i).update(bucket_top, bucket_bottom, 0, 0)
    this

method calculate(Profile this, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    int range_count = array.size(this.data_values)
    float vah_threshold = this.total * (this.vah_threshold_pc / 100)
    float val_threshold = this.total * (this.val_threshold_pc / 100)
    if range_count > 0 and not na(this.buckets)
        float poc_volume = 0
        float sum_volume = 0
        float sum_volume_up = 0
        float sum_volume_down = 0
        int range_count_opens = na(this.data_opens) ? 0 : array.size(this.data_opens)
        int range_count_closes = na(this.data_closes) ? 0 : array.size(this.data_closes)
        for i = 0 to this.resolution - 1
            Bucket bucket = this.buckets.get(i)
            float bucket_value = 0
            for j = 0 to range_count - 1
                float range_value = array.get(this.data_values, j)
                float range_high = array.get(this.data_highs, j)
                float range_low = array.get(this.data_lows, j)
                float range_size = range_high - range_low
                float overlap = math.max(0, math.min(range_high, bucket.top) - math.max(range_low, bucket.btm))
                if (i == 0 or 0 < use_open_close_data_for_ranges_shorter_than_bars) and j < range_count_opens and j < range_count_closes
                    float range_open = array.get(this.data_opens, j)
                    float range_close = array.get(this.data_closes, j)
                    if i == 0
                        if range_open < range_close
                            sum_volume_up += range_value
                        else
                            sum_volume_down += range_value
                    if j < use_open_close_data_for_ranges_shorter_than_bars
                        overlap += math.max(0, math.min(math.max(range_open, range_close), bucket.top) - math.max(math.min(range_open, range_close), bucket.btm)) / 2
                        range_size += math.abs(range_open - range_close) / 2
                float range_value_fraction = range_size > 0 ? overlap / range_size : (overlap > 0 ? 1 : 0)
                bucket_value += range_value_fraction * range_value
            bucket.update(bucket_value, this.total > 0 ? bucket_value / this.total : 0)
            if bucket_value >= poc_volume
                poc_volume := bucket_value
                this.poc_bucket_index := i
                this.poc := bucket.center
            if sum_volume < val_threshold and val_threshold <= (sum_volume + bucket_value)
                this.val_bucket_index := i
                this.val := bucket.center
            if sum_volume < vah_threshold and vah_threshold <= (sum_volume + bucket_value)
                this.vah_bucket_index := i
                this.vah := bucket.center
            sum_volume += bucket_value
        this.total_up := sum_volume_up
        this.total_down := sum_volume_down
    this

create_profile(float[] opens, float[] highs, float[] lows, float[] closes, float[] values, int resolution = 25, float vah_pc = 80, float val_pc = 20, int idx = bar_index, bool init_calculated = true, simple int use_open_close_data_for_ranges_shorter_than_bars = 4) =>
    profile = Profile.new(idx, resolution, vah_pc, val_pc, opens, highs, lows, closes, values, h = highs.max(), l = lows.min(), total = values.sum())
    profile.init(update_buckets = true)
    if init_calculated
        profile.calculate(use_open_close_data_for_ranges_shorter_than_bars)
    profile

method update(Profile this, float[] opens = na, float[] highs = na, float[] lows = na, float[] closes = na, float[] values = na) =>
    if not na(this)
        recalculation_required = false
        layout_required = false
        if not na(opens)
            this.data_opens := opens
            recalculation_required := true
        if not na(highs)
            this.data_highs := highs
            high_max = highs.max()
            layout_required := this.h != high_max
            this.h := high_max
            recalculation_required := true
        if not na(lows)
            this.data_lows := lows
            low_min = lows.min()
            layout_required := layout_required or this.l != low_min
            this.l := low_min
            recalculation_required := true
        if not na(closes)
            this.data_closes := closes
            recalculation_required := true
        if not na(values)
            this.data_values := values
            this.total := values.sum()
            recalculation_required := true
        if layout_required
            this.init(update_buckets = true)
        if recalculation_required or na(this.poc)
            this.calculate()
    this

method draw(Profile this, ProfileConfig config, int left = na, int right = na, bool extend_only = true, simple bool force_overlay = false, string poc_text_override = na) =>
    if na(this) ? false : na(this.buckets) ? false : this.buckets.size() > 0
        config.init()
        this.init()
        if config.show_background
            if na(this.plot_profile_bg)
                this.plot_profile_bg := create_box(left, this.h, right, this.l, config.args_profile_bg.xloc)
            else
                this.plot_profile_bg.left_top.update(left, this.h, config.args_profile_bg.xloc)
                this.plot_profile_bg.right_bottom.update(right, this.l, config.args_profile_bg.xloc)
            this.plot_profile_bg.draw(config.args_profile_bg, na, extend_only, force_overlay)
        if config.show_poc and not na(this.poc)
            if na(this.plot_poc)
                this.plot_poc := create_line(left, this.poc, right, this.poc, config.args_poc_line.xloc)
            else
                this.plot_poc.start.update(left, this.poc, config.args_poc_line.xloc)
                this.plot_poc.end.update(right, this.poc, config.args_poc_line.xloc)
            this.plot_poc.draw(config.args_poc_line, extend_only, force_overlay)
            if config.show_labels
                tooltip = str.format('{0} ({1})', na(poc_text_override) ? config.poc_label_text : poc_text_override, this.poc)
                txt = config.show_price_levels ? tooltip : na(poc_text_override) ? config.poc_label_text : poc_text_override
                if na(this.plot_poc_label)
                    this.plot_poc_label := create_label(create_point(right, this.poc, config.args_poc_label.xloc), txt, tooltip)
                else
                    this.plot_poc_label.point.update(right, this.poc, config.args_poc_label.xloc)
                    this.plot_poc_label.txt := txt
                    this.plot_poc_label.tooltip := tooltip
                this.plot_poc_label.draw(config.args_poc_label, force_overlay)
        if config.show_va and not na(this.vah) and not na(this.val)
            if na(this.plot_vah)
                this.plot_vah := create_line(left, this.vah, right, this.vah, config.args_vah_line.xloc)
            else
                this.plot_vah.start.update(left, this.vah, config.args_vah_line.xloc)
                this.plot_vah.end.update(right, this.vah, config.args_vah_line.xloc)
            this.plot_vah.draw(config.args_vah_line, extend_only, force_overlay)
            if na(this.plot_val)
                this.plot_val := create_line(left, this.val, right, this.val, config.args_val_line.xloc)
            else
                this.plot_val.start.update(left, this.val, config.args_val_line.xloc)
                this.plot_val.end.update(right, this.val, config.args_val_line.xloc)
            this.plot_val.draw(config.args_val_line, extend_only, force_overlay)
        this.hidden := false
    this

/////////////////////////////////////////////////////////////////////////////////
//#region    LIB SMC v30 (temporarily added here to fix 'pine compilation error')
/////////////////////////////////////////////////////////////////////////////////

//-----------------------------------------------------------------------------
//Functions
//-----------------------------------------------------------------------------

enum LevelBreakMode
    CLOSE = 'candle close price'
    HIGHLOW = 'high/low (live)'

enum SignalMode
    CONFIRMED_ONLY = 'Confirmed only'
    AGGRESSIVE_LIVE = 'Aggressive live'

type OrderBlock
    int id
    int dir
    chart.point left_top
    chart.point right_bottom
    float break_price
    LevelBreakMode break_mode = LevelBreakMode.CLOSE
    
    float[] ltf_open
    float[] ltf_high
    float[] ltf_low
    float[] ltf_close
    float[] ltf_volume

    Box plot
    Profile profile

    float probability                            = 0
    bool trailing                                = false
    bool extending                               = false
    bool awaiting_confirmation                   = false
    bool touched_break_price_before_confirmation = false
    bool soft_confirmed                          = false
    bool has_fvg_out                             = false
    bool has_big_candle                          = false
    bool hidden                                  = false
    bool broken                                  = false
    int  broken_time                             = na
    int  broken_index                            = na

type OrderBlockConfig
    bool show = true
    int show_last = 5
    bool show_id = false
    bool show_profile = true
    bool show_text = true
    bool show_fvg_out = true
    bool show_probability = false
    bool extend_until_broken = true

    BoxArgs args
    string txt = 'OB'
    BoxTextArgs txt_args
    bool use_profile = false
    ProfileConfig profile_config = na

method delete(OrderBlock this) =>
    if not na(this)
        if not na(this.plot)
            this.plot.delete()
        if not na(this.profile)
            this.profile.delete()
        this.hidden := false
    this

method delete(OrderBlock[] blocks) =>
    if not na(blocks)
        for block in blocks
            block.delete()
    blocks

create_ob(int id, int mode, int start_t, int start_i, float top, int end_t, int end_i, float bottom, float break_price = na, simple LevelBreakMode break_mode = LevelBreakMode.CLOSE) =>
    OrderBlock block = OrderBlock.new(id, mode,
     chart.point.new(start_t, start_i, top),
     chart.point.new(end_t, end_i, bottom),
     not na(break_price) ? break_price : mode == 1 ? top : bottom,
     break_mode,
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0),
     array.new<float>(0)
     )

    block

method align_to_profile(OrderBlock block, bool align_edge = false, bool align_break_price = false) =>
    if not na(block.profile)
        if align_edge and not na(block.profile.vah)
            block.left_top.price     := block.profile.vah
            block.right_bottom.price := block.profile.val
        if align_break_price and not na(block.profile.poc)
            block.break_price        := block.profile.poc
    block

method _create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if na(block.profile)
        block.profile := create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, block.left_top.index, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    else
        block.profile.update(opens, tops, bottoms, closes, values)
    block

method create_profile(OrderBlock block, float[] opens, float[] tops, float[] bottoms, float[] closes, float[] values, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    if barstate.isconfirmed and not na(block)
        block._create_profile(opens, tops, bottoms, closes, values, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)
    block

method create_profile(OrderBlock block, int resolution = 20, float vah_pc = 80, float val_pc = 20, bool init_calculated = true, simple int use_open_close_data_for_blocks_shorter_than_bars = 4) =>
    block.create_profile(block.ltf_open, block.ltf_high, block.ltf_low, block.ltf_close, block.ltf_volume, resolution, vah_pc, val_pc, init_calculated, use_open_close_data_for_blocks_shorter_than_bars)

method overlaps_range(OrderBlock this, float range_top = 0, float range_btm = 0) =>
    na(this) ? false : range_overlap(this.left_top.price, this.right_bottom.price, range_top, range_btm)

method any_overlaps(OrderBlock[] this, float range_top, float range_btm) =>
    found = false
    if not na(this)
        for i = this.size() - 1 to 0
            if this.get(i).overlaps_range(range_top, range_btm)
                found := true
                break
    found

method last_overlaps(OrderBlock[] this, float range_top, float range_btm) =>
    this.any_overlaps(range_top, range_btm)

method contains_id(OrderBlock[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for block in this
            if block.id == id
                found := true
                break
    found

current_bar_right_time() =>
    barstate.isrealtime ? math.min(time_close, timenow) : time_close

effective_live_event_time(int event_time, int fallback_time) =>
    base_time = nz(event_time, fallback_time)
    barstate.isrealtime ? math.min(base_time, current_bar_right_time()) : base_time

method rendered_right_time(OrderBlock this, bool extend_until_broken = true) =>
    base_right_time = math.max(this.left_top.time, this.right_bottom.time)
    na(this) ? na : extend_until_broken ? this.broken ? effective_live_event_time(this.broken_time, base_right_time) : current_bar_right_time() : base_right_time

method overlaps_window(OrderBlock this, int left_time, int right_time, bool extend_until_broken = true) =>
    effective_right_time = this.rendered_right_time(extend_until_broken)
    na(this) ? false : effective_right_time >= left_time and this.left_top.time <= right_time

update_broken(int mode, OrderBlock[] tracking_blocks, OrderBlock[] broken_blocks, OrderBlock[] broken_blocks_new, simple LevelBreakMode broken_by = LevelBreakMode.HIGHLOW, int keep_broken_max = 5, OrderBlock[] discarded_buffer = na) =>
    bool broken_by_close = broken_by == LevelBreakMode.CLOSE
    OrderBlock[] moved_blocks = array.new<OrderBlock>(0)
    
    broken_blocks_new.clear()
    
    tracking_size = tracking_blocks.size()
    if tracking_size > 0
        break_src = broken_by_close ? close : mode == 1 ? low : high
        
        for i = tracking_size - 1 to 0
            block = tracking_blocks.get(i)

            if broken_by != LevelBreakMode.CLOSE or barstate.isconfirmed
                if mode == 1 ? block.break_price > break_src : block.break_price < break_src
                    block.broken       := true                    
                    block.broken_time  := time_close
                    block.broken_index := bar_index + 1
                    moved_blocks.unshift(block)
                    tracking_blocks.remove(i)

        for block in moved_blocks
            broken_blocks.push(block)
            broken_blocks_new.push(block)

        if keep_broken_max >= 0
            while broken_blocks.size() > keep_broken_max
                if not na(discarded_buffer)
                    discarded_buffer.push(broken_blocks.shift())
                else
                    broken_blocks.shift()

    true

method reset_tracking(OrderBlock this) =>
    this.ltf_high.clear()
    this.ltf_low.clear()
    this.ltf_open.clear()
    this.ltf_close.clear()
    this.ltf_volume.clear()

    this.trailing := true
    this.extending := false
    this.awaiting_confirmation := false
    this.touched_break_price_before_confirmation := false
    this.soft_confirmed := false
    this.has_fvg_out := false
    this.broken := false

    this.left_top := chart.point.now(high)
    this.right_bottom := chart.point.now(low)
    this.break_price := hl2
  

method remove_insignificant(OrderBlock[] blocks, float min_size, float max_size, OrderBlock[] removed_buffer = na) =>
    if blocks.size() > 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            size = block.left_top.price - block.right_bottom.price
            if size < min_size or max_size < size
                log.info("clearing out old OB to free memory (top: {0} | bottom: {1}) with size ({2}) outside range (min: {3} | max: {4})", block.left_top.price, block.right_bottom.price, size, min_size, max_size)

                if not na(removed_buffer)
                    removed_buffer.push(block)

                block.delete()
                blocks.remove(i)
                
    blocks

track_obs(
 int swing_len,
 float swing_high_confirmed,
 float swing_low_confirmed,
 bool bull_bos_alert,
 bool bull_choch_alert,
 bool bear_bos_alert,
 bool bear_choch_alert,
 float min_block_size,
 float max_block_size,
 bool enabled = true,
 simple bool include_consecutive_bars = true,
 bool capture_profile = false,
 bool align_edge_to_value_area = false,
 bool align_break_price_to_poc = false,
 simple bool use_soft_confirm = true,
 float soft_confirm_offset = 0,
 simple bool use_soft_confirm_big_candle = true,
 simple bool use_retracements_with_FVG_out = true,
 simple LevelBreakMode broken_by = LevelBreakMode.HIGHLOW,
 simple int keep_broken_max = 5,
 simple int gc_cycle = na
 ) =>
    // Order block lifecycle:
    // 1. trailing: candidate block is tracked while price builds it
    // 2. extending: block grows as same-direction candles continue
    // 3. awaiting_confirmation: extension stopped, block waits for confirmation
    // 4. confirmed: block is copied into the tracked blocks buffer
    // 5. broken: later mitigation/break moves it into the broken history buffer

    var OrderBlock[] tracking_blocks_bull   = array.new<OrderBlock>(0)
    var OrderBlock[] tracking_blocks_bear   = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bull     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_bear     = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bull = array.new<OrderBlock>(0)
    var OrderBlock[] broken_blocks_new_bear = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bull  = array.new<OrderBlock>(0)
    var OrderBlock[] discarded_blocks_bear  = array.new<OrderBlock>(0)

    float atr = nd_atr(200)
    float fvg_min_size = atr * 0.2
    float impulse_candle_size = atr * 3
        
    var int next_id = 0
    var OrderBlock bull_ob = create_ob(0,  1, time, bar_index, high, time, bar_index, low, hl2, broken_by)
    var OrderBlock bear_ob = create_ob(0, -1, time, bar_index, high, time, bar_index, low, hl2, broken_by)

    if barstate.isfirst
        bull_ob.reset_tracking()
        bear_ob.reset_tracking()

    var float ob_size_min_bull = min_block_size
    var float ob_size_min_bear = min_block_size
    var float ob_size_max_bull = max_block_size
    var float ob_size_max_bear = max_block_size

    bool is_green = open < close
    bool is_red = close < open
    bool is_fvg_up = low - high[2] > fvg_min_size
    bool is_fvg_down = low[2] - high > fvg_min_size
    float candle_top = math.max(open, close)
    float candle_btm = math.min(open, close)
    float candle_body = math.abs(open - close)
    bool is_impulse_candle = candle_body >= impulse_candle_size
    bool is_indecision = in_range(high, low, high[1], low[1]) and candle_body[1] > candle_body or in_range(candle_top, candle_btm, candle_top[1], candle_btm[1]) or open == close
    OrderBlock bull_ob_confirmed = na
    OrderBlock bear_ob_confirmed = na
    var bool reset_bull_next_bar = false
    var bool reset_bear_next_bar = false

    if enabled
        update_broken( 1, tracking_blocks_bull, broken_blocks_bull, broken_blocks_new_bull, broken_by, keep_broken_max, discarded_blocks_bull)
        update_broken(-1, tracking_blocks_bear, broken_blocks_bear, broken_blocks_new_bear, broken_by, keep_broken_max, discarded_blocks_bear)

        if gc_cycle > 0 and bar_index % gc_cycle == 0
            tracking_blocks_bull.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bull)
            tracking_blocks_bear.remove_insignificant(min_block_size, max_block_size, discarded_blocks_bear)

        if reset_bull_next_bar
            reset_bull_next_bar := false
            bull_ob.reset_tracking()
        if reset_bear_next_bar
            reset_bear_next_bar := false
            bear_ob.reset_tracking()

        if bull_ob.trailing 
            if capture_profile or align_edge_to_value_area or align_break_price_to_poc
                bull_ob.ltf_open.push(open)
                bull_ob.ltf_high.push(high)
                bull_ob.ltf_low.push(low)
                bull_ob.ltf_close.push(close)
                bull_ob.ltf_volume.push(volume)

            _check_start_t = bull_ob.left_top.time
            _check_start_i = bull_ob.left_top.index
            _check_end_t = bull_ob.right_bottom.time
            _check_end_i = bull_ob.right_bottom.index
            _check_top = bull_ob.left_top.price
            _check_btm = bull_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bull_ob.extending

            if bull_ob.right_bottom.price > low
                if barstate.isconfirmed and _check_start_i < bar_index - 1 and use_retracements_with_FVG_out and is_fvg_down
                    if not _check_ext[2] and not tracking_blocks_bear.any_overlaps(_check_top[2], _check_btm[2]) and not bear_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bear_ob_confirmed := create_ob(next_id, -1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bear_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bear_ob_confirmed.ltf_open := bull_ob.ltf_open.copy()
                            bear_ob_confirmed.ltf_high := bull_ob.ltf_high.copy()
                            bear_ob_confirmed.ltf_low := bull_ob.ltf_low.copy()
                            bear_ob_confirmed.ltf_close := bull_ob.ltf_close.copy()
                            bear_ob_confirmed.ltf_volume := bull_ob.ltf_volume.copy()

                            if na(bull_ob.profile)
                                bear_ob_confirmed.create_profile()
                            else
                                // Ownership transfer intended: the confirmed bearish block reuses the tracked profile state.
                                bear_ob_confirmed.profile := bull_ob.profile

                            bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                        bear_ob_confirmed.right_bottom.index := bar_index
                        bear_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bear.push(bear_ob_confirmed)

                if is_green
                    bull_ob.reset_tracking()
                else 
                    reset_bull_next_bar := true

                if barstate.isconfirmed
                    bull_ob.profile := na

            else if bull_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bull_ob.extending := true

            if bull_ob.extending and is_green and bull_ob.left_top.price < high
                bull_ob.left_top.price := high
                bull_ob.right_bottom := chart.point.now(bull_ob.right_bottom.price)
                bull_ob.touched_break_price_before_confirmation := false
                bull_ob.soft_confirmed := false

                if is_impulse_candle
                    bull_ob.has_big_candle := true

        if bear_ob.trailing
            if capture_profile or align_edge_to_value_area or align_break_price_to_poc
                bear_ob.ltf_open.push(open)
                bear_ob.ltf_high.push(high)
                bear_ob.ltf_low.push(low)
                bear_ob.ltf_close.push(close)
                bear_ob.ltf_volume.push(volume)

            _check_start_t = bear_ob.left_top.time
            _check_start_i = bear_ob.left_top.index
            _check_end_t = bear_ob.right_bottom.time
            _check_end_i = bear_ob.right_bottom.index
            _check_top = bear_ob.left_top.price
            _check_btm = bear_ob.right_bottom.price
            _check_break = math.avg(_check_top, _check_btm)
            _check_ext = bear_ob.extending

            if bear_ob.left_top.price < high
                if barstate.isconfirmed and use_retracements_with_FVG_out and is_fvg_up
                    if not _check_ext[2] and not tracking_blocks_bull.any_overlaps(_check_top[2], _check_btm[2]) and not bull_ob.overlaps_range(_check_top[2], _check_btm[2])
                        next_id += 1
                        bull_ob_confirmed := create_ob(next_id, 1, _check_start_t[2], _check_start_i[2], _check_top[2], _check_end_t[2], _check_end_i[2], _check_btm[2], _check_break[2], broken_by)
                        bull_ob_confirmed.has_fvg_out := true

                        if barstate.isconfirmed and (align_edge_to_value_area or align_break_price_to_poc)
                            bull_ob_confirmed.ltf_open := bear_ob.ltf_open.copy()
                            bull_ob_confirmed.ltf_high := bear_ob.ltf_high.copy()
                            bull_ob_confirmed.ltf_low := bear_ob.ltf_low.copy()
                            bull_ob_confirmed.ltf_close := bear_ob.ltf_close.copy()
                            bull_ob_confirmed.ltf_volume := bear_ob.ltf_volume.copy()

                            if na(bear_ob.profile)
                                bull_ob_confirmed.create_profile()
                            else
                                // Ownership transfer intended: the confirmed bullish block reuses the tracked profile state.
                                bull_ob_confirmed.profile := bear_ob.profile

                            bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                        bull_ob_confirmed.right_bottom.index := bar_index
                        bull_ob_confirmed.right_bottom.time := time_close
                        tracking_blocks_bull.push(bull_ob_confirmed)

                if is_red
                    bear_ob.reset_tracking()
                else 
                    reset_bear_next_bar := true

                if barstate.isconfirmed
                    bear_ob.profile := na

            else if bear_ob.left_top.index == bar_index - 1 and include_consecutive_bars
                bear_ob.extending := true

            if bear_ob.extending and is_red
                bear_ob.right_bottom := chart.point.now(math.min(bear_ob.right_bottom.price, low))
                bear_ob.touched_break_price_before_confirmation := false
                bear_ob.soft_confirmed := false

                if is_impulse_candle
                    bear_ob.has_big_candle := true

        if barstate.isconfirmed
            if bull_ob.trailing and bull_ob.extending and bull_ob.left_top.index < bar_index and is_red and not is_indecision and in_range(close, bull_ob.left_top.price, bull_ob.right_bottom.price)
                bull_ob.left_top.price := math.max(open, bull_ob.left_top.price)
                bull_ob.right_bottom := chart.point.new(time_close[1], bar_index[1], bull_ob.right_bottom.price)
                bull_ob.extending := false
                bull_ob.awaiting_confirmation := true

                ob_length = bull_ob.right_bottom.index - bull_ob.left_top.index + 1
                ob_size_min_bull := math.round_to_mintick(min_block_size)
                ob_size_max_bull := math.round_to_mintick(max_block_size * ob_length)

                if align_edge_to_value_area or align_break_price_to_poc
                    bull_ob.create_profile()
                    bull_ob.align_to_profile(align_break_price = true)

                if not bear_ob.awaiting_confirmation and not bear_ob.extending
                    bear_ob.reset_tracking()

            if bear_ob.trailing and bear_ob.extending and bear_ob.left_top.index < bar_index and is_green and not is_indecision and in_range(close, bear_ob.left_top.price, bear_ob.right_bottom.price)
                bear_ob.left_top.price := math.max(open, bear_ob.left_top.price)
                bear_ob.right_bottom := chart.point.new(time_close[1], bar_index[1], bear_ob.right_bottom.price)
                bear_ob.extending := false
                bear_ob.awaiting_confirmation := true

                ob_length = bear_ob.right_bottom.index - bear_ob.left_top.index + 1
                ob_size_min_bear := min_block_size
                ob_size_max_bear := max_block_size * ob_length

                if align_edge_to_value_area or align_break_price_to_poc
                    bear_ob.create_profile()
                    bear_ob.align_to_profile(align_break_price = true)

                if not bull_ob.awaiting_confirmation and not bull_ob.extending
                    bull_ob.reset_tracking()

        if bull_ob.trailing and bull_ob.awaiting_confirmation
            if barstate.isconfirmed and not bull_ob.soft_confirmed
                if not bull_ob.touched_break_price_before_confirmation
                    if bull_ob.break_price > low and bull_ob.right_bottom.index < bar_index
                        bull_ob.touched_break_price_before_confirmation := true

                if bull_ob.touched_break_price_before_confirmation and bull_ob.left_top.price + soft_confirm_offset < close
                    bull_ob.soft_confirmed := true
                else if use_soft_confirm_big_candle and is_impulse_candle and is_green and close - bull_ob.left_top.price >= impulse_candle_size / 2
                    bull_ob.soft_confirmed := true

            bull_price_exited = bull_ob.left_top.price + soft_confirm_offset < close
            bull_confirm_trigger = (bull_ob.soft_confirmed and use_soft_confirm) or not na(swing_low_confirmed) or bull_bos_alert or bull_choch_alert or bar_index - bull_ob.right_bottom.index >= swing_len
            bull_should_confirm = bull_price_exited and barstate.isconfirmed and bull_confirm_trigger

            if bull_should_confirm
                if align_edge_to_value_area and not na(bull_ob.profile) ? in_range(math.round_to_mintick(bull_ob.profile.vah - bull_ob.profile.val), ob_size_max_bull, ob_size_min_bull) : in_range(math.round_to_mintick(bull_ob.left_top.price - bull_ob.right_bottom.price), ob_size_max_bull, ob_size_min_bull)
                    bull_ob.trailing := false
                    next_id += 1
                    bull_ob.id := next_id
                    bull_ob_confirmed := bull_ob.copy()
                    bull_ob_confirmed.id := bull_ob.id
                    bull_ob_confirmed.left_top := bull_ob.left_top.copy()
                    bull_ob_confirmed.right_bottom := bull_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        // Ownership transfer intended: the confirmed bullish block takes over the prepared profile state.
                        bull_ob_confirmed.profile := bull_ob.profile
                        bull_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    if not align_break_price_to_poc
                        bull_ob_confirmed.break_price := math.avg(bull_ob.left_top.price, bull_ob.right_bottom.price)
                    bull_ob.profile := na

                    if is_fvg_up and high[2] < bull_ob_confirmed.left_top.price and bull_ob_confirmed.left_top.price < low
                        bull_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bull.push(bull_ob_confirmed)

                    if barstate.isconfirmed
                        bull_ob.reset_tracking()
                else
                    bull_ob.reset_tracking()

        if bear_ob.trailing and bear_ob.awaiting_confirmation
            if barstate.isconfirmed and not bear_ob.soft_confirmed
                if not bear_ob.touched_break_price_before_confirmation
                    if bear_ob.break_price < high and bear_ob.right_bottom.index < bar_index
                        bear_ob.touched_break_price_before_confirmation := true

                if bear_ob.touched_break_price_before_confirmation and bear_ob.right_bottom.price - soft_confirm_offset > close
                    bear_ob.soft_confirmed := true
                else if use_soft_confirm_big_candle and is_impulse_candle and is_red and bear_ob.right_bottom.price - close >= impulse_candle_size / 2
                    bear_ob.soft_confirmed := true

            bear_price_exited = bear_ob.right_bottom.price - soft_confirm_offset > close
            bear_confirm_trigger = (bear_ob.soft_confirmed and use_soft_confirm) or not na(swing_high_confirmed) or bear_bos_alert or bear_choch_alert or bar_index - bear_ob.right_bottom.index >= swing_len
            bear_should_confirm = bear_price_exited and barstate.isconfirmed and bear_confirm_trigger

            if bear_should_confirm
                if align_edge_to_value_area and not na(bear_ob.profile) ? in_range(math.round_to_mintick(bear_ob.profile.vah - bear_ob.profile.val), ob_size_max_bear, ob_size_min_bear) : in_range(math.round_to_mintick(bear_ob.left_top.price - bear_ob.right_bottom.price), ob_size_max_bear, ob_size_min_bear)
                    bear_ob.trailing := false
                    next_id += 1
                    bear_ob.id := next_id
                    bear_ob_confirmed := bear_ob.copy()
                    bear_ob_confirmed.id := bear_ob.id
                    bear_ob_confirmed.left_top := bear_ob.left_top.copy()
                    bear_ob_confirmed.right_bottom := bear_ob.right_bottom.copy()

                    if align_edge_to_value_area or align_break_price_to_poc
                        // Ownership transfer intended: the confirmed bearish block takes over the prepared profile state.
                        bear_ob_confirmed.profile := bear_ob.profile
                        bear_ob_confirmed.align_to_profile(align_edge_to_value_area, align_break_price_to_poc)

                    if not align_break_price_to_poc
                        bear_ob_confirmed.break_price := math.avg(bear_ob.left_top.price, bear_ob.right_bottom.price)
                    bear_ob.profile := na

                    if is_fvg_down and low[2] < bear_ob_confirmed.right_bottom.price and bear_ob_confirmed.right_bottom.price < high
                        bear_ob_confirmed.has_fvg_out := true

                    tracking_blocks_bear.push(bear_ob_confirmed)

                    if barstate.isconfirmed
                        bear_ob.reset_tracking()
                else
                    bear_ob.reset_tracking()

    [tracking_blocks_bull, tracking_blocks_bear, bull_ob_confirmed, bear_ob_confirmed, broken_blocks_bull, broken_blocks_bear, broken_blocks_new_bull, broken_blocks_new_bear, discarded_blocks_bull, discarded_blocks_bear]

method draw(OrderBlock this, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    visible_match = na(visible_left) or na(visible_right) or this.overlaps_window(visible_left, visible_right, config.extend_until_broken)

    if not visible_match
        if not na(this.plot) and not this.hidden
            this.plot.hide()
            if not na(this.profile)
                this.profile.hide()
            this.hidden := true
        this
    else

        if barstate.islast and not na(this) and config.show
            txt_fvg = config.show_fvg_out and this.has_fvg_out ? '+FVG' : ''
            txt_probability = config.show_probability and this.probability > 0 ? str.format(' ({0,number,percent})', this.probability) : ''
            txt_id = config.show_id ? ' #' + str.tostring(this.id) : ''
            txt = config.show_text ? config.show_profile and config.profile_config.show_poc and config.profile_config.show_labels ? str.format('{0}{1}{2}', config.txt, txt_fvg, txt_id) : str.format('{0}{1}{2}{3}', config.txt, txt_fvg, txt_probability, txt_id) : ''

            xloc_bartime = config.args.xloc == xloc.bar_time
            int broken_right_time = effective_live_event_time(this.broken_time, math.max(this.left_top.time, this.right_bottom.time))

            int left = not na(left_override) ? left_override : xloc_bartime ? this.left_top.time : this.left_top.index
            int right = not na(right_override) ? right_override : config.extend_until_broken ? this.broken ? xloc_bartime ? broken_right_time : this.broken_index - 1 : xloc_bartime ? current_bar_right_time() : bar_index : xloc_bartime ? this.right_bottom.time : this.right_bottom.index

            chart.point plot_left_top = create_point(left, this.left_top.price, config.args.xloc)
            chart.point plot_right_bottom = create_point(right, this.right_bottom.price, config.args.xloc)

            if config.show
                if na(this.plot)
                    this.plot := Box.new(plot_left_top, plot_right_bottom, txt)
                else
                    this.plot.left_top := plot_left_top
                    this.plot.right_bottom := plot_right_bottom

                this.plot.draw(config.args, config.txt_args, extend_only, force_overlay)
                if this.broken or this.has_fvg_out
                    this.plot.plot.set_text(txt)

                if config.show_profile and not na(this.profile)
                    poc_txt = config.show_probability and config.profile_config.show_poc and config.profile_config.show_labels ? config.profile_config.poc_label_text + txt_fvg + txt_probability : na
                    this.profile.draw(config.profile_config, left, right, extend_only, force_overlay, poc_txt)

                if this.broken and broken_right_time <= current_bar_right_time()
                    this.plot.apply_style(config.args, config.txt_args)
                    if not na(this.profile) and config.show_profile
                        this.profile.apply_style(config.profile_config)

            this.hidden := false

    this

method hide(OrderBlock this) =>
    if not na(this) and not this.hidden
        if not na(this.plot)
            this.plot.hide()
        if not na(this.profile)
            this.profile.hide()
        this.hidden := true
    this

method draw(OrderBlock[] blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    if na(blocks) ? false : config.show and blocks.size() > 0
        count = 0
        for i = blocks.size() - 1 to 0
            block = blocks.get(i)
            visible_match = na(visible_left) or na(visible_right) or block.overlaps_window(visible_left, visible_right, config.extend_until_broken)
            if visible_match and count < config.show_last
                block.draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
                count += 1
            else
                if not na(block.plot) and not block.hidden
                    block.hide()
    blocks

method draw(map<int, OrderBlock> blocks, OrderBlockConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    blocks.values().draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
    blocks

// Market structure helpers

detect_swings(simple int length = 10) =>
    var os = 0
    float hh = na
    float ll = na
    int idx = na

    h_swing = high[length]
    l_swing = low[length]
    upper = ta.highest(high, length)
    lower = ta.lowest(low, length)

    os := h_swing > upper ? 0 : l_swing < lower ? 1 : os[1]
    hh := os == 0 and os[1] != 0 ? h_swing : na
    ll := os == 1 and os[1] != 1 ? l_swing : na
    idx := not na(hh) or not na(ll) ? bar_index - length : na

    [idx, hh, ll]

detect_pivot(simple int mode, int trend, int hhll_x, float hhll, float super_hhll = na, bool filter_insignificant_internal_breaks = false) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var sy = 0.
    var x = 0, var y = 0.
    var trail_x = 0, var trail_y = mode_high ? high : mode_low ? low : na
    var lvl_cross = true
    bool choch_alert = false
    bool bos_alert = false

    if not na(super_hhll)
        sy := super_hhll

    if not na(hhll)
        lvl_cross := true
        y := hhll
        x := hhll_x
        trail_y := hhll
        trail_x := hhll_x

    trail_y := mode_high ? math.max(high, trail_y) : math.min(low, trail_y)
    trail_x := (mode_high and trail_y == high) or (mode_low and trail_y == low) ? bar_index : trail_x

    var trend_concordant = true
    atr = ta.atr(3)

    structure_detected = switch mode
        1 => ta.crossover(close, y)
        -1 => ta.crossunder(close, y)
        => false

    if structure_detected and lvl_cross and y != sy
        lvl_cross := false

        if filter_insignificant_internal_breaks
            body = math.abs(open - close)
            distance_to_level = math.abs(open - y)
            big_candle = body > 2 * distance_to_level or body > atr

            top_wick = high - math.max(close, open)
            btm_wick = math.min(close, open) - low
            impulse_wick = switch mode
                1 => top_wick > btm_wick
                -1 => top_wick < btm_wick
                => false

            trend_concordant := big_candle or impulse_wick

        if trend_concordant
            _trend = (trend != 1 and trend != -1 ? 1 : trend)
            choch_alert := mode == _trend * -1
            bos_alert := mode == _trend

    [x, y, trail_x, trail_y, bos_alert, choch_alert]

detect_structure(simple int swing_len = 50, float super_hh = na, float super_ll = na, bool filter_insignificant_internal_breaks = true) =>
    var trend = 1

    [hhll_x, hh, ll] = detect_swings(swing_len)
    [top_x, top_y, trail_up_x, trail_up, bull_bos_alert, bull_choch_alert] = detect_pivot(1, trend, hhll_x, hh, super_hh, filter_insignificant_internal_breaks)
    [btm_x, btm_y, trail_dn_x, trail_dn, bear_bos_alert, bear_choch_alert] = detect_pivot(-1, trend, hhll_x, ll, super_ll, filter_insignificant_internal_breaks)

    trend := bull_choch_alert ? 1 : bear_choch_alert ? -1 : trend

    [trend, bull_bos_alert, bull_choch_alert, top_x, top_y, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm_y, trail_dn_x, trail_dn, ll, hhll_x]

plot_pivot_points(int mode, int x, float y, bool enabled, LabelArgs args, bool keep_history) =>
    if enabled and not na(x)
        txt_swing_point = mode == 1 ? (y > y[1] ? 'HH' : 'LH') : mode == -1 ? (y < y[1] ? 'LL' : 'HL') : na
        label_swing_point = label.new(x, y, txt_swing_point, color = args.bg_color, textcolor = args.text_color, style = args.style, size = args.size)
        if not keep_history
            label.delete(label_swing_point[1])

plot_swing_levels(int mode, int trail_x, float trail_y, int trend, bool enabled, LabelArgs label_args, LineArgs line_args, int override_right_index = na, string text_prefix = '') =>
    var label label_latest_swing = label.new(na, na, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)
    var line line_latest_swing = line.new(na, na, na, na, color = line_args.line_color, style = line_args.style)

    if enabled
        if trail_x != line_latest_swing.get_x1() or na(line_latest_swing.get_x1())
            line_latest_swing.set_xy1(trail_x, trail_y)
        else
            line_latest_swing.set_y1(trail_y)

        if barstate.islast
            hl_swing_txt = mode == 1 ? (trend < 0 ? 'Strong High' : 'Weak High') : mode == -1 ? (trend > 0 ? 'Strong Low' : 'Weak Low') : na
            right = not na(override_right_index) ? override_right_index : bar_index + 20
            line_latest_swing.set_xy2(right, trail_y)
            label_latest_swing.set_xy(right, trail_y)
            label_latest_swing.set_text(text_prefix + hl_swing_txt)

plot_structure(int x, float y, bool is_bos = false, bool is_choch = false, LabelArgs label_args, LineArgs line_args, bool keep_history, string text_prefix = '', string bos_text = 'BOS', string choch_text = 'CHoCH') =>
    if is_bos or is_choch
        txt = text_prefix + (is_choch ? choch_text : bos_text)
        structure_line = line.new(x, y, bar_index, y, color = line_args.line_color, style = line_args.style)
        structure_lbl = label.new(int(math.avg(x, bar_index)), y, txt, color = #00000000, textcolor = label_args.text_color, style = label_args.style, size = label_args.size)

        if not keep_history
            line.delete(structure_line[1])
            label.delete(structure_lbl[1])

detect_equal_level(int mode, int len, float eq_threshold, bool enabled = true) =>
    mode_high = mode == 1
    mode_low = mode == -1
    var int x1 = 0, var float y1 = 0.
    var int x2 = 0, var float y2 = 0.

    eq_alert = false
    ph = ta.pivothigh(len, len)
    pl = ta.pivotlow(len, len)

    if enabled
        eq_lvl = mode_high ? ph : pl
        if not na(eq_lvl)
            x1 := x2, y1 := y2
            x2 := bar_index - len, y2 := eq_lvl

            max = math.max(eq_lvl, y1)
            min = math.min(eq_lvl, y1)

            if mode_high and (max < min + eq_threshold) or mode_low and (min > max - eq_threshold)
                eq_alert := true

    [eq_alert, eq_alert ? x1 : na, eq_alert ? y1 : na, eq_alert ? x2 : na, eq_alert ? y2 : na]

detect_equal_levels(int len, float threshold, bool enabled = true) =>
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2] = detect_equal_level(1, len, threshold, enabled)
    [eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_level(-1, len, threshold, enabled)
    [eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2]

plot_equal_level(bool show_eq, int x1, float y1, int x2, float y2, string label_txt, LabelArgs label_args, LineArgs line_args, bool keep_history = true, bool force_overlay = false) =>
    if show_eq and not na(x1) and not na(x2) and not na(y1) and not na(y2)
        line eq_line = na
        label eq_lbl = na

        if force_overlay
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width, force_overlay = true)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, label_args.xloc, label_args.yloc, label_args.bg_color, label_args.style, label_args.text_color, label_args.size, label_args.text_align, label_args.text_font_family, force_overlay = true)
        else
            eq_line := line.new(x1, y1, x2, y2, color = line_args.line_color, style = line_args.style, width = line_args.width)
            eq_lbl := label.new(int(math.avg(x1, x2)), math.avg(y1, y2), label_txt, label_args.xloc, label_args.yloc, label_args.bg_color, label_args.style, label_args.text_color, label_args.size, label_args.text_align, label_args.text_font_family)

        if not keep_history
            line.delete(eq_line[1])
            label.delete(eq_lbl[1])

type FVGConfig
    bool show_box = true
    bool show_target = true
    bool show_target_label = true
    int show_last = 5
    bool show_text = true
    bool show_probability = false
    bool show_profile = false
    BoxArgs box_args = na
    BoxTextArgs box_text_args = na
    LineArgs line_args = na
    LabelArgs label_args = na
    string txt = na
    int extend_bars = 1
    bool extend_until_filled = false

type FVG
    int id
    int dir
    LevelBreakMode fill_mode
    chart.point left_top
    chart.point right_bottom
    float fvg_fill_target_ratio
    float fill_target_level
    float fill_current_ratio
    float fill_current_level
    float total_volume
    float probability = na
    bool filled = false
    int fill_time = na
    int fill_index = na
    Box plot_box = na
    Line plot_fill_target_level = na
    Label plot_fill_target_label = na
    bool hidden = false

method rendered_right_time(FVG this, bool extend_until_filled = true) =>
    base_right_time = math.max(this.left_top.time, this.right_bottom.time)
    effective_fill_time = effective_live_event_time(this.fill_time, base_right_time)
    na(this) ? na :
     extend_until_filled ?
         this.filled ? effective_fill_time : current_bar_right_time()
     :
         this.filled ? math.min(effective_fill_time, base_right_time) : base_right_time

method overlaps_window(FVG this, int left_time, int right_time, bool extend_until_filled = true) =>
    effective_right_time = this.rendered_right_time(extend_until_filled)
    na(this) ? false : effective_right_time >= left_time and this.left_top.time <= right_time

method contains_id(FVG[] this, int id) =>
    found = false
    if not na(this) and not na(id)
        for fvg in this
            if fvg.id == id
                found := true
                break
    found

method unshift_rotate(float[] this, float value, int max_size = 3) =>
    this.unshift(value)
    if this.size() > max_size
        this.pop()
    this

_detect_fvg(int mode, bool enabled, float size_threshold = 0) =>
    float top = low[mode == 1 ? 0 : 2]
    float btm = high[mode == 1 ? 2 : 0]

    if enabled and barstate.isconfirmed and (top - btm) > size_threshold
        [true, top, btm]
    else
        [false, na, na]

_detect_fvg_object(int mode, bool enabled, float size_threshold = 0, LevelBreakMode fill_mode = LevelBreakMode.CLOSE, float fill_target_ratio = 0.5) =>
    float top = low[mode == 1 ? 0 : 2]
    float btm = high[mode == 1 ? 2 : 0]
    float size = top - btm

    if enabled and barstate.isconfirmed and size > size_threshold
        [true, FVG.new(na, mode, fill_mode,
         left_top = chart.point.new(time[2], bar_index[2], top),
         right_bottom = chart.point.new(time_close, bar_index, btm),
         fvg_fill_target_ratio = fill_target_ratio,
         fill_target_level = mode == 1 ? top - fill_target_ratio * size : btm + fill_target_ratio * size,
         fill_current_ratio = 0,
         fill_current_level = mode == 1 ? top : btm,
         total_volume = volume[2] + volume[1] + volume)]
    else
        [false, na]

_clear_broken_fvg(int mode, array<box> upper_boxes, array<box> lower_boxes, float fill_ratio = 0.5) =>
    fvg_count = array.size(upper_boxes)
    if barstate.isconfirmed and fvg_count > 0
        for int i = fvg_count - 1 to 0
            box = switch mode
                1 => array.get(lower_boxes, i)
                -1 => array.get(upper_boxes, i)
                => na

            do_delete = switch mode
                1 => low < (box.get_top(box) - fill_ratio * (box.get_top(box) - box.get_bottom(box)))
                -1 => high > (box.get_bottom(box) + fill_ratio * (box.get_top(box) - box.get_bottom(box)))
                => false

            if do_delete
                box.delete(array.remove(upper_boxes, i))
                box.delete(array.remove(lower_boxes, i))
            else
                break

fvgs_values(float size_threshold = 0, bool enabled = true) =>
    [bullish_fvg_alert, bull_top, bull_btm] = _detect_fvg(1, enabled, size_threshold)
    [bearish_fvg_alert, bear_top, bear_btm] = _detect_fvg(-1, enabled, size_threshold)
    [bullish_fvg_alert, bull_top, bull_btm, bearish_fvg_alert, bear_top, bear_btm]

method clear_filled(FVG[] fvgs, FVG[] filled_buffer, FVG[] filled_new_buffer, int keep_history = 5, FVG[] discard_buffer = na) =>
    FVG[] moved_fvgs = array.new<FVG>(0)
    filled_new_buffer.clear()

    if na(keep_history) or keep_history <= 0
        filled_buffer.clear()

    if fvgs.size() > 0 and not na(filled_buffer)
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            if fvg.filled
                moved = fvgs.remove(i)
                moved_fvgs.unshift(moved)

    for moved in moved_fvgs
        filled_buffer.push(moved)
        filled_new_buffer.push(moved)

    if keep_history > 0
        while filled_buffer.size() > keep_history
            if not na(discard_buffer)
                discard_buffer.push(filled_buffer.shift())
            else
                filled_buffer.shift()

    fvgs

method update(FVG this) =>
    bool filled_by_close = this.fill_mode == LevelBreakMode.CLOSE
    if not this.filled and (not filled_by_close or barstate.isconfirmed)
        if this.dir == 1
            fill_src = filled_by_close ? close : low
            if this.fill_current_level > fill_src
                this.filled := this.fill_target_level > fill_src
                this.fill_current_level := math.min(this.fill_current_level, fill_src)
                this.fill_current_ratio := (this.left_top.price - this.fill_current_level) / (this.left_top.price - this.right_bottom.price)
                if this.filled
                    this.fill_time := time_close
                    this.fill_index := bar_index + 1
                true
            else
                false
        else
            fill_src = this.fill_mode == LevelBreakMode.CLOSE ? close : high
            if this.fill_current_level < fill_src
                this.filled := this.fill_target_level < fill_src
                this.fill_current_level := math.max(this.fill_current_level, fill_src)
                this.fill_current_ratio := (this.fill_current_level - this.right_bottom.price) / (this.left_top.price - this.right_bottom.price)
                if this.filled
                    this.fill_time := time_close
                    this.fill_index := bar_index + 1
                true
            else
                false
    else
        false

method update(FVG[] fvgs) =>
    if fvgs.size() > 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            fvg.update()
    fvgs

method hide(FVG this) =>
    if not na(this) and not this.hidden
        if not na(this.plot_box)
            this.plot_box.hide()
        if not na(this.plot_fill_target_label)
            this.plot_fill_target_label.hide()
            this.plot_fill_target_label.plot.set_text(na)
        this.hidden := true
    this

method delete(FVG this) =>
    if not na(this)
        if not na(this.plot_box)
            this.plot_box.delete()
        if not na(this.plot_fill_target_level)
            this.plot_fill_target_level.delete()
        if not na(this.plot_fill_target_label)
            this.plot_fill_target_label.delete()
        this.plot_box := na
        this.plot_fill_target_level := na
        this.plot_fill_target_label := na
        this.hidden := false
    this

method delete(FVG[] fvgs) =>
    if not na(fvgs)
        for fvg in fvgs
            fvg.delete()
    fvgs

method remove_insignificant(FVG[] fvgs, float size_threshold, FVG[] removed_buffer = na) =>
    if fvgs.size() > 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            size = fvg.left_top.price - fvg.right_bottom.price
            if size < size_threshold
                log.info("clearing out old FVG to free memory (top: {0} | bottom: {1}) with size ({2}) below threshold ({3})", fvg.left_top.price, fvg.right_bottom.price, size, size_threshold)
                if not na(removed_buffer)
                    removed_buffer.push(fvg)
                fvg.delete()
                fvgs.remove(i)
    fvgs

fvgs_objects(simple LevelBreakMode fill_mode = LevelBreakMode.CLOSE, float fill_target_ratio = 0.5, float size_threshold = 0, simple bool enabled = true, simple int filled_max_keep = 5, simple int gc_cycle = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] buffer_bear_discarded = array.new<FVG>(0)
    var int next_id = 0

    if barstate.isfirst and not in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    [bullish_fvg_alert, new_bull] = _detect_fvg_object(1, enabled, size_threshold, fill_mode, fill_target_ratio)
    [bearish_fvg_alert, new_bear] = _detect_fvg_object(-1, enabled, size_threshold, fill_mode, fill_target_ratio)

    buffer_bull.update()
    buffer_bear.update()

    buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, buffer_bull_discarded)
    buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, buffer_bear_discarded)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, buffer_bull_discarded)
        buffer_bear.remove_insignificant(size_threshold, buffer_bear_discarded)

    if bullish_fvg_alert
        next_id += 1
        new_bull.id := next_id
        buffer_bull.push(new_bull)
    if bearish_fvg_alert
        next_id += 1
        new_bear.id := next_id
        buffer_bear.push(new_bear)

    [bullish_fvg_alert, bearish_fvg_alert, buffer_bull, buffer_bear, new_bull, new_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, buffer_bull_discarded, buffer_bear_discarded]

method draw(FVG this, FVGConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    visible_match = na(visible_left) or na(visible_right) or this.overlaps_window(visible_left, visible_right, config.extend_until_filled)

    if not visible_match
        if not na(this.plot_box) and not this.hidden
            this.hide()
        this
    else

        if barstate.islast and not na(this) and (config.show_box or config.show_target)
            txt_probability = config.show_probability and this.probability > 0 ? str.format('({0,number,percent})', this.probability) : ''
            txt = str.format('{0}{1}', config.show_text ? config.txt + ' ' : '', config.show_target_label ? '' : txt_probability)

            xloc_bartime = config.box_args.xloc == xloc.bar_time
            int base_right_time = math.max(this.left_top.time, this.right_bottom.time)
            int fill_right_time = effective_live_event_time(this.fill_time, math.max(this.left_top.time, this.right_bottom.time))
            int left = not na(left_override) ? left_override : xloc_bartime ? this.left_top.time : this.left_top.index
            int right = not na(right_override) ? right_override :
             config.extend_until_filled ?
                 this.filled ?
                     xloc_bartime ? fill_right_time : this.fill_index - 1
                 :
                     xloc_bartime ? current_bar_right_time() : math.max(this.left_top.index + config.extend_bars, bar_index)
             :
                 this.filled ?
                     xloc_bartime ? math.min(fill_right_time, base_right_time) : math.min(this.fill_index - 1, math.max(this.left_top.index + config.extend_bars, this.right_bottom.index))
                 :
                     xloc_bartime ? base_right_time : math.max(this.left_top.index + config.extend_bars, this.right_bottom.index)

            chart.point plot_left_top = create_point(left, this.left_top.price, config.box_args.xloc)
            chart.point plot_right_bottom = create_point(right, this.right_bottom.price, config.box_args.xloc)

            if config.show_box
                if na(this.plot_box)
                    this.plot_box := Box.new(plot_left_top, plot_right_bottom, config.show_target_label ? '' : txt)
                else
                    this.plot_box.left_top := plot_left_top
                    this.plot_box.right_bottom := plot_right_bottom

                this.plot_box.draw(config.box_args, config.box_text_args, extend_only, force_overlay)
                if this.filled
                    this.plot_box.plot.set_text(txt)

            if config.show_target
                if na(this.plot_fill_target_level)
                    this.plot_fill_target_level := create_line(left, this.fill_target_level, right, this.fill_target_level, config.line_args.xloc)
                else
                    this.plot_fill_target_level.start.update(left, this.fill_target_level, config.line_args.xloc)
                    this.plot_fill_target_level.end.update(right, this.fill_target_level, config.line_args.xloc)
                this.plot_fill_target_level.draw(config.line_args, extend_only, force_overlay)

            if config.show_target_label
                txt_target = str.format('{0}{1}', config.show_text ? config.txt + ' ' : '', txt_probability)
                if na(this.plot_fill_target_label)
                    this.plot_fill_target_label := create_label(right, this.fill_target_level, config.label_args.xloc, txt_target)
                else
                    this.plot_fill_target_label.point.update(right, this.fill_target_level, config.label_args.xloc)
                    this.plot_fill_target_label.txt := txt_target
                this.plot_fill_target_label.draw(config.label_args, force_overlay)

            if this.filled and fill_right_time <= current_bar_right_time()
                if not na(this.plot_box)
                    this.plot_box.apply_style(config.box_args, config.box_text_args)
                if not na(this.plot_fill_target_level)
                    this.plot_fill_target_level.apply_style(config.line_args)
                if not na(this.plot_fill_target_label)
                    this.plot_fill_target_label.apply_style(config.label_args)

            this.hidden := false

    this

method draw(FVG[] fvgs, FVGConfig config, bool extend_only = true, simple bool force_overlay = false, int left_override = na, int right_override = na, int visible_left = na, int visible_right = na) =>
    if na(fvgs) ? false : (config.show_box or config.show_target) and fvgs.size() > 0
        count = 0
        for i = fvgs.size() - 1 to 0
            fvg = fvgs.get(i)
            visible_match = na(visible_left) or na(visible_right) or fvg.overlaps_window(visible_left, visible_right, config.extend_until_filled)
            if visible_match and count < config.show_last
                fvg.draw(config, extend_only, force_overlay, left_override, right_override, visible_left, visible_right)
                count += 1
            else
                if not na(fvg.plot_box) and not fvg.hidden
                    fvg.hide()
    fvgs

premium_discount_zones_values(int top_x, int btm_x, float trail_up, float trail_dn) =>
    x = math.max(top_x, btm_x)
    premium_top = trail_up
    premium_btm = .95 * trail_up + .05 * trail_dn
    eq_top = .525 * trail_up + .475 * trail_dn
    eq_btm = .525 * trail_dn + .475 * trail_up
    eq_center = math.avg(trail_up, trail_dn)
    discount_top = .95 * trail_dn + .05 * trail_up
    discount_btm = trail_dn
    [x, premium_top, premium_btm, eq_top, eq_center, eq_btm, discount_top, discount_btm]

premium_discount_zones_plot(bool show, int pd_start, float premium_top, float premium_btm, float eq_top, float eq_center, float eq_btm, float discount_top, float discount_btm, color color_premium, color color_equilibrium, color color_discount) =>
    var premium = box.new(na, na, na, na, bgcolor = color.new(color_premium, 80), border_color = na)
    var premium_lbl = label.new(na, na, text = 'Premium', color = #00000000, textcolor = color_premium, style = label.style_label_down, size = size.small)
    var eq = box.new(na, na, na, na, bgcolor = color.rgb(120, 123, 134, 80), border_color = na)
    var eq_lbl = label.new(na, na, text = 'Equilibrium', color = #00000000, textcolor = color_equilibrium, style = label.style_label_left, size = size.small)
    var discount = box.new(na, na, na, na, bgcolor = color.new(color_discount, 80), border_color = na)
    var discount_lbl = label.new(na, na, text = 'Discount', color = #00000000, textcolor = color_discount, style = label.style_label_up, size = size.small)
    var label pd_warning_lbl = na

    if show and barstate.isnew
        if bar_index - pd_start > 244
            if na(pd_warning_lbl)
                pd_warning_lbl := label.new(bar_index, close, 'premium zone starts too far back')
            else
                label.set_xy(pd_warning_lbl, bar_index, close)
        else
            if not na(pd_warning_lbl)
                label.delete(pd_warning_lbl)
                pd_warning_lbl := na
            box.set_lefttop(premium, pd_start, premium_top)
            box.set_rightbottom(premium, bar_index, premium_btm)
            label.set_xy(premium_lbl, int(math.avg(pd_start, bar_index)), premium_top)
            box.set_lefttop(eq, pd_start, eq_top)
            box.set_rightbottom(eq, bar_index, eq_btm)
            label.set_xy(eq_lbl, bar_index, eq_center)
            box.set_lefttop(discount, pd_start, discount_top)
            box.set_rightbottom(discount, bar_index, discount_btm)
            label.set_xy(discount_lbl, int(math.avg(pd_start, bar_index)), discount_btm)
        true
    false

