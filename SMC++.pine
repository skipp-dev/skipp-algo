[ob_blocks_bull, ob_blocks_bear, new_ob_bull, _new_ob_bear, ob_broken_bull, _ob_broken_bear, ob_broken_new_bull, _ob_broken_new_bear, ob_discarded_bull, _ob_discarded_bear] = track_obs(swing_length, hh, ll, bull_bos_alert, bull_choch_alert, bear_bos_alert, bear_choch_alert, ob_threshold_min, ob_threshold_max, enabled = enable_ob_engine, capture_profile = collect_ob_profile_current_bar, update_profile_current_bar = collect_ob_profile_current_bar, align_edge_to_value_area = use_ob_profile_effective, align_break_price_to_poc = use_ob_profile_effective, use_soft_confirm = use_ob_soft_confirm, soft_confirm_offset = soft_confirm_offset, keep_broken_max = ob_keep_broken_max, broken_by = active_break_mode, gc_cycle = object_gc_cycle, protected_bull_id = _ob_backing_zone_id)

