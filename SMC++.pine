    dashboard_row(tbl, 9, 'Exec Tier', _db_exec_tier_text, status_bg(_db_exec_tier_state), _db_text)

    dashboard_header(tbl, 10, '[ Hard Gates ]', _db_header_bg, _db_text)
    dashboard_row(tbl, 11, 'Session', _db_session_text, status_bg(_db_session_state), _db_text)
    dashboard_row(tbl, 12, 'Market Gate', _db_market_text, status_bg(_db_market_state), _db_text)
    dashboard_row(tbl, 13, 'Vola Regime', _db_vola_gate_text, status_bg(_db_vola_gate_state), _db_text)
