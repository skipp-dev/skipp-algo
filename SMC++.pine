    dashboard_row(tbl, 15, 'Micro Fresh', _db_micro_fresh_text, status_bg(_db_micro_fresh_state), _db_text)
    dashboard_row(tbl, 16, 'Volume Data', _db_volume_data_text, status_bg(_db_volume_data_state), _db_text)
    dashboard_row(tbl, 17, 'Quality Env', _db_quality_env_text, status_bg(_db_quality_env_state), _db_text)
    dashboard_row(tbl, 18, 'Quality Strict', _db_quality_strict_text, status_bg(_db_quality_strict_state), _db_text)

    dashboard_header(tbl, 19, '[ Quality ]', _db_header_bg, _db_text)
    dashboard_row(tbl, 20, 'Close Strength', close_state_text, status_bg(not use_strong_close_filter ? 0 : bull_close_strong ? 5 : -1), _db_text)
    dashboard_row(tbl, 21, 'EMA Support', ema_state_text, status_bg(not show_ema_support ? 0 : ema_support_ok ? 5 : -1), _db_text)
    dashboard_row(tbl, 22, 'ADX', _db_adx_text, status_bg(_db_adx_state), _db_text)
    dashboard_row(tbl, 23, 'Rel Volume', _db_relvol_text, status_bg(_db_relvol_state), _db_text)
    dashboard_row(tbl, 24, 'VWAP Filter', _db_vwap_text, status_bg(_db_vwap_state), _db_text)
    dashboard_row(tbl, 25, 'Context Quality', _db_context_quality_text, status_bg(_db_context_quality_state), _db_text)
    dashboard_row(tbl, 26, 'Quality Score', _db_quality_score_text, status_bg(_db_quality_score_state), _db_text)
    dashboard_row(tbl, 27, 'Quality Clean', _db_quality_clean_text, status_bg(_db_quality_clean_state), _db_text)

    dashboard_header(tbl, 28, '[ Modules ]', _db_header_bg, _db_text)
    dashboard_row(tbl, 29, 'SD Confluence', _db_sd_confluence_text, status_bg(_db_sd_confluence_state), _db_text)
    dashboard_row(tbl, 30, 'SD Osc', _db_sd_osc_text, status_bg(_db_sd_osc_state), _db_text)
