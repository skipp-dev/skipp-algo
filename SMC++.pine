    plot_swing_levels(-1, internal_trail_dn_x, internal_trail_dn, internal_display_trend, true, d.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_left), d.LineArgs.new(bull_internal_css, line.style_dashed), override_right_index = bar_index + 10, text_prefix = 'INT ')

if show_internal_bull_bos or show_internal_bull_choch
    plot_structure(internal_top_x, internal_top, show_internal_bull_bos and internal_bull_bos_sig, show_internal_bull_choch and internal_bull_choch_sig, d.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_down), d.LineArgs.new(bull_internal_css, line.style_dashed), keep_history = keep_visual_history, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

