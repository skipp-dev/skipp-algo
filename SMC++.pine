var show_fvg_filled = show_fvg and fvg_keep_filled and fvg_keep_filled_max > 0
var fvg_config_bull_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_probability = false, extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bull_fvg_line_css_filled, 0, line.style_solid, bull_fvg_css_filled, xloc.bar_index), box_text_args = BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bull_fvg_line_css_filled, line.style_solid, 1, xloc.bar_index), label_args = LabelArgs.new(#00000000, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var fvg_config_bear_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_probability = false, extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bear_fvg_line_css_filled, 0, line.style_solid, bear_fvg_css_filled, xloc.bar_index), box_text_args = BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bear_fvg_line_css_filled, line.style_solid, 1, xloc.bar_index), label_args = LabelArgs.new(#00000000, xloc = xloc.bar_index, style = label.style_label_left, size = size.normal, text_align = text.align_left))

bool bullish_fvg_filled_alert = filled_fvgs_new_bull.size() > 0
bool bearish_fvg_filled_alert = filled_fvgs_new_bear.size() > 0
float bull_filled_alert_level = bullish_fvg_filled_alert ? filled_fvgs_new_bull.last().fill_target_level : na
float bear_filled_alert_level = bearish_fvg_filled_alert ? filled_fvgs_new_bear.last().fill_target_level : na

if barstate.islast
    fvgs_bull.draw(fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    fvgs_bear.draw(fvg_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_fvg_filled
        filled_fvgs_bull.draw(fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
        filled_fvgs_bear.draw(fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        filled_fvgs_bull.delete()
        filled_fvgs_bear.delete()

    if barstate.isconfirmed
        fvg_discarded_bull.delete()
        fvg_discarded_bull.clear()
        fvg_discarded_bear.delete()
        fvg_discarded_bear.clear()

fvgs_objects_htf(FVG new_bull, FVG new_bear, bool htf_is_confirmed, float size_threshold, simple LevelBreakMode fill_mode = LevelBreakMode.CLOSE, simple float fill_target_ratio = 0.5, simple int filled_max_keep = 5, simple int gc_cycle = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] htf_buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] htf_buffer_bear_discarded = array.new<FVG>(0)

    if barstate.isfirst and not in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    bool htf_update_ok = fill_mode == LevelBreakMode.HIGHLOW or signal_mode == SignalMode.AGGRESSIVE_LIVE or barstate.isconfirmed
    if htf_update_ok
        buffer_bull.update()
        buffer_bear.update()
        buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, htf_buffer_bull_discarded)
        buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, htf_buffer_bear_discarded)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, htf_buffer_bull_discarded)
        buffer_bear.remove_insignificant(size_threshold, htf_buffer_bear_discarded)

    bool htf_insert_ok = fill_mode == LevelBreakMode.CLOSE ? htf_is_confirmed : true

    if htf_insert_ok and not na(new_bull)
        buffer_bull.push(new_bull)
    if htf_insert_ok and not na(new_bear)
        buffer_bear.push(new_bear)

    [buffer_bull, buffer_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, htf_buffer_bull_discarded, htf_buffer_bear_discarded]

var g_htf_fvg = 'Fair Value Gaps (Higher Timeframe)'
var show_htf_fvg = input.bool(true, 'Show Fair Value Gaps (HTF)', group = g_htf_fvg, inline = 'show', tooltip = SHOW_FVG + '\n' + FVG_TF)
var fvg_htf = input.timeframe('1D', '', group = g_htf_fvg, inline = 'show')
var htf_fvg_showlast = input.int(1, 'Show last', minval = 1, group = g_htf_fvg, inline = 'show2')
var htf_fvg_keep_filled = input.bool(true, 'Keep filled', group = g_htf_fvg, inline = 'keep filled')
var htf_fvg_keep_filled_max = input.int(1, '', minval = 1, group = g_htf_fvg, inline = 'keep filled')
var bull_htf_fvg_css = bull_fvg_css
var bear_htf_fvg_css = bear_fvg_css
var bull_htf_fvg_line_css = bull_fvg_line_css
var bear_htf_fvg_line_css = bear_fvg_line_css
var bull_htf_fvg_css_filled = bull_fvg_css_filled
var bear_htf_fvg_css_filled = bear_fvg_css_filled
var bull_htf_fvg_line_css_filled = bull_fvg_line_css_filled
var bear_htf_fvg_line_css_filled = bear_fvg_line_css_filled
int htf_fvg_tf_sec = nz(timeframe.in_seconds(fvg_htf), 0)

if barstate.isfirst and show_htf_fvg
    if chart_tf_sec == 0 or htf_fvg_tf_sec == 0
        runtime.error('HTF FVG requires a time-based chart and a time-based HTF.')
    if htf_fvg_tf_sec <= chart_tf_sec
        runtime.error(str.format('Show FVG (Timeframe): select a timeframe higher than the chart timeframe {0}, currently selected: {1}', timeframe.period, fvg_htf))

var htf_fvg_config_bull = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_showlast, txt = fvg_htf + ' - FVG ⬈', extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bull_htf_fvg_line_css, 0, line.style_solid, bull_htf_fvg_css, xloc = xloc.bar_time), box_text_args = BoxTextArgs.new(bull_htf_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bull_htf_fvg_line_css, line.style_solid, 1, xloc = xloc.bar_time), label_args = LabelArgs.new(bull_htf_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bear = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_showlast, txt = fvg_htf + ' - FVG ⬊', extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bear_htf_fvg_line_css, 0, line.style_solid, bear_htf_fvg_css, xloc = xloc.bar_time), box_text_args = BoxTextArgs.new(bear_htf_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bear_htf_fvg_line_css, line.style_solid, 1, xloc = xloc.bar_time), label_args = LabelArgs.new(bear_htf_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bull_filled = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_keep_filled_max, txt = '', extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bull_htf_fvg_line_css_filled, 0, line.style_solid, bull_htf_fvg_css_filled, xloc = xloc.bar_time), box_text_args = BoxTextArgs.new(bull_htf_fvg_line_css_filled, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bull_htf_fvg_line_css_filled, line.style_solid, 1, xloc = xloc.bar_time), label_args = LabelArgs.new(bull_htf_fvg_css_filled, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bear_filled = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_keep_filled_max, txt = '', extend_until_filled = fvg_extend_until_filled, box_args = BoxArgs.new(bear_htf_fvg_line_css_filled, 0, line.style_solid, bear_htf_fvg_css_filled, xloc = xloc.bar_time), box_text_args = BoxTextArgs.new(bear_htf_fvg_line_css_filled, size.normal, text.align_right, text.align_center), line_args = LineArgs.new(bear_htf_fvg_line_css_filled, line.style_solid, 1, xloc = xloc.bar_time), label_args = LabelArgs.new(bear_htf_fvg_css_filled, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))

FVG htf_new_fvg_bull = na
FVG htf_new_fvg_bear = na
FVG htf_insert_fvg_bull = na
FVG htf_insert_fvg_bear = na
var string last_htf_inserted_bull_key = ''
var string last_htf_inserted_bear_key = ''
htf_bar_changed = timeframe.change(fvg_htf)
htf_fvg_confirmed = signal_mode == SignalMode.AGGRESSIVE_LIVE ? true : barstate.isconfirmed and (htf_bar_changed or htf_fvg_tf_sec == chart_tf_sec)
if show_htf_fvg
    [_, htf_new_fvg_bull_tmp] = request.security(syminfo.tickerid, fvg_htf, _detect_fvg_object(1, true, fvg_size_threshold, LevelBreakMode.CLOSE, fvg_fill_target_ratio), gaps = barmerge.gaps_on)
    [_, htf_new_fvg_bear_tmp] = request.security(syminfo.tickerid, fvg_htf, _detect_fvg_object(-1, true, fvg_size_threshold, LevelBreakMode.CLOSE, fvg_fill_target_ratio), gaps = barmerge.gaps_on)
    htf_new_fvg_bull := htf_new_fvg_bull_tmp
    htf_new_fvg_bear := htf_new_fvg_bear_tmp
    string bull_htf_key = htf_fvg_key(htf_new_fvg_bull)
    string bear_htf_key = htf_fvg_key(htf_new_fvg_bear)
    if htf_fvg_confirmed and not na(htf_new_fvg_bull) and bull_htf_key != last_htf_inserted_bull_key
        htf_insert_fvg_bull := htf_new_fvg_bull
        last_htf_inserted_bull_key := bull_htf_key
    if htf_fvg_confirmed and not na(htf_new_fvg_bear) and bear_htf_key != last_htf_inserted_bear_key
        htf_insert_fvg_bear := htf_new_fvg_bear
        last_htf_inserted_bear_key := bear_htf_key
[htf_fvg_buffer_bull, htf_fvg_buffer_bear, htf_fvg_buffer_bull_filled, htf_fvg_buffer_bear_filled, htf_fvg_buffer_bull_filled_new, htf_fvg_buffer_bear_filled_new, htf_fvg_buffer_bull_discarded, htf_fvg_buffer_bear_discarded] = fvgs_objects_htf(htf_insert_fvg_bull, htf_insert_fvg_bear, htf_fvg_confirmed, fvg_size_threshold, active_break_mode, fvg_fill_target_ratio, htf_fvg_keep_filled_max, object_gc_cycle)

last_bull_ob_break_level = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().break_price : na
last_bear_ob_break_level = ob_blocks_bear.size() > 0 ? ob_blocks_bear.last().break_price : na
last_bull_fvg_fill_level = fvgs_bull.size() > 0 ? fvgs_bull.last().fill_target_level : na
last_bear_fvg_fill_level = fvgs_bear.size() > 0 ? fvgs_bear.last().fill_target_level : na

last_bull_ob_top = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().left_top.price : na
last_bull_ob_bottom = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().right_bottom.price : na
last_bull_fvg_top = fvgs_bull.size() > 0 ? fvgs_bull.last().left_top.price : na
last_bull_fvg_bottom = fvgs_bull.size() > 0 ? fvgs_bull.last().right_bottom.price : na

float active_bull_ob_top = na
float active_bull_ob_bottom = na
float active_bull_ob_break_level = na
float active_bull_fvg_top = na
float active_bull_fvg_bottom = na
float active_bull_fvg_fill_level = na
float active_bear_ob_break_level = na
float active_bear_fvg_fill_level = na
var float touched_bull_ob_top = na
var float touched_bull_ob_bottom = na
var int touched_bull_ob_bar_index = na
var int touched_bull_ob_id = na
var float touched_bull_fvg_top = na
var float touched_bull_fvg_bottom = na
var int touched_bull_fvg_bar_index = na
var int touched_bull_fvg_id = na
int bull_ob_scan_start = math.max(0, ob_blocks_bull.size() - long_zone_scan_limit)
int bull_fvg_scan_start = math.max(0, fvgs_bull.size() - long_zone_scan_limit)
int bear_ob_scan_start = math.max(0, ob_blocks_bear.size() - long_zone_scan_limit)
int bear_fvg_scan_start = math.max(0, fvgs_bear.size() - long_zone_scan_limit)

int best_bull_ob_idx = na
if ob_blocks_bull.size() > 0
    for i = ob_blocks_bull.size() - 1 to bull_ob_scan_start
        bull_ob_candidate = ob_blocks_bull.get(i)
        bool ob_candidate_active = low <= bull_ob_candidate.left_top.price and high >= bull_ob_candidate.right_bottom.price
        if ob_candidate_active and (na(best_bull_ob_idx) or bull_ob_candidate.right_bottom.price < ob_blocks_bull.get(best_bull_ob_idx).right_bottom.price)
            best_bull_ob_idx := i
if not na(best_bull_ob_idx)
    best_bull_ob = ob_blocks_bull.get(best_bull_ob_idx)
    active_bull_ob_top := best_bull_ob.left_top.price
    active_bull_ob_bottom := best_bull_ob.right_bottom.price
    active_bull_ob_break_level := best_bull_ob.break_price
    touched_bull_ob_top := active_bull_ob_top
    touched_bull_ob_bottom := active_bull_ob_bottom
    touched_bull_ob_bar_index := bar_index
    touched_bull_ob_id := best_bull_ob.id

int best_bull_fvg_idx = na
if fvgs_bull.size() > 0
    for i = fvgs_bull.size() - 1 to bull_fvg_scan_start
        bull_fvg_candidate = fvgs_bull.get(i)
        bool fvg_candidate_active = low <= bull_fvg_candidate.left_top.price and high >= bull_fvg_candidate.right_bottom.price
        if fvg_candidate_active and (na(best_bull_fvg_idx) or bull_fvg_candidate.right_bottom.price < fvgs_bull.get(best_bull_fvg_idx).right_bottom.price)
            best_bull_fvg_idx := i
if not na(best_bull_fvg_idx)
    best_bull_fvg = fvgs_bull.get(best_bull_fvg_idx)
    active_bull_fvg_top := best_bull_fvg.left_top.price
    active_bull_fvg_bottom := best_bull_fvg.right_bottom.price
    active_bull_fvg_fill_level := best_bull_fvg.fill_target_level
    touched_bull_fvg_top := active_bull_fvg_top
    touched_bull_fvg_bottom := active_bull_fvg_bottom
    touched_bull_fvg_bar_index := bar_index
    touched_bull_fvg_id := best_bull_fvg.id

int best_bear_ob_idx = na
if ob_blocks_bear.size() > 0
    for i = ob_blocks_bear.size() - 1 to bear_ob_scan_start
        bear_ob_candidate = ob_blocks_bear.get(i)
        bool bear_ob_candidate_active = low <= bear_ob_candidate.left_top.price and high >= bear_ob_candidate.right_bottom.price
        if bear_ob_candidate_active and (na(best_bear_ob_idx) or bear_ob_candidate.left_top.price > ob_blocks_bear.get(best_bear_ob_idx).left_top.price)
            best_bear_ob_idx := i
if not na(best_bear_ob_idx)
    active_bear_ob_break_level := ob_blocks_bear.get(best_bear_ob_idx).break_price

int best_bear_fvg_idx = na
if fvgs_bear.size() > 0
    for i = fvgs_bear.size() - 1 to bear_fvg_scan_start
        bear_fvg_candidate = fvgs_bear.get(i)
        bool bear_fvg_candidate_active = low <= bear_fvg_candidate.left_top.price and high >= bear_fvg_candidate.right_bottom.price
        if bear_fvg_candidate_active and (na(best_bear_fvg_idx) or bear_fvg_candidate.left_top.price > fvgs_bear.get(best_bear_fvg_idx).left_top.price)
            best_bear_fvg_idx := i
if not na(best_bear_fvg_idx)
    active_bear_fvg_fill_level := fvgs_bear.get(best_bear_fvg_idx).fill_target_level

bool in_bull_ob_zone = not na(active_bull_ob_top) and not na(active_bull_ob_bottom)
bool in_bull_fvg_zone = not na(active_bull_fvg_top) and not na(active_bull_fvg_bottom)
int active_long_zone_id = not na(best_bull_ob_idx) ? ob_blocks_bull.get(best_bull_ob_idx).id : not na(best_bull_fvg_idx) ? -fvgs_bull.get(best_bull_fvg_idx).id : na
bool touched_bull_ob_still_active = ob_blocks_bull.contains_id(touched_bull_ob_id)
bool touched_bull_fvg_still_active = fvgs_bull.contains_id(touched_bull_fvg_id)
bool touched_bull_ob_recent = touched_bull_ob_still_active and not na(touched_bull_ob_bar_index) and bar_index - touched_bull_ob_bar_index <= long_signal_window
bool touched_bull_fvg_recent = touched_bull_fvg_still_active and not na(touched_bull_fvg_bar_index) and bar_index - touched_bull_fvg_bar_index <= long_signal_window
bool long_zone_active = in_bull_ob_zone or in_bull_fvg_zone
bool long_zone_active_safe = long_zone_active
int active_long_zone_id_safe = active_long_zone_id
if signal_mode != SignalMode.AGGRESSIVE_LIVE and not barstate.isconfirmed
    long_zone_active_safe := long_zone_active[1]
    active_long_zone_id_safe := active_long_zone_id[1]
var int last_zone_touch_event_bar_index = na
var int last_zone_touch_event_zone_id = na
bool zone_touch_event = long_zone_active and (not long_zone_active[1] or active_long_zone_id != active_long_zone_id[1])
if zone_touch_event
    last_zone_touch_event_bar_index := bar_index
    last_zone_touch_event_zone_id := active_long_zone_id
bool zone_touch_event_recent = not na(last_zone_touch_event_bar_index) and bar_index - last_zone_touch_event_bar_index <= long_signal_window
bool zone_touch_sequence_time_ok = not na(last_zone_touch_event_bar_index) and (allow_same_bar_zone_reclaim ? bar_index >= last_zone_touch_event_bar_index : bar_index > last_zone_touch_event_bar_index)
bool ob_zone_touch_sequence_ok = zone_touch_event_recent and zone_touch_sequence_time_ok and not na(touched_bull_ob_id) and last_zone_touch_event_zone_id == touched_bull_ob_id
bool fvg_zone_touch_sequence_ok = zone_touch_event_recent and zone_touch_sequence_time_ok and not na(touched_bull_fvg_id) and last_zone_touch_event_zone_id == -touched_bull_fvg_id
bool generic_zone_touch_sequence_ok = zone_touch_event_recent and zone_touch_sequence_time_ok
bool zone_touch_tracking_active = live_exec ? long_zone_active : long_zone_active_safe
int zone_touch_tracking_id = live_exec ? active_long_zone_id : active_long_zone_id_safe
var int active_zone_touch_count = 0
var int active_zone_touch_id = na
var int last_zone_touch_bar = na
bool zone_touch_now = zone_touch_tracking_active and (not zone_touch_tracking_active[1] or zone_touch_tracking_id != zone_touch_tracking_id[1])
if zone_touch_now and last_zone_touch_bar != bar_index and not na(zone_touch_tracking_id)
    if zone_touch_tracking_id != active_zone_touch_id
        active_zone_touch_id := zone_touch_tracking_id
        active_zone_touch_count := 1
    else
        active_zone_touch_count += 1
    last_zone_touch_bar := bar_index
bool zone_touch_quality_ok = not block_third_touch or active_zone_touch_count <= max_zone_touches_for_entry
float bull_ob_break_for_alert = not na(active_bull_ob_break_level) ? active_bull_ob_break_level : last_bull_ob_break_level
float bull_fvg_fill_for_alert = not na(active_bull_fvg_fill_level) ? active_bull_fvg_fill_level : last_bull_fvg_fill_level
float bear_ob_break_for_alert = not na(active_bear_ob_break_level) ? active_bear_ob_break_level : last_bear_ob_break_level
float bear_fvg_fill_for_alert = not na(active_bear_fvg_fill_level) ? active_bear_fvg_fill_level : last_bear_fvg_fill_level
bool any_live_bull_ob_break = ob_broken_new_bull.size() > 0
bool any_live_bear_ob_break = ob_broken_new_bear.size() > 0
bool any_live_bull_fvg_fill = filled_fvgs_new_bull.size() > 0
bool any_live_bear_fvg_fill = filled_fvgs_new_bear.size() > 0
float bull_ob_live_event_level = any_live_bull_ob_break ? ob_broken_new_bull.last().break_price : bull_ob_break_for_alert
float bear_ob_live_event_level = any_live_bear_ob_break ? ob_broken_new_bear.last().break_price : bear_ob_break_for_alert
float bull_fvg_live_event_level = any_live_bull_fvg_fill ? filled_fvgs_new_bull.last().fill_target_level : bull_fvg_fill_for_alert
float bear_fvg_live_event_level = any_live_bear_fvg_fill ? filled_fvgs_new_bear.last().fill_target_level : bear_fvg_fill_for_alert
int best_live_bull_ob_idx = na
int best_live_bear_ob_idx = na
int best_live_bull_fvg_idx = na
int best_live_bear_fvg_idx = na

if not any_live_bull_ob_break and ob_blocks_bull.size() > 0
    for i = ob_blocks_bull.size() - 1 to bull_ob_scan_start
        bull_ob_live_candidate = ob_blocks_bull.get(i)
        if low <= bull_ob_live_candidate.break_price and (na(best_live_bull_ob_idx) or bull_ob_live_candidate.right_bottom.price < ob_blocks_bull.get(best_live_bull_ob_idx).right_bottom.price)
            best_live_bull_ob_idx := i
if not na(best_live_bull_ob_idx)
    any_live_bull_ob_break := true
    bull_ob_live_event_level := ob_blocks_bull.get(best_live_bull_ob_idx).break_price

if not any_live_bear_ob_break and ob_blocks_bear.size() > 0
    for i = ob_blocks_bear.size() - 1 to bear_ob_scan_start
        bear_ob_live_candidate = ob_blocks_bear.get(i)
        if high >= bear_ob_live_candidate.break_price and (na(best_live_bear_ob_idx) or bear_ob_live_candidate.left_top.price > ob_blocks_bear.get(best_live_bear_ob_idx).left_top.price)
            best_live_bear_ob_idx := i
if not na(best_live_bear_ob_idx)
    any_live_bear_ob_break := true
    bear_ob_live_event_level := ob_blocks_bear.get(best_live_bear_ob_idx).break_price

if not any_live_bull_fvg_fill and fvgs_bull.size() > 0
    for i = fvgs_bull.size() - 1 to bull_fvg_scan_start
        bull_fvg_live_candidate = fvgs_bull.get(i)
        if low <= bull_fvg_live_candidate.fill_target_level and (na(best_live_bull_fvg_idx) or bull_fvg_live_candidate.right_bottom.price < fvgs_bull.get(best_live_bull_fvg_idx).right_bottom.price)
            best_live_bull_fvg_idx := i
if not na(best_live_bull_fvg_idx)
    any_live_bull_fvg_fill := true
    bull_fvg_live_event_level := fvgs_bull.get(best_live_bull_fvg_idx).fill_target_level

if not any_live_bear_fvg_fill and fvgs_bear.size() > 0
    for i = fvgs_bear.size() - 1 to bear_fvg_scan_start
        bear_fvg_live_candidate = fvgs_bear.get(i)
        if high >= bear_fvg_live_candidate.fill_target_level and (na(best_live_bear_fvg_idx) or bear_fvg_live_candidate.left_top.price > fvgs_bear.get(best_live_bear_fvg_idx).left_top.price)
            best_live_bear_fvg_idx := i
if not na(best_live_bear_fvg_idx)
    any_live_bear_fvg_fill := true
    bear_fvg_live_event_level := fvgs_bear.get(best_live_bear_fvg_idx).fill_target_level

float long_reclaim_ob_break_src = live_exec ? high : close
float long_reclaim_fvg_break_src = live_exec ? high : close
float long_reclaim_internal_break_src = live_exec ? high : close
float long_reclaim_swing_break_src = live_exec ? high : close
bool long_reclaim_bar_ok = live_exec ? true : barstate.isconfirmed
float touched_bull_ob_top_prev = nz(touched_bull_ob_top[1], touched_bull_ob_top)
float touched_bull_fvg_top_prev = nz(touched_bull_fvg_top[1], touched_bull_fvg_top)
bool new_touched_ob_source = not na(touched_bull_ob_id) and (na(touched_bull_ob_id[1]) or touched_bull_ob_id != touched_bull_ob_id[1])
bool new_touched_fvg_source = not na(touched_bull_fvg_id) and (na(touched_bull_fvg_id[1]) or touched_bull_fvg_id != touched_bull_fvg_id[1])
bool bull_reclaim_ob_cross = touched_bull_ob_still_active and not na(touched_bull_ob_top) and long_reclaim_ob_break_src > touched_bull_ob_top and (new_touched_ob_source ? low <= touched_bull_ob_top : nz(long_reclaim_ob_break_src[1], long_reclaim_ob_break_src) <= touched_bull_ob_top_prev)
bool bull_reclaim_fvg_cross = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and long_reclaim_fvg_break_src > touched_bull_fvg_top and (new_touched_fvg_source ? low <= touched_bull_fvg_top : nz(long_reclaim_fvg_break_src[1], long_reclaim_fvg_break_src) <= touched_bull_fvg_top_prev)
bool bull_reclaim_ob_wick_reclaim = touched_bull_ob_still_active and not na(touched_bull_ob_top) and low <= touched_bull_ob_top and open <= touched_bull_ob_top and long_reclaim_ob_break_src > touched_bull_ob_top
bool bull_reclaim_fvg_wick_reclaim = touched_bull_fvg_still_active and not na(touched_bull_fvg_top) and low <= touched_bull_fvg_top and open <= touched_bull_fvg_top and long_reclaim_fvg_break_src > touched_bull_fvg_top

bool bull_reclaim_ob = long_reclaim_bar_ok and touched_bull_ob_recent and not na(touched_bull_ob_top) and (bull_reclaim_ob_cross or bull_reclaim_ob_wick_reclaim)
bool bull_reclaim_fvg = long_reclaim_bar_ok and touched_bull_fvg_recent and not na(touched_bull_fvg_top) and (bull_reclaim_fvg_cross or bull_reclaim_fvg_wick_reclaim)
bool bull_reclaim_internal_low = long_reclaim_bar_ok and not na(internal_trail_dn) and low < internal_trail_dn and long_reclaim_internal_break_src > internal_trail_dn
bool bull_reclaim_swing_low = long_reclaim_bar_ok and not na(trail_dn) and low < trail_dn and long_reclaim_swing_break_src > trail_dn
float bull_ob_zone_height = not na(touched_bull_ob_top) and not na(touched_bull_ob_bottom) ? math.max(touched_bull_ob_top - touched_bull_ob_bottom, syminfo.mintick) : na
float bull_fvg_zone_height = not na(touched_bull_fvg_top) and not na(touched_bull_fvg_bottom) ? math.max(touched_bull_fvg_top - touched_bull_fvg_bottom, syminfo.mintick) : na
float bull_ob_required_sweep_level = not na(bull_ob_zone_height) ? touched_bull_ob_top - bull_ob_zone_height * ob_reclaim_min_penetration : na
float bull_fvg_required_sweep_level = not na(bull_fvg_zone_height) ? touched_bull_fvg_top - bull_fvg_zone_height * fvg_reclaim_min_penetration : na
bool bull_ob_real_sweep = touched_bull_ob_still_active and not na(bull_ob_required_sweep_level) and low <= bull_ob_required_sweep_level
bool bull_fvg_real_sweep = touched_bull_fvg_still_active and not na(bull_fvg_required_sweep_level) and low <= bull_fvg_required_sweep_level
bool bull_reclaim_ob_strict = bull_reclaim_ob and (not use_strict_sequence or ob_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim or bull_ob_real_sweep)
bool bull_reclaim_fvg_strict = bull_reclaim_fvg and (not use_strict_sequence or fvg_zone_touch_sequence_ok) and (not use_strict_sweep_for_zone_reclaim or bull_fvg_real_sweep)
bool bull_reclaim_internal_low_strict = bull_reclaim_internal_low and (not use_strict_sequence or generic_zone_touch_sequence_ok)
bool bull_reclaim_swing_low_strict = bull_reclaim_swing_low and (not use_strict_sequence or generic_zone_touch_sequence_ok)
bool bull_reclaim_any = bull_reclaim_ob_strict or bull_reclaim_fvg_strict or bull_reclaim_internal_low_strict or bull_reclaim_swing_low_strict
bool bull_reclaim_any_for_arm = bull_reclaim_ob_strict or bull_reclaim_fvg_strict or ((bull_reclaim_internal_low_strict or bull_reclaim_swing_low_strict) and long_zone_active)

int zone_since_bars = ta.barssince(long_zone_active)
int reclaim_since_bars = ta.barssince(bull_reclaim_any)
int internal_choch_since_bars = ta.barssince(internal_bull_choch_sig)
int internal_bos_since_bars = ta.barssince(internal_bull_bos_sig)
int main_bos_since_bars = ta.barssince(bull_bos_sig)

bool zone_recent = not na(zone_since_bars) and zone_since_bars <= long_signal_window
bool reclaim_recent = not na(reclaim_since_bars) and reclaim_since_bars <= long_signal_window
bool internal_choch_recent = not na(internal_choch_since_bars) and internal_choch_since_bars <= long_signal_window
bool internal_bos_recent = not na(internal_bos_since_bars) and internal_bos_since_bars <= long_signal_window
bool main_bos_recent = not na(main_bos_since_bars) and main_bos_since_bars <= long_signal_window

bool bearish_abort_signal = bear_bos_sig or bear_choch_sig or internal_bear_bos_sig or internal_bear_choch_sig
int bearish_abort_since_bars = ta.barssince(bearish_abort_signal)
bool bearish_abort_recent = not na(bearish_abort_since_bars) and bearish_abort_since_bars <= long_signal_window
bool bearish_abort_lockout = bearish_abort_signal
bool long_confirm_bearish_guard_ok = not use_strict_confirm_guard or (not bearish_abort_signal and not bearish_abort_recent)

string long_zone_text = 'No Long Zone'
if zone_recent
    long_zone_text := 'Zone touched'
if in_bull_fvg_zone
    long_zone_text := 'In FVG Zone'
if in_bull_ob_zone
    long_zone_text := 'In OB Zone'
if in_bull_ob_zone and in_bull_fvg_zone
    long_zone_text := 'In OB + FVG Zone'

string reclaim_text = 'No Reclaim'
if reclaim_recent
    reclaim_text := 'Reclaim recent'
if bull_reclaim_internal_low_strict
    reclaim_text := 'Internal Low Reclaimed'
if bull_reclaim_swing_low_strict
    reclaim_text := 'Swing Low Reclaimed'
if bull_reclaim_fvg_strict
    reclaim_text := 'FVG Reclaimed'
if bull_reclaim_ob_strict
    reclaim_text := 'OB Reclaimed'

float long_invalidation_buffer = ob_threshold_atr * long_invalidation_atr_mult
float prior_long_trigger_level = nz(ta.highest(high, long_confirm_lookback)[1], high)

// --------------------------------------------------
// Long dip state machine
// 1) stored state
// 2) invalidation rules
// 3) arm setup
// 4) confirm setup
// 5) ready state + visual state
// --------------------------------------------------

// 1) Stored state
var bool long_setup_armed = false
var bool long_setup_confirmed = false
var int long_setup_arm_bar_index = na
var int long_confirm_bar_index = na
var float long_setup_trigger = na
var float long_invalidation_level = na
var string long_setup_source = 'None'
var int long_setup_source_id = na
var string long_setup_source_kind = 'None'
var int long_setup_serial = 0
var string long_last_invalid_source = 'None'
var float long_last_invalid_level = na

bool long_arm_signal = false
bool long_confirm_signal = false
bool long_invalidate_signal = false
string long_setup_text = 'No Setup'
int long_visual_state = 0
int long_setup_dashboard_state = 0
string long_visual_text = 'Neutral'
color long_bg_color = na
color long_bar_color = na
string arm_source_text = 'None'
float arm_invalidation_candidate = low
float arm_trigger_candidate = math.max(high, prior_long_trigger_level)
bool long_confirm_break = false
bool internal_choch_since_arm = false
bool internal_bos_since_arm = false
bool long_confirm_structure_ok = false
bool long_internal_structure_ok = false
bool long_building_state = false
bool long_plan_active = false
float long_stop_level = na
float long_risk_r = na
float long_target_1 = na
float long_target_2 = na
int long_setup_source_zone_id = na
bool long_source_tracked = false
bool long_source_alive = true
bool long_source_lost = false
bool armed_source_changed = false

if bull_reclaim_ob_strict
    arm_source_text := 'OB'
    arm_invalidation_candidate := touched_bull_ob_bottom
else if bull_reclaim_fvg_strict
    arm_source_text := 'FVG'
    arm_invalidation_candidate := touched_bull_fvg_bottom
else if bull_reclaim_swing_low_strict
    arm_source_text := 'Swing Low'
    arm_invalidation_candidate := trail_dn
else if bull_reclaim_internal_low_strict
    arm_source_text := 'Internal Low'
    arm_invalidation_candidate := internal_trail_dn

// 2) Invalidation
bool close_safe_mode = live_exec or barstate.isconfirmed
int long_setup_age = long_setup_armed and not na(long_setup_arm_bar_index) ? bar_index - long_setup_arm_bar_index : 0
int long_confirm_age = long_setup_confirmed and not na(long_confirm_bar_index) ? bar_index - long_confirm_bar_index : 0
bool confirm_is_fresh = long_setup_armed and not na(long_setup_arm_bar_index) and long_setup_age <= max_bars_arm_to_confirm
bool ready_is_fresh = long_setup_confirmed and not na(long_confirm_bar_index) and long_confirm_age <= max_bars_confirm_to_ready
long_setup_source_zone_id := long_setup_source_kind == 'OB' ? long_setup_source_id : long_setup_source_kind == 'FVG' ? -long_setup_source_id : na
long_source_tracked := long_setup_source_kind == 'OB' or long_setup_source_kind == 'FVG'
long_source_alive := long_setup_source_kind == 'OB' ? ob_blocks_bull.contains_id(long_setup_source_id) : long_setup_source_kind == 'FVG' ? fvgs_bull.contains_id(long_setup_source_id) : true
long_source_lost := (long_setup_armed or long_setup_confirmed) and long_source_tracked and not long_source_alive
armed_source_changed := long_setup_armed and not long_setup_confirmed and long_source_tracked and not long_source_lost and not na(long_setup_source_zone_id) and not na(active_long_zone_id_safe) and active_long_zone_id_safe != long_setup_source_zone_id
bool long_setup_expired = long_setup_armed and not long_setup_confirmed and long_setup_age >= long_setup_expiry_bars
bool long_confirm_expired = long_setup_confirmed and long_confirm_age >= long_confirm_expiry_bars
float long_invalidation_break_src = live_exec and use_live_invalidation_break ? low : close
bool long_broken_down = not na(long_invalidation_level) and long_invalidation_break_src < long_invalidation_level - long_invalidation_buffer
bool long_invalidated_now = long_source_lost or (close_safe_mode and (long_broken_down or long_setup_expired or long_confirm_expired)) or bearish_abort_signal
bool invalidated_prior_setup = false

if long_invalidated_now
    long_last_invalid_source := long_setup_source
    long_last_invalid_level := long_invalidation_level
    long_invalidate_signal := long_setup_armed or long_setup_confirmed
    invalidated_prior_setup := long_invalidate_signal
    long_setup_armed := false
    long_setup_confirmed := false
    long_setup_arm_bar_index := na
    long_confirm_bar_index := na
    long_setup_trigger := na
    long_invalidation_level := na
    long_setup_source := 'None'
    long_setup_source_id := na
    long_setup_source_kind := 'None'

if armed_source_changed
    long_setup_armed := false
    long_setup_confirmed := false
    long_setup_arm_bar_index := na
    long_confirm_bar_index := na
    long_setup_trigger := na
    long_invalidation_level := na
    long_setup_source := 'None'
    long_setup_source_id := na
    long_setup_source_kind := 'None'

// 3) Arm setup
if bull_reclaim_any_for_arm and (use_strict_sequence ? zone_touch_event_recent : zone_recent) and not long_setup_armed and not bearish_abort_lockout
    long_arm_signal := true
    long_setup_armed := true
    long_setup_confirmed := false
    long_setup_arm_bar_index := bar_index
    long_confirm_bar_index := na
    long_setup_trigger := arm_trigger_candidate
    long_invalidation_level := arm_invalidation_candidate
    long_setup_source := arm_source_text
    long_setup_source_id := arm_source_text == 'OB' ? touched_bull_ob_id : arm_source_text == 'FVG' ? touched_bull_fvg_id : na
    long_setup_source_kind := arm_source_text
    long_setup_serial += 1

// 4) Confirm setup
float long_confirm_break_src = live_exec and use_live_confirm_break ? high : close
bool allow_same_bar_confirm = live_exec
long_confirm_break := long_setup_armed and not long_setup_confirmed and not na(long_setup_arm_bar_index) and (bar_index > long_setup_arm_bar_index or allow_same_bar_confirm) and long_confirm_break_src > long_setup_trigger
internal_choch_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_choch_since_bars) and internal_choch_since_bars <= bar_index - long_setup_arm_bar_index
internal_bos_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_bos_since_bars) and internal_bos_since_bars <= bar_index - long_setup_arm_bar_index
long_internal_structure_ok := long_internal_structure_mode == 'Internal CHoCH only' ? (internal_bull_choch_sig or internal_choch_since_arm) : (internal_bull_choch_sig or internal_bull_bos_sig or internal_choch_since_arm or internal_bos_since_arm)
long_confirm_structure_ok := not require_internal_break_for_confirm
if not long_confirm_structure_ok
    long_confirm_structure_ok := long_internal_structure_ok

// 5) Ready state + visuals
long_plan_active := (long_setup_armed or long_setup_confirmed) and not na(long_setup_trigger) and not na(long_invalidation_level)
float long_planned_stop_level = long_plan_active ? long_invalidation_level - ob_threshold_atr * stop_buffer_atr_mult : na
float nearest_overhead_level = na
if not na(active_bear_ob_break_level) and not na(active_bear_fvg_fill_level)
    nearest_overhead_level := math.min(active_bear_ob_break_level, active_bear_fvg_fill_level)
else
    nearest_overhead_level := not na(active_bear_ob_break_level) ? active_bear_ob_break_level : active_bear_fvg_fill_level
float planned_risk = long_plan_active and not na(long_planned_stop_level) ? math.max(long_setup_trigger - long_planned_stop_level, syminfo.mintick) : na
float headroom_to_overhead = not na(nearest_overhead_level) and long_plan_active ? nearest_overhead_level - long_setup_trigger : na
bool overhead_zone_ok = not use_overhead_zone_filter or na(headroom_to_overhead) or na(planned_risk) or headroom_to_overhead >= planned_risk * min_headroom_r
bool htf_alignment_ok = (mtf_trend_1 > 0 ? 1 : 0) + (mtf_trend_2 > 0 ? 1 : 0) + (mtf_trend_3 > 0 ? 1 : 0) >= 2
int trend_quality_score = 0
trend_quality_score += bullish_trend_safe ? score_weight_structure : 0
trend_quality_score += htf_alignment_ok ? score_weight_htf : 0
trend_quality_score += ema_support_ok ? score_weight_ema : 0
trend_quality_score += adx_strong ? score_weight_adx : 0
trend_quality_score += bull_close_strong ? score_weight_close : 0
trend_quality_score += relvol_ok ? score_weight_relvol : 0
trend_quality_score += market_regime_gate_ok ? score_weight_market : 0
trend_quality_score += vola_regime_gate_safe ? score_weight_vola : 0
int trend_quality_max_score = score_weight_structure + score_weight_htf + score_weight_ema + score_weight_adx + score_weight_close + score_weight_relvol + score_weight_market + score_weight_vola
bool trend_quality_gate_ok = not use_trend_quality_score or trend_quality_score >= min_trend_quality_score
bool long_environment_gate_ok = session_structure_gate_ok and market_regime_gate_ok and vola_regime_gate_safe and trend_quality_gate_ok
bool long_filters_ok = ema_support_ok and adx_strong and relvol_ok and bull_close_strong and vwap_filter_ok and overhead_zone_ok and long_environment_gate_ok
bool long_environment_features_active = use_trade_session_gate or use_opening_range_gate or use_index_gate or use_sector_gate or use_breadth_symbol_gate or use_vola_compression_gate or use_trend_quality_score
string long_environment_focus_display = not long_environment_gate_ok ? not session_structure_gate_ok ? 'Session Block' : not market_regime_gate_ok ? 'Market Block' : not vola_regime_gate_safe ? 'Vola Block' : not trend_quality_gate_ok ? 'Trend Block' : 'Env Blocked' : 'Env OK'
string freshness_text = not long_setup_armed and not long_setup_confirmed ? 'n/a' : long_setup_confirmed ? ready_is_fresh ? 'confirm fresh' : 'confirm stale' : confirm_is_fresh ? 'armed fresh' : 'armed stale'
string source_state_text = not long_source_tracked ? 'n/a' : long_source_alive ? 'source alive' : 'source lost'
string zone_quality_text = not long_zone_active and not long_setup_armed and not long_setup_confirmed ? 'n/a' : active_zone_touch_count <= 1 ? 'fresh touch' : active_zone_touch_count == 2 ? '2nd touch' : 'crowded'
string overhead_text = not use_overhead_zone_filter ? 'off' : na(headroom_to_overhead) or na(planned_risk) ? 'clear' : str.format('{0}R', headroom_to_overhead / planned_risk)
int long_entry_score = 0
long_entry_score += bullish_trend_safe ? 1 : 0
long_entry_score += htf_alignment_ok ? 1 : 0
long_entry_score += long_internal_structure_ok ? 1 : 0
long_entry_score += bull_close_strong ? 1 : 0
long_entry_score += ema_support_ok ? 1 : 0
long_entry_score += adx_strong ? 1 : 0
long_entry_score += relvol_ok ? 1 : 0
long_entry_score += overhead_zone_ok ? 1 : 0
long_entry_score += zone_touch_quality_ok ? 1 : 0
long_entry_score += ready_is_fresh ? 1 : 0
bool entry_score_ok = long_entry_score >= min_entry_score
string long_score_detail_suffix = str.format(' | score={0}/{1}', long_entry_score, min_entry_score)
if close_safe_mode and long_confirm_break and long_confirm_structure_ok and confirm_is_fresh and long_confirm_bearish_guard_ok and (not require_entry_score_for_confirmed or entry_score_ok)
    long_setup_confirmed := true
    long_confirm_bar_index := bar_index
    long_confirm_signal := true

bool long_setup_in_progress = long_setup_armed and not long_setup_confirmed
long_building_state := long_setup_armed and long_internal_structure_ok and not long_setup_confirmed
bool long_ready_state = close_safe_mode and long_setup_confirmed and not long_confirm_expired and ready_is_fresh and long_confirm_bearish_guard_ok and zone_touch_quality_ok and long_filters_ok and (not require_entry_score_for_ready or entry_score_ok) and (not require_main_break_for_ready or bull_bos_sig or main_bos_recent)
if long_plan_active
    long_stop_level := long_planned_stop_level
    long_risk_r := math.max(long_setup_trigger - long_stop_level, syminfo.mintick)
    long_target_1 := long_setup_trigger + long_risk_r * target1_r
    long_target_2 := long_setup_trigger + long_risk_r * target2_r

varip int long_ready_state_rt_prev = 0
if barstate.isnew
    long_ready_state_rt_prev := long_ready_state[1] ? 1 : 0
bool long_ready_signal = long_ready_state and long_ready_state_rt_prev == 0
long_ready_state_rt_prev := long_ready_state ? 1 : 0

long_setup_text := 'No Setup'
if long_zone_active
    long_setup_text := 'In Zone'
if long_setup_armed
    long_setup_text := str.format('Armed | {0}', long_setup_source)
if long_building_state
    long_setup_text := str.format('Building | {0}', long_setup_source)
if long_setup_confirmed
    long_setup_text := str.format('Confirmed | {0}', long_setup_source)
if long_ready_state
    long_setup_text := str.format('Ready | {0}', long_setup_source)

long_visual_state := 0
if long_zone_active
    long_visual_state := 1
if long_setup_armed
    long_visual_state := 2
if long_building_state
    long_visual_state := 3
if long_setup_confirmed
    long_visual_state := 4
if long_ready_state
    long_visual_state := 5
if (long_setup_armed or long_setup_confirmed or long_invalidate_signal or invalidated_prior_setup) and (long_invalidated_now or bearish_abort_signal)
    long_visual_state := -1

bool long_score_soft_block = not entry_score_ok and (long_setup_confirmed or long_ready_state)
long_setup_dashboard_state := long_score_soft_block and long_visual_state > 0 ? 2 : long_visual_state

long_visual_text := status_text(long_visual_state, 'Blocked', 'Neutral', 'In Zone', 'Armed', 'Building', 'Confirmed', 'Long Ready')
if long_score_soft_block
    long_visual_text := long_ready_state ? 'Ready (Score Blocked)' : 'Confirmed (Score Blocked)'

long_bg_color := na
if long_visual_state == -1
    long_bg_color := color.new(color.red, 90)
else if long_visual_state == 1
    long_bg_color := color.new(color.aqua, 92)
else if long_visual_state == 2
    long_bg_color := color.new(color.orange, 88)
else if long_visual_state == 3
    long_bg_color := color.new(long_color_building, 84)
else if long_visual_state == 4
    long_bg_color := color.new(color.lime, 88)
else if long_visual_state == 5
    long_bg_color := color.new(color.green, 82)
if long_score_soft_block and long_visual_state > 0
    long_bg_color := color.new(color.orange, 84)

long_bar_color := na
if long_visual_state == -1
    long_bar_color := color.new(color.red, 0)
else if long_visual_state == 1
    long_bar_color := color.new(color.aqua, 45)
else if long_visual_state == 2
    long_bar_color := color.new(color.orange, 25)
else if long_visual_state == 3
    long_bar_color := color.new(long_color_building, 5)
else if long_visual_state == 4
    long_bar_color := color.new(color.lime, 0)
else if long_visual_state == 5
    long_bar_color := color.new(color.green, 0)
if long_score_soft_block and long_visual_state > 0
    long_bar_color := color.new(color.orange, 0)

if live_exec
    if not live_bull_ob_break and any_live_bull_ob_break
        live_bull_ob_break := true
    if not live_bear_ob_break and any_live_bear_ob_break
        live_bear_ob_break := true
    if not live_bull_fvg_fill and any_live_bull_fvg_fill
        live_bull_fvg_fill := true
    if not live_bear_fvg_fill and any_live_bear_fvg_fill
        live_bear_fvg_fill := true

var int last_reclaim_marker_bar = na
var int last_long_state_marker_bar = na
var int last_long_ready_marker_bar = na
var label[] reclaim_marker_history = array.new<label>(0)
var label[] long_state_marker_history = array.new<label>(0)
var label[] long_ready_marker_history = array.new<label>(0)
if barstate.islast
    trim_label_history(reclaim_marker_history, show_reclaim_markers ? long_marker_history_limit : 0)
    trim_label_history(long_state_marker_history, show_long_confirmation_markers ? long_marker_history_limit : 0)
    trim_label_history(long_ready_marker_history, show_long_confirmation_markers ? long_marker_history_limit : 0)
bool can_draw_reclaim_marker = na(last_reclaim_marker_bar) or effective_reclaim_marker_gap <= 0 or bar_index - last_reclaim_marker_bar >= effective_reclaim_marker_gap
bool can_draw_long_state_marker = na(last_long_state_marker_bar) or effective_confirm_marker_gap <= 0 or bar_index - last_long_state_marker_bar >= effective_confirm_marker_gap
bool can_draw_long_ready_marker = na(last_long_ready_marker_bar) or effective_ready_marker_gap <= 0 or bar_index - last_long_ready_marker_bar >= effective_ready_marker_gap

if show_reclaim_markers and bull_reclaim_ob_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_ob_label = label.new(bar_index, low, TXT_RECLAIM_OB, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    push_capped_label(reclaim_marker_history, reclaim_ob_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_fvg_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_fvg_label = label.new(bar_index, low, TXT_RECLAIM_FVG, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    push_capped_label(reclaim_marker_history, reclaim_fvg_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_swing_low_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_swing_label = label.new(bar_index, low, TXT_RECLAIM_SWING, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    push_capped_label(reclaim_marker_history, reclaim_swing_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_internal_low_strict and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    reclaim_internal_label = label.new(bar_index, low, TXT_RECLAIM_INTERNAL, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.tiny)
    push_capped_label(reclaim_marker_history, reclaim_internal_label, long_marker_history_limit)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

plotshape(show_strict_debug_markers and zone_touch_event, title = 'Zone Touch Event', style = shape.circle, location = location.belowbar, color = color.aqua, size = size.tiny, text = 'ZT')
plotshape(show_strict_debug_markers and bull_ob_real_sweep, title = 'OB Sweep OK', style = shape.circle, location = location.belowbar, color = color.orange, size = size.tiny, text = 'OBS')
plotshape(show_strict_debug_markers and bull_fvg_real_sweep, title = 'FVG Sweep OK', style = shape.circle, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'FVS')
plotshape(show_strict_debug_markers and bull_reclaim_ob_strict, title = 'OB Reclaim Strict', style = shape.triangleup, location = location.belowbar, color = color.orange, size = size.tiny, text = 'ROB')
plotshape(show_strict_debug_markers and bull_reclaim_fvg_strict, title = 'FVG Reclaim Strict', style = shape.triangleup, location = location.belowbar, color = color.yellow, size = size.tiny, text = 'RFV')
plotshape(show_strict_debug_markers and long_confirm_break and not long_confirm_bearish_guard_ok, title = 'Confirm Blocked By Bearish Abort', style = shape.xcross, location = location.abovebar, color = color.red, size = size.tiny, text = 'XCONF')

if show_long_confirmation_markers and internal_bull_choch_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    int_reversal_label = label.new(bar_index, high, TXT_INT_REVERSAL, color = #00000000, textcolor = long_color_reversal, style = label.style_label_down, size = size.tiny)
    push_capped_label(long_state_marker_history, int_reversal_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and internal_bull_bos_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    int_break_label = label.new(bar_index, high, TXT_INT_BREAK, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.tiny)
    push_capped_label(long_state_marker_history, int_break_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and bull_bos_sig and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    trend_confirm_label = label.new(bar_index, high, TXT_TREND_CONFIRM, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    push_capped_label(long_state_marker_history, trend_confirm_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_arm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    long_armed_label = label.new(bar_index, low, TXT_LONG_ARMED, color = #00000000, textcolor = long_color_zone, style = label.style_label_up, size = size.small)
    push_capped_label(long_state_marker_history, long_armed_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_confirm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    long_confirmed_label = label.new(bar_index, high, TXT_LONG_CONFIRMED, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.small)
    push_capped_label(long_state_marker_history, long_confirmed_label, long_marker_history_limit)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_ready_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    long_ready_label = label.new(bar_index, high, TXT_LONG_READY, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    push_capped_label(long_ready_marker_history, long_ready_label, long_marker_history_limit)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_long_confirmation_markers and long_invalidate_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    long_invalidated_label = label.new(bar_index, high, TXT_LONG_INVALIDATED, color = #00000000, textcolor = long_color_invalid, style = label.style_label_down, size = size.tiny)
    push_capped_label(long_ready_marker_history, long_invalidated_label, long_marker_history_limit)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_htf_fvg and barstate.islast
    htf_fvg_buffer_bull.draw(htf_fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    htf_fvg_buffer_bear.draw(htf_fvg_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if htf_fvg_keep_filled and htf_fvg_keep_filled_max > 0
        htf_fvg_buffer_bull_filled.draw(htf_fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
        htf_fvg_buffer_bear_filled.draw(htf_fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        htf_fvg_buffer_bull_filled.delete()
        htf_fvg_buffer_bear_filled.delete()

    if barstate.isconfirmed
        htf_fvg_buffer_bull_discarded.delete()
        htf_fvg_buffer_bull_discarded.clear()
        htf_fvg_buffer_bear_discarded.delete()
        htf_fvg_buffer_bear_discarded.clear()

var g_eq = 'Equal Highs / Lows'
var show_eq = input.bool(false, 'Equal High / Low', group = g_eq, tooltip = SHOW_EQHL)
var eq_len = input.int(3, 'Bars Confirmation', minval = 1, group = g_eq, tooltip = EQHL_BARS)
var eq_threshold_in = input.float(0.1, 'Threshold', minval = 0, maxval = 0.5, step = 0.1, group = g_eq, tooltip = EQHL_THRESHOLD)

eq_atr = nd_atr(ATR_LEN_MAIN)
eq_threshold = eq_threshold_in * eq_atr
[eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_levels(eq_len, eq_threshold, enabled = show_eq)

LabelArgs eqh_label_args = LabelArgs.new(bear_css, #00000000, style = label.style_label_down, size = size.tiny)
LineArgs eqh_line_args = LineArgs.new(bear_css, line.style_dotted)
LabelArgs eql_label_args = LabelArgs.new(bull_css, #00000000, style = label.style_label_up, size = size.tiny)
LineArgs eql_line_args = LineArgs.new(bull_css, line.style_dotted)

plot_equal_level(show_eq and eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, 'EQH', eqh_label_args, eqh_line_args, keep_history = keep_visual_history, force_overlay = false)
plot_equal_level(show_eq and eql_alert, eql_x1, eql_y1, eql_x2, eql_y2, 'EQL', eql_label_args, eql_line_args, keep_history = keep_visual_history, force_overlay = false)

// =====================
// Dashboard state + rendering
// =====================
dashboard_counts_active = show_dashboard and show_dashboard_counts
bool use_visible_window = render_visible_only and not na(visible_left_time) and not na(visible_right_time)
int visible_bull_obs = 0
int visible_bear_obs = 0
int visible_bull_fvgs = 0
int visible_bear_fvgs = 0
if dashboard_counts_active
    visible_bull_obs := use_visible_window ? count_visible_obs(ob_blocks_bull, visible_left_time, visible_right_time, ob_extend_until_broken) : ob_blocks_bull.size()
    visible_bear_obs := use_visible_window ? count_visible_obs(ob_blocks_bear, visible_left_time, visible_right_time, ob_extend_until_broken) : ob_blocks_bear.size()
    visible_bull_fvgs := use_visible_window ? count_visible_fvgs(fvgs_bull, visible_left_time, visible_right_time, fvg_extend_until_filled) : fvgs_bull.size()
    visible_bear_fvgs := use_visible_window ? count_visible_fvgs(fvgs_bear, visible_left_time, visible_right_time, fvg_extend_until_filled) : fvgs_bear.size()
htf_bull_count = (mtf_trend_1 > 0 ? 1 : 0) + (mtf_trend_2 > 0 ? 1 : 0) + (mtf_trend_3 > 0 ? 1 : 0)
htf_bear_count = (mtf_trend_1 < 0 ? 1 : 0) + (mtf_trend_2 < 0 ? 1 : 0) + (mtf_trend_3 < 0 ? 1 : 0)
int trend_state = structure_display_trend > 0 ? 5 : structure_display_trend < 0 ? -1 : 0
int htf_state = not show_mtf_trend ? 0 : htf_bull_count == 3 ? 5 : htf_bear_count == 3 ? -1 : htf_bull_count >= 2 ? 4 : htf_bear_count >= 2 ? 1 : 2
int zone_state = in_bull_ob_zone or in_bull_fvg_zone ? 4 : zone_recent ? 2 : 0
int reclaim_state = bull_reclaim_any ? 4 : reclaim_recent ? 2 : 0
int close_state = not use_strong_close_filter ? 0 : bull_close_strong ? 5 : 2
int ema_state = not show_ema_support ? 0 : ema_support_ok ? 5 : -1
int adx_state = not use_adx ? 0 : not adx_data_ok ? 0 : plus_di < minus_di ? -1 : adx_value < adx_trend_min ? 0 : adx_value < adx_strong_min ? 3 : 5
int relvol_state = not use_rel_volume ? 0 : not volume_data_ok ? allow_relvol_without_volume_data ? 3 : -1 : na(rel_volume) ? 0 : rel_volume >= relvol_good ? 5 : rel_volume >= 1.0 ? 2 : -1
int vwap_state = not use_vwap_filter ? 0 : not intraday_time_chart ? 0 : not vwap_session_active ? 0 : vwap_filter_ok ? 5 : -1
int volume_quality_state = use_ltf_for_strict_entry ? strict_ltf_available ? 5 : allow_strict_entry_without_ltf ? 3 : -1 : volume_data_ok ? 5 : allow_relvol_without_volume_data ? 3 : -1
int ltf_bias_state = not show_dashboard_ltf ? 0 : not enable_ltf_sampling ? 0 : not ltf_timeframe_valid ? 0 : not ltf_ratio_ok or not ltf_sample_count_ok ? -1 : na(ltf_bull_share) ? 0 : ltf_bull_share >= 0.60 ? 5 : ltf_bull_share >= ltf_bias_hint ? 4 : ltf_bull_share >= 0.50 ? 2 : -1
int ltf_delta_state = not show_dashboard_ltf ? 0 : not enable_ltf_sampling ? 0 : not ltf_timeframe_valid ? 0 : not ltf_ratio_ok or not ltf_sample_count_ok ? -1 : na(ltf_volume_delta) ? 0 : ltf_volume_delta >= 0.15 ? 5 : ltf_volume_delta >= 0 ? 4 : -1
int objects_state = not show_dashboard_counts ? 0 : (visible_bull_obs + visible_bull_fvgs) > 0 ? 4 : 0
int risk_state = long_plan_active ? 4 : 0
int quality_state = long_source_lost ? -1 : not zone_touch_quality_ok or not overhead_zone_ok ? 1 : long_setup_armed or long_setup_confirmed ? 4 : 0
int session_gate_state = not use_trade_session_gate and not use_opening_range_gate ? 0 : session_structure_gate_ok ? 5 : not session_gate_ok ? -1 : opening_range_ready ? -1 : 1
int market_gate_state = not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate ? 0 : market_regime_gate_ok ? 5 : market_symbols_missing and not block_on_missing_market_symbol ? 2 : -1
int vola_gate_state = not use_vola_compression_gate ? 0 : vola_regime_gate_safe ? 5 : vola_compression_recent ? 2 : 1
int trend_quality_state = not use_trend_quality_score ? 0 : trend_quality_gate_ok ? 5 : 2
bool strict_flow_active = use_strict_sequence or use_strict_sweep_for_zone_reclaim or use_strict_confirm_guard
bool strict_sequence_waiting = use_strict_sequence and not zone_touch_event_recent
bool strict_sweep_ok = long_setup_source_kind == 'OB' ? bull_ob_real_sweep : long_setup_source_kind == 'FVG' ? bull_fvg_real_sweep : bull_reclaim_ob_strict or bull_reclaim_fvg_strict or bull_reclaim_internal_low_strict or bull_reclaim_swing_low_strict
bool strict_sweep_blocked = use_strict_sweep_for_zone_reclaim and (long_setup_source_kind == 'OB' or long_setup_source_kind == 'FVG') and not strict_sweep_ok
bool strict_guard_blocked = use_strict_confirm_guard and not long_confirm_bearish_guard_ok
int entry_score_state = entry_score_ok ? long_entry_score >= 9 ? 5 : 4 : long_entry_score >= math.max(min_entry_score - 1, 1) ? 2 : -1
string trend_display = trend_state == 5 ? 'Bullish' : trend_state == -1 ? 'Bearish' : 'Neutral'
string htf_display = not show_mtf_trend ? 'Off' : str.format('{0}:{1}\n{2}:{3}\n{4}:{5}', mtf_trend_tf1, trend_text_or_na(mtf_trend_1), mtf_trend_tf2, trend_text_or_na(mtf_trend_2), mtf_trend_tf3, trend_text_or_na(mtf_trend_3))
string zone_display = long_zone_text
string reclaim_display = reclaim_text
bool long_visual_environment_blocked = long_environment_features_active and not long_environment_gate_ok and long_visual_state > 0
string long_visual_display = long_visual_environment_blocked ? str.format('{0} | {1}', long_visual_text, long_environment_focus_display) : long_visual_text
string close_display = close_state_text
string ema_display = ema_state_text
string adx_display = not use_adx ? 'Off' : str.format('{0,number,#.#} | {1}', adx_value, adx_state_text)
string relvol_display = relvol_text
string vwap_display = vwap_state_text
string session_gate_display = not use_trade_session_gate and not use_opening_range_gate ? 'Off' : not intraday_time_chart ? 'n/a' : not session_gate_ok ? 'Out of Session' : not use_opening_range_gate ? 'OK' : not opening_range_ready ? 'OR Pending' : opening_range_gate_ok ? 'OK' : opening_range_bias_mode == 'Above OR High' ? 'Below OR High' : 'Below OR Mid'
string market_gate_display = not use_index_gate and not use_sector_gate and not use_breadth_symbol_gate ? 'Off' : market_symbols_missing ? block_on_missing_market_symbol ? 'Missing/Blocked' : 'Missing/Ignored' : market_regime_gate_ok ? 'Risk-On' : 'Blocked'
string vola_gate_display = not use_vola_compression_gate ? 'Off' : vola_compression_recent ? vola_expansion_now ? 'Compression -> Expansion' : 'Compression Only' : 'No Compression'
string trend_quality_display = not use_trend_quality_score ? 'Off' : str.format('{0}/{1}\nMin {2}\n{3}', trend_quality_score, trend_quality_max_score, min_trend_quality_score, trend_quality_gate_ok ? 'OK' : 'Blocked')
string strict_ltf_display = not use_ltf_for_strict_entry ? 'Off' : strict_ltf_available ? 'OK' : allow_strict_entry_without_ltf ? 'Fallback' : not enable_ltf_sampling ? 'Off' : not ltf_timeframe_valid ? 'n/a' : not ltf_ratio_ok or not ltf_sample_count_ok ? 'Guarded' : not volume_data_ok ? 'No Vol' : 'Blocked'
string volume_quality_display = str.format('{0}\nStrict {1}', volume_data_ok ? 'OK' : 'Limited', strict_ltf_display)
string ltf_bias_display = not show_dashboard_ltf ? 'Hidden' : not enable_ltf_sampling ? 'Off' : not ltf_timeframe_valid ? 'n/a' : not ltf_ratio_ok or not ltf_sample_count_ok ? 'Guarded' : na(ltf_bull_share) ? 'n/a' : str.format('{0,number,percent}', ltf_bull_share)
string ltf_delta_display = not show_dashboard_ltf ? 'Hidden' : not enable_ltf_sampling ? 'Off' : not ltf_timeframe_valid ? 'n/a' : not ltf_ratio_ok or not ltf_sample_count_ok ? 'Guarded' : na(ltf_volume_delta) ? 'n/a' : str.format('{0,number,percent}', ltf_volume_delta)
string objects_display = not show_dashboard_counts ? 'Hidden' : str.format('OB {0}/{1}\nFVG {2}/{3}', visible_bull_obs, visible_bear_obs, visible_bull_fvgs, visible_bear_fvgs)
string setup_age_display = not show_dashboard_setup_age ? 'Hidden' : long_setup_confirmed ? str.format('confirmed {0}', long_confirm_age) : long_setup_armed ? str.format('armed {0}', long_setup_age) : 'n/a'
string setup_quality_display = str.format('{0}\n{1}\n{2}\nEnv {3}\nHeadroom {4}', freshness_text, source_state_text, zone_quality_text, long_environment_focus_display, overhead_text)
string strict_sequence_display = not use_strict_sequence ? 'off' : zone_touch_event_recent ? 'zone ok' : 'wait zone'
string strict_sweep_display = not use_strict_sweep_for_zone_reclaim ? 'off' : long_setup_source_kind == 'OB' ? strict_sweep_ok ? 'OB ok' : 'OB miss' : long_setup_source_kind == 'FVG' ? strict_sweep_ok ? 'FVG ok' : 'FVG miss' : strict_sweep_ok ? 'ok' : 'n/a'
string strict_guard_display = not use_strict_confirm_guard ? 'off' : long_confirm_bearish_guard_ok ? 'guard ok' : 'bear abort'
string strict_flow_focus_display = not strict_flow_active ? 'off' : strict_guard_blocked ? 'Bear Abort' : strict_sweep_blocked ? 'Sweep Miss' : strict_sequence_waiting ? 'Waiting Zone' : 'Strict OK'
bool long_setup_strict_blocked = strict_flow_active and strict_flow_focus_display != 'off' and strict_flow_focus_display != 'Strict OK' and long_visual_state > 0
bool long_setup_environment_blocked = long_environment_features_active and not long_environment_gate_ok and long_visual_state > 0
string long_setup_context_suffix = long_setup_strict_blocked ? strict_flow_focus_display : ''
if long_setup_environment_blocked
    long_setup_context_suffix := str.length(long_setup_context_suffix) > 0 ? str.format('{0} | {1}', long_setup_context_suffix, long_environment_focus_display) : long_environment_focus_display
string long_setup_display = str.length(long_setup_context_suffix) > 0 ? str.format('{0} | {1}', long_setup_text, long_setup_context_suffix) : long_setup_text
string long_strict_alert_suffix = strict_flow_active ? str.format(' | strict={0}', strict_flow_focus_display) : ''
string long_environment_alert_suffix = long_environment_features_active ? str.format(' | env={0}', long_environment_focus_display) : ''
string strict_flow_display = str.format('State {0}\nZone {1}\nSweep {2}\nGuard {3}', strict_flow_focus_display, strict_sequence_display, strict_sweep_display, strict_guard_display)
string entry_score_display = str.format('{0}/10\nMin {1}\n{2}', long_entry_score, min_entry_score, entry_score_ok ? 'Actionable' : 'Blocked')
string dashboard_swing_levels_display = str.format('Swing {0}/{1}\nInt {2}/{3}', format_level(trail_up), format_level(trail_dn), show_internals ? format_level(internal_trail_up) : 'Off', show_internals ? format_level(internal_trail_dn) : 'Off')
string dashboard_long_zones_display = str.format('OB {0}/{1}\nFVG {2}/{3}', format_level(not na(active_bull_ob_top) ? active_bull_ob_top : last_bull_ob_top), format_level(not na(active_bull_ob_bottom) ? active_bull_ob_bottom : last_bull_ob_bottom), format_level(not na(active_bull_fvg_top) ? active_bull_fvg_top : last_bull_fvg_top), format_level(not na(active_bull_fvg_bottom) ? active_bull_fvg_bottom : last_bull_fvg_bottom))
string dashboard_long_triggers_display = str.format('OB mid {0}\nFVG fill {1}\nInvalid {2}', format_level(not na(active_bull_ob_break_level) ? active_bull_ob_break_level : last_bull_ob_break_level), format_level(not na(active_bull_fvg_fill_level) ? active_bull_fvg_fill_level : last_bull_fvg_fill_level), format_level(long_invalidation_level))
string risk_display = not long_plan_active ? 'n/a' : str.format('Trig {0}\nStop {1}\nT1 {2}\nT2 {3}', format_level(long_setup_trigger), format_level(long_stop_level), format_level(long_target_1), format_level(long_target_2))
int ob_zone_state = not na(active_bull_ob_top) ? 4 : not na(last_bull_ob_top) ? 2 : 0
int fvg_zone_state = not na(active_bull_fvg_top) ? 4 : not na(last_bull_fvg_top) ? 2 : 0
int long_zones_state = math.max(ob_zone_state, fvg_zone_state)
string dashboard_legend_display = 'Zone: Aqua\nArmed: Orange\nBuilding: Gold\nConfirm: Lime\nReady: Green\nFail: Red'
color dashboard_header_bg = color.new(color.black, 100)
color dashboard_text = chart.fg_color
color dashboard_long_text = long_visual_state == 3 ? long_dashboard_building_text : dashboard_text
color dashboard_long_visual_bg = long_visual_environment_blocked ? long_environment_focus_display == 'Session Block' ? color.new(color.blue, 72) : long_environment_focus_display == 'Market Block' ? color.new(color.red, 75) : long_environment_focus_display == 'Vola Block' ? color.new(color.orange, 72) : long_environment_focus_display == 'Trend Block' ? color.new(color.yellow, 68) : status_bg(long_visual_state) : status_bg(long_visual_state)
color dashboard_setup_quality_bg = not long_environment_features_active or long_environment_gate_ok ? status_bg(quality_state) : long_environment_focus_display == 'Session Block' ? color.new(color.blue, 72) : long_environment_focus_display == 'Market Block' ? color.new(color.red, 75) : long_environment_focus_display == 'Vola Block' ? color.new(color.orange, 72) : long_environment_focus_display == 'Trend Block' ? color.new(color.yellow, 68) : status_bg(quality_state)
color dashboard_swing_bg = color.new(color.silver, 88)
color dashboard_trigger_bg = color.new(color.black, 100)
color dashboard_risk_bg = color.new(color.black, 92)
color dashboard_legend_bg = color.new(color.black, 88)
color dashboard_setup_age_bg = color.new(color.silver, 88)
color dashboard_strict_flow_bg = not strict_flow_active ? status_bg(0) : strict_guard_blocked ? color.new(color.red, 75) : strict_sweep_blocked ? color.new(color.orange, 72) : strict_sequence_waiting ? color.new(color.aqua, 80) : color.new(color.lime, 72)
var table smc_dashboard = table.new(position.bottom_right, 2, 29, border_width = 0)

if show_dashboard and barstate.islast
    dashboard_row(smc_dashboard, 0, 'SMC++', signal_mode_text, dashboard_header_bg, dashboard_text)
    dashboard_row(smc_dashboard, 1, 'Trend', trend_display, status_bg(trend_state), dashboard_text)
    dashboard_row(smc_dashboard, 2, 'HTF Trend', htf_display, status_bg(htf_state), dashboard_text)
    dashboard_row(smc_dashboard, 3, 'Pullback Zone', zone_display, status_bg(zone_state), dashboard_text)
    dashboard_row(smc_dashboard, 4, 'Reclaim', reclaim_display, status_bg(reclaim_state), dashboard_text)
    dashboard_row(smc_dashboard, 5, 'Long Setup', long_setup_display, status_bg(long_setup_dashboard_state), dashboard_long_text)
    dashboard_row(smc_dashboard, 6, 'Setup Age', setup_age_display, dashboard_setup_age_bg, dashboard_text)
    dashboard_row(smc_dashboard, 7, 'Long Visual', long_visual_display, dashboard_long_visual_bg, dashboard_long_text)
    dashboard_row(smc_dashboard, 8, 'Close Strength', close_display, status_bg(close_state), dashboard_text)
    dashboard_row(smc_dashboard, 9, 'EMA Support', ema_display, status_bg(ema_state), dashboard_text)
    dashboard_row(smc_dashboard, 10, 'ADX', adx_display, status_bg(adx_state), dashboard_text)
    dashboard_row(smc_dashboard, 11, 'Rel Volume', relvol_display, status_bg(relvol_state), dashboard_text)
    dashboard_row(smc_dashboard, 12, 'VWAP Filter', vwap_display, status_bg(vwap_state), dashboard_text)
    dashboard_row(smc_dashboard, 13, 'Volume Data', volume_quality_display, status_bg(volume_quality_state), dashboard_text)
    dashboard_row(smc_dashboard, 14, 'LTF Bias', ltf_bias_display, status_bg(ltf_bias_state), dashboard_text)
    dashboard_row(smc_dashboard, 15, 'LTF Delta', ltf_delta_display, status_bg(ltf_delta_state), dashboard_text)
    dashboard_row(smc_dashboard, 16, 'Objects', objects_display, status_bg(objects_state), dashboard_text)
    dashboard_row(smc_dashboard, 17, 'Swing H/L', dashboard_swing_levels_display, dashboard_swing_bg, dashboard_text)
    dashboard_row(smc_dashboard, 18, 'Long Zones', dashboard_long_zones_display, status_bg(long_zones_state), dashboard_text)
    dashboard_row(smc_dashboard, 19, 'Long Triggers', dashboard_long_triggers_display, dashboard_trigger_bg, dashboard_text)
    dashboard_row(smc_dashboard, 20, 'Setup Quality', setup_quality_display, dashboard_setup_quality_bg, dashboard_text)
    dashboard_row(smc_dashboard, 21, 'Strict Flow', strict_flow_display, dashboard_strict_flow_bg, dashboard_text)
    dashboard_row(smc_dashboard, 22, 'Entry Score', entry_score_display, status_bg(entry_score_state), dashboard_text)
    dashboard_row(smc_dashboard, 23, 'Session', session_gate_display, status_bg(session_gate_state), dashboard_text)
    dashboard_row(smc_dashboard, 24, 'Market Gate', market_gate_display, status_bg(market_gate_state), dashboard_text)
    dashboard_row(smc_dashboard, 25, 'Vola Regime', vola_gate_display, status_bg(vola_gate_state), dashboard_text)
    dashboard_row(smc_dashboard, 26, 'Trend Quality', trend_quality_display, status_bg(trend_quality_state), dashboard_text)
    dashboard_row(smc_dashboard, 27, 'Risk Plan', risk_display, risk_state > 0 ? dashboard_risk_bg : status_bg(risk_state), dashboard_text)
    dashboard_row(smc_dashboard, 28, 'Legend', dashboard_legend_display, dashboard_legend_bg, dashboard_text)
else if barstate.islast
    table.clear(smc_dashboard, 0, 0, 1, 28)

bgcolor(show_long_background ? long_bg_color : na, title = 'Long-only Background')
barcolor(color_long_bars ? long_bar_color : na)
plot(show_risk_levels and long_plan_active ? long_setup_trigger : na, 'Long Trigger', color = color.new(color.aqua, 0), linewidth = 2, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_invalidation_level : na, 'Long Invalidation', color = color.new(color.orange, 0), linewidth = 1, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_stop_level : na, 'Long Stop', color = color.new(color.red, 0), linewidth = 2, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_target_1 : na, 'Long Target 1', color = color.new(color.lime, 0), linewidth = 1, style = plot.style_linebr)
plot(show_risk_levels and long_plan_active ? long_target_2 : na, 'Long Target 2', color = color.new(color.green, 0), linewidth = 1, style = plot.style_linebr)

// --------------------------------------------------
// Long-dip alert presets
// --------------------------------------------------
alert_long_watchlist = bullish_trend_safe and long_zone_active_safe
alert_long_armed = bullish_trend_safe and zone_recent and reclaim_recent and long_setup_in_progress
alert_long_early = bullish_trend_safe and long_setup_in_progress and zone_recent and reclaim_recent and long_internal_structure_ok and bull_close_strong and ema_support_ok
alert_long_clean = close_safe_mode and bullish_trend_safe and zone_recent and reclaim_recent and long_setup_confirmed and bull_close_strong and ema_support_ok and adx_strong and relvol_ok and vwap_filter_ok
alert_long_entry_best = close_safe_mode and bullish_trend_safe and reclaim_recent and long_ready_state and bull_close_strong and ema_support_ok and vwap_filter_ok and long_environment_gate_ok and entry_score_ok
bool strict_entry_ltf_ok = not use_ltf_for_strict_entry or (strict_ltf_available and ltf_volume_delta >= 0) or (allow_strict_entry_without_ltf and strict_ltf_unavailable)
float long_watchlist_alert_level = not na(active_bull_ob_bottom) ? active_bull_ob_bottom : not na(active_bull_fvg_bottom) ? active_bull_fvg_bottom : not na(last_bull_ob_bottom) ? last_bull_ob_bottom : not na(last_bull_fvg_bottom) ? last_bull_fvg_bottom : low
float long_early_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_clean_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_entry_best_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
float long_entry_strict_alert_level = not na(long_setup_trigger) ? long_setup_trigger : long_watchlist_alert_level
alert_long_entry_strict = close_safe_mode and bullish_trend_safe and htf_bull_count >= 2 and zone_recent and reclaim_recent and long_ready_state and bull_close_strong and ema_support_ok and adx_strong and relvol_ok and vwap_filter_ok and strict_entry_ltf_ok and long_environment_gate_ok and entry_score_ok
alert_long_fail = long_invalidate_signal
var int long_watchlist_serial = 0
varip int long_watchlist_rt_prev_active = 0
varip int long_watchlist_rt_prev_id = na
if barstate.isnew
    long_watchlist_rt_prev_active := alert_long_watchlist[1] ? 1 : 0
    long_watchlist_rt_prev_id := active_long_zone_id_safe[1]
bool long_watchlist_source_changed = alert_long_watchlist and (long_watchlist_rt_prev_active == 0 or active_long_zone_id_safe != long_watchlist_rt_prev_id)
long_watchlist_rt_prev_active := alert_long_watchlist ? 1 : 0
long_watchlist_rt_prev_id := active_long_zone_id_safe
if long_watchlist_source_changed
    long_watchlist_serial += 1
var int last_long_armed_alert_serial = na
var int last_long_early_alert_serial = na
var int last_long_clean_alert_serial = na
var int last_long_entry_best_alert_serial = na
var int last_long_entry_strict_alert_serial = na
bool alert_long_watchlist_event = long_watchlist_source_changed and long_watchlist_serial > 0
bool alert_long_armed_event = alert_long_armed and long_setup_serial > 0 and last_long_armed_alert_serial != long_setup_serial
if alert_long_armed_event
    last_long_armed_alert_serial := long_setup_serial
bool alert_long_early_event = alert_long_early and long_setup_serial > 0 and last_long_early_alert_serial != long_setup_serial
if alert_long_early_event
    last_long_early_alert_serial := long_setup_serial
bool alert_long_clean_event = alert_long_clean and long_setup_serial > 0 and last_long_clean_alert_serial != long_setup_serial
if alert_long_clean_event
    last_long_clean_alert_serial := long_setup_serial
bool alert_long_entry_best_event = alert_long_entry_best and long_setup_serial > 0 and last_long_entry_best_alert_serial != long_setup_serial
if alert_long_entry_best_event
    last_long_entry_best_alert_serial := long_setup_serial
bool alert_long_entry_strict_event = alert_long_entry_strict and long_setup_serial > 0 and last_long_entry_strict_alert_serial != long_setup_serial
if alert_long_entry_strict_event
    last_long_entry_strict_alert_serial := long_setup_serial
bool bull_ob_broken_event = ob_broken_new_bull.size() > 0
bool bear_ob_broken_event = ob_broken_new_bear.size() > 0

varip bool long_arm_signal_latched = false
varip bool long_confirm_signal_latched = false
varip bool long_ready_signal_latched = false
varip bool long_invalidate_signal_latched = false
varip bool bull_ob_broken_event_latched = false
varip bool bear_ob_broken_event_latched = false
varip bool bull_fvg_filled_event_latched = false
varip bool bear_fvg_filled_event_latched = false
varip bool live_bull_ob_break_latched = false
varip bool live_bear_ob_break_latched = false
varip bool live_bull_fvg_fill_latched = false
varip bool live_bear_fvg_fill_latched = false
varip bool long_dynamic_alert_sent = false

if barstate.isnew
    long_arm_signal_latched := false
    long_confirm_signal_latched := false
    long_ready_signal_latched := false
    long_invalidate_signal_latched := false
    bull_ob_broken_event_latched := false
    bear_ob_broken_event_latched := false
    bull_fvg_filled_event_latched := false
    bear_fvg_filled_event_latched := false
    live_bull_ob_break_latched := false
    live_bear_ob_break_latched := false
    live_bull_fvg_fill_latched := false
    live_bear_fvg_fill_latched := false
    long_dynamic_alert_sent := false

if live_exec ? long_arm_signal : barstate.isconfirmed and long_arm_signal
    long_arm_signal_latched := true
if live_exec ? long_confirm_signal : barstate.isconfirmed and long_confirm_signal
    long_confirm_signal_latched := true
if live_exec ? long_ready_signal : barstate.isconfirmed and long_ready_signal
    long_ready_signal_latched := true
if live_exec ? long_invalidate_signal : barstate.isconfirmed and long_invalidate_signal
    long_invalidate_signal_latched := true
if bull_ob_broken_event
    bull_ob_broken_event_latched := true
if bear_ob_broken_event
    bear_ob_broken_event_latched := true
if bullish_fvg_filled_alert
    bull_fvg_filled_event_latched := true
if bearish_fvg_filled_alert
    bear_fvg_filled_event_latched := true
if live_bull_ob_break
    live_bull_ob_break_latched := true
if live_bear_ob_break
    live_bear_ob_break_latched := true
if live_bull_fvg_fill
    live_bull_fvg_fill_latched := true
if live_bear_fvg_fill
    live_bear_fvg_fill_latched := true

bool long_arm_close_safe = barstate.isconfirmed and long_setup_armed and not long_setup_armed[1]
bool long_confirm_close_safe = barstate.isconfirmed and long_setup_confirmed and not long_setup_confirmed[1]
bool long_ready_close_safe = barstate.isconfirmed and long_ready_state and not long_ready_state[1]
bool long_invalidated_close_safe = barstate.isconfirmed and not long_setup_armed and not long_setup_confirmed and (long_setup_armed[1] or long_setup_confirmed[1])

// Alerts use clearer wording but keep the same underlying trigger logic.
alertcondition(long_arm_signal_latched, 'Long Armed', 'SMC++: long setup armed after reclaim and zone confirmation.')
alertcondition(long_confirm_signal_latched, 'Long Confirmed', 'SMC++: long setup confirmed after trigger break and internal structure confirmation, with strict-flow and environment-gate context plus optional score gating.')
alertcondition(long_ready_signal_latched, 'Long Ready', 'SMC++: long setup is ready with filters aligned, with strict-flow and environment-gate context plus optional score gating.')
alertcondition(long_invalidate_signal_latched, 'Long Invalidated', 'SMC++: long setup was invalidated.')
alertcondition(long_arm_close_safe, 'Long Armed (Close Safe)', 'SMC++: long setup remained armed into the confirmed close.')
alertcondition(long_confirm_close_safe, 'Long Confirmed (Close Safe)', 'SMC++: long setup remained confirmed at bar close, with environment-gate context and optional score gating.')
alertcondition(long_ready_close_safe, 'Long Ready (Close Safe)', 'SMC++: long setup remained ready at bar close, with environment-gate context and optional score gating.')
alertcondition(long_invalidated_close_safe, 'Long Invalidated (Close Safe)', 'SMC++: long setup ended invalidated at bar close.')
alertcondition(alert_long_watchlist_event, 'Long Dip Watchlist', 'SMC++: bullish trend with active pullback zone.')
alertcondition(alert_long_armed_event, 'Long Dip Armed+', 'SMC++: strict reclaim qualified and long setup armed.')
alertcondition(alert_long_early_event, 'Long Dip Early', 'SMC++: early bullish long-dip hint with strict reclaim qualification and internal confirmation.')
alertcondition(alert_long_clean_event, 'Long Dip Clean', 'SMC++: clean long-dip setup confirmed, with environment-gate context.')
alertcondition(alert_long_entry_best_event, 'Long Dip Entry Best', 'SMC++: best standard long-dip entry condition.')
alertcondition(alert_long_entry_strict_event, 'Long Dip Entry Strict', 'SMC++: strict long-dip entry with HTF and momentum alignment.')
alertcondition(long_invalidate_signal_latched, 'Long Dip Failed', 'SMC++: long-dip setup invalidated.')
alertcondition(bull_bos_sig, 'Bullish BOS Detected', 'SMC++: bullish break of structure detected.')
alertcondition(bull_choch_sig, 'Bullish CHoCH Detected', 'SMC++: bullish change of character detected.')
alertcondition(bear_bos_sig, 'Bearish BOS Detected', 'SMC++: bearish break of structure detected.')
alertcondition(bear_choch_sig, 'Bearish CHoCH Detected', 'SMC++: bearish change of character detected.')
alertcondition(bull_ob_broken_event_latched, 'Bullish Order Block Broken', 'SMC++: price broke a bullish order block.')
alertcondition(bear_ob_broken_event_latched, 'Bearish Order Block Broken', 'SMC++: price broke a bearish order block.')
alertcondition(eqh_alert, 'Equal Highs Detected', 'SMC++: equal highs detected.')
alertcondition(eql_alert, 'Equal Lows Detected', 'SMC++: equal lows detected.')
alertcondition(bullish_fvg_alert, 'Bullish FVG Formed', 'SMC++: bullish fair value gap formed.')
alertcondition(bearish_fvg_alert, 'Bearish FVG Formed', 'SMC++: bearish fair value gap formed.')
alertcondition(bull_fvg_filled_event_latched, 'Bullish FVG Filled', 'SMC++: bullish fair value gap filled.')
alertcondition(bear_fvg_filled_event_latched, 'Bearish FVG Filled', 'SMC++: bearish fair value gap filled.')
alertcondition(live_bull_ob_break_latched, 'Bullish OB Live Break', 'SMC++: intrabar bullish order block break detected.')
alertcondition(live_bear_ob_break_latched, 'Bearish OB Live Break', 'SMC++: intrabar bearish order block break detected.')
alertcondition(live_bull_fvg_fill_latched, 'Bullish FVG Live Fill', 'SMC++: intrabar bullish fair value gap fill detected.')
alertcondition(live_bear_fvg_fill_latched, 'Bearish FVG Live Fill', 'SMC++: intrabar bearish fair value gap fill detected.')
alertcondition(bullish_trend_started, 'Bullish Trend Started', 'SMC++: structure trend turned bullish.')
alertcondition(bearish_trend_started, 'Bearish Trend Started', 'SMC++: structure trend turned bearish.')
alertcondition(directional_trend_started, 'Trend Direction Changed', 'SMC++: structure trend turned directional.')

varip string dynamic_alert_seen_keys = ''

if barstate.isnew
    dynamic_alert_seen_keys := ''

if enable_dynamic_alerts and bull_bos_sig and not str.contains(dynamic_alert_seen_keys, '|bull_bos|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bull_bos|'
    alert(build_dynamic_alert_message(true, true, 'Bullish BOS', 'Structure break confirmed', top, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bull_choch_sig and not str.contains(dynamic_alert_seen_keys, '|bull_choch|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bull_choch|'
    alert(build_dynamic_alert_message(true, true, 'Bullish CHoCH', 'Character shift confirmed', top, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bear_bos_sig and not str.contains(dynamic_alert_seen_keys, '|bear_bos|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bear_bos|'
    alert(build_dynamic_alert_message(true, true, 'Bearish BOS', 'Structure break confirmed', btm, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bear_choch_sig and not str.contains(dynamic_alert_seen_keys, '|bear_choch|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bear_choch|'
    alert(build_dynamic_alert_message(true, true, 'Bearish CHoCH', 'Character shift confirmed', btm, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and not na(new_ob_bull) and not str.contains(dynamic_alert_seen_keys, '|new_bull_ob|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|new_bull_ob|'
    alert(build_dynamic_alert_message(true, true, 'Bullish Order Block', 'New order block confirmed', new_ob_bull.break_price, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and not na(new_ob_bear) and not str.contains(dynamic_alert_seen_keys, '|new_bear_ob|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|new_bear_ob|'
    alert(build_dynamic_alert_message(true, true, 'Bearish Order Block', 'New order block confirmed', new_ob_bear.break_price, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bullish_fvg_alert and not str.contains(dynamic_alert_seen_keys, '|new_bull_fvg|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|new_bull_fvg|'
    alert(build_dynamic_alert_message(true, true, 'Bullish FVG', 'New fair value gap formed', not na(new_fvg_bull) ? new_fvg_bull.fill_target_level : na, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bearish_fvg_alert and not str.contains(dynamic_alert_seen_keys, '|new_bear_fvg|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|new_bear_fvg|'
    alert(build_dynamic_alert_message(true, true, 'Bearish FVG', 'New fair value gap formed', not na(new_fvg_bear) ? new_fvg_bear.fill_target_level : na, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bullish_fvg_filled_alert and not str.contains(dynamic_alert_seen_keys, '|bull_fvg_filled|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bull_fvg_filled|'
    alert(build_dynamic_alert_message(true, true, 'Bullish FVG Filled', 'Gap fill target reached', bull_filled_alert_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and bearish_fvg_filled_alert and not str.contains(dynamic_alert_seen_keys, '|bear_fvg_filled|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|bear_fvg_filled|'
    alert(build_dynamic_alert_message(true, true, 'Bearish FVG Filled', 'Gap fill target reached', bear_filled_alert_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_ob_break and not str.contains(dynamic_alert_seen_keys, '|live_bull_ob_break|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|live_bull_ob_break|'
    alert(build_dynamic_alert_message(true, true, 'Bullish OB Live Break', 'Intrabar bullish order block break detected', bull_ob_live_event_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bear_ob_break and not str.contains(dynamic_alert_seen_keys, '|live_bear_ob_break|')
    dynamic_alert_seen_keys := dynamic_alert_seen_keys + '|live_bear_ob_break|'
    alert(build_dynamic_alert_message(true, true, 'Bearish OB Live Break', 'Intrabar bearish order block break detected', bear_ob_live_event_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text), alert.freq_all)
if enable_dynamic_alerts and enable_live_break_alerts and live_exec and live_bull_fvg_fill and not str.contains(dynamic_alert_seen_keys, '|live_bull_fvg_fill|')
