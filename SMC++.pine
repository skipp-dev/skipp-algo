var bool show_internals = input.bool(false, 'Show Internal Structure', group = g_struct, inline = 'internals')
var int internal_length = input.int(DEFAULT_INTERNAL_LENGTH, 'Internal Size', minval = 3, group = g_struct, inline = 'internals')
var bool show_latest_swings_levels = input.bool(true, 'Show Strong/Weak High/Low', group = g_struct, tooltip = SHOW_SWHL_POINTS)

var bool show_bull_bos = show_Structure and (show_bull == 'All' or show_bull == 'BOS')
var bool show_bull_choch = show_Structure and (show_bull == 'All' or show_bull == 'CHoCH')
var bool show_bear_bos = show_Structure and (show_bear == 'All' or show_bear == 'BOS')
var bool show_bear_choch = show_Structure and (show_bear == 'All' or show_bear == 'CHoCH')

var g_ob = 'Order Blocks'
var show_ob = input.bool(true, 'Show Order Blocks', group = g_ob, inline = 'OB', tooltip = SWING_OB)
var bull_ob_css = input.color(color.new(#3668f2, 80), '', group = g_ob, inline = 'OB')
var bear_ob_css = input.color(color.new(#f925eb, 80), '', group = g_ob, inline = 'OB')
var bull_ob_css_line = input.color(color.new(#3668f2, 15), '', group = g_ob, inline = 'OB')
var bear_ob_css_line = input.color(color.new(#f925eb, 15), '', group = g_ob, inline = 'OB')
var ob_showlast = input.int(DEFAULT_OB_SHOW_LAST, 'Show last', minval = 1, group = g_ob, inline = 'OB')
var ob_filter_min_mult = input.float(DEFAULT_OB_FILTER_MIN_MULT, 'Size Filter (ATR x) Min', minval = 0, step = 0.1, group = g_ob, inline = 'OB Filter')
var ob_filter_max_mult = input.float(DEFAULT_OB_FILTER_MAX_MULT, 'Max', minval = 1, step = 0.1, group = g_ob, inline = 'OB Filter', tooltip = FILTER_OB)
var show_ob_id = false
var ob_extend_until_broken = input.bool(true, 'Extend until broken', group = g_ob)
var ob_keep_broken = input.bool(true, 'Keep broken', group = g_ob, inline = 'keep broken')
var ob_keep_broken_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 0, group = g_ob, inline = 'keep broken')
var bull_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken')
var bear_ob_css_broken = input.color(color.new(color.gray, 90), '', group = g_ob, inline = 'keep broken')
var bull_ob_line_css_broken = color.new(bull_ob_css_broken, 50)
var bear_ob_line_css_broken = color.new(bear_ob_css_broken, 50)
var use_ob_profile = input.bool(true, 'Use profiles', group = g_ob, display = display.none, tooltip = 'Narrows the box to the value area and can align the break price to the profile POC.')
var use_ob_soft_confirm = input.bool(true, 'Use soft confirm', inline = 'soft confirm', group = g_ob, display = display.none, tooltip = 'A block may confirm early if price interacts with the break area and then exits in trend direction.')
var soft_confirm_offset_atr_len = ATR_LEN_MAIN
var soft_confirm_offset_atr_mult = 1.0
var use_retracements_with_FVG_out = input.bool(true, 'Use retracements with FVG-out as trend-supporting OB', group = g_ob, display = display.none, tooltip = 'Allows certain failed extensions with FVG confirmation to become valid continuation order blocks.')
var use_ob_engine = input.bool(true, 'Use OB engine', group = g_ob, display = display.none, tooltip = 'Keeps OB-based long-dip logic and alerts running even if chart rendering is hidden.')

active_break_mode = signal_mode == SignalMode.CONFIRMED_ONLY ? LevelBreakMode.CLOSE : LevelBreakMode.HIGHLOW
signal_mode_text = signal_mode == SignalMode.CONFIRMED_ONLY ? 'confirmed' : 'live'
visible_left_time = render_visible_only ? chart.left_visible_bar_time : na
visible_right_time = render_visible_only ? chart.right_visible_bar_time : na

float soft_confirm_offset = ND.atr(soft_confirm_offset_atr_len) * soft_confirm_offset_atr_mult
ob_threshold_atr = ND.atr(ATR_LEN_MAIN)
ob_threshold_min = ob_threshold_atr * ob_filter_min_mult
ob_threshold_max = ob_threshold_atr * ob_filter_max_mult

var PF.ProfileConfig profile_config_bull = PF.ProfileConfig.new(poc_label_text = 'OB - POC ⬈', extend = ob_extend_until_broken, show_labels = true, args_poc_line = D.LineArgs.new(bull_ob_css_line, line.style_dashed, xloc = xloc.bar_time), args_poc_label = D.LabelArgs.new(bull_ob_css_line, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal))
var PF.ProfileConfig profile_config_bear = PF.ProfileConfig.new(poc_label_text = 'OB - POC ⬊', extend = ob_extend_until_broken, show_labels = true, args_poc_line = D.LineArgs.new(bear_ob_css_line, line.style_dashed, xloc = xloc.bar_time), args_poc_label = D.LabelArgs.new(bear_ob_css_line, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal))
var OrderBlockConfig ob_config_bull = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = D.BoxArgs.new(bg_color = bull_ob_css, border_color = #00000000, xloc = xloc.bar_time), txt_args = D.BoxTextArgs.new(color.green, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull)
var OrderBlockConfig ob_config_bear = OrderBlockConfig.new(show_ob, ob_showlast, show_id = show_ob_id, show_profile = use_ob_profile, args = D.BoxArgs.new(bg_color = bear_ob_css, border_color = #00000000, xloc = xloc.bar_time), txt_args = D.BoxTextArgs.new(color.red, size.normal, text_halign = text.align_right), show_text = false, extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bear)
var PF.ProfileConfig profile_config_bull_broken = PF.ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = D.LineArgs.new(bull_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_time), args_poc_label = D.LabelArgs.new(#00000000))
var PF.ProfileConfig profile_config_bear_broken = PF.ProfileConfig.new(extend = ob_extend_until_broken, show_labels = false, args_poc_line = D.LineArgs.new(bear_ob_line_css_broken, line.style_dashed, xloc = xloc.bar_time), args_poc_label = D.LabelArgs.new(#00000000))
var OrderBlockConfig ob_config_bull_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = D.BoxArgs.new(bg_color = bull_ob_css_broken, border_color = #00000000, xloc = xloc.bar_time), txt_args = D.BoxTextArgs.new(bull_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bull_broken)
var OrderBlockConfig ob_config_bear_broken = OrderBlockConfig.new(show_ob, ob_keep_broken_max, show_profile = true, args = D.BoxArgs.new(bg_color = bear_ob_css_broken, border_color = #00000000, xloc = xloc.bar_time), txt_args = D.BoxTextArgs.new(bear_ob_line_css_broken, size.normal, text_halign = text.align_right), txt = '', extend_until_broken = ob_extend_until_broken, profile_config = profile_config_bear_broken)

int chart_tf_sec = nz(timeframe.in_seconds(), 0)
auto_selected_ltf = auto_ltf_timeframe(chart_tf_sec)
effective_ltf_timeframe = ltf_auto_select ? auto_selected_ltf : ltf_timeframe
int effective_ltf_tf_sec = nz(timeframe.in_seconds(effective_ltf_timeframe), 0)
ltf_timeframe_valid = chart_tf_sec > 0 and str.length(effective_ltf_timeframe) > 0 and effective_ltf_tf_sec > 0 and effective_ltf_tf_sec < chart_tf_sec
ltf_sampling_active = enable_ltf_sampling and ltf_timeframe_valid
int marker_gap_reference_seconds = marker_gap_reference_minutes * 60
int effective_reclaim_marker_gap = scaled_marker_gap(reclaim_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_confirm_marker_gap = scaled_marker_gap(confirm_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)
int effective_ready_marker_gap = scaled_marker_gap(ready_marker_spacing_bars, auto_scale_marker_gaps, chart_tf_sec, marker_gap_reference_seconds, marker_gap_max_scale)

float[] ltf_opens = ltf_sampling_active ? request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, open) : array.new<float>(0)
float[] ltf_closes = ltf_sampling_active ? request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, close) : array.new<float>(0)
float[] ltf_volumes = ltf_sampling_active ? request.security_lower_tf(syminfo.tickerid, effective_ltf_timeframe, volume) : array.new<float>(0)
[ltf_sample_count, ltf_bull_share, ltf_volume_delta] = ltf_stats(ltf_opens, ltf_closes, ltf_volumes)

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)

plot(show_ema_support ? ema_fast : na, 'EMA Fast', color = color.new(color.lime, 0), linewidth = 2)
plot(show_ema_support ? ema_slow : na, 'EMA Slow', color = color.new(color.teal, 0), linewidth = 2)

[plus_di, minus_di, adx_value] = ta.dmi(adx_len, adx_len)
bool adx_data_ok = not na(adx_value) and not na(plus_di) and not na(minus_di)
float rel_volume_ma = ta.sma(volume, relvol_len)
float rel_volume = na(volume) or na(rel_volume_ma) or rel_volume_ma <= 0 ? na : volume / rel_volume_ma

bar_range = math.max(high - low, syminfo.mintick)
bull_close_in_range = (close - low) / bar_range

bool bull_close_strong = not use_strong_close_filter ? true : bull_close_in_range >= min_close_in_range_pct
string close_state_text = not use_strong_close_filter ? 'off' : bull_close_strong ? 'Strong Close' : 'Weak Close'

bool ema_support_ok = not show_ema_support ? true : close >= ema_fast and ema_fast >= ema_slow and ema_fast > ema_fast[1]
string ema_state_text = not show_ema_support ? 'off' : ema_support_ok ? 'OK' : 'No'

bool adx_strong = not use_adx ? true : adx_data_ok and adx_value >= adx_strong_min and plus_di >= minus_di
string adx_state_text = not use_adx ? 'off' : not adx_data_ok ? 'n/a' : plus_di < minus_di ? 'Bearish pressure' : adx_value < adx_trend_min ? 'Sideways' : adx_value < adx_strong_min ? 'Trend building' : 'Trend'

bool relvol_ok = not use_rel_volume ? true : not na(rel_volume) and rel_volume >= relvol_good
string relvol_text = not use_rel_volume ? 'off' : na(rel_volume) ? 'n/a' : str.format('{0,number,#.##}x', rel_volume)

mtf_trend_1 = show_mtf_trend ? request.security(syminfo.tickerid, mtf_trend_tf1, get_structure_display_trend_only(swing_length), gaps = barmerge.gaps_off) : na
mtf_trend_2 = show_mtf_trend ? request.security(syminfo.tickerid, mtf_trend_tf2, get_structure_display_trend_only(swing_length), gaps = barmerge.gaps_off) : na
mtf_trend_3 = show_mtf_trend ? request.security(syminfo.tickerid, mtf_trend_tf3, get_structure_display_trend_only(swing_length), gaps = barmerge.gaps_off) : na

[trend, bull_bos_alert, bull_choch_alert, top_x, top, trail_up_x, trail_up, hh, bear_bos_alert, bear_choch_alert, btm_x, btm, trail_dn_x, trail_dn, ll, hhll_x] = detect_structure(swing_length, filter_insignificant_internal_breaks = true)
// Separate display-only trend state: avoid exposing the engine's bullish bootstrap bias before a real structure break occurs.
bool bullish_structure_break = bull_bos_alert or bull_choch_alert
bool bearish_structure_break = bear_bos_alert or bear_choch_alert
bool structure_break_detected = bullish_structure_break or bearish_structure_break
structure_display_trend = not na(ta.barssince(structure_break_detected)) ? trend : 0
bool bullish_trend_condition = structure_display_trend == 1
bool bearish_trend_condition = structure_display_trend == -1
bool bullish_trend_started = bullish_trend_condition and not bullish_trend_condition[1]
bool bearish_trend_started = bearish_trend_condition and not bearish_trend_condition[1]
bool directional_trend_started = bullish_trend_started or bearish_trend_started

[internal_trend, internal_bull_bos_alert, internal_bull_choch_alert, internal_top_x, internal_top, internal_trail_up_x, internal_trail_up, internal_hh, internal_bear_bos_alert, internal_bear_choch_alert, internal_btm_x, internal_btm, internal_trail_dn_x, internal_trail_dn, internal_ll, internal_hhll_x] = detect_structure(internal_length, top, btm, filter_insignificant_internal_breaks = true)

bool internal_structure_break_detected = internal_bull_bos_alert or internal_bull_choch_alert or internal_bear_bos_alert or internal_bear_choch_alert
internal_display_trend = not na(ta.barssince(internal_structure_break_detected)) ? internal_trend : 0

var D.LabelArgs pivot_label_args_bull = D.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_up)
var D.LabelArgs pivot_label_args_bear = D.LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_down)
var D.LabelArgs swing_level_label_args_bull = D.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_left)
var D.LabelArgs swing_level_label_args_bear = D.LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_left)
var D.LabelArgs structure_label_args_bull = D.LabelArgs.new(bull_css, #00000000, size = size.small, style = label.style_label_down)
var D.LabelArgs structure_label_args_bear = D.LabelArgs.new(bear_css, #00000000, size = size.small, style = label.style_label_down)
var D.LineArgs structure_line_args_bull = D.LineArgs.new(bull_css, line.style_solid, 2)
var D.LineArgs structure_line_args_bear = D.LineArgs.new(bear_css, line.style_solid, 2)
var D.LineArgs swing_level_line_args_bull = D.LineArgs.new(bull_css, line.style_solid, 2)
var D.LineArgs swing_level_line_args_bear = D.LineArgs.new(bear_css, line.style_solid, 2)

var color bull_internal_css = color.new(bull_css, 78)
var color bear_internal_css = color.new(bear_css, 78)

var D.LabelArgs swing_level_label_args_internal_bull = D.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_left)
var D.LabelArgs swing_level_label_args_internal_bear = D.LabelArgs.new(bear_internal_css, #00000000, size = size.tiny, style = label.style_label_left)

var D.LabelArgs structure_label_args_internal_bull = D.LabelArgs.new(bull_internal_css, #00000000, size = size.tiny, style = label.style_label_down)
var D.LabelArgs structure_label_args_internal_bear = D.LabelArgs.new(bear_internal_css, #00000000, size = size.tiny, style = label.style_label_down)

var D.LineArgs structure_line_args_internal_bull = D.LineArgs.new(bull_internal_css, line.style_dashed)
var D.LineArgs structure_line_args_internal_bear = D.LineArgs.new(bear_internal_css, line.style_dashed)

var D.LineArgs swing_level_line_args_internal_bull = D.LineArgs.new(bull_internal_css, line.style_dashed)
var D.LineArgs swing_level_line_args_internal_bear = D.LineArgs.new(bear_internal_css, line.style_dashed)

var color long_color_zone = color.aqua
var color long_color_reclaim = color.orange
var color long_color_reversal = color.yellow
var color long_color_building = color.rgb(212, 170, 34)
var color long_color_confirmed = color.lime
var color long_color_ready = color.green
var color long_color_invalid = color.red
var color long_dashboard_building_text = color.rgb(105, 74, 0)

bool show_internal_bull_bos = show_internals and (show_bull == 'All' or show_bull == 'BOS')
bool show_internal_bull_choch = show_internals and (show_bull == 'All' or show_bull == 'CHoCH')
bool show_internal_bear_bos = show_internals and (show_bear == 'All' or show_bear == 'BOS')
bool show_internal_bear_choch = show_internals and (show_bear == 'All' or show_bear == 'CHoCH')

// Pivot labels (HH/LH/HL/LL)
if show_swing_points
    plot_pivot_points(1, top_x, top, show_swing_points and not na(hh), pivot_label_args_bear, keep_history = true)
    plot_pivot_points(-1, btm_x, btm, show_swing_points and not na(ll), pivot_label_args_bull, keep_history = true)

// UX-Fix:
// If the user enables swing points they usually also expect the active swing levels.
bool show_chart_swing_levels = show_latest_swings_levels or show_swing_points

if show_chart_swing_levels
    plot_swing_levels(1, trail_up_x, trail_up, structure_display_trend, true, swing_level_label_args_bear, swing_level_line_args_bear, override_right_index = bar_index + 20)
    plot_swing_levels(-1, trail_dn_x, trail_dn, structure_display_trend, true, swing_level_label_args_bull, swing_level_line_args_bull, override_right_index = bar_index + 20)

if show_bull_bos or show_bull_choch
    plot_structure(top_x, top, show_bull_bos and bull_bos_alert, show_bull_choch and bull_choch_alert, structure_label_args_bull, structure_line_args_bull, keep_history = true)

if show_bear_bos or show_bear_choch
    plot_structure(btm_x, btm, show_bear_bos and bear_bos_alert, show_bear_choch and bear_choch_alert, structure_label_args_bear, structure_line_args_bear, keep_history = true)

// Internal structure: lighter dashed rendering
if show_internals
    plot_swing_levels(1, internal_trail_up_x, internal_trail_up, internal_display_trend, true, swing_level_label_args_internal_bear, swing_level_line_args_internal_bear, override_right_index = bar_index + 10, text_prefix = 'INT ')
    plot_swing_levels(-1, internal_trail_dn_x, internal_trail_dn, internal_display_trend, true, swing_level_label_args_internal_bull, swing_level_line_args_internal_bull, override_right_index = bar_index + 10, text_prefix = 'INT ')

if show_internal_bull_bos or show_internal_bull_choch
    plot_structure(internal_top_x, internal_top, show_internal_bull_bos and internal_bull_bos_alert, show_internal_bull_choch and internal_bull_choch_alert, structure_label_args_internal_bull, structure_line_args_internal_bull, keep_history = true, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

if show_internal_bear_bos or show_internal_bear_choch
    plot_structure(internal_btm_x, internal_btm, show_internal_bear_bos and internal_bear_bos_alert, show_internal_bear_choch and internal_bear_choch_alert, structure_label_args_internal_bear, structure_line_args_internal_bear, keep_history = true, text_prefix = 'INT ', bos_text = 'Break', choch_text = 'Reversal')

bool enable_ob_engine = use_ob_engine
[ob_blocks_bull, ob_blocks_bear, new_ob_bull, new_ob_bear, ob_broken_bull, ob_broken_bear, ob_broken_new_bull, ob_broken_new_bear, ob_discarded_bull, ob_discarded_bear] = track_obs(swing_length, hh, ll, bull_bos_alert, bull_choch_alert, bear_bos_alert, bear_choch_alert, ob_threshold_min, ob_threshold_max, enabled = enable_ob_engine, capture_profile = use_ob_profile, align_edge_to_value_area = use_ob_profile, align_break_price_to_poc = use_ob_profile, use_soft_confirm = use_ob_soft_confirm, soft_confirm_offset = soft_confirm_offset, keep_broken_max = ob_keep_broken_max, broken_by = active_break_mode)

var map<int, OrderBlock> ob_registry_bull = map.new<int, OrderBlock>()
var map<int, OrderBlock> ob_registry_bear = map.new<int, OrderBlock>()
ob_registry_bull.clear()
ob_registry_bear.clear()
for block in ob_blocks_bull
    ob_registry_bull.put(block.id, block)
for block in ob_blocks_bear
    ob_registry_bear.put(block.id, block)

varip bool live_bull_ob_break = false
varip bool live_bear_ob_break = false
varip bool live_bull_fvg_fill = false
varip bool live_bear_fvg_fill = false
varip int intrabar_event_count = 0
varip int reclaim_marker_drawn_bar_index = na
varip int long_state_marker_drawn_bar_index = na
varip int long_ready_marker_drawn_bar_index = na

if barstate.isnew
    live_bull_ob_break := false
    live_bear_ob_break := false
    live_bull_fvg_fill := false
    live_bear_fvg_fill := false
    intrabar_event_count := 0
    reclaim_marker_drawn_bar_index := na
    long_state_marker_drawn_bar_index := na
    long_ready_marker_drawn_bar_index := na

if barstate.islast
    ob_blocks_bull.draw(ob_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    ob_blocks_bear.draw(ob_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_ob and ob_keep_broken and ob_keep_broken_max > 0
        if barstate.islastconfirmedhistory[1]
            ob_broken_bull.draw(ob_config_bull_broken, visible_left = visible_left_time, visible_right = visible_right_time)
            ob_broken_bear.draw(ob_config_bear_broken, visible_left = visible_left_time, visible_right = visible_right_time)
        else
            ob_broken_new_bull.draw(ob_config_bull_broken, visible_left = visible_left_time, visible_right = visible_right_time)
            ob_broken_new_bear.draw(ob_config_bear_broken, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        ob_broken_bull.delete()
        ob_broken_bear.delete()

    if barstate.isconfirmed
        ob_discarded_bull.delete()
        ob_discarded_bear.delete()

var g_fvg = 'Fair Value Gaps'
var show_fvg = input.bool(true, 'Show Fair Value Gaps', group = g_fvg, inline = 'show', tooltip = SHOW_FVG)
var fvg_showlast = input.int(DEFAULT_FVG_SHOW_LAST, 'Show last', minval = 1, group = g_fvg, inline = 'show2')
var fvg_extend_until_filled = input.bool(true, 'Extend until filled', group = g_fvg, inline = 'ext')
var fvg_keep_filled = input.bool(true, 'Keep filled', group = g_fvg, inline = 'keep filled')
var fvg_keep_filled_max = input.int(DEFAULT_KEEP_HISTORY, '', minval = 1, group = g_fvg, inline = 'keep filled')
var bull_fvg_css = input.color(color.new(#00ff68, 90), '', group = g_fvg, inline = 'show')
var bear_fvg_css = input.color(color.new(#ff0008, 90), '', group = g_fvg, inline = 'show')
var bull_fvg_line_css = input.color(color.new(#00ff68, 25), '', group = g_fvg, inline = 'show')
var bear_fvg_line_css = input.color(color.new(#ff0008, 25), '', group = g_fvg, inline = 'show')
var bull_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bear_fvg_css_filled = input.color(color.new(color.gray, 80), '', group = g_fvg, inline = 'keep filled')
var bull_fvg_line_css_filled = color.new(bull_fvg_css_filled, 50)
var bear_fvg_line_css_filled = color.new(bear_fvg_css_filled, 50)
var filter_insignificant_fvgs = input.bool(true, 'Filter: min size', group = g_fvg, inline = 'fvg_min', tooltip = FILTER_FVG)
var min_fvg_size_atr_len = input.int(ATR_LEN_MAIN, 'ATR Length', minval = 1, group = g_fvg, inline = 'fvg_min')
var min_fvg_size_atr_mult = input.float(DEFAULT_FVG_MIN_SIZE_MULT, 'x', minval = 0, step = 0.1, group = g_fvg, inline = 'fvg_min')
float fvg_size_threshold = filter_insignificant_fvgs ? ND.atr(min_fvg_size_atr_len) * min_fvg_size_atr_mult : 0
var float fvg_fill_target_pct = input.float(DEFAULT_FVG_FILL_TARGET_PCT, 'Filled at %', minval = 0, maxval = 100, step = 5, group = g_fvg)
float fvg_fill_target_ratio = math.max(0.0, math.min(1.0, fvg_fill_target_pct / 100.0))
var use_fvg_engine = input.bool(true, 'Use FVG engine', group = g_fvg, display = display.none, tooltip = 'Keeps FVG-based long-dip logic and alerts running even if chart rendering is hidden.')

bool enable_fvg_engine = use_fvg_engine
[bullish_fvg_alert, bearish_fvg_alert, fvgs_bull, fvgs_bear, new_fvg_bull, new_fvg_bear, filled_fvgs_bull, filled_fvgs_bear, filled_fvgs_new_bull, filled_fvgs_new_bear, fvg_discarded_bull, fvg_discarded_bear] = fvgs_objects(active_break_mode, fvg_fill_target_ratio, fvg_size_threshold, enable_fvg_engine, fvg_keep_filled_max)

var map<int, FVG> fvg_registry_bull = map.new<int, FVG>()
var map<int, FVG> fvg_registry_bear = map.new<int, FVG>()
fvg_registry_bull.clear()
fvg_registry_bear.clear()
fvg_slot = 0
for fvg in fvgs_bull
    fvg_registry_bull.put(fvg_slot, fvg)
    fvg_slot += 1
fvg_slot := 0
for fvg in fvgs_bear
    fvg_registry_bear.put(fvg_slot, fvg)
    fvg_slot += 1

var fvg_config_bull = FVGConfig.new(show_box = show_fvg, show_target = show_fvg, show_target_label = true, show_last = fvg_showlast, txt = 'FVG ⬈', show_probability = true, extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bull_fvg_line_css, 0, line.style_solid, bull_fvg_css, xloc.bar_time), box_text_args = D.BoxTextArgs.new(bull_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bull_fvg_line_css, line.style_solid, 1, xloc.bar_time), label_args = D.LabelArgs.new(bull_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var fvg_config_bear = FVGConfig.new(show_box = show_fvg, show_target = show_fvg, show_target_label = true, show_last = fvg_showlast, txt = 'FVG ⬊', show_probability = true, extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bear_fvg_line_css, 0, line.style_solid, bear_fvg_css, xloc.bar_time), box_text_args = D.BoxTextArgs.new(bear_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bear_fvg_line_css, line.style_solid, 1, xloc.bar_time), label_args = D.LabelArgs.new(bear_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var show_fvg_filled = show_fvg and fvg_keep_filled and fvg_keep_filled_max > 0
var fvg_config_bull_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_probability = false, extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bull_fvg_line_css_filled, 0, line.style_solid, bull_fvg_css_filled, xloc.bar_time), box_text_args = D.BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bull_fvg_line_css_filled, line.style_solid, 1, xloc.bar_time), label_args = D.LabelArgs.new(#00000000, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal, text_align = text.align_left))
var fvg_config_bear_filled = FVGConfig.new(show_box = show_fvg_filled, show_target = show_fvg_filled, show_last = fvg_keep_filled_max, txt = '', show_probability = false, extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bear_fvg_line_css_filled, 0, line.style_solid, bear_fvg_css_filled, xloc.bar_time), box_text_args = D.BoxTextArgs.new(chart.fg_color, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bear_fvg_line_css_filled, line.style_solid, 1, xloc.bar_time), label_args = D.LabelArgs.new(#00000000, xloc = xloc.bar_time, style = label.style_label_left, size = size.normal, text_align = text.align_left))

bool bullish_fvg_filled_alert = filled_fvgs_new_bull.size() > 0
bool bearish_fvg_filled_alert = filled_fvgs_new_bear.size() > 0
float bull_filled_alert_level = bullish_fvg_filled_alert ? filled_fvgs_new_bull.first().fill_target_level : na
float bear_filled_alert_level = bearish_fvg_filled_alert ? filled_fvgs_new_bear.first().fill_target_level : na

if barstate.islast
    fvgs_bull.draw(fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    fvgs_bear.draw(fvg_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if show_fvg_filled
        if barstate.islastconfirmedhistory[1]
            filled_fvgs_bull.draw(fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
            filled_fvgs_bear.draw(fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
        else
            filled_fvgs_new_bull.draw(fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
            filled_fvgs_new_bear.draw(fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        filled_fvgs_bull.delete()
        filled_fvgs_bear.delete()

    if barstate.isconfirmed
        fvg_discarded_bull.delete()
        fvg_discarded_bear.delete()

fvgs_objects_htf(FVG new_bull, FVG new_bear, bool htf_is_confirmed, float size_threshold, simple LevelBreakMode fill_mode = LevelBreakMode.CLOSE, simple float fill_target_ratio = 0.5, simple int filled_max_keep = 5, simple int gc_cycle = na) =>
    var FVG[] buffer_bull = array.new<FVG>(0)
    var FVG[] buffer_bear = array.new<FVG>(0)
    var FVG[] buffer_bull_filled = array.new<FVG>(0)
    var FVG[] buffer_bear_filled = array.new<FVG>(0)
    var FVG[] buffer_bull_filled_new = array.new<FVG>(0)
    var FVG[] buffer_bear_filled_new = array.new<FVG>(0)
    var FVG[] htf_buffer_bull_discarded = array.new<FVG>(0)
    var FVG[] htf_buffer_bear_discarded = array.new<FVG>(0)

    if barstate.isfirst and not M.in_range(fill_target_ratio, 1, 0)
        runtime.error(str.format("FVG fill_target_ratio {0} ({0,number,percent}) not in range [0-1]. We chose not to support this for performance reasons (avoiding box overlap)", fill_target_ratio))

    if fill_mode == LevelBreakMode.CLOSE ? htf_is_confirmed : true
        buffer_bull.update()
        buffer_bear.update()
        buffer_bull.clear_filled(buffer_bull_filled, buffer_bull_filled_new, filled_max_keep, htf_buffer_bull_discarded)
        buffer_bear.clear_filled(buffer_bear_filled, buffer_bear_filled_new, filled_max_keep, htf_buffer_bear_discarded)

    if gc_cycle > 0 and bar_index % gc_cycle == 0
        buffer_bull.remove_insignificant(size_threshold, htf_buffer_bull_discarded)
        buffer_bear.remove_insignificant(size_threshold, htf_buffer_bear_discarded)

    bool htf_insert_ok = fill_mode == LevelBreakMode.CLOSE ? htf_is_confirmed : true

    if htf_insert_ok and not na(new_bull)
        buffer_bull.push(new_bull)
    if htf_insert_ok and not na(new_bear)
        buffer_bear.push(new_bear)

    [buffer_bull, buffer_bear, buffer_bull_filled, buffer_bear_filled, buffer_bull_filled_new, buffer_bear_filled_new, htf_buffer_bull_discarded, htf_buffer_bear_discarded]

var g_htf_fvg = 'Fair Value Gaps (Higher Timeframe)'
var show_htf_fvg = input.bool(true, 'Show Fair Value Gaps (HTF)', group = g_htf_fvg, inline = 'show', tooltip = SHOW_FVG + '\n' + FVG_TF)
var fvg_htf = input.timeframe('1D', '', group = g_htf_fvg, inline = 'show')
var htf_fvg_showlast = input.int(1, 'Show last', minval = 1, group = g_htf_fvg, inline = 'show2')
var htf_fvg_keep_filled = input.bool(true, 'Keep filled', group = g_htf_fvg, inline = 'keep filled')
var htf_fvg_keep_filled_max = input.int(1, '', minval = 1, group = g_htf_fvg, inline = 'keep filled')
var bull_htf_fvg_css = bull_fvg_css
var bear_htf_fvg_css = bear_fvg_css
var bull_htf_fvg_line_css = bull_fvg_line_css
var bear_htf_fvg_line_css = bear_fvg_line_css
var bull_htf_fvg_css_filled = bull_fvg_css_filled
var bear_htf_fvg_css_filled = bear_fvg_css_filled
var bull_htf_fvg_line_css_filled = bull_fvg_line_css_filled
var bear_htf_fvg_line_css_filled = bear_fvg_line_css_filled
int htf_fvg_tf_sec = nz(timeframe.in_seconds(fvg_htf), 0)

if barstate.isfirst and show_htf_fvg
    if chart_tf_sec == 0 or htf_fvg_tf_sec == 0
        runtime.error('HTF FVG requires a time-based chart and a time-based HTF.')
    if htf_fvg_tf_sec <= chart_tf_sec
        runtime.error(str.format('Show FVG (Timeframe): select a timeframe higher than the chart timeframe {0}, currently selected: {1}', timeframe.period, fvg_htf))

var htf_fvg_config_bull = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_showlast, txt = fvg_htf + ' - FVG ⬈', extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bull_htf_fvg_line_css, 0, line.style_solid, bull_htf_fvg_css, xloc = xloc.bar_time), box_text_args = D.BoxTextArgs.new(bull_htf_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bull_htf_fvg_line_css, line.style_solid, 1, xloc = xloc.bar_time), label_args = D.LabelArgs.new(bull_htf_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bear = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_showlast, txt = fvg_htf + ' - FVG ⬊', extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bear_htf_fvg_line_css, 0, line.style_solid, bear_htf_fvg_css, xloc = xloc.bar_time), box_text_args = D.BoxTextArgs.new(bear_htf_fvg_line_css, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bear_htf_fvg_line_css, line.style_solid, 1, xloc = xloc.bar_time), label_args = D.LabelArgs.new(bear_htf_fvg_line_css, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bull_filled = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_keep_filled_max, txt = '', extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bull_htf_fvg_line_css_filled, 0, line.style_solid, bull_htf_fvg_css_filled, xloc = xloc.bar_time), box_text_args = D.BoxTextArgs.new(bull_htf_fvg_line_css_filled, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bull_htf_fvg_line_css_filled, line.style_solid, 1, xloc = xloc.bar_time), label_args = D.LabelArgs.new(bull_htf_fvg_css_filled, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))
var htf_fvg_config_bear_filled = FVGConfig.new(show_box = show_htf_fvg, show_target = show_htf_fvg, show_last = htf_fvg_keep_filled_max, txt = '', extend_until_filled = fvg_extend_until_filled, box_args = D.BoxArgs.new(bear_htf_fvg_line_css_filled, 0, line.style_solid, bear_htf_fvg_css_filled, xloc = xloc.bar_time), box_text_args = D.BoxTextArgs.new(bear_htf_fvg_line_css_filled, size.normal, text.align_right, text.align_center), line_args = D.LineArgs.new(bear_htf_fvg_line_css_filled, line.style_solid, 1, xloc = xloc.bar_time), label_args = D.LabelArgs.new(bear_htf_fvg_css_filled, xloc = xloc.bar_time, style = label.style_label_left, size = size.small, text_align = text.align_left))

[_, htf_new_fvg_bull] = request.security(syminfo.tickerid, fvg_htf, _detect_fvg_object(1, show_htf_fvg, fvg_size_threshold, LevelBreakMode.CLOSE, fvg_fill_target_ratio), gaps = barmerge.gaps_on)
[_, htf_new_fvg_bear] = request.security(syminfo.tickerid, fvg_htf, _detect_fvg_object(-1, show_htf_fvg, fvg_size_threshold, LevelBreakMode.CLOSE, fvg_fill_target_ratio), gaps = barmerge.gaps_on)
htf_bar_changed = timeframe.change(fvg_htf)
htf_fvg_confirmed = signal_mode == SignalMode.AGGRESSIVE_LIVE ? true : barstate.isconfirmed and (htf_bar_changed or htf_fvg_tf_sec == chart_tf_sec)
[htf_fvg_buffer_bull, htf_fvg_buffer_bear, htf_fvg_buffer_bull_filled, htf_fvg_buffer_bear_filled, htf_fvg_buffer_bull_filled_new, htf_fvg_buffer_bear_filled_new, htf_fvg_buffer_bull_discarded, htf_fvg_buffer_bear_discarded] = fvgs_objects_htf(htf_new_fvg_bull, htf_new_fvg_bear, htf_fvg_confirmed, fvg_size_threshold, active_break_mode, fvg_fill_target_ratio, 2)

last_bull_ob_break_level = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().break_price : na
last_bear_ob_break_level = ob_blocks_bear.size() > 0 ? ob_blocks_bear.last().break_price : na
last_bull_fvg_fill_level = fvgs_bull.size() > 0 ? fvgs_bull.last().fill_target_level : na
last_bear_fvg_fill_level = fvgs_bear.size() > 0 ? fvgs_bear.last().fill_target_level : na

last_bull_ob_top = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().left_top.price : na
last_bull_ob_bottom = ob_blocks_bull.size() > 0 ? ob_blocks_bull.last().right_bottom.price : na
last_bull_fvg_top = fvgs_bull.size() > 0 ? fvgs_bull.last().left_top.price : na
last_bull_fvg_bottom = fvgs_bull.size() > 0 ? fvgs_bull.last().right_bottom.price : na

float active_bull_ob_top = na
float active_bull_ob_bottom = na
float active_bull_ob_break_level = na
float active_bull_fvg_top = na
float active_bull_fvg_bottom = na
float active_bull_fvg_fill_level = na
float active_bear_ob_break_level = na
float active_bear_fvg_fill_level = na

int bull_ob_scan_start = math.max(ob_blocks_bull.size() - long_zone_scan_limit, 0)
if ob_blocks_bull.size() > 0
    for i = ob_blocks_bull.size() - 1 to bull_ob_scan_start
        bull_ob_candidate = ob_blocks_bull.get(i)
        bool ob_candidate_active = low <= bull_ob_candidate.left_top.price and high >= bull_ob_candidate.right_bottom.price
        if ob_candidate_active
            active_bull_ob_top := bull_ob_candidate.left_top.price
            active_bull_ob_bottom := bull_ob_candidate.right_bottom.price
            active_bull_ob_break_level := bull_ob_candidate.break_price
            break

int bull_fvg_scan_start = math.max(fvgs_bull.size() - long_zone_scan_limit, 0)
if fvgs_bull.size() > 0
    for i = fvgs_bull.size() - 1 to bull_fvg_scan_start
        bull_fvg_candidate = fvgs_bull.get(i)
        bool fvg_candidate_active = low <= bull_fvg_candidate.left_top.price and high >= bull_fvg_candidate.right_bottom.price
        if fvg_candidate_active
            active_bull_fvg_top := bull_fvg_candidate.left_top.price
            active_bull_fvg_bottom := bull_fvg_candidate.right_bottom.price
            active_bull_fvg_fill_level := bull_fvg_candidate.fill_target_level
            break

int bear_ob_scan_start = math.max(ob_blocks_bear.size() - long_zone_scan_limit, 0)
if ob_blocks_bear.size() > 0
    for i = ob_blocks_bear.size() - 1 to bear_ob_scan_start
        bear_ob_candidate = ob_blocks_bear.get(i)
        bool bear_ob_candidate_active = low <= bear_ob_candidate.left_top.price and high >= bear_ob_candidate.right_bottom.price
        if bear_ob_candidate_active
            active_bear_ob_break_level := bear_ob_candidate.break_price
            break

int bear_fvg_scan_start = math.max(fvgs_bear.size() - long_zone_scan_limit, 0)
if fvgs_bear.size() > 0
    for i = fvgs_bear.size() - 1 to bear_fvg_scan_start
        bear_fvg_candidate = fvgs_bear.get(i)
        bool bear_fvg_candidate_active = low <= bear_fvg_candidate.left_top.price and high >= bear_fvg_candidate.right_bottom.price
        if bear_fvg_candidate_active
            active_bear_fvg_fill_level := bear_fvg_candidate.fill_target_level
            break

bool in_bull_ob_zone = not na(active_bull_ob_top) and not na(active_bull_ob_bottom)
bool in_bull_fvg_zone = not na(active_bull_fvg_top) and not na(active_bull_fvg_bottom)
bool long_zone_active = in_bull_ob_zone or in_bull_fvg_zone
float bull_ob_break_for_alert = not na(active_bull_ob_break_level) ? active_bull_ob_break_level : last_bull_ob_break_level
float bull_fvg_fill_for_alert = not na(active_bull_fvg_fill_level) ? active_bull_fvg_fill_level : last_bull_fvg_fill_level
float bear_ob_break_for_alert = not na(active_bear_ob_break_level) ? active_bear_ob_break_level : last_bear_ob_break_level
float bear_fvg_fill_for_alert = not na(active_bear_fvg_fill_level) ? active_bear_fvg_fill_level : last_bear_fvg_fill_level
bool any_live_bull_ob_break = ob_broken_new_bull.size() > 0
bool any_live_bear_ob_break = ob_broken_new_bear.size() > 0
bool any_live_bull_fvg_fill = filled_fvgs_new_bull.size() > 0
bool any_live_bear_fvg_fill = filled_fvgs_new_bear.size() > 0
float bull_ob_live_event_level = any_live_bull_ob_break ? ob_broken_new_bull.first().break_price : bull_ob_break_for_alert
float bear_ob_live_event_level = any_live_bear_ob_break ? ob_broken_new_bear.first().break_price : bear_ob_break_for_alert
float bull_fvg_live_event_level = any_live_bull_fvg_fill ? filled_fvgs_new_bull.first().fill_target_level : bull_fvg_fill_for_alert
float bear_fvg_live_event_level = any_live_bear_fvg_fill ? filled_fvgs_new_bear.first().fill_target_level : bear_fvg_fill_for_alert

if not any_live_bull_ob_break and ob_blocks_bull.size() > 0
    for i = ob_blocks_bull.size() - 1 to bull_ob_scan_start
        bull_ob_live_candidate = ob_blocks_bull.get(i)
        if low <= bull_ob_live_candidate.break_price
            any_live_bull_ob_break := true
            bull_ob_live_event_level := bull_ob_live_candidate.break_price
            break

if not any_live_bear_ob_break and ob_blocks_bear.size() > 0
    for i = ob_blocks_bear.size() - 1 to bear_ob_scan_start
        bear_ob_live_candidate = ob_blocks_bear.get(i)
        if high >= bear_ob_live_candidate.break_price
            any_live_bear_ob_break := true
            bear_ob_live_event_level := bear_ob_live_candidate.break_price
            break

if not any_live_bull_fvg_fill and fvgs_bull.size() > 0
    for i = fvgs_bull.size() - 1 to bull_fvg_scan_start
        bull_fvg_live_candidate = fvgs_bull.get(i)
        if low <= bull_fvg_live_candidate.fill_target_level
            any_live_bull_fvg_fill := true
            bull_fvg_live_event_level := bull_fvg_live_candidate.fill_target_level
            break

if not any_live_bear_fvg_fill and fvgs_bear.size() > 0
    for i = fvgs_bear.size() - 1 to bear_fvg_scan_start
        bear_fvg_live_candidate = fvgs_bear.get(i)
        if high >= bear_fvg_live_candidate.fill_target_level
            any_live_bear_fvg_fill := true
            bear_fvg_live_event_level := bear_fvg_live_candidate.fill_target_level
            break

float long_reclaim_ob_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE ? high : close
float long_reclaim_fvg_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE ? high : close
float long_reclaim_internal_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE ? high : close
float long_reclaim_swing_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE ? high : close
bool long_reclaim_bar_ok = signal_mode == SignalMode.AGGRESSIVE_LIVE ? true : barstate.isconfirmed

bool bull_reclaim_ob = long_reclaim_bar_ok and in_bull_ob_zone and long_reclaim_ob_break_src > active_bull_ob_top
bool bull_reclaim_fvg = long_reclaim_bar_ok and in_bull_fvg_zone and long_reclaim_fvg_break_src > active_bull_fvg_top
bool bull_reclaim_internal_low = long_reclaim_bar_ok and not na(internal_trail_dn) and low < internal_trail_dn and long_reclaim_internal_break_src > internal_trail_dn
bool bull_reclaim_swing_low = long_reclaim_bar_ok and not na(trail_dn) and low < trail_dn and long_reclaim_swing_break_src > trail_dn
bool bull_reclaim_any = bull_reclaim_ob or bull_reclaim_fvg or bull_reclaim_internal_low or bull_reclaim_swing_low

int zone_since_bars = ta.barssince(long_zone_active)
int reclaim_since_bars = ta.barssince(bull_reclaim_any)
int internal_choch_since_bars = ta.barssince(internal_bull_choch_alert)
int internal_bos_since_bars = ta.barssince(internal_bull_bos_alert)
int main_bos_since_bars = ta.barssince(bull_bos_alert)

bool zone_recent = not na(zone_since_bars) and zone_since_bars <= long_signal_window
bool reclaim_recent = not na(reclaim_since_bars) and reclaim_since_bars <= long_signal_window
bool internal_choch_recent = not na(internal_choch_since_bars) and internal_choch_since_bars <= long_signal_window
bool internal_bos_recent = not na(internal_bos_since_bars) and internal_bos_since_bars <= long_signal_window
bool main_bos_recent = not na(main_bos_since_bars) and main_bos_since_bars <= long_signal_window

bool bearish_abort_signal = bear_bos_alert or bear_choch_alert or internal_bear_bos_alert or internal_bear_choch_alert
int bearish_abort_since_bars = ta.barssince(bearish_abort_signal)
bool bearish_abort_recent = not na(bearish_abort_since_bars) and bearish_abort_since_bars <= long_signal_window

string long_zone_text = 'No Long Zone'
if zone_recent
    long_zone_text := 'Zone touched'
if in_bull_fvg_zone
    long_zone_text := 'In FVG Zone'
if in_bull_ob_zone
    long_zone_text := 'In OB Zone'
if in_bull_ob_zone and in_bull_fvg_zone
    long_zone_text := 'In OB + FVG Zone'

string reclaim_text = 'No Reclaim'
if reclaim_recent
    reclaim_text := 'Reclaim recent'
if bull_reclaim_internal_low
    reclaim_text := 'Internal Low Reclaimed'
if bull_reclaim_swing_low
    reclaim_text := 'Swing Low Reclaimed'
if bull_reclaim_fvg
    reclaim_text := 'FVG Reclaimed'
if bull_reclaim_ob
    reclaim_text := 'OB Reclaimed'

float long_invalidation_buffer = ob_threshold_atr * long_invalidation_atr_mult
float prior_long_trigger_level = nz(ta.highest(high, long_confirm_lookback)[1], high)

// --------------------------------------------------
// Long dip state machine
// 1) stored state
// 2) invalidation rules
// 3) arm setup
// 4) confirm setup
// 5) ready state + visual state
// --------------------------------------------------

// 1) Stored state
var bool long_setup_armed = false
var bool long_setup_confirmed = false
var int long_setup_age = 0
var int long_confirm_age = 0
var int long_setup_arm_bar_index = na
var float long_setup_trigger = na
var float long_invalidation_level = na
var string long_setup_source = 'None'
var string long_last_invalid_source = 'None'
var float long_last_invalid_level = na

bool long_arm_signal = false
bool long_confirm_signal = false
bool long_invalidate_signal = false
string long_setup_text = 'No Setup'
int long_visual_state = 0
int long_setup_dashboard_state = 0
string long_visual_text = 'Neutral'
color long_bg_color = na
color long_bar_color = na
string arm_source_text = 'None'
float arm_invalidation_candidate = low
float arm_trigger_candidate = math.max(high, prior_long_trigger_level)
bool long_confirm_break = false
bool internal_choch_since_arm = false
bool internal_bos_since_arm = false
bool long_confirm_structure_ok = false
bool long_internal_structure_ok = false
bool long_building_state = false

if bull_reclaim_ob
    arm_source_text := 'OB'
    arm_invalidation_candidate := active_bull_ob_bottom
else if bull_reclaim_fvg
    arm_source_text := 'FVG'
    arm_invalidation_candidate := active_bull_fvg_bottom
else if bull_reclaim_swing_low
    arm_source_text := 'Swing Low'
    arm_invalidation_candidate := trail_dn
else if bull_reclaim_internal_low
    arm_source_text := 'Internal Low'
    arm_invalidation_candidate := internal_trail_dn

// 2) Invalidation
if long_setup_armed and not long_setup_confirmed
    long_setup_age += 1

if long_setup_confirmed
    long_confirm_age += 1

bool long_setup_expired = long_setup_armed and not long_setup_confirmed and long_setup_age > long_setup_expiry_bars
float long_invalidation_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE and use_live_invalidation_break ? low : close
bool long_broken_down = not na(long_invalidation_level) and long_invalidation_break_src < long_invalidation_level - long_invalidation_buffer
bool long_invalidated_now = bearish_abort_signal or long_broken_down or long_setup_expired

if long_invalidated_now
    long_last_invalid_source := long_setup_source
    long_last_invalid_level := long_invalidation_level
    long_invalidate_signal := long_setup_armed or long_setup_confirmed
    long_setup_armed := false
    long_setup_confirmed := false
    long_setup_age := 0
    long_confirm_age := 0
    long_setup_arm_bar_index := na
    long_setup_trigger := na
    long_invalidation_level := na
    long_setup_source := 'None'

// 3) Arm setup
if bull_reclaim_any and zone_recent and not long_setup_armed and not bearish_abort_recent
    long_arm_signal := true
    long_setup_armed := true
    long_setup_confirmed := false
    long_setup_age := 0
    long_confirm_age := 0
    long_setup_arm_bar_index := bar_index
    long_setup_trigger := arm_trigger_candidate
    long_invalidation_level := arm_invalidation_candidate
    long_setup_source := arm_source_text

// 4) Confirm setup
float long_confirm_break_src = signal_mode == SignalMode.AGGRESSIVE_LIVE and use_live_confirm_break ? high : close
long_confirm_break := long_setup_armed and not long_setup_confirmed and long_setup_age > 0 and long_confirm_break_src > long_setup_trigger
internal_choch_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_choch_since_bars) and internal_choch_since_bars <= bar_index - long_setup_arm_bar_index
internal_bos_since_arm := long_setup_armed and not na(long_setup_arm_bar_index) and not na(internal_bos_since_bars) and internal_bos_since_bars <= bar_index - long_setup_arm_bar_index
long_internal_structure_ok := long_internal_structure_mode == 'Internal CHoCH only' ? (internal_bull_choch_alert or internal_choch_since_arm) : (internal_bull_choch_alert or internal_bull_bos_alert or internal_choch_since_arm or internal_bos_since_arm)
long_confirm_structure_ok := not require_internal_break_for_confirm
if not long_confirm_structure_ok
    long_confirm_structure_ok := long_internal_structure_ok

if long_confirm_break and long_confirm_structure_ok
    long_setup_confirmed := true
    long_confirm_age := 0
    long_confirm_signal := true

// 5) Ready state + visuals
bool long_filters_ok = ema_support_ok and adx_strong and relvol_ok and bull_close_strong
bool long_ready_state = long_setup_confirmed and long_filters_ok and (not require_main_break_for_ready or bull_bos_alert or main_bos_recent)
long_building_state := long_setup_armed and long_internal_structure_ok and not long_setup_confirmed

bool long_ready_signal = long_ready_state and not long_ready_state[1]

long_setup_text := 'No Setup'
if long_zone_active
    long_setup_text := 'In Zone'
if long_setup_armed
    long_setup_text := str.format('Armed | {0}', long_setup_source)
if long_building_state
    long_setup_text := str.format('Building | {0}', long_setup_source)
if long_setup_confirmed
    long_setup_text := str.format('Confirmed | {0}', long_setup_source)
if long_ready_state
    long_setup_text := str.format('Ready | {0}', long_setup_source)

long_visual_state := 0
if long_zone_active
    long_visual_state := 1
if long_setup_armed
    long_visual_state := 2
if long_building_state
    long_visual_state := 3
if long_setup_confirmed
    long_visual_state := 4
if long_ready_state
    long_visual_state := 5
if (long_setup_armed or long_setup_confirmed or long_invalidate_signal) and (long_invalidated_now or bearish_abort_recent)
    long_visual_state := -1

long_setup_dashboard_state := long_visual_state

long_visual_text := status_text(long_visual_state, 'Blocked', 'Neutral', 'In Zone', 'Armed', 'Building', 'Confirmed', 'Long Ready')

long_bg_color := na
if long_visual_state == -1
    long_bg_color := color.new(color.red, 90)
else if long_visual_state == 1
    long_bg_color := color.new(color.aqua, 92)
else if long_visual_state == 2
    long_bg_color := color.new(color.orange, 88)
else if long_visual_state == 3
    long_bg_color := color.new(long_color_building, 84)
else if long_visual_state == 4
    long_bg_color := color.new(color.lime, 88)
else if long_visual_state == 5
    long_bg_color := color.new(color.green, 82)

long_bar_color := na
if long_visual_state == -1
    long_bar_color := color.new(color.red, 0)
else if long_visual_state == 1
    long_bar_color := color.new(color.aqua, 45)
else if long_visual_state == 2
    long_bar_color := color.new(color.orange, 25)
else if long_visual_state == 3
    long_bar_color := color.new(long_color_building, 5)
else if long_visual_state == 4
    long_bar_color := color.new(color.lime, 0)
else if long_visual_state == 5
    long_bar_color := color.new(color.green, 0)

if signal_mode == SignalMode.AGGRESSIVE_LIVE
    if not live_bull_ob_break and any_live_bull_ob_break
        live_bull_ob_break := true
        intrabar_event_count += 1
    if not live_bear_ob_break and any_live_bear_ob_break
        live_bear_ob_break := true
        intrabar_event_count += 1
    if not live_bull_fvg_fill and any_live_bull_fvg_fill
        live_bull_fvg_fill := true
        intrabar_event_count += 1
    if not live_bear_fvg_fill and any_live_bear_fvg_fill
        live_bear_fvg_fill := true
        intrabar_event_count += 1

var int last_reclaim_marker_bar = na
var int last_long_state_marker_bar = na
var int last_long_ready_marker_bar = na
bool can_draw_reclaim_marker = na(last_reclaim_marker_bar) or effective_reclaim_marker_gap <= 0 or bar_index - last_reclaim_marker_bar >= effective_reclaim_marker_gap
bool can_draw_long_state_marker = na(last_long_state_marker_bar) or effective_confirm_marker_gap <= 0 or bar_index - last_long_state_marker_bar >= effective_confirm_marker_gap
bool can_draw_long_ready_marker = na(last_long_ready_marker_bar) or effective_ready_marker_gap <= 0 or bar_index - last_long_ready_marker_bar >= effective_ready_marker_gap

if show_reclaim_markers and bull_reclaim_ob and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    label.new(bar_index, low, TXT_RECLAIM_OB, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_fvg and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    label.new(bar_index, low, TXT_RECLAIM_FVG, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_swing_low and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    label.new(bar_index, low, TXT_RECLAIM_SWING, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.small)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_reclaim_markers and bull_reclaim_internal_low and can_draw_reclaim_marker and reclaim_marker_drawn_bar_index != bar_index
    label.new(bar_index, low, TXT_RECLAIM_INTERNAL, color = #00000000, textcolor = long_color_reclaim, style = label.style_label_up, size = size.tiny)
    reclaim_marker_drawn_bar_index := bar_index
    last_reclaim_marker_bar := bar_index

if show_long_confirmation_markers and internal_bull_choch_alert and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_INT_REVERSAL, color = #00000000, textcolor = long_color_reversal, style = label.style_label_down, size = size.tiny)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and internal_bull_bos_alert and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_INT_BREAK, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.tiny)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and bull_bos_alert and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_TREND_CONFIRM, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_arm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    label.new(bar_index, low, TXT_LONG_ARMED, color = #00000000, textcolor = long_color_zone, style = label.style_label_up, size = size.small)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_confirm_signal and can_draw_long_state_marker and long_state_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_LONG_CONFIRMED, color = #00000000, textcolor = long_color_confirmed, style = label.style_label_down, size = size.small)
    long_state_marker_drawn_bar_index := bar_index
    last_long_state_marker_bar := bar_index

if show_long_confirmation_markers and long_ready_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_LONG_READY, color = #00000000, textcolor = long_color_ready, style = label.style_label_down, size = size.small)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_long_confirmation_markers and long_invalidate_signal and can_draw_long_ready_marker and long_ready_marker_drawn_bar_index != bar_index
    label.new(bar_index, high, TXT_LONG_INVALIDATED, color = #00000000, textcolor = long_color_invalid, style = label.style_label_down, size = size.tiny)
    long_ready_marker_drawn_bar_index := bar_index
    last_long_ready_marker_bar := bar_index

if show_htf_fvg and barstate.islast
    htf_fvg_buffer_bull.draw(htf_fvg_config_bull, visible_left = visible_left_time, visible_right = visible_right_time)
    htf_fvg_buffer_bear.draw(htf_fvg_config_bear, visible_left = visible_left_time, visible_right = visible_right_time)

    if htf_fvg_keep_filled and htf_fvg_keep_filled_max > 0
        if barstate.islastconfirmedhistory[1]
            htf_fvg_buffer_bull_filled.draw(htf_fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
            htf_fvg_buffer_bear_filled.draw(htf_fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
        else
            htf_fvg_buffer_bull_filled_new.draw(htf_fvg_config_bull_filled, visible_left = visible_left_time, visible_right = visible_right_time)
            htf_fvg_buffer_bear_filled_new.draw(htf_fvg_config_bear_filled, visible_left = visible_left_time, visible_right = visible_right_time)
    else
        htf_fvg_buffer_bull_filled.delete()
        htf_fvg_buffer_bear_filled.delete()

    htf_fvg_buffer_bull_discarded.delete()
    htf_fvg_buffer_bear_discarded.delete()

var g_eq = 'Equal Highs / Lows'
var show_eq = input.bool(false, 'Equal High / Low', group = g_eq, tooltip = SHOW_EQHL)
var eq_len = input.int(3, 'Bars Confirmation', minval = 1, group = g_eq, tooltip = EQHL_BARS)
var eq_threshold_in = input.float(0.1, 'Threshold', minval = 0, maxval = 0.5, step = 0.1, group = g_eq, tooltip = EQHL_THRESHOLD)

eq_atr = ND.atr(ATR_LEN_MAIN)
eq_threshold = eq_threshold_in * eq_atr
[eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, eql_alert, eql_x1, eql_y1, eql_x2, eql_y2] = detect_equal_levels(eq_len, eq_threshold, enabled = show_eq)

D.LabelArgs eqh_label_args = D.LabelArgs.new(bear_css, #00000000, style = label.style_label_down, size = size.tiny)
D.LineArgs eqh_line_args = D.LineArgs.new(bear_css, line.style_dotted)
D.LabelArgs eql_label_args = D.LabelArgs.new(bull_css, #00000000, style = label.style_label_up, size = size.tiny)
D.LineArgs eql_line_args = D.LineArgs.new(bull_css, line.style_dotted)

plot_equal_level(show_eq and eqh_alert, eqh_x1, eqh_y1, eqh_x2, eqh_y2, 'EQH', eqh_label_args, eqh_line_args, keep_history = true, force_overlay = false)
plot_equal_level(show_eq and eql_alert, eql_x1, eql_y1, eql_x2, eql_y2, 'EQL', eql_label_args, eql_line_args, keep_history = true, force_overlay = false)

// =====================
// Dashboard state + rendering
// =====================
dashboard_counts_active = show_dashboard and show_dashboard_counts
bool use_visible_window = render_visible_only and not na(visible_left_time) and not na(visible_right_time)
int visible_bull_obs = 0
int visible_bear_obs = 0
int visible_bull_fvgs = 0
int visible_bear_fvgs = 0
if dashboard_counts_active
    visible_bull_obs := use_visible_window ? count_visible_obs(ob_blocks_bull, visible_left_time, visible_right_time) : ob_registry_bull.size()
    visible_bear_obs := use_visible_window ? count_visible_obs(ob_blocks_bear, visible_left_time, visible_right_time) : ob_registry_bear.size()
    visible_bull_fvgs := use_visible_window ? count_visible_fvgs(fvgs_bull, visible_left_time, visible_right_time) : fvg_registry_bull.size()
    visible_bear_fvgs := use_visible_window ? count_visible_fvgs(fvgs_bear, visible_left_time, visible_right_time) : fvg_registry_bear.size()
htf_bull_count = (mtf_trend_1 > 0 ? 1 : 0) + (mtf_trend_2 > 0 ? 1 : 0) + (mtf_trend_3 > 0 ? 1 : 0)
htf_bear_count = (mtf_trend_1 < 0 ? 1 : 0) + (mtf_trend_2 < 0 ? 1 : 0) + (mtf_trend_3 < 0 ? 1 : 0)
int trend_state = structure_display_trend > 0 ? 5 : structure_display_trend < 0 ? -1 : 0
int htf_state = not show_mtf_trend ? 0 : htf_bull_count == 3 ? 5 : htf_bear_count == 3 ? -1 : htf_bull_count >= 2 ? 4 : htf_bear_count >= 2 ? 1 : 2
int htf1_state = not show_mtf_trend ? 0 : mtf_trend_1 > 0 ? 5 : mtf_trend_1 < 0 ? -1 : 0
int htf2_state = not show_mtf_trend ? 0 : mtf_trend_2 > 0 ? 5 : mtf_trend_2 < 0 ? -1 : 0
int htf3_state = not show_mtf_trend ? 0 : mtf_trend_3 > 0 ? 5 : mtf_trend_3 < 0 ? -1 : 0
int zone_state = in_bull_ob_zone or in_bull_fvg_zone ? 4 : zone_recent ? 2 : 0
int reclaim_state = bull_reclaim_any ? 4 : reclaim_recent ? 2 : 0
int close_state = not use_strong_close_filter ? 0 : bull_close_strong ? 5 : 2
int ema_state = not show_ema_support ? 0 : ema_support_ok ? 5 : -1
int adx_state = not use_adx ? 0 : not adx_data_ok ? 0 : plus_di < minus_di ? -1 : adx_value < adx_trend_min ? 0 : adx_value < adx_strong_min ? 3 : 5
int relvol_state = not use_rel_volume ? 0 : na(rel_volume) ? 0 : rel_volume >= relvol_good ? 5 : rel_volume >= 1.0 ? 2 : -1
int ltf_bias_state = not show_dashboard_ltf ? 0 : na(ltf_bull_share) ? 0 : ltf_bull_share >= 0.60 ? 5 : ltf_bull_share >= ltf_bias_hint ? 4 : ltf_bull_share >= 0.50 ? 2 : -1
int ltf_delta_state = not show_dashboard_ltf ? 0 : na(ltf_volume_delta) ? 0 : ltf_volume_delta >= 0.15 ? 5 : ltf_volume_delta >= 0 ? 4 : -1
int objects_state = not show_dashboard_counts ? 0 : (visible_bull_obs + visible_bull_fvgs) > 0 ? 4 : 0
string trend_display = trend_state == 5 ? 'Bullish' : trend_state == -1 ? 'Bearish' : 'Neutral'
string htf_display = not show_mtf_trend ? 'Off' : str.format('{0}:{1}\n{2}:{3}\n{4}:{5}', mtf_trend_tf1, trend_text_or_na(mtf_trend_1), mtf_trend_tf2, trend_text_or_na(mtf_trend_2), mtf_trend_tf3, trend_text_or_na(mtf_trend_3))
string zone_display = long_zone_text
string reclaim_display = reclaim_text
string long_setup_display = long_setup_text
string long_visual_display = long_visual_text
string close_display = close_state_text
string ema_display = ema_state_text
string adx_display = not use_adx ? 'Off' : str.format('{0,number,#.#} | {1}', adx_value, adx_state_text)
string relvol_display = relvol_text
string ltf_bias_display = not show_dashboard_ltf ? 'Hidden' : na(ltf_bull_share) ? 'n/a' : str.format('{0,number,percent}', ltf_bull_share)
string ltf_delta_display = not show_dashboard_ltf ? 'Hidden' : na(ltf_volume_delta) ? 'n/a' : str.format('{0,number,percent}', ltf_volume_delta)
string objects_display = not show_dashboard_counts ? 'Hidden' : str.format('OB {0}/{1}\nFVG {2}/{3}', visible_bull_obs, visible_bear_obs, visible_bull_fvgs, visible_bear_fvgs)
string setup_age_display = not show_dashboard_setup_age ? 'Hidden' : long_setup_confirmed ? str.format('confirmed {0}', long_confirm_age) : long_setup_armed ? str.format('armed {0}', long_setup_age) : 'n/a'
string dashboard_swing_levels_display = str.format('Swing {0}/{1}\nInt {2}/{3}', format_level(trail_up), format_level(trail_dn), show_internals ? format_level(internal_trail_up) : 'Off', show_internals ? format_level(internal_trail_dn) : 'Off')
string dashboard_long_zones_display = str.format('OB {0}/{1}\nFVG {2}/{3}', format_level(not na(active_bull_ob_top) ? active_bull_ob_top : last_bull_ob_top), format_level(not na(active_bull_ob_bottom) ? active_bull_ob_bottom : last_bull_ob_bottom), format_level(not na(active_bull_fvg_top) ? active_bull_fvg_top : last_bull_fvg_top), format_level(not na(active_bull_fvg_bottom) ? active_bull_fvg_bottom : last_bull_fvg_bottom))
string dashboard_long_triggers_display = str.format('OB mid {0}\nFVG fill {1}', format_level(not na(active_bull_ob_break_level) ? active_bull_ob_break_level : last_bull_ob_break_level), format_level(not na(active_bull_fvg_fill_level) ? active_bull_fvg_fill_level : last_bull_fvg_fill_level))
int ob_zone_state = not na(active_bull_ob_top) ? 4 : not na(last_bull_ob_top) ? 2 : 0
int fvg_zone_state = not na(active_bull_fvg_top) ? 4 : not na(last_bull_fvg_top) ? 2 : 0
int long_zones_state = math.max(ob_zone_state, fvg_zone_state)
string dashboard_legend_display = 'Zone: Aqua\nArmed: Orange\nBuilding: Gold\nConfirm: Lime\nReady: Green\nFail: Red'
color dashboard_header_bg = color.new(color.black, 100)
color dashboard_text = chart.fg_color
color dashboard_long_text = long_visual_state == 3 ? long_dashboard_building_text : dashboard_text
color dashboard_swing_bg = color.new(color.silver, 88)
color dashboard_trigger_bg = color.new(color.black, 100)
color dashboard_legend_bg = color.new(color.black, 88)
color dashboard_setup_age_bg = color.new(color.silver, 88)
var table smc_dashboard = table.new(position.bottom_right, 2, 19, border_width = 0)

if show_dashboard and barstate.islast
    dashboard_row(smc_dashboard, 0, 'SMC++', signal_mode_text, dashboard_header_bg, dashboard_text)
    dashboard_row(smc_dashboard, 1, 'Trend', trend_display, status_bg(trend_state), dashboard_text)
    dashboard_row(smc_dashboard, 2, 'HTF Trend', htf_display, status_bg(htf_state), dashboard_text)
    dashboard_row(smc_dashboard, 3, 'Pullback Zone', zone_display, status_bg(zone_state), dashboard_text)
    dashboard_row(smc_dashboard, 4, 'Reclaim', reclaim_display, status_bg(reclaim_state), dashboard_text)
    dashboard_row(smc_dashboard, 5, 'Long Setup', long_setup_display, status_bg(long_setup_dashboard_state), dashboard_long_text)
    dashboard_row(smc_dashboard, 6, 'Setup Age', setup_age_display, dashboard_setup_age_bg, dashboard_text)
    dashboard_row(smc_dashboard, 7, 'Long Visual', long_visual_display, status_bg(long_visual_state), dashboard_long_text)
    dashboard_row(smc_dashboard, 8, 'Close Strength', close_display, status_bg(close_state), dashboard_text)
    dashboard_row(smc_dashboard, 9, 'EMA Support', ema_display, status_bg(ema_state), dashboard_text)
    dashboard_row(smc_dashboard, 10, 'ADX', adx_display, status_bg(adx_state), dashboard_text)
    dashboard_row(smc_dashboard, 11, 'Rel Volume', relvol_display, status_bg(relvol_state), dashboard_text)
    dashboard_row(smc_dashboard, 12, 'LTF Bias', ltf_bias_display, status_bg(ltf_bias_state), dashboard_text)
    dashboard_row(smc_dashboard, 13, 'LTF Delta', ltf_delta_display, status_bg(ltf_delta_state), dashboard_text)
    dashboard_row(smc_dashboard, 14, 'Objects', objects_display, status_bg(objects_state), dashboard_text)
    dashboard_row(smc_dashboard, 15, 'Swing H/L', dashboard_swing_levels_display, dashboard_swing_bg, dashboard_text)
    dashboard_row(smc_dashboard, 16, 'Long Zones', dashboard_long_zones_display, status_bg(long_zones_state), dashboard_text)
    dashboard_row(smc_dashboard, 17, 'Long Triggers', dashboard_long_triggers_display, dashboard_trigger_bg, dashboard_text)
    dashboard_row(smc_dashboard, 18, 'Legend', dashboard_legend_display, dashboard_legend_bg, dashboard_text)
else if barstate.islast
    table.clear(smc_dashboard, 0, 0, 1, 18)

bgcolor(show_long_background ? long_bg_color : na, title = 'Long-only Background')
barcolor(color_long_bars ? long_bar_color : na)

// --------------------------------------------------
// Long-dip alert presets
// --------------------------------------------------
alert_long_watchlist = bullish_trend_condition and long_zone_active
alert_long_armed = bullish_trend_condition and long_zone_active and reclaim_recent and long_setup_armed
alert_long_early = bullish_trend_condition and long_zone_active and reclaim_recent and long_internal_structure_ok and bull_close_strong and ema_support_ok
alert_long_clean = barstate.isconfirmed and bullish_trend_condition and long_zone_active and reclaim_recent and long_setup_confirmed and bull_close_strong and ema_support_ok and adx_strong and relvol_ok
alert_long_entry_best = barstate.isconfirmed and bullish_trend_condition and reclaim_recent and long_ready_state and bull_close_strong and ema_support_ok
alert_long_entry_strict = barstate.isconfirmed and bullish_trend_condition and htf_bull_count >= 2 and long_zone_active and reclaim_recent and long_ready_state and bull_close_strong and ema_support_ok and adx_strong and relvol_ok and (na(ltf_volume_delta) or ltf_volume_delta >= 0)
alert_long_fail = long_invalidate_signal

// Alerts use clearer wording but keep the same underlying trigger logic.
alertcondition(long_arm_signal, 'Long Armed', 'SMC++: long setup armed after reclaim and zone confirmation.')
alertcondition(long_confirm_signal, 'Long Confirmed', 'SMC++: long setup confirmed after trigger break and internal structure confirmation.')
alertcondition(long_ready_signal, 'Long Ready', 'SMC++: long setup is ready with filters aligned.')
alertcondition(long_invalidate_signal, 'Long Invalidated', 'SMC++: long setup was invalidated.')
alertcondition(alert_long_watchlist, 'Long Dip Watchlist', 'SMC++: bullish trend with active pullback zone.')
alertcondition(alert_long_armed, 'Long Dip Armed+', 'SMC++: reclaim detected and long setup armed.')
alertcondition(alert_long_early, 'Long Dip Early', 'SMC++: early bullish long-dip hint with internal confirmation.')
alertcondition(alert_long_clean, 'Long Dip Clean', 'SMC++: clean long-dip setup confirmed.')
alertcondition(alert_long_entry_best, 'Long Dip Entry Best', 'SMC++: best standard long-dip entry condition.')
alertcondition(alert_long_entry_strict, 'Long Dip Entry Strict', 'SMC++: strict long-dip entry with HTF and momentum alignment.')
alertcondition(alert_long_fail, 'Long Dip Failed', 'SMC++: long-dip setup invalidated.')
alertcondition(bull_bos_alert, 'Bullish BOS Detected', 'SMC++: bullish break of structure detected.')
alertcondition(bull_choch_alert, 'Bullish CHoCH Detected', 'SMC++: bullish change of character detected.')
alertcondition(bear_bos_alert, 'Bearish BOS Detected', 'SMC++: bearish break of structure detected.')
alertcondition(bear_choch_alert, 'Bearish CHoCH Detected', 'SMC++: bearish change of character detected.')
alertcondition(ob_broken_new_bull.size() > 0, 'Bullish Order Block Broken', 'SMC++: price broke a bullish order block.')
alertcondition(ob_broken_new_bear.size() > 0, 'Bearish Order Block Broken', 'SMC++: price broke a bearish order block.')
alertcondition(eqh_alert, 'Equal Highs Detected', 'SMC++: equal highs detected.')
alertcondition(eql_alert, 'Equal Lows Detected', 'SMC++: equal lows detected.')
alertcondition(bullish_fvg_alert, 'Bullish FVG Formed', 'SMC++: bullish fair value gap formed.')
alertcondition(bearish_fvg_alert, 'Bearish FVG Formed', 'SMC++: bearish fair value gap formed.')
alertcondition(bullish_fvg_filled_alert, 'Bullish FVG Filled', 'SMC++: bullish fair value gap filled.')
alertcondition(bearish_fvg_filled_alert, 'Bearish FVG Filled', 'SMC++: bearish fair value gap filled.')
alertcondition(live_bull_ob_break, 'Bullish OB Live Break', 'SMC++: intrabar bullish order block break detected.')
alertcondition(live_bear_ob_break, 'Bearish OB Live Break', 'SMC++: intrabar bearish order block break detected.')
alertcondition(live_bull_fvg_fill, 'Bullish FVG Live Fill', 'SMC++: intrabar bullish fair value gap fill detected.')
alertcondition(live_bear_fvg_fill, 'Bearish FVG Live Fill', 'SMC++: intrabar bearish fair value gap fill detected.')
alertcondition(bullish_trend_started, 'Bullish Trend Started', 'SMC++: structure trend turned bullish.')
alertcondition(bearish_trend_started, 'Bearish Trend Started', 'SMC++: structure trend turned bearish.')
alertcondition(directional_trend_started, 'Trend Direction Changed', 'SMC++: structure trend turned directional.')

fire_dynamic_alert(enable_dynamic_alerts, bull_bos_alert, 'Bullish BOS', 'Structure break confirmed', top, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bull_choch_alert, 'Bullish CHoCH', 'Character shift confirmed', top, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bear_bos_alert, 'Bearish BOS', 'Structure break confirmed', btm, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bear_choch_alert, 'Bearish CHoCH', 'Character shift confirmed', btm, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, not na(new_ob_bull), 'Bullish Order Block', 'New order block confirmed', not na(new_ob_bull) ? new_ob_bull.break_price : na, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, not na(new_ob_bear), 'Bearish Order Block', 'New order block confirmed', not na(new_ob_bear) ? new_ob_bear.break_price : na, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bullish_fvg_alert, 'Bullish FVG', 'New fair value gap formed', not na(new_fvg_bull) ? new_fvg_bull.fill_target_level : na, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bearish_fvg_alert, 'Bearish FVG', 'New fair value gap formed', not na(new_fvg_bear) ? new_fvg_bear.fill_target_level : na, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bullish_fvg_filled_alert, 'Bullish FVG Filled', 'Gap fill target reached', bull_filled_alert_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, bearish_fvg_filled_alert, 'Bearish FVG Filled', 'Gap fill target reached', bear_filled_alert_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts and enable_live_break_alerts and signal_mode == SignalMode.AGGRESSIVE_LIVE, live_bull_ob_break, 'Bullish OB Live Break', 'Intrabar bullish order block break detected', bull_ob_live_event_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts and enable_live_break_alerts and signal_mode == SignalMode.AGGRESSIVE_LIVE, live_bear_ob_break, 'Bearish OB Live Break', 'Intrabar bearish order block break detected', bear_ob_live_event_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts and enable_live_break_alerts and signal_mode == SignalMode.AGGRESSIVE_LIVE, live_bull_fvg_fill, 'Bullish FVG Live Fill', 'Intrabar bullish fair value gap fill detected', bull_fvg_live_event_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts and enable_live_break_alerts and signal_mode == SignalMode.AGGRESSIVE_LIVE, live_bear_fvg_fill, 'Bearish FVG Live Fill', 'Intrabar bearish fair value gap fill detected', bear_fvg_live_event_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, long_arm_signal, 'Long Armed', str.format('Long setup armed from {0}', long_setup_source), long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, long_confirm_signal, 'Long Confirmed', str.format('Trigger cleared from {0}', long_setup_source), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, long_ready_signal, 'Long Ready', str.format('Filters aligned for {0}', long_setup_source), long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_watchlist, 'Long Dip Watchlist', 'Bullish trend with active pullback zone', long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_armed, 'Long Dip Armed+', 'Reclaim detected and setup armed', long_invalidation_level, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_early, 'Long Dip Early', 'Internal confirmation starting', long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_clean, 'Long Dip Clean', 'Confirmed long-dip setup', long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_entry_best, 'Long Dip Entry Best', 'Standard long entry condition met', long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_entry_strict, 'Long Dip Entry Strict', 'Strict long entry condition met', long_setup_trigger, 1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, alert_long_fail, 'Long Dip Failed', 'Setup invalidated', long_last_invalid_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)
fire_dynamic_alert(enable_dynamic_alerts, long_invalidate_signal, 'Long Invalidated', str.format('Setup invalidated from {0}', long_last_invalid_source), long_last_invalid_level, -1, ltf_bull_share, ltf_volume_delta, signal_mode_text)

/////////////////////////////////////////////////////////////////////////////////
//#endregion                      IMPLEMENTATION
/////////////////////////////////////////////////////////////////////////////////
