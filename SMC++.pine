const int ATR_LEN_MAIN = 50
const int ATR_LEN_PROFILE = 200
const int ATR_LEN_PIVOT_FILTER = 3
const int DEFAULT_SWING_LENGTH = 50
const int DEFAULT_INTERNAL_LENGTH = 5
const int DEFAULT_OB_SHOW_LAST = 2
const int DEFAULT_FVG_SHOW_LAST = 2
const int DEFAULT_KEEP_HISTORY = 1
const float DEFAULT_OB_FILTER_MIN_MULT = 0.5
const float DEFAULT_OB_FILTER_MAX_MULT = 2.5
const float DEFAULT_FVG_MIN_SIZE_MULT = 0.5
const float DEFAULT_FVG_FILL_TARGET_PCT = 60.0
const string DEFAULT_LTF_TIMEFRAME = '1'
const string DEFAULT_TREND_TF_1 = '240'
const string DEFAULT_TREND_TF_2 = '1D'
const string DEFAULT_TREND_TF_3 = '1W'
const string TXT_RECLAIM_OB = 'Reclaim OB'
const string TXT_RECLAIM_FVG = 'Reclaim FVG'
const string TXT_RECLAIM_SWING = 'Reclaim Swing Low'
const string TXT_RECLAIM_INTERNAL = 'Reclaim Internal Low'
const string TXT_LONG_ARMED = 'Long Armed'
const string TXT_LONG_CONFIRMED = 'Long Confirmed'
const string TXT_LONG_READY = 'Long Ready'
const string TXT_LONG_INVALIDATED = 'Long Invalidated'
const string TXT_INT_REVERSAL = 'INT Reversal'
const string TXT_INT_BREAK = 'INT Break'
const string TXT_TREND_CONFIRM = 'Trend Confirm'

auto_ltf_timeframe(int chart_seconds) =>
    chart_seconds <= 60 ? '' :
     chart_seconds <= 180 ? '1' :
     chart_seconds <= 300 ? '1' :
     chart_seconds <= 900 ? '3' :
     chart_seconds <= 1800 ? '5' :
     chart_seconds <= 3600 ? '15' :
     chart_seconds <= 14400 ? '30' :
     chart_seconds <= 86400 ? '60' :
     chart_seconds <= 604800 ? '240' :
     '1D'

trend_text(int trend_value) =>
    trend_value > 0 ? 'Bullish' : trend_value < 0 ? 'Bearish' : 'Neutral'

trend_text_or_na(float trend_value) =>
    na(trend_value) or trend_value == 0 ? 'n/a' : trend_value > 0 ? 'Bullish' : 'Bearish'

format_level(float value) =>
    na(value) ? 'n/a' : str.tostring(value, format.mintick)

edge(bool condition) =>
    condition and not condition[1]

status_bg(int state) =>
    state <= -1 ? color.new(color.red, 75) :
     state == 0 ? color.new(color.gray, 80) :
     state == 1 ? color.new(color.aqua, 80) :
     state == 2 ? color.new(color.orange, 72) :
     state == 3 ? color.new(color.yellow, 68) :
     state == 4 ? color.new(color.lime, 72) :
     color.new(color.green, 60)

status_text(int state, string blocked, string neutral, string prep1, string prep2, string prep3, string confirm, string ready) =>
    state <= -1 ? blocked :
     state == 0 ? neutral :
     state == 1 ? prep1 :
     state == 2 ? prep2 :
     state == 3 ? prep3 :
     state == 4 ? confirm :
     ready

dashboard_row(table tbl, int row, string name, string value, color bg, color txt) =>
    table.cell(tbl, 0, row, name, text_color = txt, bgcolor = bg)
    table.cell(tbl, 1, row, value, text_color = txt, bgcolor = bg)

scaled_marker_gap(int base_gap, bool auto_scale, int chart_tf_seconds, int reference_tf_seconds, float max_scale) =>
    scale_base = reference_tf_seconds > 0 ? reference_tf_seconds : 180
    ratio = scale_base > 0 and chart_tf_seconds > 0 ? chart_tf_seconds / scale_base : 1.0
    bounded_scale = auto_scale ? math.min(math.max(math.sqrt(ratio), 1.0), max_scale) : 1.0
    int(math.round(base_gap * bounded_scale))

ltf_stats(float[] opens, float[] closes, float[] volumes) =>
    sample_count = opens.size()
    bull_count = 0
    bear_count = 0
    bull_volume = 0.0
    bear_volume = 0.0

    if sample_count > 0
        for i = 0 to sample_count - 1
            open_value = opens.get(i)
            close_value = closes.get(i)
            volume_value = i < volumes.size() ? volumes.get(i) : 0.0
            if close_value > open_value
                bull_count += 1
                bull_volume += volume_value
            else if close_value < open_value
                bear_count += 1
                bear_volume += volume_value

    total_volume = bull_volume + bear_volume
    bull_share = sample_count > 0 ? bull_count / sample_count : na
    volume_delta = total_volume > 0 ? (bull_volume - bear_volume) / total_volume : na
    [sample_count, bull_share, volume_delta]

get_structure_display_trend_only(simple int structure_len) =>
    [trend, bull_bos_alert, bull_choch_alert, _, _, _, _, _, bear_bos_alert, bear_choch_alert, _, _, _, _, _, _] = detect_structure(structure_len, filter_insignificant_internal_breaks = true)
    bool structure_break_detected = bull_bos_alert or bull_choch_alert or bear_bos_alert or bear_choch_alert
    not na(ta.barssince(structure_break_detected)) ? trend : 0

get_confirmed_structure_trend(string trend_tf, simple int structure_len) =>
    request.security(syminfo.tickerid, trend_tf, get_structure_display_trend_only(structure_len)[1], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

count_visible_obs(OrderBlock[] blocks, int visible_left, int visible_right, bool extend_until_broken = true) =>
    visible_count = 0
    if not na(blocks)
        for block in blocks
            if block.overlaps_window(visible_left, visible_right, extend_until_broken)
                visible_count += 1
    visible_count

count_visible_fvgs(FVG[] fvgs, int visible_left, int visible_right, bool extend_until_filled = true) =>
    visible_count = 0
    if not na(fvgs)
        for fvg in fvgs
            if fvg.overlaps_window(visible_left, visible_right, extend_until_filled)
                visible_count += 1
    visible_count

build_dynamic_alert_message(bool enabled, bool condition, string event_name, string detail, float level, int direction, float ltf_bull_share, float ltf_volume_delta, string mode_text) =>
    if enabled and condition
        direction_text = direction > 0 ? 'bullish' : direction < 0 ? 'bearish' : 'neutral'
        share_text = na(ltf_bull_share) ? 'n/a' : str.format('{0,number,percent}', ltf_bull_share)
        delta_text = na(ltf_volume_delta) ? 'n/a' : str.format('{0,number,percent}', ltf_volume_delta)
        str.format('SMC++ | {0} | {1} | {2} | dir={3} | level={4} | tf={5} | mode={6} | ltf_bull_share={7} | ltf_volume_delta={8}', syminfo.ticker, event_name, detail, direction_text, format_level(level), timeframe.period, mode_text, share_text, delta_text)
    else
        ''

external_trend_gate(simple string symbol, simple int fast_len, simple int slow_len) =>
    [ext_close, ext_fast, ext_slow] = request.security(symbol, timeframe.period, [close, ta.ema(close, fast_len), ta.ema(close, slow_len)], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off, ignore_invalid_symbol = true, calc_bars_count = 300)

    bool ext_missing = na(ext_close) or na(ext_fast) or na(ext_slow)
    [ext_missing, not ext_missing and ext_close > ext_fast and ext_fast > ext_slow]

external_breadth_gate(simple string symbol) =>
    ext_breadth = request.security(symbol, timeframe.period, close, gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off, ignore_invalid_symbol = true, calc_bars_count = 100)

    bool breadth_missing = na(ext_breadth)
    [breadth_missing, not breadth_missing and ext_breadth > 0]

htf_fvg_key(FVG fvg) =>
    not na(fvg) ? str.format('{0}|{1}|{2}|{3}', fvg.left_top.time, fvg.right_bottom.time, format_level(fvg.left_top.price), format_level(fvg.right_bottom.price)) : ''

push_capped_label(label[] buffer, label new_label, int max_keep) =>
    if not na(new_label)
        if max_keep <= 0
            label.delete(new_label)
        else
            buffer.push(new_label)
            while buffer.size() > max_keep
                label.delete(buffer.shift())

trim_label_history(label[] history, int max_keep) =>
    if max_keep <= 0
        for i = history.size() - 1 to 0
            label.delete(history.get(i))
        history.clear()
    else
        while history.size() > max_keep
            label.delete(history.shift())

string SHOW_SWING = 'Display market structure.'
string SHOW_SWING_POINTS = 'Display swing points as labels on the chart.'
string SHOW_SWHL_POINTS = 'Highlight the most recent strong and weak highs/lows on the chart.'
string SWING_OB = 'Display swing order blocks on the chart.\n\nThis controls how many recent swing order blocks are shown.'
string FILTER_OB = 'Order Block size filter based on ATR multiples. Blocks smaller than the minimum or larger than the maximum are ignored.'
string SHOW_EQHL = 'Display equal highs and equal lows on the chart.'
string EQHL_BARS = 'Number of bars used to confirm equal highs and equal lows.'
string EQHL_THRESHOLD = 'Sensitivity threshold used for equal high / low detection. Lower values return fewer but usually cleaner levels.'
string SHOW_FVG = 'Display fair value gaps on the chart.'
string FILTER_FVG = 'Filter out fair value gaps that are too small to matter.'
string FVG_TF = 'Higher timeframe used for the higher-timeframe FVG overlay.'
string SIGNAL_MODE_TOOLTIP = 'Confirmed only is the safer non-repainting mode. Aggressive live allows intrabar high/low driven updates and alerts, so states can change before candle close and should be treated as non-final until the bar confirms.'
string LTF_TOOLTIP = 'Uses request.security_lower_tf() to summarize intrabar participation and pressure.'
string DASHBOARD_TOOLTIP = 'Compact state table showing trend, OB/FVG counts, HTF alignment and intrabar pressure.'
string PERFORMANCE_TOOLTIP = 'Restrict object rendering to the current visible chart window to reduce clutter and improve responsiveness.'

var g_mode = 'Execution Mode'
var SignalMode signal_mode = input.enum(SignalMode.CONFIRMED_ONLY, 'Signal Mode', group = g_mode, tooltip = SIGNAL_MODE_TOOLTIP, display = display.status_line)

var g_ltf = 'Lower Timeframe'
var bool enable_ltf_sampling = input.bool(true, 'Use lower timeframe sampling', group = g_ltf, tooltip = LTF_TOOLTIP)
var bool use_ltf_for_strict_entry = input.bool(true, 'Use LTF for strict entry', group = g_ltf, tooltip = 'Keeps lower-timeframe sampling active for strict-entry filters even when the dashboard and dynamic alerts are off.')
var bool allow_strict_entry_without_ltf = input.bool(false, 'Allow strict entry without LTF when unavailable', group = g_ltf, display = display.none, tooltip = 'Optional fallback. When enabled, strict-entry alerts may still trigger when lower-timeframe sampling is unavailable on the current chart.')
var bool use_ltf_for_dynamic_alerts = input.bool(false, 'Use LTF in dynamic alerts', group = g_ltf, tooltip = 'When off, dynamic alert messages do not force lower-timeframe sampling just for message decoration.')
var bool ltf_auto_select = input.bool(true, 'Auto-select lower timeframe', group = g_ltf)
var string ltf_timeframe = input.timeframe(DEFAULT_LTF_TIMEFRAME, 'Lower timeframe', group = g_ltf, display = display.status_line)
var float ltf_bias_hint = input.float(0.55, 'Bull share hint', minval = 0.5, maxval = 1.0, step = 0.05, group = g_ltf)

var g_mtf = 'Higher Timeframe Trend'
var bool show_mtf_trend = input.bool(true, 'Show HTF trend summary', group = g_mtf)
var string mtf_trend_tf1 = input.timeframe(DEFAULT_TREND_TF_1, 'Trend TF 1', group = g_mtf, inline = 'mtf1', display = display.status_line)
var string mtf_trend_tf2 = input.timeframe(DEFAULT_TREND_TF_2, 'Trend TF 2', group = g_mtf, inline = 'mtf2', display = display.status_line)
var string mtf_trend_tf3 = input.timeframe(DEFAULT_TREND_TF_3, 'Trend TF 3', group = g_mtf, inline = 'mtf3', display = display.status_line)

var g_dashboard = 'Dashboard'
var bool show_dashboard = input.bool(true, 'Show dashboard', group = g_dashboard, tooltip = DASHBOARD_TOOLTIP)
var bool show_dashboard_ltf = input.bool(true, 'Show LTF details', group = g_dashboard)
var bool show_dashboard_counts = input.bool(true, 'Show object counts', group = g_dashboard)
var bool show_dashboard_setup_age = input.bool(true, 'Show setup age', group = g_dashboard)

var g_alerts = 'Alerts'
var bool enable_dynamic_alerts = input.bool(true, 'Enable dynamic alerts', group = g_alerts)
var bool enable_live_break_alerts = input.bool(true, 'Enable intrabar live break alerts', group = g_alerts)
var string dynamic_long_alert_mode = input.string('Priority', 'Dynamic long alerts', options = ['Priority', 'All lifecycle'], group = g_alerts, tooltip = 'Priority sends only the highest long lifecycle message per bar. All lifecycle allows multiple long lifecycle messages on the same bar.')

var g_perf = 'Performance'
